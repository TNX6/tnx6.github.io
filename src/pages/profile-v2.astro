              <button class="item-action-btn ${useDisabled ? 'is-disabled' : ''}" type="button" data-item-action="use" ${useDisabled ? 'disabled aria-disabled="true"' : ''}>${useDisabled ? 'لا يمكن استخدامه' : 'استخدام'}</button>
              <button class="item-action-btn" type="button" data-item-action="gift">إهداء</button>
              <button class="item-action-btn ${saleDisabled ? 'is-disabled' : ''}" type="button" data-item-action="sell" ${saleDisabled ? 'disabled aria-disabled="true"' : ''}>${saleDisabled ? 'لا يباع' : 'بيع'}</button>
