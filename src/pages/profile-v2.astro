        requestAnimationFrame(() => {
          renderInventoryPaginationV2(list.length, totalPages);
        });
      }




      /* INVENTORY SELL UI FUNCTIONS */
      const TNX_API_ORIGIN = 'https://api.tnx6.xyz'

      function findCatalogItemByName(name) {
        const target = String(name || '').trim()
        const normalizedTarget = normalize(target)

        return (state.items || []).find((item) => {
          const text = String(item.text || item.name || '').trim()
          return text === target || normalize(text) === normalizedTarget
        }) || null
      }

      function itemSellPrice(meta) {
        const value = Math.max(0, Math.floor(Number(meta?.value || 0)))
        return Math.max(1, Math.floor(value * 0.5))
      }

      function isSaleDisabled(meta) {
        if (!meta) return true
        return meta.excludeSale === true || meta.excludeSale === 1 || String(meta.excludeSale).toLowerCase() === 'true'
      }

      function boolFlag(value) {
        if (value === true || value === 1) return true
        const text = String(value ?? '').trim().toLowerCase()
        return text === 'true' || text === 'yes' || text === '1' || text === 'disabled' || text === 'off'
      }

      function falseFlag(value) {
        if (value === false || value === 0) return true
        const text = String(value ?? '').trim().toLowerCase()
        return text === 'false' || text === 'no' || text === '0' || text === 'enabled' || text === 'on'
      }

      function isUseDisabled(meta, item = null) {
        const sources = [meta || {}, item || {}]

        for (const source of sources) {
          const disabledValue =
            source.excludeUsage ??
            source.excludeUse ??
            source.disableUsage ??
            source.disableUse ??
            source.disabledUsage ??
            source.disabledUse ??
            source.noUsage ??
            source.noUse ??
            source.notUsable ??
            source.isUseDisabled

          if (disabledValue !== undefined && disabledValue !== null && disabledValue !== '') {
            if (boolFlag(disabledValue)) return true
            if (falseFlag(disabledValue)) return false
          }

          const enabledValue =
            source.canUse ??
            source.usable ??
            source.isUsable ??
            source.allowUse ??
            source.useEnabled

          if (enabledValue !== undefined && enabledValue !== null && enabledValue !== '') {
            if (boolFlag(enabledValue)) return false
            if (falseFlag(enabledValue)) return true
          }
        }

        return false
      }

      async function getCurrentAccount() {
        if (state.currentAccountLoaded) return state.currentAccount || null
        state.currentAccountLoaded = true

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/me', {
            credentials: 'include',
            cache: 'no-store',
          })

          if (!res.ok) return null

          const data = await res.json()
          state.currentAccount = data?.user || null
          return state.currentAccount
        } catch {
          return null
        }
      }

      function accountMatchesViewedUser(account) {
        if (!account || !state.activeUser) return false

        const accountLogin = normalize(account.login || account.displayName || '')
        const viewedLogin = normalize(userLogin(state.activeUser) || userName(state.activeUser) || '')

        const accountId = String(account.twitchId || account.twitch_id || account.id || '')
        const viewedId = String(userId(state.activeUser) || get(state.activeUser, ['twitchId', 'twitch_id'], '') || '')

        return Boolean(
          (accountId && viewedId && accountId === viewedId) ||
          (accountLogin && viewedLogin && accountLogin === viewedLogin)
        )
      }

      function sortedInventoryForSell(items) {
        return [...(items || [])].sort((a, b) =>
          Number(b.qty || b.quantity || 0) - Number(a.qty || a.quantity || 0) ||
          String(a.name || '').localeCompare(String(b.name || ''))
        )
      }


      function readInventoryItemQuantity(item) {
        const raw = item?.qty ?? item?.quantity ?? item?.count ?? 0;
        const value = Math.floor(Number(raw || 0));
        return Number.isFinite(value) ? Math.max(0, value) : 0;
      }

      function writeInventoryItemQuantity(item, quantity) {
        const next = Math.max(0, Math.floor(Number(quantity || 0)));

        if (Object.prototype.hasOwnProperty.call(item, "qty")) {
          item.qty = next;
        }

        if (Object.prototype.hasOwnProperty.call(item, "quantity")) {
          item.quantity = next;
        }

        if (
          !Object.prototype.hasOwnProperty.call(item, "qty") &&
          !Object.prototype.hasOwnProperty.call(item, "quantity")
        ) {
          item.quantity = next;
        }
      }

      function compactInventoryName(value) {
        return String(value || "")
          .trim()
          .toLowerCase()
          .replace(/\s+/g, "");
      }

      function findInventoryItemByName(items, name) {
        const wanted = compactInventoryName(name);

        for (const item of items || []) {
          const itemName = item?.name ?? item?.text ?? item?.itemName ?? "";

          if (compactInventoryName(itemName) === wanted) {
            return item;
          }
        }

        return null;
      }


      function activeInventoryReservationKey() {
        const viewedId = String(userId(state.activeUser) || get(state.activeUser, ['twitchId', 'twitch_id'], '') || '').trim();
        const viewedLogin = String(userLogin(state.activeUser) || get(state.activeUser, ['login', 'userLogin'], '') || '').trim().toLowerCase();

        return viewedId || viewedLogin || '';
      }

      async function fetchInventorySellReservations() {
        const viewedId = String(userId(state.activeUser) || get(state.activeUser, ['twitchId', 'twitch_id'], '') || '').trim();
        const viewedLogin = String(userLogin(state.activeUser) || get(state.activeUser, ['login', 'userLogin'], '') || '').trim().toLowerCase();

        const params = new URLSearchParams();

        if (viewedId) {
          params.set('twitchId', viewedId);
        } else if (viewedLogin) {
          params.set('login', viewedLogin);
        } else {
          return [];
        }

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/inventory/sell-reservations?' + params.toString(), {
            credentials: 'include',
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok || !data.ok) {
            return [];
          }

          return Array.isArray(data.reservations) ? data.reservations : [];
        } catch {
          return [];
        }
      }

      async function applyRemoteSellReservationsToInventory(items) {
        if (!Array.isArray(items) || !items.length) {
          return false;
        }

        const reservations = await fetchInventorySellReservations();

        if (!reservations.length) {
          return false;
        }

        let changed = false;

        for (const reservation of reservations) {
          const itemName = String(reservation.itemName || '').trim();
          const quantity = Math.max(0, Math.floor(Number(reservation.quantity || 0)));

          if (!itemName || quantity <= 0) {
            continue;
          }

          if (applyLocalSellToInventory(items, itemName, quantity)) {
            changed = true;
          }
        }

        return changed;
      }



      const INVENTORY_PAGE_SIZE = 6;
      let inventoryCurrentPage = 1;
      let inventoryCurrentKey = "";

      function getInventoryPaginationKey() {
        try {
          if (typeof activeInventoryReservationKey === 'function') {
            return activeInventoryReservationKey() || "";
          }
        } catch {}

        try {
          const viewedId = String(userId(state.activeUser) || get(state.activeUser, ['twitchId', 'twitch_id'], '') || '').trim();
          const viewedLogin = String(userLogin(state.activeUser) || get(state.activeUser, ['login', 'userLogin'], '') || '').trim().toLowerCase();
          return viewedId || viewedLogin || "";
        } catch {
          return "";
        }
      }

      function applyInventoryPagination() {
        const box = $('inventory');

        if (!box) {
          return;
        }

        box.querySelectorAll('.inventory-pagination').forEach((el) => el.remove());

        const cards = [...box.querySelectorAll('.item')];

        if (!cards.length) {
          return;
        }

        const key = getInventoryPaginationKey();

        if (key !== inventoryCurrentKey) {
          inventoryCurrentKey = key;
          inventoryCurrentPage = 1;
        }

        const totalPages = Math.max(1, Math.ceil(cards.length / INVENTORY_PAGE_SIZE));
        inventoryCurrentPage = Math.max(1, Math.min(inventoryCurrentPage, totalPages));

        const start = (inventoryCurrentPage - 1) * INVENTORY_PAGE_SIZE;
        const end = start + INVENTORY_PAGE_SIZE;

        cards.forEach((card, index) => {
          card.style.display = index >= start && index < end ? '' : 'none';
        });

        if (cards.length <= INVENTORY_PAGE_SIZE) {
          return;
        }

        const controls = document.createElement('div');
        controls.className = 'inventory-pagination';
        controls.innerHTML = `
          <button type="button" class="inventory-page-btn" data-inventory-page="prev" ${inventoryCurrentPage <= 1 ? 'disabled' : ''}>السابق</button>
          <span class="inventory-page-info">صفحة ${formatNumber(inventoryCurrentPage)} / ${formatNumber(totalPages)}</span>
          <button type="button" class="inventory-page-btn" data-inventory-page="next" ${inventoryCurrentPage >= totalPages ? 'disabled' : ''}>التالي</button>
        `;

        const handler = (event) => {
          const button = event.target.closest('[data-inventory-page]');

          if (!button || button.disabled) {
            return;
          }

          const direction = button.dataset.inventoryPage;

          if (direction === 'prev') {
            inventoryCurrentPage -= 1;
          } else if (direction === 'next') {
            inventoryCurrentPage += 1;
          }

          applyInventoryPagination();
        };

        if (typeof addListener === 'function') {
          addListener(controls, 'click', handler);
        } else {
          controls.addEventListener('click', handler);
        }

        box.appendChild(controls);
      }

      function updateInventoryItemDomAfterSell(soldName, quantity) {
        const box = $('inventory');

        if (!box) {
          return false;
        }

        const wanted = compactInventoryName(soldName);
        const amount = Math.max(1, Math.floor(Number(quantity || 1)));
        let changed = false;

        box.querySelectorAll('[data-sell-item]').forEach((button) => {
          const buttonName = button.dataset.sellItem || '';

          if (compactInventoryName(buttonName) !== wanted) {
            return;
          }

          const current = Math.max(0, Math.floor(Number(button.dataset.sellQty || 0)));
          const next = Math.max(0, current - amount);
          const card = button.closest('.item');

          if (next <= 0) {
            if (card) {
              card.remove();
              changed = true;
            }

            return;
          }

          button.dataset.sellQty = String(next);

          const row = button.closest('.inventory-sell-row');
          if (row) {
            const priceText = row.querySelector('.inventory-sell-price');
            if (priceText) {
              const meta = findCatalogItemByName(buttonName);
              const price = meta && !isSaleDisabled(meta) ? itemSellPrice(meta) : 0;
              priceText.textContent = 'بيع: ' + formatNumber(price) + ' نقطة';
            }
          }

          changed = true;
        });

        if (!box.querySelector('.item')) {
          box.innerHTML = '<div class="empty">ما عنده أغراض في الحقيبة.</div>';
          changed = true;
        }

        return changed;
      }

      function applyLocalSellToInventory(items, soldName, quantity) {
        const wanted = compactInventoryName(soldName);
        const amount = Math.max(1, Math.floor(Number(quantity || 1)));

        if (!Array.isArray(items)) {
          return false;
        }

        for (let i = 0; i < items.length; i += 1) {
          const item = items[i];
          const itemName = item?.name ?? item?.text ?? item?.itemName ?? "";

          if (compactInventoryName(itemName) !== wanted) {
            continue;
          }

          const current = readInventoryItemQuantity(item);
          const next = Math.max(0, current - amount);

          if (next <= 0) {
            items.splice(i, 1);
          } else {
            writeInventoryItemQuantity(item, next);
          }

          return true;
        }

        return false;
      }

      function setupInventorySellHandler(items) {
        const box = $('inventory')
        if (!box || box.dataset.sellHandlerReady === '1') return

        box.dataset.sellHandlerReady = '1'

        addListener(box, 'click', async (event) => {
          const button = event.target.closest('[data-sell-item]')
          if (!button) return

          event.preventDefault()
          event.stopPropagation()

          const allowed = await isProfileOwnerV36(state.activeUser)
          if (!allowed) {
            await syncOwnerControlsV36(state.activeUser)
            return
          }

          const name = button.dataset.sellItem || ''
          const qty = Math.max(1, Math.floor(Number(button.dataset.sellQty || 1)))
          const item = findInventoryItemByName(items, name) || { name, qty }
          const meta = findCatalogItemByName(name)

          openInventorySellModal(item, meta, items)
        })
      }


      function getSellAllEligibleInventoryItems(items) {
        const list = Array.isArray(items) ? items : [];

        return list
          .map((item) => {
            const name = String(item?.name || item?.text || item?.itemName || '').trim();
            const qty = Math.max(0, Math.floor(Number(item?.qty ?? item?.quantity ?? 0)));

            if (!name || qty <= 0) return null;

            const meta = itemMetaForDetail(name);

            if (itemDetailIsSaleDisabled(meta)) return null;

            const price = itemDetailSellPrice(meta);

            if (!Number.isFinite(price) || price <= 0) return null;

            return {
              item,
              name,
              qty,
              price,
              total: price * qty,
            };
          })
          .filter(Boolean);
      }

      function renderInventorySellAllButton(items, canSell) {
        return; // legacy disabled: using tnxMountSellAllButtonV2
        const box = $('inventory');

        if (!box) return;

