        inventoryBox.parentElement?.insertBefore(row, inventoryBox);

        const fmt = (value) => {
          if (typeof formatNumber === 'function') return formatNumber(value);
          return String(value);
        };

        const getEntryName = (entry) => String(entry?.name || entry?.itemName || entry?.item_name || '').trim();
        const getEntryQty = (entry) => Math.max(1, Math.floor(Number(entry?.qty || entry?.quantity || entry?.amount || 1)));
        const getEntryTotal = (entry) => Math.max(0, Math.floor(Number(entry?.total || entry?.sellTotal || entry?.sell_total || 0)));

        btn.addEventListener('click', async () => {
          const currentItems = Array.isArray(items) ? items : sourceItems;
          if (typeof refreshActiveProfileFromD1 === 'function') {
            note.textContent = 'جاري تحديث الحقيبة...';
            await refreshActiveProfileFromD1();
          }

          const freshItems = Array.isArray(window.__tnxInventoryFullList)
            ? window.__tnxInventoryFullList
            : Array.isArray(state?.activeUser?.inventory)
              ? state.activeUser.inventory
              : currentItems;

          const currentSellable = typeof tnxSellAllEligibleV2 === 'function'
            ? tnxSellAllEligibleV2(freshItems)
            : [];

          if (!currentSellable.length) {
            window.alert('ما عندك أغراض قابلة للبيع.');
            return;
          }

          const payloadItems = currentSellable
            .map((entry) => ({
              itemName: getEntryName(entry),
              quantity: getEntryQty(entry),
            }))
            .filter((entry) => entry.itemName && entry.quantity > 0);

          if (!payloadItems.length) {
            window.alert('ما عندك أغراض قابلة للبيع.');
            return;
          }

          const estimatedTotal = currentSellable.reduce((sum, entry) => sum + getEntryTotal(entry), 0);

          const confirmed = await tnxOpenSellAllConfirmModal({
            itemCount: payloadItems.length,
            total: estimatedTotal,
            fmt,
          });

          if (!confirmed) {
            return;
          }

          const oldText = btn.textContent;

          try {
            btn.disabled = true;
            btn.textContent = 'جاري البيع...';
            note.textContent = 'جاري إرسال طلب بيع واحد...';

            if (typeof tnxSetSellAllInventoryLock === 'function') {
              tnxSetSellAllInventoryLock('جاري بيع الكل...');
            }

            const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell-all', {
              method: 'POST',
              credentials: 'include',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                items: payloadItems,
              }),
            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok || !data?.ok) {
              throw new Error(data?.message || data?.error || 'فشل إرسال طلب بيع الكل.');
            }

            note.textContent = 'جاري تنفيذ البيع...';

            if (typeof tnxWaitSellRequestCompleteV2 === 'function') {
              await tnxWaitSellRequestCompleteV2(data.requestId);
            }
            if (typeof refreshActiveProfileFromD1 === 'function') {
              await refreshActiveProfileFromD1();
              setTimeout(() => refreshActiveProfileFromD1(), 1200);
              setTimeout(() => refreshActiveProfileFromD1(), 3000);
            }

            for (const entry of currentSellable) {
              const name = getEntryName(entry);
              const qty = getEntryQty(entry);

              if (name && typeof applyLocalSellToInventory === 'function') {
                applyLocalSellToInventory(currentItems, name, qty);
              }
            }

            if (typeof renderInventory === 'function') {
              renderInventory(window.__tnxInventoryFullList || freshItems || currentItems);
            }

            requestAnimationFrame(() => {
              if (typeof enhanceInventorySellButtons === 'function') {
                enhanceInventorySellButtons(window.__tnxInventoryFullList || freshItems || currentItems);
              }

              setTimeout(() => {
                if (typeof tnxClearSellAllInventoryLock === 'function') {
                  tnxClearSellAllInventoryLock();
                }
              }, 350);
            });
          } catch (error) {
            console.error('[Sell All Bulk] Failed:', error);

            btn.disabled = false;
            btn.textContent = oldText || 'بيع الكل';
            note.textContent = error?.message || 'فشل بيع الكل.';

            if (typeof tnxClearSellAllInventoryLock === 'function') {
              tnxClearSellAllInventoryLock();
            }

            window.alert(error?.message || 'فشل بيع الكل.');
          }
        });
      }

