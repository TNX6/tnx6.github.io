      function tnxNumberFromText(value) {
        const clean = String(value || '').replace(/[^\d]/g, '');
        const number = Math.floor(Number(clean || 0));

        return Number.isFinite(number) ? number : 0;
      }

      function tnxFormatDisplayNumber(value) {
        const number = Math.max(0, Math.floor(Number(value || 0)));

        try {
          return number.toLocaleString('en-US');
        } catch {
          return String(number);
        }
      }

      function tnxFindDisplayedPointsElement() {
        const inventory = document.getElementById('inventory');

        const labels = Array.from(document.querySelectorAll('body *')).filter((el) => {
          if (!el || el.children.length > 0) return false;
          if (inventory && inventory.contains(el)) return false;

          const text = String(el.textContent || '').trim();

          return text === 'نقطة' || text === 'النقاط' || text === 'نقاط';
        });

        for (const label of labels) {
          const host = label.closest('.card, section, article, div') || label.parentElement;

          if (!host) continue;
          if (inventory && inventory.contains(host)) continue;

          const numbers = Array.from(host.querySelectorAll('*')).filter((el) => {
            if (!el || el.children.length > 0) return false;
            if (inventory && inventory.contains(el)) return false;

            const text = String(el.textContent || '').trim();

            return /^[\d\s,٬.]+$/.test(text) && tnxNumberFromText(text) > 0;
          });

          if (numbers.length) {
            numbers.sort((a, b) => tnxNumberFromText(b.textContent) - tnxNumberFromText(a.textContent));
            return numbers[0];
          }
        }

        const fallback = Array.from(document.querySelectorAll('body *')).find((el) => {
          if (!el || el.children.length > 0) return false;
          if (inventory && inventory.contains(el)) return false;

          const text = String(el.textContent || '').trim();

          return /^[\d\s,٬.]+$/.test(text) && tnxNumberFromText(text) >= 1000;
        });

        return fallback || null;
      }


      function tnxAnimateDisplayedNumber(target, fromValue, toValue, duration = 850) {
        if (!target) return;

        const from = Math.max(0, Math.floor(Number(fromValue || 0)));
        const to = Math.max(0, Math.floor(Number(toValue || 0)));

        if (from === to) {
          target.textContent = tnxFormatDisplayNumber(to);
          return;
        }

        const oldFrame = Number(target.getAttribute('data-tnx-points-animation-frame') || 0);

        if (oldFrame) {
          cancelAnimationFrame(oldFrame);
        }

        const startedAt = performance.now();

        const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

        const tick = (now) => {
          const progress = Math.min(1, (now - startedAt) / duration);
          const eased = easeOutCubic(progress);
          const current = Math.round(from + ((to - from) * eased));

          target.textContent = tnxFormatDisplayNumber(current);

          if (progress < 1) {
            const frame = requestAnimationFrame(tick);
            target.setAttribute('data-tnx-points-animation-frame', String(frame));
          } else {
            target.textContent = tnxFormatDisplayNumber(to);
            target.removeAttribute('data-tnx-points-animation-frame');
          }
        };

        const frame = requestAnimationFrame(tick);
        target.setAttribute('data-tnx-points-animation-frame', String(frame));
      }
      function tnxApplyLocalPointBoostAfterSellAll(amount, animate = true) {
        const boost = Math.max(0, Math.floor(Number(amount || 0)));

        if (!boost) return;

        const target = tnxFindDisplayedPointsElement();

        if (!target) return;

        const previousBoost = Math.floor(Number(target.getAttribute('data-tnx-sell-all-point-boost') || 0));
        const currentDisplayed = tnxNumberFromText(target.textContent);

        if (previousBoost === boost && target.getAttribute('data-tnx-sell-all-point-done') === '1') {
          return;
        }

        let base = tnxNumberFromText(target.getAttribute('data-tnx-sell-all-point-base') || '');

        if (!base) {
          base = Math.max(0, currentDisplayed - previousBoost);
        }

        const nextValue = base + boost;

        target.setAttribute('data-tnx-sell-all-point-base', String(base));
        target.setAttribute('data-tnx-sell-all-point-boost', String(boost));
        target.setAttribute('data-tnx-sell-all-point-done', '1');

        if (animate && typeof tnxAnimateDisplayedNumber === 'function') {
          tnxAnimateDisplayedNumber(target, currentDisplayed, nextValue, 900);
        } else {
          target.textContent = tnxFormatDisplayNumber(nextValue);
        }
      }

      function tnxOpenSellAllConfirmModal(options = {}) {
        return new Promise((resolve) => {
          const fmt = typeof options.fmt === 'function'
            ? options.fmt
            : (value) => String(value || 0);

          const itemCount = Math.max(0, Math.floor(Number(options.itemCount || 0)));
          const total = Math.max(0, Math.floor(Number(options.total || 0)));

          document.querySelectorAll('.tnx-sell-all-confirm-backdrop').forEach((el) => el.remove());

          const safe = typeof esc === 'function'
            ? esc
            : (value) => String(value || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');

          const backdrop = document.createElement('div');
          backdrop.className = 'tnx-sell-all-confirm-backdrop';

          backdrop.innerHTML =
            '<div class="tnx-sell-all-confirm-modal" role="dialog" aria-modal="true" aria-label="تأكيد بيع الكل">' +
              '<div class="tnx-sell-all-confirm-head">' +
                '<div class="tnx-sell-all-confirm-icon">↯</div>' +
                '<h3 class="tnx-sell-all-confirm-title">تأكيد بيع الكل</h3>' +
                '<div class="tnx-sell-all-confirm-desc">سيتم بيع كل الأغراض القابلة للبيع من حقيبتك وإضافة النقاط مباشرة.</div>' +
              '</div>' +
              '<div class="tnx-sell-all-confirm-stats">' +
                '<div class="tnx-sell-all-confirm-stat">' +
                  '<span class="tnx-sell-all-confirm-label">عدد الأنواع</span>' +
                  '<span class="tnx-sell-all-confirm-value">' + safe(fmt(itemCount)) + '</span>' +
                '</div>' +
                '<div class="tnx-sell-all-confirm-stat">' +
                  '<span class="tnx-sell-all-confirm-label">الإجمالي المتوقع</span>' +
                  '<span class="tnx-sell-all-confirm-value">' + safe(fmt(total)) + ' نقطة</span>' +
                '</div>' +
              '</div>' +
              '<div class="tnx-sell-all-confirm-actions">' +
                '<button type="button" class="tnx-sell-all-confirm-btn cancel" data-sell-all-confirm="no">إلغاء</button>' +
                '<button type="button" class="tnx-sell-all-confirm-btn confirm" data-sell-all-confirm="yes">تأكيد البيع</button>' +
              '</div>' +
            '</div>';

          const close = (value) => {
            document.removeEventListener('keydown', onKeyDown);
            backdrop.remove();
            resolve(value);
          };

          const onKeyDown = (event) => {
            if (event.key === 'Escape') {
              close(false);
            }
          };

          backdrop.addEventListener('click', (event) => {
            if (event.target === backdrop) {
              close(false);
            }

            const button = event.target?.closest?.('[data-sell-all-confirm]');

            if (!button) {
              return;
            }

            close(button.getAttribute('data-sell-all-confirm') === 'yes');
          });

          document.addEventListener('keydown', onKeyDown);
          document.body.appendChild(backdrop);

          requestAnimationFrame(() => {
            backdrop.querySelector('[data-sell-all-confirm="yes"]')?.focus?.();
          });
        });
      }
      async function tnxMountSellAllButtonV2(items) {
        document.querySelectorAll('.tnx-sell-all-row, .inventory-sell-all-bar').forEach((el) => el.remove());

        const inventoryBox = document.getElementById('inventory');

        if (!inventoryBox) {
          return;
        }

        const sourceItems = Array.isArray(items) ? items : [];
        const sellable = typeof tnxSellAllEligibleV2 === 'function'
          ? tnxSellAllEligibleV2(sourceItems)
          : [];

        if (!sellable.length) {
          return;
        }

        const row = document.createElement('div');
        row.className = 'tnx-sell-all-row';

        const btn = document.createElement('button');
        btn.className = 'tnx-sell-all-btn';
        btn.type = 'button';
        btn.textContent = 'بيع الكل';

        const note = document.createElement('div');
        note.className = 'tnx-sell-all-note';
        note.textContent = '';

        row.appendChild(btn);
        row.appendChild(note);

        inventoryBox.parentElement?.insertBefore(row, inventoryBox);

        const fmt = (value) => {
          if (typeof formatNumber === 'function') return formatNumber(value);
          return String(value);
        };

        const getEntryName = (entry) => String(entry?.name || entry?.itemName || entry?.item_name || '').trim();
        const getEntryQty = (entry) => Math.max(1, Math.floor(Number(entry?.qty || entry?.quantity || entry?.amount || 1)));
        const getEntryTotal = (entry) => Math.max(0, Math.floor(Number(entry?.total || entry?.sellTotal || entry?.sell_total || 0)));

        btn.addEventListener('click', async () => {
          const currentItems = Array.isArray(items) ? items : sourceItems;
          const currentSellable = typeof tnxSellAllEligibleV2 === 'function'
            ? tnxSellAllEligibleV2(currentItems)
            : [];

          if (!currentSellable.length) {
            window.alert('ما عندك أغراض قابلة للبيع.');
            return;
          }

          const payloadItems = currentSellable
            .map((entry) => ({
              itemName: getEntryName(entry),
              quantity: getEntryQty(entry),
            }))
            .filter((entry) => entry.itemName && entry.quantity > 0);

          if (!payloadItems.length) {
            window.alert('ما عندك أغراض قابلة للبيع.');
            return;
          }

          const estimatedTotal = currentSellable.reduce((sum, entry) => sum + getEntryTotal(entry), 0);

          const confirmed = await tnxOpenSellAllConfirmModal({
            itemCount: payloadItems.length,
            total: estimatedTotal,
            fmt,
          });

          if (!confirmed) {
            return;
          }

          const oldText = btn.textContent;

          try {
            btn.disabled = true;
            btn.textContent = 'جاري البيع...';
            note.textContent = 'جاري إرسال طلب بيع واحد...';

            if (typeof tnxSetSellAllInventoryLock === 'function') {
              tnxSetSellAllInventoryLock('جاري بيع الكل...');
            }

            const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell-all', {
              method: 'POST',
              credentials: 'include',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                items: payloadItems,
              }),
            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok || !data?.ok) {
              throw new Error(data?.message || data?.error || 'فشل إرسال طلب بيع الكل.');
            }

            note.textContent = 'جاري تنفيذ البيع...';

            if (typeof tnxWaitSellRequestCompleteV2 === 'function') {
              await tnxWaitSellRequestCompleteV2(data.requestId);
            }

            const localSellTotal = Math.max(0, Math.floor(Number(data?.sellTotal || estimatedTotal || 0)));

            if (typeof tnxApplyLocalPointBoostAfterSellAll === 'function') {
              tnxApplyLocalPointBoostAfterSellAll(localSellTotal, true);
              setTimeout(() => tnxApplyLocalPointBoostAfterSellAll(localSellTotal, false), 800);
              setTimeout(() => tnxApplyLocalPointBoostAfterSellAll(localSellTotal, false), 2000);
            }

            for (const entry of currentSellable) {
              const name = getEntryName(entry);
              const qty = getEntryQty(entry);

              if (name && typeof applyLocalSellToInventory === 'function') {
                applyLocalSellToInventory(currentItems, name, qty);
              }
            }

            if (typeof renderInventory === 'function') {
              renderInventory(currentItems);
            }

            requestAnimationFrame(() => {
              if (typeof enhanceInventorySellButtons === 'function') {
                enhanceInventorySellButtons(currentItems);
              }

              setTimeout(() => {
                if (typeof tnxClearSellAllInventoryLock === 'function') {
                  tnxClearSellAllInventoryLock();
                }
              }, 350);
            });
          } catch (error) {
            console.error('[Sell All Bulk] Failed:', error);

            btn.disabled = false;
            btn.textContent = oldText || 'بيع الكل';
            note.textContent = error?.message || 'فشل بيع الكل.';

            if (typeof tnxClearSellAllInventoryLock === 'function') {
              tnxClearSellAllInventoryLock();
            }

            window.alert(error?.message || 'فشل بيع الكل.');
          }
        });
      }

