          '.mb-upgrade-v4-actions{display:flex;align-items:center;gap:9px}' +
          '.mb-upgrade-v4-confirm{flex:1;height:42px;border:0;border-radius:13px;background:#ff8a5b;color:#2a160c;cursor:pointer;font-size:13px;font-weight:1000;display:inline-flex;align-items:center;justify-content:center;gap:7px}' +
          '.mb-upgrade-v4-confirm:hover{background:#ff9d6b}' +
          '.mb-upgrade-v4-confirm:disabled{opacity:.62;cursor:not-allowed}' +
          '.mb-upgrade-v4-cancel{height:42px;padding:0 18px;border-radius:13px;border:1px solid rgba(255,255,255,.1);background:transparent;color:rgba(255,255,255,.6);cursor:pointer;font-size:13px;font-weight:900}' +
          '.mb-upgrade-v4-cancel:hover{color:#fff;border-color:rgba(255,255,255,.2)}'

        document.head.appendChild(style)
      }

      async function mbUpgradeV4Poll(requestId, modal, confirmButton) {
        const startedAt = Date.now()

        while (Date.now() - startedAt < 70000) {
          await new Promise((resolve) => setTimeout(resolve, 1500))

          const result = await mbUpgradeV4Fetch('/api/me/mailbox/upgrade-status?id=' + encodeURIComponent(requestId), {
            method: 'GET',
          })

          const response = result.response
          const data = result.data

          if (!response.ok || !data.ok) continue

          if (data.status === 'completed') {
            mbUpgradeV4State(
              modal,
              'success',
              'تم تطوير البريد بنجاح. السعة الجديدة: ' + mbUpgradeV4Format(data.targetCapacity) + ' رسالة.'
            )

            try {
              if (typeof loadMailboxUpgradeInfo === 'function') await loadMailboxUpgradeInfo()
            } catch {}

            // إعادة تحميل النقاط وبيانات البروفايل من D1 بعد الخصم (يمسح كاش الاقتصاد/الحقيبة ويعيد الجلب)
            try {
              if (typeof refreshActiveProfileFromD1 === 'function') await refreshActiveProfileFromD1()
            } catch {}

            if (confirmButton) {
              confirmButton.textContent = 'تم التطوير'
              confirmButton.disabled = true
            }

            setTimeout(() => {
              mbUpgradeV4Remove()
            }, 1500)

            return
          }

          if (data.status === 'rejected') {
            mbUpgradeV4State(modal, 'error', mbUpgradeV4Error(data.errorMessage || data.error || 'rejected'))

            if (confirmButton) {
              confirmButton.textContent = 'تأكيد التطوير'
              confirmButton.disabled = false
            }

            return
          }
        }

        mbUpgradeV4State(modal, 'error', 'تأخر تنفيذ الطلب. جرّب من جديد بعد قليل.')

        if (confirmButton) {
          confirmButton.textContent = 'تأكيد التطوير'
          confirmButton.disabled = false
        }
      }

      async function mbUpgradeV4Open() {
        if (window.__mbUpgradeV4Opening) return
        window.__mbUpgradeV4Opening = true

        try {
          mbUpgradeV4Style()
          mbUpgradeV4Remove()

          let info = null

          try {
            const result = await mbUpgradeV4Fetch('/api/me/mailbox/upgrade-info', {
              method: 'GET',
            })

            if (result.response.ok && result.data.ok) {
              info = result.data
            }
          } catch {}

          if (!info) {
            info = {
              used: 0,
              capacity: 5,
              maxCapacity: 45,
              nextCapacity: 10,
              increase: 5,
              cost: 25000,
              canUpgrade: true,
            }
          }

          const used = Number(info.used || 0)
          const capacity = Number(info.capacity || 5)
          const nextCapacity = Number(info.nextCapacity || 10)
          const increase = Number(info.increase || Math.max(0, nextCapacity - capacity))
          const cost = Number(info.cost || 0)
          const canUpgrade = Boolean(info.canUpgrade)

          const doneStages = Math.max(0, Math.min(8, Math.round((capacity - 5) / 5)))
          const stageLabel = doneStages >= 8 ? 'وصلت للحد الأعلى' : 'المرحلة ' + mbUpgradeV4Format(doneStages + 1) + ' من 8'

          let stagesHtml = '<div class="mb-upgrade-v4-stages">'
          for (let i = 0; i < 8; i++) {
            stagesHtml += '<div class="mb-upgrade-v4-stage' + (i < doneStages ? ' done' : (i === doneStages && canUpgrade) ? ' next' : '') + '"></div>'
          }
          stagesHtml += '</div>'

          const arrowSvg = '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 18-6-6 6-6"/></svg>'

          const modal = document.createElement('div')
          modal.className = 'mb-upgrade-v4-modal'
          modal.setAttribute('data-mb-upgrade-v4-modal', 'true')

          modal.innerHTML =
            '<div class="mb-upgrade-v4-dialog">' +
              '<button class="mb-upgrade-v4-close" type="button" data-mb-upgrade-v4-close aria-label="إغلاق">×</button>' +

              '<div class="mb-upgrade-v4-head">' +
                '<div class="mb-upgrade-v4-head-icon">' + mbV2IconSvg('up', 22) + '</div>' +
                '<div><h3>تطوير البريد</h3><p>' + stageLabel + '</p></div>' +
              '</div>' +

              (canUpgrade
                ? '<div class="mb-upgrade-v4-compare">' +
                    '<div class="mb-upgrade-v4-col"><small>السعة الحالية</small><strong>' + mbUpgradeV4Format(capacity) + '</strong><em>رسالة</em></div>' +
                    '<div class="mb-upgrade-v4-mid">' + arrowSvg + '<span>+' + mbUpgradeV4Format(increase) + '</span></div>' +
                    '<div class="mb-upgrade-v4-col mb-upgrade-v4-col-next"><small>بعد التطوير</small><strong>' + mbUpgradeV4Format(nextCapacity) + '</strong><em>رسالة</em></div>' +
                  '</div>' +
                  stagesHtml +
                  '<div class="mb-upgrade-v4-cost">' +
                    '<span class="mb-upgrade-v4-cost-label">' + mbV2IconSvg('coin', 16) + 'تكلفة التطوير</span>' +
                    '<span class="mb-upgrade-v4-cost-value">' + mbUpgradeV4Format(cost) + ' <i>نقطة</i></span>' +
                  '</div>'
                : '<div class="mb-upgrade-v4-compare">' +
                    '<div class="mb-upgrade-v4-col mb-upgrade-v4-col-next"><small>السعة الحالية</small><strong>' + mbUpgradeV4Format(capacity) + '</strong><em>رسالة</em></div>' +
                  '</div>' +
                  stagesHtml +
                  '<div class="mb-upgrade-v4-max">صندوق بريدك وصل لأعلى سعة متاحة حاليًا.</div>'
              ) +

              '<div class="mb-upgrade-v4-state" data-mb-upgrade-v4-state></div>' +

              '<div class="mb-upgrade-v4-actions">' +
                (canUpgrade ? '<button class="mb-upgrade-v4-confirm" type="button" data-mb-upgrade-v4-confirm data-target-capacity="' + nextCapacity + '">' + mbV2IconSvg('check', 16) + 'تأكيد التطوير</button>' : '') +
                '<button class="mb-upgrade-v4-cancel" type="button" data-mb-upgrade-v4-close>' + (canUpgrade ? 'إلغاء' : 'إغلاق') + '</button>' +
              '</div>' +
            '</div>'

          document.body.appendChild(modal)

          modal.querySelectorAll('[data-mb-upgrade-v4-close]').forEach((button) => {
            button.addEventListener('click', () => modal.remove())
          })

          const confirmButton = modal.querySelector('[data-mb-upgrade-v4-confirm]')

          if (confirmButton) {
            confirmButton.addEventListener('click', async () => {
              const targetCapacity = Number(confirmButton.dataset.targetCapacity || 0)

              confirmButton.disabled = true
              confirmButton.textContent = 'جاري التنفيذ...'
              mbUpgradeV4State(modal, 'loading', 'جاري إرسال طلب التطوير...')

              try {
                const result = await mbUpgradeV4Fetch('/api/me/mailbox/upgrade', {
                  method: 'POST',
                  body: JSON.stringify({
                    targetCapacity,
                  }),
                })

                const response = result.response
                const data = result.data

                if (!response.ok || !data.ok) {
                  if (data.error === 'upgrade_already_pending' && data.requestId) {
                    mbUpgradeV4State(modal, 'loading', 'عندك طلب قيد التنفيذ. ننتظر النتيجة...')
                    await mbUpgradeV4Poll(data.requestId, modal, confirmButton)
                    return
                  }

                  mbUpgradeV4State(modal, 'error', mbUpgradeV4Error(data.error))
                  confirmButton.disabled = false
                  confirmButton.textContent = 'تأكيد التطوير'
                  return
                }

                mbUpgradeV4State(modal, 'loading', 'تم إرسال الطلب. جاري تنفيذ التطوير...')
                await mbUpgradeV4Poll(data.requestId, modal, confirmButton)
              } catch {
                mbUpgradeV4State(modal, 'error', 'صار خطأ في الاتصال. جرّب مرة ثانية.')
                confirmButton.disabled = false
                confirmButton.textContent = 'تأكيد التطوير'
              }
            })
          }
        } finally {
          setTimeout(() => {
            window.__mbUpgradeV4Opening = false
          }, 500)
        }
      }

      if (!window.__mbUpgradeV4ClickInstalled) {
        window.__mbUpgradeV4ClickInstalled = true

        document.addEventListener('click', (event) => {
          const target = event.target

          if (!(target instanceof Element)) return

          const button = target.closest('[data-mb-upgrade-open-v4]')

          if (!button) return

          event.preventDefault()
          event.stopPropagation()

          try {
            if (typeof event.stopImmediatePropagation === 'function') {
              event.stopImmediatePropagation()
            }
          } catch {}

          mbUpgradeV4Open()
        }, true)
      }



      /* ============================================================
         عرض في السوق (Market List Modal)
         UI فقط: POST /api/me/market/list ثم متابعة my-listings
         ============================================================ */

      const MK_DURATIONS = [
