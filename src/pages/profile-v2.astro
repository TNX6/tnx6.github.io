        // D1 is the only inventory source for profile-v2.
        // Do not fall back to __REMOVED_OLD_INVENTORY_JSON__ or profile.inventory,
        // otherwise sold items can reappear from the old static GitHub JSON.
        merged.inventory = Array.isArray(user.inventory) ? user.inventory : []

        merged.mailbox = Array.isArray(profile.mailbox)
          ? profile.mailbox
          : Array.isArray(mail.messages)
            ? mail.messages
            : Array.isArray(mail.mailbox)
              ? mail.mailbox
              : Array.isArray(user.mailbox)
                ? user.mailbox
                : []

        return applyLeaderboardMetrics(merged)
      }

      function itemName(entry) {
        return String(get(entry, ['name', 'itemName', 'item', 'Name', 'key'], '')).trim()
      }

      function itemQty(entry) {
        return Math.max(1, num(get(entry, ['quantity', 'qty', 'amount', 'count', 'Value'], 1)))
      }

      function catalogItem(name) {
        const itemKey = key(name)
        return state.items.find((item) => key(get(item, ['name', 'itemName', 'title'], '')) === itemKey) || null
      }

      function itemMeta(name) {
        const itemKey = key(name)
        const hard = Object.entries(HARD_ITEMS).find(([hardName]) => key(hardName) === itemKey)?.[1]
        if (hard) return hard

        const item = catalogItem(name)
        if (!item) return { icon: '📦', rarity: 'Common', cat: 'economy' }

        return {
          icon: get(item, ['icon', 'emoji'], '📦'),
          rarity: get(item, ['rarity'], 'Common'),
          cat: get(item, ['category', 'type', 'cat'], 'economy'),
        }
      }

      /* PROFILE_INVENTORY_D1_ONLY_V2 */
      /* PROFILE_INVENTORY_D1_SOURCE_V1 */
      /* INVENTORY_SELL_LOCK_INTEGRATED_V10 */
      const INVENTORY_SELL_LOCK_KEY_V10 = 'tnx_inventory_sold_locks_v10';
      const INVENTORY_SELL_LOCK_TTL_V10 = 35 * 60 * 1000;

      function inventorySellLockScope(user = state.activeUser) {
        try {
          const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim();
          const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase();
          return viewedId || viewedLogin || 'tnx_6';
        } catch {
          return 'tnx_6';
        }
      }

      function readInventorySellLocksV10() {
        let rows = [];

        try {
          const current = JSON.parse(localStorage.getItem(INVENTORY_SELL_LOCK_KEY_V10) || '[]');
          if (Array.isArray(current)) rows = rows.concat(current);
        } catch {}

        // Migration from earlier working versions, then remove noisy old versions.
        for (const legacyKey of ['tnx_inventory_sold_locks_v8', 'tnx_inventory_sold_locks_v9']) {
          try {
            const legacy = JSON.parse(localStorage.getItem(legacyKey) || '[]');
            if (Array.isArray(legacy)) rows = rows.concat(legacy);
            localStorage.removeItem(legacyKey);
          } catch {}
        }

        for (const badKey of [
          'tnx_inventory_sold_locks_v5',
          'tnx_inventory_sold_locks_v6',
          'tnx_inventory_sold_locks_v7',
        ]) {
          try { localStorage.removeItem(badKey); } catch {}
        }

        const seen = new Set();
        rows = rows
          .filter((row) => row && row.itemName && (Date.now() - Number(row.ts || 0)) < INVENTORY_SELL_LOCK_TTL_V10)
          .filter((row) => {
            const id = String(row.id || `${row.scope || ''}:${row.itemName}:${row.quantity}:${row.ts}`);
            if (seen.has(id)) return false;
            seen.add(id);
            return true;
          });

        try {
          localStorage.setItem(INVENTORY_SELL_LOCK_KEY_V10, JSON.stringify(rows));
        } catch {}

        return rows;
      }

      function writeInventorySellLocksV10(rows) {
        try {
          localStorage.setItem(INVENTORY_SELL_LOCK_KEY_V10, JSON.stringify(Array.isArray(rows) ? rows : []));
        } catch {}
      }

      function inventorySellLockName(value) {
        return key(value);
      }

      function addInventorySellLock(itemName, quantity, sourceQty, user = state.activeUser) {
        const name = String(itemName || '').trim();
        const itemKey = inventorySellLockName(name);
        const qty = Math.max(1, Math.floor(Number(quantity || 1)));

        if (!itemKey) return '';

        const id = `${Date.now()}_${Math.random().toString(16).slice(2)}`;
        const rows = readInventorySellLocksV10();

        rows.push({
          id,
          scope: inventorySellLockScope(user),
          itemName: name,
          itemKey,
          quantity: qty,
          sourceQty: Math.max(1, Math.floor(Number(sourceQty || qty))),
          ts: Date.now(),
        });

        writeInventorySellLocksV10(rows);
        return id;
      }

      function removeInventorySellLock(id) {
        if (!id) return;

        writeInventorySellLocksV10(
          readInventorySellLocksV10().filter((row) => row.id !== id)
        );
      }

      function sellLocksForInventoryUser(user) {
        const scope = inventorySellLockScope(user);

        return readInventorySellLocksV10().filter((row) => {
          if (!row.scope) return true;
          return String(row.scope) === scope;
        });
      }

      function applyInventorySellLocksToEntries(entries, user) {
        if (!Array.isArray(entries) || !entries.length) return [];

        const locks = sellLocksForInventoryUser(user);
        if (!locks.length) return entries.slice();

        const adjusted = [];

        for (const entry of entries) {
          const name = itemName(entry);
          const entryKey = inventorySellLockName(name);
          const originalQty = itemQty(entry);
          let soldQty = 0;

          for (const lock of locks) {
            const lockKey = String(lock.itemKey || inventorySellLockName(lock.itemName));

            if (!entryKey || !lockKey || entryKey !== lockKey) continue;

            const sourceQty = Math.max(0, Math.floor(Number(lock.sourceQty || 0)));

            // If GitHub already exported the new lower quantity, do not subtract the local lock again.
            if (sourceQty > 0 && originalQty < sourceQty) continue;

            soldQty += Math.max(1, Math.floor(Number(lock.quantity || 1)));
          }

          const remaining = originalQty - soldQty;

          if (remaining <= 0) continue;

          if (typeof entry === 'object' && entry !== null) {
            const clone = { ...entry };

            if ('qty' in clone) clone.qty = remaining;
            else if ('quantity' in clone) clone.quantity = remaining;
            else if ('amount' in clone) clone.amount = remaining;
            else if ('count' in clone) clone.count = remaining;
            else clone.quantity = remaining;

            adjusted.push(clone);
          } else {
            adjusted.push({
              name,
              quantity: remaining,
            });
          }
        }

        return adjusted;
      }

      function setInventoryCountFromItems(items) {
        const count = Array.isArray(items) ? items.length : 0;
        setText('inventoryCount', `${count} ${count === 1 ? 'غرض' : 'أغراض'}`);
      }

      function inventoryItems(user) {
        return applyInventorySellLocksToEntries(Array.isArray(user.inventory) ? user.inventory : [], user)
          .map((entry) => {
            const name = itemName(entry)
            const meta = itemMeta(name)
            const details = catalogItem(name)

            return {
              name,
              qty: itemQty(entry),
              icon: meta.icon || '📦',
              rarity: meta.rarity || 'Common',
              cat: meta.cat || 'economy',
              description: get(details, ['description', 'desc', 'how'], 'غرض من حقيبة العضو.'),
            }
          })
          .filter((item) => item.name)
      }

      function badgeName(badge) {
        return String(get(badge, ['name', 'badgeName', 'title', 'value1'], '')).trim()
      }

      function badgeImage(badge) {
        return safeUrl(get(badge, ['url', 'image', 'badgeUrl', 'value2'], ''))
      }

      function badgeRarity(badge) {
        const explicit = normalize(get(badge, ['rarity', 'tier', 'badgeRarity', 'type'], ''))
        if (explicit) {
          if (explicit.includes('mythic') || explicit.includes('اسطوري') || explicit.includes('أسطوري')) return 'Mythic'
          if (explicit.includes('legendary') || explicit.includes('legend')) return 'Legendary'
          if (explicit.includes('epic')) return 'Epic'
          if (explicit.includes('rare')) return 'Rare'
          if (explicit.includes('common')) return 'Common'
        }

        const name = normalize(badgeName(badge))

        if (
          name.includes('vip') ||
          name.includes('king') ||
          name.includes('ملك') ||
          name.includes('3m') ||
          name.includes('1m') ||
          name.includes('1000q') ||
          name.includes('100d') ||
          name.includes('500k')
        ) return 'Legendary'

        if (
          name.includes('250k') ||
          name.includes('600q') ||
          name.includes('60d') ||
          name.includes('500q')
        ) return 'Epic'

        if (
          name.includes('100k') ||
          name.includes('300q') ||
          name.includes('30d') ||
          name.includes('law') ||
          name.includes('محامي')
        ) return 'Rare'

        return 'Common'
      }

      function badgeXpValue(rarity) {
        const table = {
          Common: 500,
          Rare: 1500,
          Epic: 4000,
          Legendary: 8000,
          Mythic: 15000,
        }

        return table[rarity] || table.Common
      }

      function badgeXp(badge) {
        return badgeXpValue(badgeRarity(badge))
      }

      function totalBadgeXp(badges) {
        // Badge XP يعتمد على البادجات الحالية فقط.
        // إذا العضو باع/أهدى بادج وانحذف من user_badges.json، ينقص XP تلقائيًا.
        return (Array.isArray(badges) ? badges : []).reduce((sum, badge) => sum + badgeXp(badge), 0)
      }

      function fallbackAvatar(name) {
        const letter = encodeURIComponent((name || 'U').charAt(0).toUpperCase())
        return `data:image/svg+xml;utf8,
        <svg xmlns='http://www.w3.org/2000/svg' width='300' height='300' viewBox='0 0 300 300'>
          <defs>
            <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
              <stop stop-color='%23ffdf8a'/>
              <stop offset='1' stop-color='%23613f13'/>
            </linearGradient>
          </defs>
          <rect width='300' height='300' rx='58' fill='%23090909'/>
          <circle cx='150' cy='132' r='70' fill='url(%23g)' opacity='.95'/>
          <text x='150' y='168' font-size='92' text-anchor='middle' font-family='Arial' font-weight='900' fill='%23100b04'>${letter}</text>
          <rect x='60' y='222' width='180' height='22' rx='11' fill='%23ffdf8a' opacity='.22'/>
        </svg>`
      }

      function fallbackCover() {
        return `radial-gradient(circle at 50% 20%, rgba(255,223,138,.24), transparent 35%),
                linear-gradient(135deg, #1a1208, #080808 58%, #1d160b)`
      }

      // XP sources: watchtime + daily login + currently owned badges.
      // Watchtime: 1 hour = 3,000 XP, so 1 minute = 50 XP.
      const WATCH_MINUTE_WEIGHT = 50
      const DAILY_LOGIN_XP = 500

      function currentPoints(user) {
        const rawPoints = num(deepGet(user, ['points', 'totalPoints', 'balance', 'loyaltyPoints'], 0))

        try {
          if (typeof getOptimisticEconomyV1 === 'function') {
            const optimistic = getOptimisticEconomyV1(user || state.activeUser)
            const optimisticPoints = Math.max(0, Math.floor(Number(optimistic?.points || 0)))

            if (optimisticPoints > rawPoints) {
              return optimisticPoints
            }
          }
        } catch {}

        return rawPoints
      }


      function watchSeconds(user) {
        const watchtimeValue = deepGet(user, [
          'watchtime',
          'Watchtime',
          'watchTime',
          'WatchTime',
          'twitchWatchtime',
          'twitch_watchtime'
        ], '')

        if (watchtimeValue !== '') {
          const parsedWatchtime = parseWatchtimeText(watchtimeValue)
          if (parsedWatchtime > 0) return parsedWatchtime
        }

        const directSeconds = num(deepGet(user, [
          'watchSeconds',
          'watchtimeSeconds',
          'watchTimeSeconds',
          'totalWatchSeconds',
          'totalWatchtimeSeconds'
        ], 0))

        if (directSeconds > 0) return directSeconds

        const directMinutes = num(deepGet(user, [
          'watchMinutes',
          'watchtimeMinutes',
          'watchTimeMinutes',
          'totalWatchMinutes',
          'totalWatchtimeMinutes'
        ], 0))

        if (directMinutes > 0) return directMinutes * 60

        const directHours = num(deepGet(user, [
          'watchHours',
          'watchtimeHours',
          'watchTimeHours',
          'totalWatchHours',
          'totalWatchtimeHours'
        ], 0))

        if (directHours > 0) return directHours * 3600

        return parseWatchtimeText(deepGet(user, [
          'watchtimeText',
          'watchTimeText',
          'watchTime',
          'totalWatchtime',
          'totalWatchTime'
        ], ''))
      }

      function parseWatchtimeText(value) {
        const text = String(value || '').toLowerCase().trim()
        if (!text) return 0

        const clockMatch = text.match(/^(\d+):(\d{1,2})(?::(\d{1,2}))?$/)
        if (clockMatch) {
          const first = Number(clockMatch[1])
          const second = Number(clockMatch[2])
          const third = Number(clockMatch[3] || 0)

          if (clockMatch[3] !== undefined) return (first * 3600) + (second * 60) + third
          return (first * 60) + second
        }

        let seconds = 0

        const dayMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:d|day|days|يوم|ايام|أيام)/)
        const hourMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:h|hr|hrs|hour|hours|ساعة|ساعه)/)
        const minuteMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:m|min|mins|minute|minutes|دقيقة|دقيقه)/)
        const secondMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:s|sec|secs|second|seconds|ثانية|ثانيه)/)

        if (dayMatch) seconds += Number(dayMatch[1]) * 86400
        if (hourMatch) seconds += Number(hourMatch[1]) * 3600
        if (minuteMatch) seconds += Number(minuteMatch[1]) * 60
        if (secondMatch) seconds += Number(secondMatch[1])

        if (seconds > 0) return seconds

        const plainNumber = Number(text.replace(/,/g, ''))
        if (Number.isFinite(plainNumber) && plainNumber > 0) {
          return plainNumber * 60
        }

        return 0
      }

      function watchMinutes(user) {
        return Math.floor(watchSeconds(user) / 60)
      }

      function levelScore(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const watchScore = watchMinutes(user) * WATCH_MINUTE_WEIGHT
        const loginScore = dailyLoginXp(user)
        const badgesScore = totalBadgeXp(badges)

        return Math.floor(watchScore + loginScore + badgesScore)
      }

      function calculateLevel(user) {
        const score = levelScore(user)
        let level = 1
        let remaining = score
        let required = getRequiredXp(level)

        while (remaining >= required && level < 250) {
          remaining -= required
          level++
          required = getRequiredXp(level)
        }

        return {
          level,
          currentXp: remaining,
          requiredXp: required,
          percent: required > 0 ? Math.min(100, Math.round((remaining / required) * 100)) : 0,
          mode: 'XP',
          score,
          watchScore: watchMinutes(user) * WATCH_MINUTE_WEIGHT,
          dailyLoginScore: dailyLoginXp(user),
          dailyLoginCount: dailyLoginCount(user),
          badgeScore: totalBadgeXp(Array.isArray(user.badges) ? user.badges : []),
          watchMinutes: watchMinutes(user),
        }
      }

      function getRequiredXp(level) {
        return Math.floor(10000 * Math.pow(level, 1.17) + (level * 2500))
      }

      function getLevelTitle(level) {
        if (level >= 50) return 'أسطورة المجلس'
        if (level >= 35) return 'عضو نخبة'
        if (level >= 20) return 'ثقيل بالمجلس'
        if (level >= 10) return 'عضو فعّال'
        if (level >= 5) return 'عضو معروف'
        return 'عضو جديد'
      }

      function levelRankFor(user) {
        const rows = state.users
          .map((rawUser) => {
            const merged = mergeUser(rawUser)
            const levelData = calculateLevel(merged)

            return {
              user: merged,
              level: levelData.level,
              score: levelData.score,
              points: currentPoints(merged),
              name: userName(merged) || userLogin(merged),
            }
          })
          .filter((row) => userId(row.user) || userLogin(row.user) || userName(row.user))
          .sort((a, b) => {
            if (b.level !== a.level) return b.level - a.level
            if (b.score !== a.score) return b.score - a.score
            if (b.points !== a.points) return b.points - a.points
            return String(a.name).localeCompare(String(b.name))
          })

        const index = rows.findIndex((row) => matchUser(row.user, user))
        return index >= 0 ? index + 1 : null
      }

      function rankFor(user) {
        const rank = levelRankFor(user)
        return rank ? `#${rank}` : '—'
      }

      function messagesFor(user) {
        return get(user, ['messages', 'messageCount', 'chatMessages'], 0)
      }

      function dailyLoginCount(user) {
        return num(deepGet(user, [
          'dailyLogin',
          'dailyLogins',
          'daily_login',
          'daily_logins',
          'dailyCheckIns',
          'dailyCheckins',
          'checkins',
          'checkIns',
          'attendance',
          'loginCount',
          'login_count',
          'daily',
          'streak'
        ], 0))
      }

      function dailyLoginXp(user) {
        return dailyLoginCount(user) * DAILY_LOGIN_XP
      }

      function checkinsFor(user) {
        return dailyLoginCount(user)
      }

      function chipsFor(user, level, badges, inventory) {
        const chips = []

        const job = get(user, ['jobName'], '')
        if (job) chips.push(job)

        if (level >= 20) chips.push('ثقيل بالمجلس')
        else if (level >= 10) chips.push('متفاعل')
        else if (level >= 5) chips.push('عضو معروف')

        if (badges.length >= 10) chips.push('صاحب بادجات')
        if (inventory.some((item) => normalize(item.name).includes('vip'))) chips.unshift('VIP')
        if (!chips.length) chips.push('عضو')

        return chips.slice(0, 5)
      }


      /* Next badge card */
      function nextBadgeClean(value) {
        return String(value || "").trim().replace(/\s+/g, " ");
      }

      function nextBadgeKey(value) {
        return nextBadgeClean(value)
          .toLowerCase()
          .split(/\s*-\s*/)[0]
          .replace(/\s+/g, "")
          .replace(/[^a-z0-9\u0600-\u06ff]/g, "");
      }

      function ownedBadgeKeySet(badges = []) {
        return new Set(
          badges
            .map((badge) => {
              if (typeof badge === "string") return badge;
              return badge?.name || badge?.title || badge?.key || badge?.badge || "";
            })
            .map(nextBadgeKey)
            .filter(Boolean)
        );
      }

      function nextBadgeMeta(name) {
        if (typeof window.TNX_GET_BADGE_META === "function") {
          return window.TNX_GET_BADGE_META(name);
        }

        return {
          title: name,
          category: "عام",
          rarity: "عادي",
          how: "يتم الحصول عليه من التفاعل داخل المجتمع",
        };
      }

      function buildNextBadgeCandidates(user, badges = []) {
        const points = currentPoints(user);
        const checkins = checkinsFor(user);

        return [
          { name: "100K", type: "النقاط", current: points, target: 100000, unit: "نقطة" },
          { name: "250K", type: "النقاط", current: points, target: 250000, unit: "نقطة" },
          { name: "500K", type: "النقاط", current: points, target: 500000, unit: "نقطة" },
          { name: "1M", type: "النقاط", current: points, target: 1000000, unit: "نقطة" },

          { name: "15D", type: "الحضور", current: checkins, target: 15, unit: "يوم" },
          { name: "30D", type: "الحضور", current: checkins, target: 30, unit: "يوم" },
          { name: "60D", type: "الحضور", current: checkins, target: 60, unit: "يوم" },
          { name: "100D", type: "الحضور", current: checkins, target: 100, unit: "يوم" },
          { name: "150D", type: "الحضور", current: checkins, target: 150, unit: "يوم" },
        ].map((badge) => {
          const meta = nextBadgeMeta(badge.name);
          const percent = badge.target > 0
            ? Math.max(0, Math.min(100, Math.floor((badge.current / badge.target) * 100)))
            : 0;

          return {
            ...badge,
            meta,
            percent,
            remaining: Math.max(0, badge.target - badge.current),
            owned: ownedBadgeKeySet(badges).has(nextBadgeKey(badge.name)),
          };
        });
      }

      function pickNextBadge(user, badges = []) {
        const candidates = buildNextBadgeCandidates(user, badges)
          .filter((badge) => !badge.owned);

        if (!candidates.length) return null;

        return candidates.sort((a, b) => {
          const aReady = a.current >= a.target ? 1 : 0;
          const bReady = b.current >= b.target ? 1 : 0;

          if (aReady !== bReady) return bReady - aReady;
          if (a.percent !== b.percent) return b.percent - a.percent;
          return a.target - b.target;
        })[0];
      }

      function setupNextBadgeToggle() {
        const toggle = $("nextBadgeMiniToggle");
        const box = $("nextBadgeMiniBox");

        if (!toggle || !box || toggle.dataset.bound === "1") return;

        toggle.dataset.bound = "1";

        toggle.addEventListener("click", () => {
          const willOpen = box.hidden;

          box.hidden = !willOpen;
          toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
          toggle.classList.toggle("is-open", willOpen);
        });
      }

      function renderNextBadge(user, badges = []) {
        const box = $("nextBadgeMiniBox");
        if (!box) return;

        setupNextBadgeToggle();

        const next = pickNextBadge(user, badges);

        if (!next) {
          box.classList.add("is-done");
          box.classList.remove("is-ready");

          setText("nextBadgeMiniValue", "مكتمل");
          setText("nextBadgeMiniMeta", "كل بادجات النقاط والحضور الأساسية مفتوحة");
          setText("nextBadgeMiniPercent", "100%");
          setText("nextBadgeMiniRemain", "ما بقي شيء في المسارات الأساسية الحالية.");

          const fill = $("nextBadgeMiniFill");
          if (fill) fill.style.width = "100%";

          return;
        }

        const isReady = next.current >= next.target;

        box.classList.toggle("is-ready", isReady);
        box.classList.remove("is-done");

        setText("nextBadgeMiniValue", next.name);
        setText(
          "nextBadgeMiniMeta",
          next.type + " · " + formatNumber(Math.min(next.current, next.target)) + " / " + formatNumber(next.target) + " " + next.unit
        );
        setText("nextBadgeMiniPercent", next.percent + "%");
        setText(
          "nextBadgeMiniRemain",
          isReady
            ? "أنت مستوفي شرط هذا البادج."
            : "متبقي " + formatNumber(next.remaining) + " " + next.unit
        );

        const fill = $("nextBadgeMiniFill");
        if (fill) fill.style.width = next.percent + "%";
      }

      function renderProfile(rawUser) {
        const user = mergeUser(rawUser)
        state.activeUser = user

        $('searchView')?.classList.add('hidden')
        $('notFoundView')?.classList.add('hidden')
        $('profileView')?.classList.remove('hidden')

        const login = userLogin(user)
        const name = userName(user) || login
        const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], '')) || fallbackAvatar(name)
        const cover = safeUrl(get(user, ['bannerImage', 'banner', 'backgroundImage'], ''))
        const badges = Array.isArray(user.badges) ? user.badges : []
        const inventory = inventoryItems(user)
        const mail = mailItems(user)
        const level = calculateLevel(user)
        const bio = get(user, ['bio'], 'ملف العضو يعرض المستوى، الحقيبة، البادجات، والبريد في صفحة واحدة بشكل واضح.')

        document.documentElement.style.setProperty('--cover-image', cover ? `url("${cover}")` : fallbackCover())

        if ($('avatar')) $('avatar').src = avatar
        if ($('onlineDot')) $('onlineDot').style.display = get(user, ['online', 'isOnline'], false) ? 'block' : 'none'

        setText('displayName', name)
        setText('handle', '@' + login)
        setText('bio', bio)

        setText('levelNumber', level.level)
        setText('levelWatermark', level.level)
        setText('levelTitle', getLevelTitle(level.level))
        setText('currentXp', `${formatNumber(level.currentXp)} XP`)
        setText('neededXp', `${formatNumber(level.requiredXp)} XP`)
        if ($('xpFill')) $('xpFill').style.width = level.percent + '%'
        renderXpBreakdown(level)
        applyAvatarFrame(level.level)

        setText('rank', rankFor(user))
        setText('messages', formatNumber(messagesFor(user)))
        setText('checkins', formatNumber(checkinsFor(user)))
        setProfilePointsV1(currentPoints(user))

        setText('inventoryCount', `${inventory.length} ${inventory.length === 1 ? 'غرض' : 'أغراض'}`)
        setText('badgesCount', `${badges.length} مفتوحة`)
        renderNextBadge(user, badges)
        setText('mailCount', mail.length)

        if ($('badgesPageLink')) $('badgesPageLink').href = `/badges?user=${encodeURIComponent(login)}`

        renderChips(chipsFor(user, level.level, badges, inventory))
        renderInventory(inventory)
        enhanceInventorySellButtons(inventory)
        renderBadges(badges)
        renderFeaturedBadgesCleanV29(user)
        renderMail(mail)
        loadD1MailboxForProfile(user)
        installMailboxAutoRefresh()
        try { initWorkshopForProfile(user) } catch {}
        syncOwnerControlsV36(user)
      }

      function renderChips(chips) {
        const box = $('chips')
        if (!box) return

        box.innerHTML = chips.map((chip, index) => `
          <span class="chip${index === 0 ? ' gold' : ''}">${esc(chip)}</span>
        `).join('')
      }

      function applyAvatarFrame(level) {
        const wrap = document.querySelector('.avatar-wrap')
        if (!wrap) return

        wrap.classList.remove(
          'level-frame-basic',
          'level-frame-gold',
          'level-frame-animated',
          'level-frame-legendary',
          'level-frame-special'
        )

        if (level >= 50) wrap.classList.add('level-frame-special')
        else if (level >= 35) wrap.classList.add('level-frame-legendary')
        else if (level >= 20) wrap.classList.add('level-frame-animated')
        else if (level >= 10) wrap.classList.add('level-frame-gold')
        else wrap.classList.add('level-frame-basic')
      }

      function renderXpBreakdown(level) {
        const box = $('xpBreakdown')
        if (!box) return

        const rows = [
          { label: 'المشاهدة', value: level.watchScore },
          { label: 'تسجيل الدخول', value: level.dailyLoginScore },
          { label: 'البادجات', value: level.badgeScore },
          { label: 'المجموع', value: level.score, total: true },
        ]

        box.innerHTML = rows.map((row) => `
          <div class="xp-source${row.total ? ' total' : ''}">
            <span>${esc(row.label)}</span>
            <strong>${formatNumber(row.value)} XP</strong>
          </div>
        `).join('')
      }

      function renderInventoryRaw(items) {
        const box = $('inventory')
        if (!box) return

        if (!items.length) {
          box.innerHTML = `<div class="empty">الحقيبة فاضية.</div>`
          return
        }

        const sorted = [...items].sort((a, b) => b.qty - a.qty || a.name.localeCompare(b.name))

        box.innerHTML = sorted.map((item, index) => {
          const color = rarityColors[item.rarity] || rarityColors[item.cat] || '#ffffff'
          return `
            <button
              class="item"
              type="button"
              data-item-index="${index}"
              data-item-name="${esc(item.name)}"
              data-item-qty="${esc(item.qty)}"
              data-item-icon="${esc(item.icon)}"
              data-item-rarity="${esc(item.rarity || item.cat || '')}"
              style="--rarity-color:${color}"
            >
              <div class="item-icon">${esc(item.icon)}</div>
              <div>
                <h3 class="item-name">${esc(item.name)}</h3>
                <div class="item-meta">
                  <span class="qty">x${formatNumber(item.qty)}</span>
                  <span>${esc(item.rarity || item.cat || 'Item')}</span>
                </div>
              </div>
            </button>
          `
        }).join('')

        box.querySelectorAll('[data-item-index]').forEach((button) => {
          addListener(button, 'click', async () => {
            const allowed = await isProfileOwnerV36(state.activeUser)
            if (!allowed) {
              await syncOwnerControlsV36(state.activeUser)
              return
            }

            const item = sorted[Number(button.dataset.itemIndex)]
            if (item) await openItemModal(item)
          })
        })
      }

      const INVENTORY_PAGE_SIZE_V2 = 6;
      let inventoryPageV2 = 1;
      let inventoryPageKeyV2 = "";

      function getInventoryPageKeyV2() {
        try {
          const viewedId = String(userId(state.activeUser) || get(state.activeUser, ['twitchId', 'twitch_id'], '') || '').trim();
          const viewedLogin = String(userLogin(state.activeUser) || get(state.activeUser, ['login', 'userLogin'], '') || '').trim().toLowerCase();
          return viewedId || viewedLogin || "";
        } catch {
          return "";
        }
      }

      function renderInventoryPaginationV2(totalItems, totalPages) {
        const box = $('inventory');

        document.querySelectorAll('.inventory-pagination, .inventory-pagination-v2').forEach((el) => el.remove());

