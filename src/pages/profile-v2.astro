      function renderSearch(query) {
        const target = $('searchResults')
        if (!target) return

        const q = normalize(query)
        target.innerHTML = ''
        if (!q) return

        const matches = state.users.filter((user) =>
          normalize(userName(user)).includes(q) || normalize(userLogin(user)).includes(q)
        ).slice(0, 10)

        target.innerHTML = matches.map((user) => {
          const login = userLogin(user)
          const name = userName(user) || login
          const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], '')) || fallbackAvatar(name)

          return `
            <button type="button" class="search-result" data-login="${esc(login)}">
              <img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy" />
              <div>
                <strong>${esc(name)}</strong>
                <span>@${esc(login)}</span>
              </div>
            </button>
          `
        }).join('')
      }

      function findUser(login) {
        const target = normalize(login)
        return state.users.find((user) =>
          normalize(userLogin(user)) === target || normalize(userName(user)) === target
        ) || null
      }


      function isOwnProfile(user, authUser) {
        if (!user || !authUser) return false

        const profileLogin = normalize(userLogin(user))
        const authLogin = normalize(authUser.login)
        const profileId = String(userId(user) || get(user, ['twitchId'], '')).trim()
        const authId = String(authUser.twitchId || authUser.id || '').trim()

        return Boolean(
          (profileLogin && authLogin && profileLogin === authLogin) ||
          (profileId && authId && profileId === authId)
        )
      }

      function requestedProfileTokenV36() {
        try {
          return String(new URLSearchParams(location.search).get('user') || '').trim().replace(/^@+/, '')
        } catch {
          return ''
        }
      }

      function authLoginTokensV36(authUser) {
        const set = new Set()

        ;[
          authUser?.login,
          authUser?.userLogin,
          authUser?.displayName,
          authUser?.userName,
          authUser?.name,
        ].forEach((value) => {
          const token = normalize(String(value || '').replace(/^@+/, ''))
          if (token) set.add(token)
        })

        return set
      }

      function authIdTokensV36(authUser) {
        const set = new Set()

        ;[
          authUser?.twitchId,
          authUser?.twitch_id,
          authUser?.id,
          authUser?.userId,
          authUser?.UserId,
        ].forEach((value) => {
          const token = String(value || '').trim()
          if (token) set.add(token)
        })

        return set
      }

      function authOwnsRequestedProfileV36(authUser) {
        if (!authUser) return false

        const requested = requestedProfileTokenV36()
        if (!requested) return null

        const requestedLogin = normalize(requested)
        const requestedId = String(requested || '').trim()

        const authLogins = authLoginTokensV36(authUser)
        const authIds = authIdTokensV36(authUser)

        return Boolean(
          (requestedId && authIds.has(requestedId)) ||
          (requestedLogin && authLogins.has(requestedLogin))
        )
      }

      async function isProfileOwnerV36(user = state.activeUser) {
        const authUser = await getLoggedInUser()
        if (!authUser) return false

        const ownsRequested = authOwnsRequestedProfileV36(authUser)

        // أهم نقطة:
        // إذا الرابط فيه ?user=someone، الملكية تعتمد على someone نفسه، وليس بيانات activeUser بعد الدمج.
        // هذا يمنع فتح قوائم الحقيبة في بروفايلات الناس.
        if (ownsRequested !== null) return ownsRequested

        return isOwnProfile(user, authUser)
      }

      async function syncOwnerControlsV36(user = state.activeUser) {
        const allowed = await isProfileOwnerV36(user)

        if (user && state.activeUser !== user) return allowed

        document.documentElement.classList.toggle('tnx-profile-readonly-v36', !allowed)

        const mailButton = $('openMailButton')
        if (mailButton) {
          mailButton.hidden = !allowed
          mailButton.disabled = !allowed
          mailButton.tabIndex = allowed ? 0 : -1
          mailButton.setAttribute('aria-hidden', allowed ? 'false' : 'true')
        }

        if (!allowed) {
          closeMail()

          document
            .querySelectorAll('.bp29-shell, .bp29-toast, .featured-badge-modal-test, .featured-badge-toast')
            .forEach((el) => el.remove())

          document
            .querySelectorAll('.bp29-plus, .profile-featured-badge-add, #featuredBadgePlusTest, [data-featured-badge-add-v22], [data-tnxbp-add-v24]')
            .forEach((el) => el.remove())

          document
            .querySelectorAll('.inventory-sell-row')
            .forEach((el) => el.remove())

          document
            .querySelectorAll('.modal-backdrop.show')
            .forEach((modal) => {
              if (modal.querySelector('.item-modal')) modal.remove()
            })
        }

        return allowed
      }

      function showAccountTools(user, authUser) {
        const box = $('accountTools')
        if (!box || !authUser) return

        const login = authUser.login || userLogin(user) || ''
        const publicUrl = new URL(location.origin + location.pathname)
        publicUrl.searchParams.set('user', login)

        const handle = $('accountHandle')
        if (handle) handle.textContent = login ? '@' + login : '@---'

        const publicLink = $('accountPublicLink')
        if (publicLink) publicLink.href = publicUrl.toString()

        box.classList.remove('hidden')
      }

      function hideAccountTools() {
        $('accountTools')?.classList.add('hidden')
      }

      async function logoutAccount() {
        try {
          await fetch('https://api.tnx6.xyz/auth/logout', {
            method: 'POST',
            credentials: 'include',
          })
        } catch {}

        location.href = '/profile'
      }

      async function getLoggedInUser() {
        try {
          const res = await fetch('https://api.tnx6.xyz/api/me', {
            method: 'GET',
            credentials: 'include',
            cache: 'no-store',
          })

          if (!res.ok) return null

          const data = await res.json().catch(() => null)
          return data?.authenticated && data?.user ? data.user : null
        } catch {
          return null
        }
      }

      function userFromAuth(authUser) {
        if (!authUser) return null

        const login = String(authUser.login || '').trim()
        const twitchId = String(authUser.twitchId || authUser.id || '').trim()
        const name = String(authUser.displayName || login || 'مستخدم Twitch').trim()
        const avatar = String(authUser.profileImageUrl || '').trim()

        return {
          id: twitchId,
          userId: twitchId,
          twitchId,
          userLogin: login,
          login,
          userName: name,
          displayName: name,
          profileImageUrl: avatar,
          avatar,
          bio: 'هذا ملفك الشخصي في نظام TNX6. من هنا بتشوف مستواك، أغراضك، بادجاتك، والبريد.',
        }
      }

      async function openFromQuery() {
        const raw = new URLSearchParams(location.search).get('user')

        if (!raw) {
          const authUser = await getLoggedInUser()

          if (authUser?.login) {
            const user = findUser(authUser.login) || userFromAuth(authUser)

            if (user) {
              await renderProfileFromD1(user)
              return
            }
          }

          stopInventoryAutoRefresh()
          stopInventoryLivePollerV3()
          $('searchView')?.classList.remove('hidden')
          $('profileView')?.classList.add('hidden')
          $('notFoundView')?.classList.add('hidden')
          return
        }

        const user = findUser(raw)

        if (!user) {
          stopInventoryAutoRefresh()
          stopInventoryLivePollerV3()
          $('searchView')?.classList.add('hidden')
          $('profileView')?.classList.add('hidden')
          $('notFoundView')?.classList.remove('hidden')
          return
        }

        await renderProfileFromD1(user)
      }

      function profileLink(user) {
        const url = new URL(location.href)
        url.searchParams.set('user', userLogin(user))
        url.hash = ''
        return url.toString()
      }

      async function loadJson(url, fallback) {
        try {
          const res = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!res.ok) return fallback
          return await res.json()
        } catch {
          return fallback
        }
      }

      function d1InventoryCacheKey(user) {
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()
        return viewedId || viewedLogin || ''
      }

      async function loadInventoryFromD1(user) {
        const cacheKey = d1InventoryCacheKey(user)
        if (!cacheKey) return null

        if (state.d1InventoryCache[cacheKey]) {
          return state.d1InventoryCache[cacheKey]
        }

        const params = new URLSearchParams()
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()

        if (viewedId) params.set('twitchId', viewedId)
        else if (viewedLogin) params.set('login', viewedLogin)
        else return null

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/profile/inventory?' + params.toString(), {
            cache: 'no-store',
          })

          if (!res.ok) return null

          const data = await res.json().catch(() => null)

          if (!data?.ok || !Array.isArray(data.items)) return null

          state.d1InventoryCache[cacheKey] = data
          return data
        } catch {
          return null
        }
      }

      async function userWithD1Inventory(user) {
        const data = await loadInventoryFromD1(user)

        if (!data || !Array.isArray(data.items)) return user

        const d1User = data.user || {}

        return {
          ...user,
          twitchId: String(d1User.twitchId || get(user, ['twitchId', 'twitch_id', 'userId', 'id'], '') || ''),
          userId: String(d1User.twitchId || get(user, ['userId', 'id', 'twitchId', 'twitch_id'], '') || ''),
          login: String(d1User.login || get(user, ['login', 'userLogin'], '') || ''),
          userLogin: String(d1User.login || get(user, ['userLogin', 'login'], '') || ''),
          displayName: String(d1User.displayName || get(user, ['displayName', 'userName'], '') || ''),
          userName: String(d1User.displayName || get(user, ['userName', 'displayName'], '') || ''),
          profileImageUrl: String(d1User.profileImageUrl || get(user, ['profileImageUrl', 'avatar'], '') || ''),
          avatar: String(d1User.profileImageUrl || get(user, ['avatar', 'profileImageUrl'], '') || ''),
          inventory: data.items.map((item) => ({
            name: String(item.name || item.itemName || item.itemKey || '').trim(),
            quantity: Math.max(0, Math.floor(Number(item.quantity || item.qty || 0))),
            itemKey: String(item.itemKey || '').trim(),
            updatedAt: item.updatedAt || '',
          })).filter((item) => item.name && item.quantity > 0),
          inventorySource: 'd1',
        }
      }

      function d1EconomyCacheKey(user) {
        return d1InventoryCacheKey(user)
      }

      async function loadEconomyFromD1(user) {
        const cacheKey = d1EconomyCacheKey(user)
        if (!cacheKey) return null

        if (state.d1EconomyCache[cacheKey]) {
          return state.d1EconomyCache[cacheKey]
        }

        const params = new URLSearchParams()
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()

        if (viewedId) params.set('twitchId', viewedId)
        else if (viewedLogin) params.set('login', viewedLogin)
        else return null

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/profile/economy?' + params.toString(), {
            cache: 'no-store',
          })

          if (!res.ok) return null

          const data = await res.json().catch(() => null)

          if (!data?.ok || !data.economy) return null

          state.d1EconomyCache[cacheKey] = data
          return data
        } catch {
          return null
        }
      }

      function getOptimisticEconomyV1(user) {
        try {
          const key = d1EconomyCacheKey(user || state.activeUser)
          const store = window.__tnxOptimisticEconomyV1 || null

          if (!key || !store || store.key !== key) return null
          if (Date.now() > Number(store.expiresAt || 0)) {
            window.__tnxOptimisticEconomyV1 = null
            return null
          }

          return store
        } catch {
          return null
        }
      }

      function clearOptimisticEconomyV1() {
        try {
          window.__tnxOptimisticEconomyV1 = null
        } catch {}
      }

      function resolveEconomyAmountsV1(user, d1Points, d1Gold) {
        const rawPoints = Math.max(0, Math.floor(Number(d1Points || 0)))
        const rawGold = Math.max(0, Math.floor(Number(d1Gold || 0)))
        const optimistic = getOptimisticEconomyV1(user)

        if (!optimistic) {
          return {
            points: rawPoints,
            gold: rawGold,
            optimistic: false,
          }
        }

        const optimisticPoints = Math.max(0, Math.floor(Number(optimistic.points || 0)))

        if (rawPoints >= optimisticPoints) {
          clearOptimisticEconomyV1()

          return {
            points: rawPoints,
            gold: rawGold,
            optimistic: false,
          }
        }

        return {
          points: optimisticPoints,
          gold: Math.max(rawGold, Math.floor(optimisticPoints / 10)),
          optimistic: true,
        }
      }

      function updateEconomyUiV1(user) {
        try {
          if (!user) return

          const points = Math.max(0, Math.floor(Number(currentPoints(user) || 0)))
          const inventory = inventoryItems(user)
          const badges = Array.isArray(user.badges) ? user.badges : []
          const level = calculateLevel(user)

          setProfilePointsV1(points)
          setText('rank', rankFor(user))
          renderChips(chipsFor(user, level.level, badges, inventory))
          renderNextBadge(user, badges)
        } catch (error) {
          console.warn('Failed to update local economy UI:', error)
        }
      }

      function applyLocalEconomyAfterSellV1(sellTotal) {
        try {
          if (!state.activeUser) return

          const delta = Math.max(0, Math.floor(Number(sellTotal || 0)))

          if (delta <= 0) return

          const current = Math.max(0, Math.floor(Number(currentPoints(state.activeUser) || 0)))
          const nextPoints = current + delta
          const nextGold = Math.floor(nextPoints / 10)
          const key = d1EconomyCacheKey(state.activeUser)

          if (key) {
            window.__tnxOptimisticEconomyV1 = {
              key,
              points: nextPoints,
              gold: nextGold,
              delta,
              expiresAt: Date.now() + 30000,
            }
          }

          state.activeUser = {
            ...state.activeUser,
            points: nextPoints,
            totalPoints: nextPoints,
            balance: nextPoints,
            gold: nextGold,
            economySource: 'local-sell-optimistic',
          }

          updateEconomyUiV1(state.activeUser)
        } catch (error) {
          console.warn('Failed to apply local economy after sell:', error)
        }
      }

      async function userWithD1Economy(user) {
        const data = await loadEconomyFromD1(user)

        if (!data || !data.economy) return user

        const d1User = data.user || {}
        const economy = data.economy || {}
        const rawPoints = Math.max(0, Math.floor(Number(economy.points || 0)))
        const rawGold = Math.max(0, Math.floor(Number(economy.gold || 0)))
        const resolvedEconomy = resolveEconomyAmountsV1(user, rawPoints, rawGold)
        const points = resolvedEconomy.points
        const gold = resolvedEconomy.gold

        return {
          ...user,
          twitchId: String(d1User.twitchId || get(user, ['twitchId', 'twitch_id', 'userId', 'id'], '') || ''),
          userId: String(d1User.twitchId || get(user, ['userId', 'id', 'twitchId', 'twitch_id'], '') || ''),
          login: String(d1User.login || get(user, ['login', 'userLogin'], '') || ''),
          userLogin: String(d1User.login || get(user, ['userLogin', 'login'], '') || ''),
          displayName: String(d1User.displayName || get(user, ['displayName', 'userName'], '') || ''),
          userName: String(d1User.displayName || get(user, ['userName', 'displayName'], '') || ''),
          profileImageUrl: String(d1User.profileImageUrl || get(user, ['profileImageUrl', 'avatar'], '') || ''),
          avatar: String(d1User.profileImageUrl || get(user, ['avatar', 'profileImageUrl'], '') || ''),
          points,
          totalPoints: points,
          balance: points,
          gold,
          economyUpdatedAt: economy.updatedAt || null,
          economySource: resolvedEconomy.optimistic ? 'd1-optimistic' : 'd1',
        }
      }

      async function userWithD1ProfileData(user) {
        const withInventory = await userWithD1Inventory(user)
        return await userWithD1Economy(withInventory)
      }

      async function renderProfileFromD1(user) {
        const hydratedUser = await userWithD1ProfileData(user)
        renderProfile(hydratedUser)
        startInventoryLivePollerV3()
        startEconomyLivePollerV1()
      }

      function clearD1InventoryCacheForUser(user) {
        try {
          const cacheKey = d1InventoryCacheKey(user || state.activeUser)
          if (cacheKey && state.d1InventoryCache) delete state.d1InventoryCache[cacheKey]
        } catch {}
      }

      function clearD1EconomyCacheForUser(user) {
        try {
          const cacheKey = d1EconomyCacheKey(user || state.activeUser)
          if (cacheKey && state.d1EconomyCache) delete state.d1EconomyCache[cacheKey]
        } catch {}
      }

      async function refreshActiveProfileFromD1() {
        try {
          if (!state.activeUser) return
          clearD1InventoryCacheForUser(state.activeUser)
          clearD1EconomyCacheForUser(state.activeUser)
          await renderProfileFromD1(state.activeUser)
        } catch (error) {
          console.warn('Failed to refresh D1 profile data after sell status:', error)
        }
      }

      /* TNX_INVENTORY_LIVE_POLLER_V3_FIXED_SCOPE */
      const INVENTORY_LIVE_POLL_VISIBLE_MS = 5000
      const INVENTORY_LIVE_POLL_HIDDEN_MS = 25000

      function getInventoryLivePollerV3() {
        if (!window.__tnxInventoryLivePollerV3) {
          window.__tnxInventoryLivePollerV3 = {
            timer: 0,
            running: false,
            lastSignature: '',
            lastStartedKey: '',
            listenersInstalled: false,
          }
        }

        return window.__tnxInventoryLivePollerV3
      }

      function inventoryLivePollKey(user) {
        return d1InventoryCacheKey(user || state.activeUser)
      }

      function inventoryLiveSignatureFromItems(items) {
        if (!Array.isArray(items)) return ''

        return items
          .map((item) => {
            const name = normalize(String(item.name || item.itemName || item.itemKey || '').trim())
            const qty = Math.max(0, Math.floor(Number(item.quantity || item.qty || 0)))
            return name && qty > 0 ? `${name}:${qty}` : ''
          })
          .filter(Boolean)
          .sort()
          .join('|')
      }

      function inventoryLiveSignatureFromUser(user) {
        return inventoryItems(user)
          .map((item) => `${normalize(item.name)}:${Math.max(0, Math.floor(Number(item.qty || 0)))}`)
          .filter(Boolean)
          .sort()
          .join('|')
      }

      function inventoryLivePollDelay() {
        return document.hidden ? INVENTORY_LIVE_POLL_HIDDEN_MS : INVENTORY_LIVE_POLL_VISIBLE_MS
      }

      function inventoryLiveProfileIsReady() {
        return Boolean(state.activeUser) && !$('profileView')?.classList.contains('hidden')
      }

      function stopInventoryLivePollerV3() {
        const poller = getInventoryLivePollerV3()

        if (poller.timer) {
          window.clearTimeout(poller.timer)
          poller.timer = 0
        }
      }

      function scheduleInventoryLivePollerV3(delay) {
        const poller = getInventoryLivePollerV3()

        if (poller.timer) {
          window.clearTimeout(poller.timer)
          poller.timer = 0
        }

        poller.timer = window.setTimeout(() => {
          poller.timer = 0
          runInventoryLivePollerV3()
        }, delay)
      }

      function startInventoryLivePollerV3() {
        const poller = getInventoryLivePollerV3()

        if (!inventoryLiveProfileIsReady()) {
          stopInventoryLivePollerV3()
          return
        }

        const key = inventoryLivePollKey(state.activeUser)

        if (!key) {
          stopInventoryLivePollerV3()
          return
        }

        poller.lastStartedKey = key
        poller.lastSignature = inventoryLiveSignatureFromUser(state.activeUser)

        if (!poller.listenersInstalled) {
          poller.listenersInstalled = true

          addListener(document, 'visibilitychange', () => {
            if (inventoryLiveProfileIsReady()) {
              scheduleInventoryLivePollerV3(document.hidden ? INVENTORY_LIVE_POLL_HIDDEN_MS : 500)
            }
          })

          addListener(window, 'focus', () => {
            if (inventoryLiveProfileIsReady()) {
              scheduleInventoryLivePollerV3(500)
            }
          })
        }

        scheduleInventoryLivePollerV3(INVENTORY_LIVE_POLL_VISIBLE_MS)
      }

      function buildD1InventoryUrlForUser(user) {
        const params = new URLSearchParams()
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()

        if (viewedId) params.set('twitchId', viewedId)
        else if (viewedLogin) params.set('login', viewedLogin)
        else return ''

        return TNX_API_ORIGIN + '/api/profile/inventory?' + params.toString()
      }

      async function runInventoryLivePollerV3() {
        const poller = getInventoryLivePollerV3()

        if (!inventoryLiveProfileIsReady()) {
          stopInventoryLivePollerV3()
          return
        }

        if (poller.running) {
          scheduleInventoryLivePollerV3(inventoryLivePollDelay())
          return
        }

        const key = inventoryLivePollKey(state.activeUser)
        const url = buildD1InventoryUrlForUser(state.activeUser)

        if (!key || !url) {
          stopInventoryLivePollerV3()
          return
        }

        poller.running = true

        try {
          const res = await fetch(url, { cache: 'no-store' })
          const data = res.ok ? await res.json().catch(() => null) : null

          if (!data?.ok || !Array.isArray(data.items)) {
            return
          }

          const nextSignature = inventoryLiveSignatureFromItems(data.items)

          if (nextSignature !== poller.lastSignature || key !== poller.lastStartedKey) {
            poller.lastSignature = nextSignature
            poller.lastStartedKey = key

            const nextInventory = data.items
              .map((item) => ({
                name: String(item.name || item.itemName || item.itemKey || '').trim(),
                quantity: Math.max(0, Math.floor(Number(item.quantity || item.qty || 0))),
                itemKey: String(item.itemKey || '').trim(),
                updatedAt: item.updatedAt || '',
              }))
              .filter((item) => item.name && item.quantity > 0)

            const nextUser = {
              ...state.activeUser,
              inventory: nextInventory,
              inventorySource: 'd1-live',
            }

            state.activeUser = nextUser

            const inventory = inventoryItems(nextUser)
            const badges = Array.isArray(nextUser.badges) ? nextUser.badges : []
            const level = calculateLevel(nextUser)

            setText('inventoryCount', `${inventory.length} ${inventory.length === 1 ? 'غرض' : 'أغراض'}`)
            renderChips(chipsFor(nextUser, level.level, badges, inventory))
            renderInventory(inventory)
            enhanceInventorySellButtons(inventory)
          }
        } catch (error) {
          console.warn('Inventory live poll failed:', error)
        } finally {
          poller.running = false
          scheduleInventoryLivePollerV3(inventoryLivePollDelay())
        }
      }


      /* TNX_ECONOMY_LIVE_POLLER_V1 */
      const ECONOMY_LIVE_POLL_VISIBLE_MS = 5000
      const ECONOMY_LIVE_POLL_HIDDEN_MS = 25000

      function getEconomyLivePollerV1() {
        if (!window.__tnxEconomyLivePollerV1) {
          window.__tnxEconomyLivePollerV1 = {
            timer: 0,
            running: false,
            lastSignature: '',
            lastStartedKey: '',
            listenersInstalled: false,
          }
        }

        return window.__tnxEconomyLivePollerV1
      }

      function economyLivePollKey(user) {
        return d1EconomyCacheKey(user || state.activeUser)
      }

      function economyLiveSignatureFromData(data) {
        if (!data?.economy) return ''

        const points = Math.max(0, Math.floor(Number(data.economy.points || 0)))
        const gold = Math.max(0, Math.floor(Number(data.economy.gold || 0)))
        const updatedAt = String(data.economy.updatedAt || '')

        return `${points}|${gold}|${updatedAt}`
      }

      function economyLiveSignatureFromUser(user) {
        if (!user) return ''

        const points = Math.max(0, Math.floor(Number(currentPoints(user) || 0)))
        const gold = Math.max(0, Math.floor(Number(get(user, ['gold'], 0) || 0)))
        const updatedAt = String(get(user, ['economyUpdatedAt'], '') || '')

        return `${points}|${gold}|${updatedAt}`
      }

      function economyLivePollDelay() {
        return document.hidden ? ECONOMY_LIVE_POLL_HIDDEN_MS : ECONOMY_LIVE_POLL_VISIBLE_MS
      }

      function stopEconomyLivePollerV1() {
        const poller = getEconomyLivePollerV1()

        if (poller.timer) {
          window.clearTimeout(poller.timer)
          poller.timer = 0
        }

        poller.running = false
        poller.lastStartedKey = ''
        poller.lastSignature = ''
      }

      function scheduleEconomyLivePollerV1(delay = ECONOMY_LIVE_POLL_VISIBLE_MS) {
        const poller = getEconomyLivePollerV1()

        if (poller.timer) {
          window.clearTimeout(poller.timer)
        }

        poller.timer = window.setTimeout(runEconomyLivePollerV1, Math.max(500, delay))
      }

      function economyLiveProfileIsReady() {
        return Boolean(state.activeUser && $('profileView') && !$('profileView').classList.contains('hidden'))
      }

      function startEconomyLivePollerV1() {
        const poller = getEconomyLivePollerV1()

        if (!economyLiveProfileIsReady()) {
          stopEconomyLivePollerV1()
          return
        }

        const key = economyLivePollKey(state.activeUser)

        if (!key) {
          stopEconomyLivePollerV1()
          return
        }

        poller.lastStartedKey = key
        poller.lastSignature = economyLiveSignatureFromUser(state.activeUser)

        if (!poller.listenersInstalled) {
          poller.listenersInstalled = true

          addListener(document, 'visibilitychange', () => {
            if (economyLiveProfileIsReady()) {
              scheduleEconomyLivePollerV1(document.hidden ? ECONOMY_LIVE_POLL_HIDDEN_MS : 500)
            }
          })

          addListener(window, 'focus', () => {
            if (economyLiveProfileIsReady()) {
              scheduleEconomyLivePollerV1(500)
            }
          })
        }

        scheduleEconomyLivePollerV1(ECONOMY_LIVE_POLL_VISIBLE_MS)
      }

      function buildD1EconomyUrlForUser(user) {
        const params = new URLSearchParams()
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()

        if (viewedId) params.set('twitchId', viewedId)
        else if (viewedLogin) params.set('login', viewedLogin)
        else return ''

        return TNX_API_ORIGIN + '/api/profile/economy?' + params.toString()
      }

      async function runEconomyLivePollerV1() {
        const poller = getEconomyLivePollerV1()

        if (!economyLiveProfileIsReady()) {
          stopEconomyLivePollerV1()
          return
        }

        if (poller.running) {
          scheduleEconomyLivePollerV1(economyLivePollDelay())
          return
        }

        const key = economyLivePollKey(state.activeUser)
        const url = buildD1EconomyUrlForUser(state.activeUser)

        if (!key || !url) {
          stopEconomyLivePollerV1()
          return
        }

        poller.running = true

        try {
          const res = await fetch(url, { cache: 'no-store' })
          const data = res.ok ? await res.json().catch(() => null) : null

          if (!data?.ok || !data.economy) {
            return
          }

          const nextSignature = economyLiveSignatureFromData(data)

          if (nextSignature !== poller.lastSignature || key !== poller.lastStartedKey) {
            poller.lastSignature = nextSignature
            poller.lastStartedKey = key

            const rawPoints = Math.max(0, Math.floor(Number(data.economy.points || 0)))
            const rawGold = Math.max(0, Math.floor(Number(data.economy.gold || 0)))
            const resolvedEconomy = resolveEconomyAmountsV1(state.activeUser, rawPoints, rawGold)
            const points = resolvedEconomy.points
            const gold = resolvedEconomy.gold

            const nextUser = {
              ...state.activeUser,
              points,
              totalPoints: points,
              balance: points,
              gold,
              economyUpdatedAt: data.economy.updatedAt || null,
              economySource: resolvedEconomy.optimistic ? 'd1-live-optimistic' : 'd1-live',
            }

            state.activeUser = nextUser

            const inventory = inventoryItems(nextUser)
            const badges = Array.isArray(nextUser.badges) ? nextUser.badges : []
            const level = calculateLevel(nextUser)

            setProfilePointsV1(points)
            setText('rank', rankFor(nextUser))
            renderChips(chipsFor(nextUser, level.level, badges, inventory))
            renderNextBadge(nextUser, badges)
          }
        } catch (error) {
          console.warn('Economy live poll failed:', error)
        } finally {
          poller.running = false
          scheduleEconomyLivePollerV1(economyLivePollDelay())
        }
      }


      addListener($('searchInput'), 'input', (event) => renderSearch(event.target.value))
      addListener($('clearSearch'), 'click', () => {
        if (!$('searchInput') || !$('searchResults')) return
        $('searchInput').value = ''
        $('searchResults').innerHTML = ''
        $('searchInput').focus()
      })

      addListener($('searchResults'), 'click', async (event) => {
        const button = event.target.closest('[data-login]')
        if (!button) return
        const user = findUser(button.dataset.login)
        if (!user) return

        history.replaceState(null, '', profileLink(user))
