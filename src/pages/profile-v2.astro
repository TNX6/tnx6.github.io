          const target = event.target
          if (!(target instanceof Element)) return

          // زر فتح الورشة (داخل بطاقة الدخول في الصفحة)
          if (target.closest('[data-ws-open]')) {
            event.preventDefault()
            wsOpenModal()
            return
          }

          const overlay = wsModalEl()

          // إغلاق بالضغط خارج المودال
          if (overlay && target === overlay) {
            wsCloseModal()
            return
          }

          if (target.closest('[data-ws-close]')) {
            wsCloseModal()
            return
          }

          if (!target.closest('#wsModal')) return

          const selectButton = target.closest('[data-ws-select]')
          if (selectButton) {
            wsState.selectedId = selectButton.getAttribute('data-ws-select') || ''
            renderWorkshop()
            return
          }

          const viewButton = target.closest('[data-ws-view]')
          if (viewButton) {
            wsState.view = viewButton.getAttribute('data-ws-view') === 'history' ? 'history' : 'craft'
            renderWorkshop()
