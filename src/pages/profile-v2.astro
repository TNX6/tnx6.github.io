          const claimButton = target.closest('[data-ws-claim]')
          if (claimButton) {
            event.preventDefault()
            wsClaimCraft(claimButton.getAttribute('data-ws-claim') || '', claimButton)
            return
          }

          const closeRevealButton = target.closest('[data-ws-reveal-close]')
          if (closeRevealButton) {
            wsState.reveal = null
            loadWorkshop(true)
          }
        })
      }

      /* mailbox-relative-time-avatar-helpers */
      function formatMailboxRelativeTime(value) {
        if (!value) return '';

        let date = null;
        try {
          date = new Date(value);
        } catch {}

        if (!date || Number.isNaN(date.getTime())) {
          try {
            date = new Date(String(value).replace(' ', 'T'));
          } catch {}
        }

        if (!date || Number.isNaN(date.getTime())) return String(value);

        const now = new Date();
        let diffMs = now.getTime() - date.getTime();

        if (diffMs < 0) diffMs = 0;

        const minute = 60 * 1000;
        const hour = 60 * minute;
        const day = 24 * hour;

        if (diffMs < minute) return 'الآن';

        const minutes = Math.floor(diffMs / minute);
        if (minutes < 60) return minutes + 'د';

        const hours = Math.floor(diffMs / hour);
        if (hours < 24) return hours + 'س';

        const days = Math.floor(diffMs / day);
        if (days === 1) return '1يوم';
        if (days < 30) return days + 'يوم';

        const months = Math.floor(days / 30);
        if (months < 12) return months + 'ش';

        const years = Math.floor(days / 365);
        return years + 'سنة';
      }

      function resolveMailboxAvatar(mail) {
        if (!mail || typeof mail !== 'object') return '';

        const directCandidates = [
          mail.fromProfileImageUrl,
          mail.from_profile_image_url,
          mail.profileImageUrl,
          mail.profile_image_url,
          mail.senderProfileImageUrl,
          mail.sender_profile_image_url,
          mail.fromAvatarUrl,
          mail.from_avatar_url,
          mail.avatarUrl,
          mail.avatar_url,
          mail.userProfileImageUrl,
          mail.user_profile_image_url
        ];

        for (const value of directCandidates) {
          if (value && String(value).trim()) return String(value).trim();
        }

        const senderId =
          String(
            mail.fromUserId ||
            mail.from_user_id ||
            mail.senderUserId ||
            mail.sender_user_id ||
            ''
          ).trim();

        const senderLogin =
          String(
            mail.fromUserLogin ||
            mail.from_user_login ||
            mail.fromUserName ||
            mail.from_user_name ||
            mail.senderLogin ||
            mail.sender_login ||
            mail.userLogin ||
            mail.user_login ||
            ''
          ).trim().toLowerCase();

        const globalMaps = [
          window.__tnxMailboxAvatarMap,
          window.__tnxUserProfileMap,
          window.__tnxProfileImageMap
        ];

        for (const map of globalMaps) {
          if (!map || typeof map !== 'object') continue;

          if (senderId && map[senderId]) return String(map[senderId]).trim();
          if (senderLogin && map[senderLogin]) return String(map[senderLogin]).trim();
        }

        return '';
      }

      function getMailboxAvatarFallbackLetter(mail) {
        const raw =
          String(
            mail?.fromDisplayName ||
            mail?.from_display_name ||
            mail?.fromUserLogin ||
            mail?.from_user_login ||
            mail?.senderLogin ||
            mail?.sender_login ||
            '?'
          ).trim();

        if (!raw) return '?';
        return raw.charAt(0).toUpperCase();
      }

      function renderMailboxAvatarHtml(mail) {
        const avatarUrl = resolveMailboxAvatar(mail);

        if (avatarUrl) {
          const safeAlt = escapeHtml(
            String(
              mail?.fromDisplayName ||
              mail?.from_display_name ||
              mail?.fromUserLogin ||
              mail?.from_user_login ||
              'user'
            )
          );

          return '<img src="' + escapeHtml(avatarUrl) + '" alt="' + safeAlt + '" class="mail-message-avatar-img" loading="lazy" referrerpolicy="no-referrer">';
        }

        return '<span class="mail-message-avatar-fallback">' + escapeHtml(getMailboxAvatarFallbackLetter(mail)) + '</span>';
      }


      // fix-escapehtml-missing
      function escapeHtml(value) {
        try {
          if (typeof esc === 'function') {
            return esc(value);
          }
        } catch {}

        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      // mailbox-v2-single-renderer
      // renderMail صار wrapper خفيف فوق renderMailboxProV2 (المصدر الوحيد للعرض)
      async function renderMail(mail) {
        const box = $('mailList')
        if (!box) return

        if (!box.querySelector('.mail-pro')) {
          box.innerHTML =
            '<style>' +
            MAILBOX_V2_OVERRIDE_CSS +
            '</style>' +
            '<div class="mail-pro"></div>'
        }

        // سعة البريد تتحدث بالخلفية فقط، ولا تحجب رسم الرسائل.
        try {
          const now = Date.now()
          if (!mailboxUpgradeInfoLoaded && !window.__tnxMailboxUpgradeInfoInFlight) {
            window.__tnxMailboxUpgradeInfoAt = now
            window.__tnxMailboxUpgradeInfoInFlight = true
            loadMailboxUpgradeInfo()
              .catch(() => {})
              .finally(() => { window.__tnxMailboxUpgradeInfoInFlight = false })
          } else if (!window.__tnxMailboxUpgradeInfoAt || now - window.__tnxMailboxUpgradeInfoAt > 30000) {
            window.__tnxMailboxUpgradeInfoAt = now
            loadMailboxUpgradeInfo().catch(() => {})
          }
        } catch {}

        const list = Array.isArray(mail) ? mail : mbV2NormalizeMessages(mail)
        renderMailboxProV2(list)
      }

