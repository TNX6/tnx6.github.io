      function wsTickCountdown() {
        const box = wsBox()
        if (!box) return

        let needsReload = false

        box.querySelectorAll('[data-ws-job]').forEach((card) => {
          const finishMs = Number(card.dataset.wsFinish || 0)
          const duration = Math.max(1, Number(card.dataset.wsDuration || 1))

          if (!finishMs) return

          const remaining = Math.max(0, Math.ceil((finishMs - Date.now()) / 1000))
          const percent = Math.max(0, Math.min(100, Math.round(((duration - remaining) / duration) * 100)))
          const remainingEl = card.querySelector('[data-ws-remaining]')
          const barEl = card.querySelector('[data-ws-bar]')
          const pctEl = card.querySelector('[data-ws-pct]')
          const ringEl = card.querySelector('[data-ws-ring]')

          if (remainingEl) remainingEl.textContent = wsRemainingText(remaining)
          if (barEl) barEl.style.width = percent + '%'
          if (pctEl) pctEl.textContent = percent + '%'

          if (ringEl) {
            const dash = Number(ringEl.getAttribute('stroke-dasharray')) || 213.6
            ringEl.style.strokeDashoffset = (dash * (1 - percent / 100)).toFixed(1)
          }

          if (remaining <= 0) needsReload = true
        })

        if (needsReload && !wsState.reloadQueued) {
          wsState.reloadQueued = true
          loadWorkshop(true).finally(() => { wsState.reloadQueued = false })
        }
      }

      function wsEnsureTimers() {
        // عداد الثواني فقط والمودال مفتوح — ما فيه intervals دائمة
        const hasCrafting = wsState.jobs.active.some((job) => job.status === 'crafting') && wsModalOpen()
        const hasPending =
          wsState.jobs.active.some((job) => job.status === 'pending_start' || job.status === 'pending_claim') ||
          (wsState.reveal && wsState.reveal.phase === 'waiting')

        if (hasCrafting && !wsState.timer) {
          wsState.timer = window.setInterval(wsTickCountdown, 1000)
        } else if (!hasCrafting && wsState.timer) {
          window.clearInterval(wsState.timer)
          wsState.timer = null
        }

        if (hasPending && !wsState.pollTimer) {
          wsState.pollTimer = window.setInterval(() => loadWorkshop(true), 4000)
        } else if (!hasPending && wsState.pollTimer) {
          window.clearInterval(wsState.pollTimer)
          wsState.pollTimer = null
        }
      }

      if (!window.__wsActionsDelegated) {
        window.__wsActionsDelegated = true

