    /* Real Profile V2 layout */
    .profile-v2-page {
      position: relative;
      min-height: 100vh;
      color: #ede8df;
      background: #060608 !important;
      overflow-x: hidden;
    }

    .profile-v2-page::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        radial-gradient(ellipse 50% 40% at 50% 0%, rgba(212,175,55,.055), transparent 62%),
        radial-gradient(ellipse 30% 30% at 85% 100%, rgba(155,109,255,.035), transparent 70%);
    }

    .profile-v2-page::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: .55;
      background-image:
        linear-gradient(rgba(255,255,255,.012) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.012) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 62% 50% at 50% 20%, black, transparent);
    }

    .profile-v2-layout {
      position: relative;
      z-index: 1;
      width: min(1060px, calc(100% - 32px));
      margin: 28px auto;
    }

    .profile-v2-shell {
      border-radius: 26px;
      border: 1px solid rgba(255,255,255,.055);
      background: rgba(255,255,255,.018);
      box-shadow: 0 16px 50px rgba(0,0,0,.40);
      overflow: hidden;
    }

    .v2-cover {
      position: relative;
      min-height: 260px;
      padding: 24px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      background:
        linear-gradient(to top, #060608 0%, rgba(6,6,8,.30) 55%, rgba(6,6,8,.60)),
        radial-gradient(ellipse 70% 50% at 50% 50%, rgba(212,175,55,.07), transparent 62%),
        linear-gradient(145deg, #0c0a06, #060608 55%, #0a0810);
      border-bottom: 1px solid rgba(255,255,255,.055);
    }

    .v2-cover::after {
      content: "";
      position: absolute;
      inset-inline: 0;
      bottom: 0;
      height: 95px;
      background: linear-gradient(to top, #060608, transparent);
      pointer-events: none;
      z-index: 1;
    }

    .v2-cover-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      opacity: .55;
      z-index: 0;
    }

    .v2-mail-btn {
      position: absolute;
      right: 24px;
      bottom: 28px;
      z-index: 3;
      min-width: 126px;
      min-height: 48px;
      border: 0;
      border-radius: 14px;
      background: linear-gradient(135deg, #f0d060, #d4af37);
      color: #060608;
      font: inherit;
      font-size: 14px;
      font-weight: 1000;
      cursor: pointer;
      box-shadow: 0 10px 28px rgba(212,175,55,.20);
    }

    .v2-profile-head {
      position: relative;
      z-index: 3;
      width: 100%;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 20px;
      align-items: end;
      padding-right: 170px;
    }

    .v2-avatar-wrap {
      width: 128px !important;
      height: 128px !important;
      position: relative;
      isolation: isolate;
    }

    .v2-avatar-wrap .avatar-ring {
      position: absolute;
      inset: -4px;
      border-radius: 30px;
      background: conic-gradient(from 0deg, #3d2a0a, #f0d060, #6b4a10, #f0d060, #3d2a0a);
      z-index: 0;
    }

    .v2-avatar-wrap .avatar,
    .v2-avatar-wrap #avatar {
      position: relative;
      z-index: 1;
      width: 100% !important;
      height: 100% !important;
      object-fit: cover;
      border-radius: 26px !important;
      border: 3px solid #060608 !important;
      background: #111;
      display: block;
    }

    .v2-avatar-wrap .online-dot {
      position: absolute;
      bottom: 5px;
      left: 5px;
      z-index: 4;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      border: 3px solid #060608;
      background: #5ef5a0;
      box-shadow: 0 0 12px rgba(94,245,160,.5);
