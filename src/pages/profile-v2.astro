            refreshActiveProfileFromD1();

            msg.className = 'inventory-sell-message err'

            const code = String(error?.message || '')
            const apiMessage = String(error?.data?.message || '')

            if (code === 'Unauthorized') {
              msg.textContent = 'لازم تسجل دخولك بتويتش قبل البيع.'
            } else if (code === 'Item sale is disabled') {
