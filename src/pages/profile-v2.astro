        width: 100%;
      }

      .profile-account-dropdown {
        left: 50%;
        transform: translateX(-50%);
        width: min(92vw, 280px);
      }
    }


    /* Hide deprecated profile account controls */
    #accountTools,
    #profileAccountMenu {
      display: none !important;
    }


    /* Profile polish: skeleton, smooth modals, legendary glow */
    .profile-skeleton {
      width: min(100% - 32px, 1180px);
      margin: 26px auto;
      position: relative;
      z-index: 1;
    }

    .profile-skeleton.is-hidden {
      display: none !important;
    }

    .skeleton-shell {
      overflow: hidden;
      border-radius: 32px;
      border: 1px solid rgba(255,255,255,.08);
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)),
        rgba(12,12,15,.72);
      box-shadow: 0 24px 70px rgba(0,0,0,.38);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .skeleton-cover {
      height: 190px;
      background:
        radial-gradient(circle at 18% 20%, rgba(255,223,138,.16), transparent 38%),
        radial-gradient(circle at 82% 80%, rgba(145,70,255,.14), transparent 42%),
        linear-gradient(135deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border-bottom: 1px solid rgba(255,255,255,.06);
    }

    .skeleton-head {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 0 28px 28px;
      margin-top: -52px;
    }

    .skeleton-avatar {
      width: 118px;
      height: 118px;
      border-radius: 28px;
      border: 4px solid rgba(8,8,8,.96);
      background: rgba(255,255,255,.08);
      flex: 0 0 auto;
    }

    .skeleton-lines {
      width: min(100%, 560px);
      display: grid;
      gap: 12px;
      padding-top: 54px;
    }

    .skeleton-line {
      height: 16px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
    }

    .skeleton-name {
      width: 46%;
      height: 28px;
    }

    .skeleton-handle {
      width: 26%;
    }

    .skeleton-bio {
      width: 72%;
    }

    .skeleton-grid {
      display: grid;
      grid-template-columns: 1.35fr .65fr;
      gap: 18px;
      padding: 0 28px 28px;
    }

    .skeleton-card {
      min-height: 150px;
      border-radius: 24px;
      background: rgba(255,255,255,.055);
      border: 1px solid rgba(255,255,255,.055);
    }

    .skeleton-card:first-child {
      min-height: 210px;
    }

    .skeleton-card:nth-child(3) {
      grid-column: 1 / -1;
      min-height: 110px;
    }

    .skeleton-pulse {
      position: relative;
      overflow: hidden;
    }

    .skeleton-pulse::after {
      content: "";
      position: absolute;
      inset: 0;
      transform: translateX(100%);
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.10), transparent);
      animation: skeletonPulse 1.35s infinite;
    }

    @keyframes skeletonPulse {
      100% {
        transform: translateX(-100%);
      }
    }

    @keyframes modalSoftSlideIn {
      from {
        opacity: 0;
        transform: translateY(18px) scale(.985);
        filter: blur(5px);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    }

    @keyframes modalBackdropFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    #mailModal:not(.hidden),
    .mail-modal:not(.hidden),
    .item-modal:not(.hidden),
    [data-item-modal]:not(.hidden),
    [data-modal]:not(.hidden) {
      animation: modalBackdropFade .18s ease both;
    }

    #mailModal:not(.hidden) > *,
    .mail-modal:not(.hidden) > *,
    .item-modal:not(.hidden) > *,
    [data-item-modal]:not(.hidden) > *,
    [data-modal]:not(.hidden) > * {
      animation: modalSoftSlideIn .28s cubic-bezier(.22, .9, .25, 1) both;
      will-change: transform, opacity, filter;
    }

    .legendary-glow {
      position: relative;
      border-color: rgba(255, 213, 106, .48) !important;
      box-shadow:
        0 0 0 1px rgba(255, 213, 106, .16),
        0 0 22px rgba(255, 183, 66, .18),
        inset 0 0 18px rgba(255, 213, 106, .055) !important;
      animation: legendaryPulse 2.25s ease-in-out infinite;
    }

    .legendary-glow::before {
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 0%, rgba(255, 223, 138, .18), transparent 45%),
        linear-gradient(135deg, rgba(255, 223, 138, .10), transparent 55%);
      opacity: .72;
      mix-blend-mode: screen;
    }

    @keyframes legendaryPulse {
      0%, 100% {
        box-shadow:
          0 0 0 1px rgba(255, 213, 106, .12),
          0 0 18px rgba(255, 183, 66, .15),
          inset 0 0 16px rgba(255, 213, 106, .05);
      }
      50% {
        box-shadow:
          0 0 0 1px rgba(255, 213, 106, .30),
          0 0 34px rgba(255, 183, 66, .34),
          inset 0 0 22px rgba(255, 213, 106, .10);
      }
    }

    @media (max-width: 760px) {
      .skeleton-head {
        align-items: flex-start;
        padding-inline: 20px;
      }

      .skeleton-avatar {
        width: 92px;
        height: 92px;
        border-radius: 22px;
      }

      .skeleton-lines {
        padding-top: 45px;
      }

      .skeleton-grid {
        grid-template-columns: 1fr;
        padding-inline: 20px;
      }

      .skeleton-card:nth-child(3) {
        grid-column: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .skeleton-pulse::after,
      .legendary-glow,
      #mailModal:not(.hidden) > *,
      .mail-modal:not(.hidden) > *,
      .item-modal:not(.hidden) > *,
      [data-item-modal]:not(.hidden) > *,
      [data-modal]:not(.hidden) > * {
        animation: none !important;
      }
    }


    /* TNX level clean system */
    .profile-head .avatar-wrap {
      position: relative !important;
      isolation: isolate !important;
      overflow: visible !important;
    }

    #avatarRing.avatar-ring {
      position: absolute !important;
      inset: -6px !important;
      border-radius: 34px !important;
      z-index: 0 !important;
      pointer-events: none !important;
      background:
        conic-gradient(
          from -90deg,
          #ffdf8a 0deg,
          #d7a84f calc(var(--avatar-xp-percent, 0) * 3.6deg),
          rgba(255,255,255,.075) calc(var(--avatar-xp-percent, 0) * 3.6deg),
          rgba(255,255,255,.075) 360deg
        ) !important;
      box-shadow:
        0 0 22px rgba(215,168,79,.16),
        inset 0 0 0 1px rgba(255,255,255,.04) !important;
      animation: none !important;
      transition: filter .22s ease, box-shadow .22s ease;
    }

    .profile-head .avatar {
      position: relative !important;
      z-index: 1 !important;
    }

    .avatar-level-pill {
      position: absolute !important;
      left: -5px !important;
      bottom: -7px !important;
      z-index: 6 !important;
      min-width: 62px !important;
      height: 31px !important;
      padding: 0 11px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      border-radius: 12px !important;
      border: 1px solid rgba(255,218,106,.52) !important;
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.015)),
        rgba(7,7,9,.97) !important;
      color: #ffdf8a !important;
      font-size: .82rem !important;
      font-weight: 950 !important;
      line-height: 1 !important;
      letter-spacing: .015em !important;
      direction: ltr !important;
      box-shadow:
        0 10px 24px rgba(0,0,0,.42),
        0 0 14px rgba(255,218,106,.16) !important;
    }

    .level-card {
      min-height: 132px !important;
      padding: 22px 28px 24px !important;
      display: flex !important;
      align-items: center !important;
      background:
        radial-gradient(circle at 88% 20%, rgba(215,168,79,.10), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.025)),
        rgba(12,12,14,.82) !important;
      border-color: rgba(255,255,255,.095) !important;
    }

    .level-card .level-main {
      width: 100% !important;
      display: block !important;
    }

    .level-card .level-info {
      width: 100% !important;
      display: grid !important;
      grid-template-columns: 1fr auto !important;
      grid-template-areas:
        "title xp"
        "bar bar" !important;
      align-items: center !important;
      gap: 20px 18px !important;
      padding: 0 !important;
    }

    .level-card #levelTitle {
      grid-area: title !important;
      display: block !important;
      justify-self: start !important;
      margin: 0 !important;
      color: #d7a84f !important;
      font-size: clamp(1.25rem, 1.45vw, 1.65rem) !important;
      font-weight: 950 !important;
      line-height: 1.1 !important;
      letter-spacing: 0 !important;
      text-align: right !important;
      white-space: nowrap !important;
      text-shadow: 0 12px 30px rgba(215,168,79,.08) !important;
    }

    #levelProgressInline {
      grid-area: xp !important;
      justify-self: end !important;
      min-height: 22px !important;
      padding: 0 10px !important;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      border-radius: 999px !important;
      border: 1px solid rgba(255,255,255,.06) !important;
      background: rgba(0,0,0,.34) !important;
      color: rgba(255,255,255,.82) !important;
      font-size: clamp(.72rem, .78vw, .82rem) !important;
      font-weight: 800 !important;
      line-height: 1 !important;
      direction: ltr !important;
      white-space: nowrap !important;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.04) !important;
    }

    .level-card .xp-bar {
      grid-area: bar !important;
      width: 100% !important;
      height: 14px !important;
      margin: 0 !important;
      border-radius: 999px !important;
      background: rgba(255,255,255,.095) !important;
      border: 1px solid rgba(255,255,255,.055) !important;
      overflow: hidden !important;
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.035),
        inset 0 8px 18px rgba(0,0,0,.22) !important;
    }

    .level-card .xp-fill {
      height: 100% !important;
      border-radius: inherit !important;
      background:
        linear-gradient(90deg, #8b5e21 0%, #bb8430 44%, #f0c85f 100%) !important;
      box-shadow:
        0 0 22px rgba(255,207,95,.22),
        inset 0 1px 0 rgba(255,255,255,.22) !important;
      transition: width .45s ease !important;
      position: relative !important;
      overflow: hidden !important;
    }

    .level-card .xp-fill::after {
      content: "";
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.28), transparent);
      animation: tnxXpShine 3.2s ease-in-out infinite;
    }

    @keyframes tnxXpShine {
      0% { left: -100%; }
      16% { left: 100%; }
      100% { left: 100%; }
    }

    .level-card .level-badge,
    .level-card .level-badge *,
    .level-card .xp-text,
    .level-card #xpBreakdown,
    .level-card .xp-breakdown,
    .level-card [data-level-percent] {
      display: none !important;
    }

    .tnx-confetti-layer {
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      overflow: hidden;
    }

    .tnx-confetti-piece {
      position: absolute;
      top: -16px;
      width: 8px;
      height: 14px;
      border-radius: 3px;
      opacity: .95;
      background: linear-gradient(180deg, #fff2a8, #d7a84f);
      box-shadow: 0 0 12px rgba(255,218,106,.25);
      animation: tnxConfettiFall var(--fall-duration, 2.8s) cubic-bezier(.2,.7,.25,1) forwards;
    }

    .tnx-confetti-piece:nth-child(4n) {
      background: rgba(145,70,255,.9);
    }

    @keyframes tnxConfettiFall {
      0% {
        transform: translate3d(0, -20px, 0) rotate(0deg);
        opacity: 0;
      }
      8% { opacity: 1; }
      100% {
        transform: translate3d(var(--fall-x, 0px), calc(100vh + 90px), 0) rotate(var(--fall-rotate, 620deg));
        opacity: 0;
      }
    }

    @media (max-width: 720px) {
      .level-card {
        min-height: auto !important;
        padding: 22px 20px 24px !important;
      }

      .level-card .level-info {
        grid-template-columns: 1fr !important;
        grid-template-areas:
          "title"
          "xp"
          "bar" !important;
        gap: 12px !important;
      }

      .level-card #levelTitle {
        white-space: normal !important;
      }

      #levelProgressInline {
        width: fit-content !important;
        justify-self: end !important;
      }

      .avatar-level-pill {
        left: -5px !important;
        bottom: -6px !important;
        min-width: 58px !important;
        height: 29px !important;
        font-size: .78rem !important;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .level-card .xp-fill::after,
      .tnx-confetti-piece {
        animation: none !important;
      }
    }


    /* Final skeleton visibility fix */
    #profileSkeleton.is-hidden,
    .tnx-profile-page:has(#profileView:not(.hidden)) #profileSkeleton,
    .tnx-profile-page:has(#searchView:not(.hidden)) #profileSkeleton,
    .tnx-profile-page:has(#notFoundView:not(.hidden)) #profileSkeleton {
      display: none !important;
    }


    /* Discord-style featured badges */
    .profile-featured-badges {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 7px;
      margin: 2px 0 12px;
      min-height: 34px;
      flex-wrap: wrap;
    }

    .profile-featured-badges.hidden {
      display: none !important;
    }

    .featured-mini-badge {
      position: relative;
      width: 31px;
      height: 31px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      border: 1px solid rgba(255, 223, 138, .22);
      background:
        radial-gradient(circle at 50% 20%, rgba(255, 223, 138, .14), transparent 42%),
        rgba(0, 0, 0, .34);
      color: rgba(255, 239, 196, .94);
      box-shadow:
        0 10px 22px rgba(0, 0, 0, .28),
        inset 0 1px 0 rgba(255,255,255,.04);
      cursor: default;
      transition:
        transform .16s ease,
        border-color .16s ease,
        background .16s ease,
        box-shadow .16s ease;
    }

    .featured-mini-badge:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 223, 138, .46);
      background:
        radial-gradient(circle at 50% 20%, rgba(255, 223, 138, .22), transparent 45%),
        rgba(255, 255, 255, .06);
      box-shadow:
        0 14px 30px rgba(0, 0, 0, .34),
        0 0 18px rgba(255, 223, 138, .12);
    }

    .featured-mini-badge img {
      width: 21px;
      height: 21px;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 5px 10px rgba(0,0,0,.35));
    }

    .featured-mini-badge span {
      font-size: 16px;
      line-height: 1;
      filter: drop-shadow(0 5px 10px rgba(0,0,0,.35));
    }

    .featured-mini-badge::after {
      content: attr(data-tip);
      position: absolute;
      right: 50%;
      bottom: calc(100% + 9px);
      transform: translateX(50%) translateY(4px);
      width: max-content;
      max-width: 210px;
      padding: 7px 10px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(8, 8, 11, .96);
      color: rgba(255,255,255,.9);
      font-size: 12px;
      font-weight: 850;
      line-height: 1.35;
      text-align: center;
      white-space: nowrap;
      box-shadow: 0 16px 36px rgba(0,0,0,.45);
      opacity: 0;
      pointer-events: none;
      transition: opacity .14s ease, transform .14s ease;
      z-index: 20;
    }

    .featured-mini-badge:hover::after {
      opacity: 1;
      transform: translateX(50%) translateY(0);
    }

    .featured-mini-badge.rarity-mythic,
    .featured-mini-badge.rarity-legendary {
      border-color: rgba(255, 223, 138, .36);
      box-shadow:
        0 10px 24px rgba(0,0,0,.30),
        0 0 18px rgba(255, 223, 138, .14);
