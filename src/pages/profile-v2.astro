---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'Profile V2 — TNX6',
  ignoreTitleTemplate: true,
  description: 'TNX6 community member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page profile-v2-page" dir="rtl">
    <section id="profileSkeleton" class="profile-skeleton" aria-label="جاري تحميل البروفايل">
      <div class="skeleton-shell">
        <div class="skeleton-cover"></div>

        <div class="skeleton-head">
          <div class="skeleton-avatar skeleton-pulse"></div>

          <div class="skeleton-lines">
            <div class="skeleton-line skeleton-name skeleton-pulse"></div>
            <div class="skeleton-line skeleton-handle skeleton-pulse"></div>
            <div class="skeleton-line skeleton-bio skeleton-pulse"></div>
          </div>
        </div>

        <div class="skeleton-grid">
          <div class="skeleton-card skeleton-pulse"></div>
          <div class="skeleton-card skeleton-pulse"></div>
          <div class="skeleton-card skeleton-pulse"></div>
        </div>
      </div>
    </section>
    <section id="searchView" class="profile-search hidden">
<div class="search-card profile-login-card">
        <span class="eyebrow">TNX6 PROFILE</span>

        <h1>حسابك في الموقع</h1>

        <p class="login-description">
          سجّل دخولك عبر Twitch للوصول إلى بروفايلك، بادجاتك، أغراضك، ومستواك داخل المجتمع.
        </p>

        <a
          class="twitch-login-btn"
          href="https://api.tnx6.xyz/auth/twitch/login"
          aria-label="تسجيل الدخول عبر Twitch"
        >
          <span class="twitch-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/>
            </svg>
          </span>
          تسجيل الدخول عبر Twitch
        </a>

        <p class="login-note">
          لا يتم استخدام حسابك إلا للتحقق من هويتك داخل الموقع.
        </p>

        <div id="searchResults" class="search-results" hidden></div>
      </div>
    </section>

    <section id="notFoundView" class="not-found hidden">
      <strong>ما لقيت العضو</strong>
      <span>تأكد من الاسم أو من ملفات الـ API.</span>
    </section>

    
        <section id="profileView" class="profile-page profile-v2-layout hidden">
          <section class="profile-v2-shell">
            <div class="v2-cover" id="cover">
              <div class="v2-cover-bg" aria-hidden="true"></div>
              <div class="v2-cover-shade" aria-hidden="true"></div>
              <canvas id="coverCanvas" class="v2-cover-canvas"></canvas>

              <button class="v2-mail-btn" type="button" id="openMailButton">
                البريد
                <span class="mail-count" id="mailCount">0</span>
              </button>

              <div class="v2-profile-head">
                <div class="avatar-wrap v2-avatar-wrap" id="avatarWrap">
                  <div class="avatar-ring" id="avatarRing"></div>
                  <img class="avatar" id="avatar" alt="Profile Avatar" />
                  <span class="online-dot" id="onlineDot"></span>
                  <span class="avatar-level-pill" id="avatarLevelBadge">LVL 1</span>
                </div>

                <div class="v2-identity">
                  <div class="v2-name-row">
                    <h1 class="display-name" id="displayName">---</h1>
                    <span class="handle" id="handle">---</span>
                  </div>

                  <div id="featuredBadges" class="profile-featured-badges hidden" aria-label="بادجات العضو المميزة"></div>

                  <p class="bio" id="bio">---</p>
                  <div class="chips" id="chips"></div>
                </div>
              </div>
            </div>

            <div class="v2-stats-strip">
              <div class="v2-stat-item">
                <span class="stat-value" id="rank">---</span>
                <span class="stat-label">الرتبة</span>
              </div>

              <div class="v2-stat-item">
                <span class="stat-value" id="messages">---</span>
                <span class="stat-label">رسالة</span>
              </div>

              <div class="v2-stat-item">
                <span class="stat-value" id="checkins">---</span>
                <span class="stat-label">دخول يومي</span>
              </div>

              <div class="v2-stat-item">
                <span class="stat-value" id="points">---</span>
                <span class="stat-label">نقطة</span>
              </div>
            </div>

            <section class="v2-level-section">
              <span class="v2-level-watermark" id="levelWatermark">1</span>

              <div class="v2-level-info">
                <h2 id="levelTitle">تقدم المستوى</h2>

                <div class="v2-xp-bar">
                  <div class="v2-xp-fill" id="xpFill"></div>
                </div>

                <div class="v2-xp-text">
                  <span id="currentXp">0 XP</span>
                  <span id="neededXp">0 XP</span>
                </div>

                <div class="v2-xp-breakdown" id="xpBreakdown"></div>
              </div>

              <div class="v2-level-ring-wrap">
                <svg class="v2-level-ring-svg" viewBox="0 0 110 110" aria-hidden="true">
                  <defs>
                    <linearGradient id="ringGradV2" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="#d4af37"/>
                      <stop offset="100%" stop-color="#f0d060"/>
                    </linearGradient>
                  </defs>
                  <circle class="v2-level-ring-bg" cx="55" cy="55" r="48"/>
                  <circle class="v2-level-ring-fill" id="levelRingFill" cx="55" cy="55" r="48" stroke-dasharray="301.6" stroke-dashoffset="301.6"/>
                </svg>

                <div class="v2-level-ring-center">
                  <span>LEVEL</span>
                  <strong id="levelNumber">1</strong>
                </div>
              </div>
            </section>

            <div class="v2-content">
              <div class="v2-main-stack">
                <section class="card v2-card">
                  <div class="card-header">
                    <h2 class="card-title">الحقيبة</h2>
                    <span class="card-subtitle" id="inventoryCount">0 غرض</span>
                  </div>

                  <div class="inventory" id="inventory"></div>
                </section>
              </div>

              <aside class="v2-side-stack">
                <section class="card v2-card">
                  <div class="card-header">
                    <h2 class="card-title">البادجات</h2>
                    <span class="card-subtitle" id="badgesCount">0 مفتوحة</span>
                  </div>

                  <div class="badges" id="badges"></div>
                </section>

                <section class="card v2-card next-badge-card-v2" id="nextBadgeMiniBox">
                  <div class="v2-next-head">
                    <h2>البادج القادم</h2>
                    <span id="nextBadgeMiniPercent">0%</span>
                  </div>

                  <strong class="v2-next-name" id="nextBadgeMiniValue">---</strong>

                  <div class="v2-next-track">
                    <div class="v2-next-fill" id="nextBadgeMiniFill"></div>
                  </div>

                  <div class="v2-next-meta">
                    <span id="nextBadgeMiniRemain">---</span>
                    <b id="nextBadgeMiniMeta">---</b>
                  </div>
                </section>
              </aside>
            </div>
          </section>

          <section class="actions-row v2-actions-row">
            <div id="profileAccountMenu" class="profile-account-menu hidden">
              <button id="profileAccountToggle" class="profile-account-toggle" type="button" aria-expanded="false">
                إدارة الحساب
                <span>▾</span>
              </button>

              <div id="profileAccountDropdown" class="profile-account-dropdown hidden">
                <div class="profile-account-mini-status">
                  <span class="profile-account-dot"></span>
                  <div>
                    <strong>متصل عبر Twitch</strong>
                    <small id="profileAccountHandle">@---</small>
                  </div>
                </div>

                <a id="profileAccountPublicLink" href="/profile" class="profile-account-menu-item">فتح صفحتي العامة</a>
                <button id="profileAccountLogout" type="button" class="profile-account-menu-item danger">تسجيل الخروج</button>
              </div>
            </div>
          </section>
        </section>


    <div class="modal-backdrop" id="mailModal" aria-hidden="true">
      <div class="mail-modal">
        <div class="modal-head">
          <h3>البريد</h3>
          <button class="close-btn" type="button" id="closeMailButton">×</button>
        </div>

        <div class="mail-list" id="mailList"></div>
      </div>
    </div>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    :root {
      --bg: #070707;
      --panel: rgba(18, 18, 20, 0.78);
      --panel2: rgba(255, 255, 255, 0.055);
      --line: rgba(255, 215, 130, 0.18);
      --gold: #d7a84f;
      --gold2: #ffdf8a;
      --text: #f4f0e8;
      --muted: rgba(244, 240, 232, 0.62);
      --danger: #ff5d5d;
      --green: #7CFFB2;
      --shadow: 0 28px 90px rgba(0, 0, 0, 0.62);
      --radius: 28px;
      --cover-image: radial-gradient(circle at 50% 20%, rgba(255,223,138,.24), transparent 35%),
                     linear-gradient(135deg, #1a1208, #080808 58%, #1d160b);
    }

    .hidden {
      display: none !important;
    }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .55) rgba(0, 0, 0, .48);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.48); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.48);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.95), rgba(194,146,0,.6));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 70% 10%, rgba(215, 168, 79, 0.15), transparent 34%),
        radial-gradient(circle at 20% 80%, rgba(255, 223, 138, 0.09), transparent 40%),
        linear-gradient(145deg, #030303, #0b0b0e 60%, #030303);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Tahoma, Arial, sans-serif;
    }

    .tnx-profile-page::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 46px 46px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,.9), transparent 90%);
      pointer-events: none;
      z-index: 0;
    }

    .profile-search {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      min-height: 78vh;
      margin: 34px auto;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 620px);
      border: 1px solid var(--line);
      border-radius: calc(var(--radius) + 8px);
      background:
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025)),
        rgba(10, 10, 12, 0.78);
      box-shadow: var(--shadow);
      padding: 2rem;
      text-align: center;
      backdrop-filter: blur(18px);
    }

    .eyebrow {
      display: inline-flex;
      border: 1px solid rgba(255,223,138,.28);
      border-radius: 999px;
      background: rgba(215,168,79,.1);
      color: var(--gold2);
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: var(--muted);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: var(--gold2);
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,223,138,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.34);
      padding: .85rem;
    }

    .search-box span {
      color: var(--gold2);
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,223,138,.2);
      border-radius: 999px;
      background: rgba(215,168,79,.1);
      color: var(--gold2);
      font-size: 1.12rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,223,138,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: var(--gold2);
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255,223,138,.42);
      background: rgba(215,168,79,.08);
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
      margin: 34px auto;
    }

    .not-found strong {
      color: var(--gold2);
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: var(--muted);
      font-size: .9rem;
    }

    .profile-page {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      margin: 34px auto;
    }

    .profile-shell {
      border: 1px solid var(--line);
      border-radius: calc(var(--radius) + 8px);
      background:
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025)),
        rgba(10, 10, 12, 0.72);
      box-shadow: var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(18px);
    }

    .cover {
      min-height: 330px;
      position: relative;
      background:
        linear-gradient(to top, rgba(7,7,7,1), rgba(7,7,7,.15) 55%, rgba(7,7,7,.35)),
        var(--cover-image),
        radial-gradient(circle at center, #292014, #070707 65%);
      background-size: cover;
      background-position: center;
      padding: 28px;
      display: flex;
      align-items: flex-end;
    }

    .cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(0,0,0,.72), transparent 50%, rgba(0,0,0,.32)),
        radial-gradient(circle at 50% 100%, rgba(215,168,79,.16), transparent 35%);
      pointer-events: none;
    }

    .profile-head {
      position: relative;
      z-index: 2;
      width: 100%;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 22px;
      align-items: end;
    }

    @property --frame-angle {
      syntax: "<angle>";
      inherits: false;
      initial-value: 160deg;
    }

    .avatar-wrap {
      width: 148px;
      height: 148px;
      position: relative;
      flex: none;
      isolation: isolate;
    }

    .avatar-ring {
      position: absolute;
      inset: -5px;
      border-radius: 34px;
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #3a2b17,
        #8a6a35,
        #5d4219,
        #8a6a35,
        #3a2b17
      );
      box-shadow: 0 0 26px rgba(215,168,79,.18);
      transition: filter .2s ease, box-shadow .2s ease;
      transform: translateZ(0);
      z-index: 0;
    }

    .avatar-wrap.level-frame-basic .avatar-ring {
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #2b2b2d,
        #9b8a68,
        #343436,
        #9b8a68,
        #2b2b2d
      );
      box-shadow: 0 0 22px rgba(255,255,255,.08);
    }

    .avatar-wrap.level-frame-gold .avatar-ring {
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #5d4219,
        #ffdf8a,
        #9c6b20,
        #ffdf8a,
        #5d4219
      );
      box-shadow: 0 0 38px rgba(215,168,79,.28);
    }

    .avatar-wrap.level-frame-animated .avatar-ring {
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #5d4219,
        #ffdf8a,
        #7a4dff,
        #ffdf8a,
        #5d4219
      );
      box-shadow: 0 0 42px rgba(255,223,138,.34), 0 0 18px rgba(122,77,255,.16);
      animation: avatarFrameGradientSpin 7s linear infinite;
    }

    .avatar-wrap.level-frame-legendary .avatar-ring {
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #331400,
        #ffdf8a,
        #ff5d5d,
        #b36bff,
        #ffdf8a,
        #331400
      );
      box-shadow: 0 0 54px rgba(255,223,138,.42), 0 0 26px rgba(255,93,93,.2);
      animation: avatarFrameGradientSpin 5s linear infinite, avatarFrameSoftPulse 2.4s ease-in-out infinite;
    }

    .avatar-wrap.level-frame-special .avatar-ring {
      background: conic-gradient(
        from var(--frame-angle, 160deg),
        #ffffff,
        #ffdf8a,
        #7CFFB2,
        #b36bff,
        #ffdf8a,
        #ffffff
      );
      box-shadow: 0 0 70px rgba(255,223,138,.52), 0 0 35px rgba(124,255,178,.22), 0 0 22px rgba(179,107,255,.22);
      animation: avatarFrameGradientSpin 4s linear infinite, avatarFrameSoftPulse 1.8s ease-in-out infinite;
    }

    .avatar-wrap.level-frame-special::after {
      content: "";
      position: absolute;
      inset: -12px;
      border-radius: 42px;
      border: 1px solid rgba(255,223,138,.22);
      box-shadow: 0 0 38px rgba(255,223,138,.18);
      animation: avatarFrameSoftPulse 1.8s ease-in-out infinite;
      pointer-events: none;
      z-index: -1;
    }

    @keyframes avatarFrameGradientSpin {
      from { --frame-angle: 160deg; }
      to { --frame-angle: 520deg; }
    }

    @keyframes avatarFrameSoftPulse {
      0%, 100% { filter: brightness(1); opacity: .9; }
      50% { filter: brightness(1.22); opacity: 1; }
    }

    .avatar {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 30px;
      object-fit: cover;
      border: 4px solid #090909;
      background: #111;
      display: block;
    }

    .online-dot {
      position: absolute;
      bottom: 7px;
      left: 7px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--green);
      border: 4px solid #080808;
      box-shadow: 0 0 18px rgba(124, 255, 178, .75);
    }

    .identity {
      min-width: 0;
    }

    .name-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .display-name {
      margin: 0;
      font-size: clamp(32px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -1.5px;
      font-weight: 900;
      text-shadow: 0 18px 40px rgba(0,0,0,.75);
      word-break: break-word;
    }

    .handle {
      color: var(--gold2);
      font-size: 15px;
      font-weight: 800;
      padding: 7px 12px;
      border: 1px solid rgba(255,223,138,.25);
      border-radius: 999px;
      background: rgba(0,0,0,.36);
      direction: ltr;
    }

    .bio {
      margin: 0;
      max-width: 680px;
      color: rgba(244,240,232,.76);
      font-size: 16px;
      line-height: 1.8;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      margin-top: 16px;
    }

    .chip {
      padding: 9px 13px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.065);
      color: rgba(255,255,255,.82);
      font-weight: 750;
      font-size: 13px;
    }

    .chip.gold {
      border-color: rgba(255, 223, 138, .34);
      background: rgba(215,168,79,.12);
      color: var(--gold2);
    }

    .mail-area {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
    }

    .mail-btn {
      appearance: none;
      border: 0;
      cursor: pointer;
      border-radius: 18px;
      padding: 15px 18px;
      min-width: 150px;
      color: #15100a;
      background: linear-gradient(135deg, var(--gold2), var(--gold));
      font-size: 16px;
      font-weight: 950;
      box-shadow: 0 18px 38px rgba(215,168,79,.2);
      transition: transform .18s ease, filter .18s ease;
      position: relative;
    }

    .mail-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.06);
    }

    .mail-count {
      position: absolute;
      top: -9px;
      right: -9px;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--danger);
      color: white;
      display: grid;
      place-items: center;
      border: 3px solid #080808;
      font-size: 13px;
      font-weight: 950;
    }

    .content {
      padding: 26px;
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 20px;
    }

    .main-stack,
    .side-stack {
      display: grid;
      gap: 20px;
      align-content: start;
    }

    .card {
      border: 1px solid rgba(255,255,255,.09);
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.065), rgba(255,255,255,.028)),
        rgba(12,12,14,.76);
      box-shadow: 0 20px 55px rgba(0,0,0,.28);
      overflow: hidden;
    }

    .card-header {
      padding: 20px 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .rank-header {
      padding: 0 0 10px;
    }

    .card-title {
      margin: 0;
      font-size: 20px;
      font-weight: 950;
      letter-spacing: -.4px;
    }

    .card-subtitle {
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .level-card {
      padding: 20px;
    }

    .level-main {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 18px;
      width: 100%;
      direction: rtl;
    }

    .level-info {
      flex: 1 1 auto;
      min-width: 0;
      direction: rtl;
      align-self: stretch;
      padding-top: 4px;
    }

    .level-badge {
      flex: 0 0 118px;
      width: 118px;
      height: 118px;
      margin: 0;
      align-self: flex-start;
      border-radius: 28px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 20%, rgba(255,223,138,.45), transparent 34%),
        linear-gradient(145deg, #251908, #0f0d0a);
      border: 1px solid rgba(255,223,138,.28);
      box-shadow: inset 0 0 30px rgba(255,223,138,.08), 0 20px 55px rgba(0,0,0,.35);
    }

    .level-badge span {
      display: block;
      font-size: 12px;
      color: var(--muted);
      font-weight: 800;
      text-align: center;
      margin-bottom: 4px;
    }

    .level-badge strong {
      display: block;
      font-size: 48px;
      line-height: .9;
      color: var(--gold2);
      font-weight: 1000;
      text-align: center;
    }

    .level-info h2 {
      margin: 0 0 12px;
      font-size: 25px;
      font-weight: 950;
      text-align: right;
    }

    .level-info p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }

    .xp-bar {
      height: 18px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.08);
      position: relative;
    }

    .xp-fill {
      height: 100%;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(90deg, #8d5e1f, #ffdf8a);
      box-shadow: 0 0 26px rgba(255,223,138,.35);
      transition: width .8s ease;
    }

    .xp-text {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      color: rgba(244,240,232,.72);
      font-size: 13px;
      font-weight: 800;
    }

    .xp-breakdown {
      margin-top: 14px;
      max-width: 100%;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .xp-source {
      border: 1px solid rgba(255,255,255,.075);
      border-radius: 16px;
      background: rgba(0,0,0,.18);
      padding: 10px 11px;
    }

    .xp-source span {
      display: block;
      color: var(--muted);
      font-size: 11px;
      font-weight: 850;
      margin-bottom: 4px;
    }

    .xp-source strong {
      display: block;
      color: var(--gold2);
      font-size: 14px;
      font-weight: 1000;
      direction: ltr;
      text-align: right;
    }

    .xp-source.total {
      grid-column: 1 / -1;
      background: rgba(215,168,79,.095);
      border-color: rgba(255,223,138,.18);
    }


    .inventory {
      padding: 18px 20px 20px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .item {
      min-height: 92px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 13px;
      align-items: center;
      padding: 14px;
      border-radius: 22px;
      background: rgba(255,255,255,.045);
      border: 1px solid rgba(255,255,255,.075);
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }

    .item:hover {
      transform: translateY(-2px);
      border-color: rgba(255,223,138,.22);
      background: rgba(255,255,255,.065);
    }

    .item::before {
      content: "";
      position: absolute;
      inset-inline-start: 0;
      top: 0;
      width: 4px;
      height: 100%;
      background: var(--rarity-color);
      opacity: .9;
    }

    .item-icon {
      width: 52px;
      height: 52px;
      border-radius: 17px;
      display: grid;
      place-items: center;
      background: rgba(0,0,0,.22);
      border: 1px solid rgba(255,255,255,.08);
      font-size: 27px;
    }

    .item-name {
      margin: 0;
      font-size: 15px;
      font-weight: 950;
      color: #fff;
    }

    .item-meta {
      margin-top: 5px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .qty {
      color: var(--gold2);
    }

    .badges {
      padding: 18px 20px 20px;
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }

    .badge {
      aspect-ratio: 1;
      min-height: 86px;
      border-radius: 22px;
      background:
        radial-gradient(circle at 50% 20%, rgba(255,223,138,.14), transparent 42%),
        rgba(255,255,255,.045);
      border: 1px solid rgba(255,255,255,.08);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 7px;
      position: relative;
      overflow: hidden;
      transition: transform .18s ease, border-color .18s ease;
    }

    .badge:hover {
      transform: translateY(-3px);
      border-color: rgba(255,223,138,.25);
    }

    .badge img {
      width: 52px;
      height: 52px;
      object-fit: contain;
      filter: drop-shadow(0 8px 18px rgba(0,0,0,.35));
    }

    .badge-icon {
      font-size: 28px;
      filter: drop-shadow(0 8px 18px rgba(0,0,0,.35));
    }

    .badge-name {
      font-size: 11px;
      font-weight: 900;
      color: rgba(244,240,232,.78);
      text-align: center;
      line-height: 1.25;
    }

    .rank-card {
      padding: 20px;
    }

    .rank-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,.075);
    }

    .rank-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .rank-label {
      color: var(--muted);
      font-weight: 800;
      font-size: 13px;
    }

    .rank-value {
      color: #fff;
      font-weight: 1000;
      font-size: 16px;
      direction: ltr;
    }

    .empty {
      color: var(--muted);
      padding: 20px;
      font-weight: 800;
      grid-column: 1 / -1;
    }

    .actions-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: .7rem;
      margin-top: 18px;
    }

    .actions-row a,
    .actions-row button {
      border: 1px solid rgba(255,223,138,.18);
      border-radius: 999px;
      background: rgba(8,8,12,.78);
      color: var(--gold2);
      padding: .74rem 1.05rem;
      font-family: inherit;
      font-size: .82rem;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
      backdrop-filter: blur(14px);
    }

    .actions-row a:hover,
    .actions-row button:hover {
      border-color: rgba(255,223,138,.42);
      background: rgba(215,168,79,.12);
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 120;
      background: rgba(0,0,0,.68);
      backdrop-filter: blur(10px);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .modal-backdrop.show {
      display: flex;
    }

    .mail-modal,
    .item-modal {
      width: min(560px, 100%);
      max-height: 82vh;
      overflow: hidden;
      border-radius: 30px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.035)),
        #0d0d10;
      border: 1px solid rgba(255,223,138,.18);
      box-shadow: 0 35px 100px rgba(0,0,0,.75);
    }

    .modal-head {
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }

    .modal-head h3 {
      margin: 0;
      font-size: 22px;
      font-weight: 1000;
    }

    .close-btn {
      width: 38px;
      height: 38px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.1);
      color: white;
      background: rgba(255,255,255,.07);
      cursor: pointer;
      font-size: 20px;
      font-weight: 900;
    }

    .mail-list {
      padding: 16px;
      display: grid;
      gap: 12px;
      max-height: 62vh;
      overflow: auto;
    }

    .mail-message {
      padding: 15px;
      border-radius: 20px;
      background: rgba(255,255,255,.055);
      border: 1px solid rgba(255,255,255,.08);
    }

    .mail-message strong {
      display: block;
      margin-bottom: 6px;
      color: var(--gold2);
      font-size: 14px;
    }

    .mail-message p {
      margin: 0;
      color: rgba(244,240,232,.78);
      line-height: 1.7;
      font-size: 14px;
    }

    .item-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      padding: 0 16px 16px;
    }

    .item-action-btn {
      border: 1px solid rgba(255,223,138,.16);
      border-radius: 16px;
      background: rgba(255,255,255,.055);
      color: rgba(244,240,232,.9);
      padding: 11px 12px;
      font-family: inherit;
      font-weight: 950;
      cursor: pointer;
      transition: transform .16s ease, border-color .16s ease, background .16s ease;
    }

    .item-action-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(255,223,138,.35);
      background: rgba(215,168,79,.11);
      color: var(--gold2);
    }

    .item-command-hint {
      margin: 0 16px 16px;
      border: 1px solid rgba(255,223,138,.14);
      border-radius: 18px;
      background: rgba(0,0,0,.24);
      padding: 12px;
      color: rgba(244,240,232,.8);
      font-size: 13px;
      font-weight: 800;
      line-height: 1.7;
    }

    .item-command-hint code {
      display: inline-block;
      direction: ltr;
      color: var(--gold2);
      background: rgba(255,223,138,.08);
      border: 1px solid rgba(255,223,138,.14);
      border-radius: 999px;
      padding: 3px 8px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12px;
    }

    .back-top {
      position: fixed;
      left: 1rem;
      bottom: 1rem;
      z-index: 60;
      width: 3rem;
      height: 3rem;
      border: 1px solid rgba(255,223,138,.32);
      border-radius: 999px;
      background: rgba(8,8,12,.88);
      color: var(--gold2);
      font-size: 1.15rem;
      font-weight: 950;
      cursor: pointer;
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: 160ms ease;
      backdrop-filter: blur(12px);
    }

    .back-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (max-width: 940px) {
      .profile-head {
        grid-template-columns: 1fr;
        align-items: center;
        text-align: center;
      }

      .avatar-wrap {
        margin: 0 auto;
      }

      .chips,
      .name-row {
        justify-content: center;
      }

      .mail-area {
        justify-content: center;
      }

      .content {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .profile-page,
      .profile-search {
        width: min(100% - 18px, 1180px);
        margin: 10px auto;
      }

      .cover {
        padding: 18px;
        min-height: 380px;
      }

      .content {
        padding: 14px;
      }

      .inventory {
        grid-template-columns: 1fr;
      }

      .badges {
        grid-template-columns: repeat(3, 1fr);
      }

      .level-main {
        flex-direction: row;
        align-items: flex-start;
        text-align: right;
        direction: rtl;
      }

      .level-info h2 {
        text-align: right;
      }

      .level-badge {
        flex-basis: 108px;
        width: 108px;
        height: 108px;
        margin: 0;
      }

      .xp-breakdown,
      .item-actions {
        grid-template-columns: 1fr;
      }
    }

    .twitch-login-btn {
      width: min(100%, 360px);
      margin: 26px auto 0;
      min-height: 58px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border-radius: 18px;
      border: 1px solid rgba(145, 70, 255, .55);
      background:
        radial-gradient(circle at 30% 0%, rgba(255,255,255,.20), transparent 34%),
        linear-gradient(135deg, #9146ff, #5f22c8);
      color: #fff;
      font-weight: 950;
      letter-spacing: -.02em;
      box-shadow: 0 18px 50px rgba(145, 70, 255, .22);
      transition: transform .18s ease, filter .18s ease, border-color .18s ease;
    }

    .twitch-login-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
      border-color: rgba(255,255,255,.42);
    }

    .twitch-icon {
      width: 30px;
      height: 30px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: rgba(255,255,255,.16);
      border: 1px solid rgba(255,255,255,.14);
      font-size: 17px;
    }

    .login-note {
      margin: 14px auto 0 !important;
      max-width: 520px;
      color: rgba(255,255,255,.48) !important;
      font-size: .92rem;
      line-height: 1.8;
    }


    /* Login prompt design */
    .profile-search {
      position: relative;
      isolation: isolate;
      min-height: 72vh;
      overflow: hidden;
    }

    .profile-search .profile-login-card {
      width: min(100%, 620px);
      margin-inline: auto;
      padding: 48px 32px;
      border-radius: 28px;
      text-align: center;
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)),
        rgba(20, 20, 25, .72);
      border: 1px solid rgba(255, 255, 255, .085);
      box-shadow:
        0 26px 60px rgba(0, 0, 0, .48),
        inset 0 1px 0 rgba(255,255,255,.06);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      overflow: hidden;
    }

    .profile-search .profile-login-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.28), transparent);
      pointer-events: none;
    }

    .profile-search .eyebrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      padding: 7px 17px;
      border-radius: 999px;
      border: 1px solid rgba(215, 168, 79, .32);
      background: rgba(215, 168, 79, .07);
      color: #d7a84f;
      font-size: .74rem;
      font-weight: 950;
      letter-spacing: .12em;
      text-transform: uppercase;
      box-shadow: 0 0 22px rgba(215, 168, 79, .10);
    }

    .profile-search .profile-login-card h1 {
      margin: 0 0 14px;
      font-size: clamp(2.15rem, 6vw, 4.2rem);
      line-height: 1.05;
      font-weight: 950;
      letter-spacing: -.06em;
      color: #fff;
      background: linear-gradient(180deg, #fff 0%, #d7d7d7 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 18px 42px rgba(0,0,0,.34);
    }

    .login-description {
      max-width: 520px;
      margin: 0 auto 30px !important;
      color: rgba(255,255,255,.60) !important;
      font-size: 1.02rem;
      line-height: 1.9;
      font-weight: 750;
    }

    .twitch-login-btn {
      width: min(100%, 380px);
      min-height: 58px;
      margin: 0 auto;
      padding: 15px 24px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      border-radius: 17px;
      border: 0;
      background: linear-gradient(135deg, #a970ff 0%, #9146ff 52%, #772ce8 100%);
      color: #fff;
      font-size: 1.06rem;
      font-weight: 950;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      box-shadow:
        0 14px 34px rgba(145, 70, 255, .34),
        inset 0 0 0 1px rgba(255,255,255,.12);
      transition: transform .2s ease, filter .2s ease, box-shadow .2s ease;
    }

    .twitch-login-btn::after {
      content: "";
      position: absolute;
      top: 0;
      right: -120%;
      width: 90%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
      transform: skewX(-18deg);
      transition: right .55s ease;
    }

    .twitch-login-btn:hover {
      transform: translateY(-3px);
      filter: brightness(1.08);
      box-shadow:
        0 22px 44px rgba(145, 70, 255, .44),
        inset 0 0 0 1px rgba(255,255,255,.18);
    }

    .twitch-login-btn:hover::after {
      right: 130%;
    }

    .twitch-login-btn:active {
      transform: translateY(-1px);
    }

    .twitch-icon {
      width: 31px;
      height: 31px;
      display: grid;
      place-items: center;
      border-radius: 11px;
      background: rgba(255,255,255,.16);
      border: 1px solid rgba(255,255,255,.14);
      flex: 0 0 auto;
    }

    .twitch-icon svg {
      width: 19px;
      height: 19px;
      fill: #fff;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,.22));
    }

    .login-note {
      max-width: 500px;
      margin: 22px auto 0 !important;
      color: rgba(255,255,255,.46) !important;
      font-size: .9rem;
      line-height: 1.8;
      font-weight: 650;
    }

    .login-glow-orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(72px);
      opacity: .34;
      z-index: -1;
      pointer-events: none;
      animation: loginFloat 10s infinite ease-in-out;
    }

    .login-orb-1 {
      width: 280px;
      height: 280px;
      background: #9146ff;
      top: 40px;
      left: calc(50% - 430px);
    }

    .login-orb-2 {
      width: 240px;
      height: 240px;
      background: #d7a84f;
      bottom: 60px;
      right: calc(50% - 420px);
      animation-delay: 2s;
    }

    @keyframes loginFloat {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(18px, 26px, 0); }
    }

    @media (max-width: 560px) {
      .profile-search .profile-login-card {
        padding: 36px 20px;
        border-radius: 24px;
      }

      .login-description {
        font-size: .95rem;
      }

      .twitch-login-btn {
        min-height: 56px;
        font-size: 1rem;
      }
    }


    /* Fix Arabic title clipping */
    .profile-search .profile-login-card h1 {
      line-height: 1.22 !important;
      padding-bottom: .14em;
      margin-bottom: 8px;
      overflow: visible;
    }


    /* Smooth login background glow without clipped orbs */
    .profile-search {
      overflow: visible !important;
    }

    .login-glow-orb,
    .login-orb-1,
    .login-orb-2 {
      display: none !important;
    }

    .profile-search::before {
      content: "";
      position: fixed;
      inset: -20%;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 22%, rgba(145, 70, 255, .16), transparent 34%),
        radial-gradient(circle at 78% 82%, rgba(215, 168, 79, .13), transparent 36%);
      filter: blur(18px);
      opacity: .9;
    }

    .profile-search::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 38px 38px;
      mask-image: radial-gradient(circle at center, black, transparent 75%);
      opacity: .45;
    }


    /* Logged account tools */
    .account-tools {
      width: min(100% - 32px, 1180px);
      margin: 26px auto 14px;
      padding: 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      border-radius: 22px;
      border: 1px solid rgba(255, 223, 138, .18);
      background:
        linear-gradient(135deg, rgba(255, 223, 138, .08), rgba(145, 70, 255, .06)),
        rgba(12, 12, 14, .72);
      box-shadow: 0 18px 48px rgba(0,0,0,.34);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .account-tools.hidden {
      display: none !important;
    }

    .account-status {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: #62f5a3;
      box-shadow: 0 0 18px rgba(98, 245, 163, .75);
      flex: 0 0 auto;
