          const pick = event.target.closest('[data-sell-qty-pick]')
          const step = event.target.closest('[data-sell-qty-step]')

          if (pick) {
            setQty(pick.dataset.sellQtyPick)
          }

          if (step) {
            setQty(selectedQty + Math.floor(Number(step.dataset.sellQtyStep || 0)))
          }
        })

        if (qtyInput) {
          addListener(qtyInput, 'input', () => setQty(qtyInput.value))
          addListener(qtyInput, 'blur', () => setQty(qtyInput.value))
        }

        modal.querySelectorAll('[data-sell-close]').forEach((button) => {
          addListener(button, 'click', close)
        })

        addListener(modal, 'click', (event) => {
          if (event.target === modal) close()
        })

        addListener(submit, 'click', async () => {
          const qty = clampQty(selectedQty)

          submit.disabled = true
          qtyButtons().forEach((button) => { button.disabled = true })
          if (qtyInput) qtyInput.disabled = true
          msg.className = 'inventory-sell-message'
          msg.textContent = 'جاري تسجيل البيع...'

          const localSellLockId = addInventorySellLock(name, qty, owned, state.activeUser);

          try {
            const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell', {
              method: 'POST',
              credentials: 'include',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                itemName: apiItemName,
                quantity: qty,
              }),
            })

            const data = await res.json().catch(() => ({}))

            if (!res.ok || !data.ok) {
              const sellError = new Error(data.error || 'sell_failed')
              sellError.data = data
