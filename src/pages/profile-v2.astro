      // mailbox-upgrade-v4-opener
      function mbUpgradeV4Format(value) {
        try {
          if (typeof formatNumber === 'function') return formatNumber(value)
        } catch {}

        try {
          return new Intl.NumberFormat('ar-SA').format(Number(value || 0))
        } catch {
          return String(value || 0)
        }
      }

      function mbUpgradeV4Api(path) {
        try {
          if (typeof API_BASE === 'string' && API_BASE) {
            return API_BASE.replace(/\/$/, '') + path
          }
        } catch {}

        return 'https://api.tnx6.xyz' + path
      }

      async function mbUpgradeV4Fetch(path, options) {
        const response = await fetch(mbUpgradeV4Api(path), {
          credentials: 'include',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/json',
            ...((options && options.headers) || {}),
          },
          ...(options || {}),
        })

        const data = await response.json().catch(() => ({}))

        return {
          response,
          data,
        }
      }

      function mbUpgradeV4Remove() {
        document.querySelectorAll('[data-mb-upgrade-v4-modal]').forEach((modal) => modal.remove())
      }

      function mbUpgradeV4State(modal, type, message) {
        const state = modal ? modal.querySelector('[data-mb-upgrade-v4-state]') : null

        if (!state) return

        state.dataset.state = type || ''
        state.textContent = message || ''
      }

      function mbUpgradeV4Error(error) {
        if (error === 'not_enough_points') return 'ما عندك نقاط كافية للتطوير.'
        if (error === 'mailbox_not_owned') return 'لازم تفعل صندوق البريد أولًا.'
        if (error === 'mailbox_not_found') return 'صندوق البريد غير مفعّل.'
        if (error === 'max_capacity_reached') return 'وصلت للحد الأعلى.'
        if (error === 'target_capacity_changed') return 'مساحة البريد تغيرت. افتح نافذة التطوير من جديد.'
        if (error === 'upgrade_already_pending') return 'عندك طلب تطوير قيد التنفيذ.'
        if (error === 'Unauthorized') return 'لازم تسجل دخول أولًا.'
        return 'تعذر تنفيذ طلب التطوير.'
      }

