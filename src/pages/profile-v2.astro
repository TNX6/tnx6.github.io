        const isOk = job.status === 'success'
        const label = isOk ? 'نجح تصنيع' : job.status === 'failed' ? 'فشل تصنيع' : 'تعذر تصنيع'
        const when = wsTimeShort(job.completedAt || job.updatedAt || job.createdAt)

        return (
          '<div class="ws-tl-row ' + (isOk ? 'ok' : 'no') + '">' +
            '<span class="ws-tl-dot">' + wsIcon(isOk ? 'check' : 'x', 11) + '</span>' +
            '<div class="ws-tl-body">' +
