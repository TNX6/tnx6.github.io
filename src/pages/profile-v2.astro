       `

      // mailbox-v2-delegated-actions
      // استبدال innerHTML في renderMailboxProV2 كان يفقد listeners الأزرار،
      // لذلك الحذف/الهدايا/حذف الكل صارت delegation واحدة على مستوى document.
      if (!window.__mbV2ActionsDelegated) {
        window.__mbV2ActionsDelegated = true

        document.addEventListener('click', (event) => {
          const target = event.target
          if (!(target instanceof Element)) return

          const root = target.closest('.mail-pro[data-mailbox-v2="true"]')
          if (!root) return

          const retryButton = target.closest('[data-mail-retry]')
          if (retryButton) {
            event.preventDefault()
            mbV2ResetRenderCache(root)
            root.dataset.mbv2EmptyConfirmed = '0'
            renderMailboxProV2([])

            try {
              loadD1MailboxForProfile(state.activeUser, true)
            } catch {}

            return
          }

          const clearButton = target.closest('[data-mail-clear]')
          if (clearButton) {
            event.preventDefault()
            clearMailboxMessages(clearButton)
            return
          }

          const deleteButton = target.closest('[data-mail-delete]')
          const giftButton = target.closest('[data-mail-gift-action]')
          const actionButton = deleteButton || giftButton
          if (!actionButton) return

          event.preventDefault()

          const messageId = actionButton.getAttribute('data-message-id') || ''
          if (!messageId) return

          const list = (state.activeUser && Array.isArray(state.activeUser.mailbox)) ? state.activeUser.mailbox : []
          const message = list.find((entry) => mailboxMessageId(entry) === messageId) || { id: messageId }

          if (deleteButton) {
            deleteMailboxMessage(message, deleteButton)
            return
          }

          submitMailboxGiftAction(message, giftButton.getAttribute('data-mail-gift-action') || '', giftButton)
        })
      }


