      function tnxNormalizeUseInputName(value) {
        try {
          if (typeof compactInventoryName === 'function') {
            return compactInventoryName(value);
          }
        } catch {}

        return String(value || '')
          .trim()
          .toLowerCase()
          .replace(/\s+/g, ' ')
          .replace(/ـ/g, '')
          .replace(/[\u064B-\u065F\u0670]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ى/g, 'ي')
          .replace(/ة/g, 'ه');
      }

      function tnxGetUseInputRule(itemName) {
        const key = tnxNormalizeUseInputName(itemName);

        const rules = [
          {
            names: ['تغير العنوان مطور', 'تغيير العنوان مطور'],
            label: 'العنوان الجديد',
            placeholder: 'مثال: مرحبا بالجميع',
            maxLength: 120,
            required: true,
          },
        ];

        return rules.find((rule) => rule.names.some((name) => tnxNormalizeUseInputName(name) === key)) || null;
      }

