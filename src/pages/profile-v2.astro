      async function submitInventoryGiftFromProfile(modal, item) {
        const hint = modal.querySelector('[data-item-hint]')
        const recipientInput = hint?.querySelector('[data-gift-recipient]')
        const quantityInput = hint?.querySelector('[data-gift-quantity]')
        const messageInput = hint?.querySelector('[data-gift-message]')
        const statusBox = hint?.querySelector('[data-gift-status]')
        const submitButton = hint?.querySelector('[data-submit-inventory-gift]')

        const recipientLogin = String(recipientInput?.value || '').trim()
        const quantity = Math.max(1, Math.floor(Number(quantityInput?.value || 1)))
        const maxQty = Math.max(1, item.qty || 1)
        const message = String(messageInput?.value || '').trim()

        if (!recipientLogin) {
          if (statusBox) statusBox.textContent = 'اختر المستلم أولًا.'
          return
        }

        if (quantity > maxQty) {
          if (statusBox) statusBox.textContent = 'الكمية أكبر من الموجود في حقيبتك.'
          return
        }

        if (submitButton) {
          submitButton.disabled = true
          submitButton.setAttribute('aria-disabled', 'true')
        }

        if (statusBox) {
          statusBox.textContent = 'جاري إرسال طلب الإهداء...'
        }

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/gift', {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              recipientLogin,
              itemName: item.name,
              quantity,
              message,
            }),
          })

          const data = await res.json().catch(() => null)

          if (!res.ok || !data || data.ok !== true) {
            throw new Error((data && (data.error || data.message)) || 'gift_request_failed')
          }

          const requestId = String(data.requestId || data.id || '').trim()

          if (statusBox) {
            statusBox.textContent = 'تم إرسال الطلب للبوت. جاري التحقق من النتيجة...'
          }

          if (requestId) {
            await pollInventoryGiftStatus(requestId, statusBox)
          } else if (statusBox) {
            statusBox.textContent = 'تم إرسال طلب الإهداء.'
          }

          optimisticRemoveGiftedInventoryItem(item.name, quantity)

          window.setTimeout(() => {
            modal.remove()
            loadD1MailboxForProfile(state.activeUser, true)
          }, 600)
        } catch (error) {
          if (submitButton) {
            submitButton.disabled = false
            submitButton.removeAttribute('aria-disabled')
          }

          if (statusBox) {
            statusBox.textContent = 'تعذر إرسال الهدية: ' + (error?.message || 'خطأ غير معروف')
          }
        }
      }

      async function pollInventoryGiftStatus(requestId, statusBox) {
        for (let attempt = 0; attempt < 18; attempt++) {
          await new Promise((resolve) => window.setTimeout(resolve, 1500))

          const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/gift-status?id=' + encodeURIComponent(requestId), {
            credentials: 'include',
            cache: 'no-store',
          })

          const data = await res.json().catch(() => null)

          if (!res.ok || !data || data.ok !== true) {
            continue
          }

          const status = String(data.status || data.request?.status || '').toLowerCase()
          const errorMessage = String(data.errorMessage || data.request?.errorMessage || '').trim()

          if (status === 'completed') {
            if (statusBox) statusBox.textContent = 'تم إرسال الهدية إلى بريد المستلم.'
            return
          }

          if (status === 'rejected') {
            throw new Error(errorMessage || 'تم رفض الإهداء.')
          }

          if (statusBox) {
            statusBox.textContent = 'الطلب قيد المعالجة...'
          }
        }

        if (statusBox) {
          statusBox.textContent = 'تم إرسال الطلب، لكن المعالجة أخذت وقت أطول. افحص البريد بعد قليل.'
        }
      }

