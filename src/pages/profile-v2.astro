      }

      async function waitForProfileUseRequestCompletion(requestId, hint) {
        const id = String(requestId || '').trim();

        if (!id) {
          return true;
        }

        const startedAt = Date.now();
        const timeoutMs = 30000;
        const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

        while (Date.now() - startedAt < timeoutMs) {
          await delay(900);

          const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/use-status?id=' + encodeURIComponent(id), {
            method: 'GET',
            credentials: 'include',
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok || !data?.ok) {
            continue;
          }

          const status = String(data?.request?.status || '').toLowerCase();

          if (hint && status === 'processing') {
            hint.textContent = 'جاري تنفيذ استخدام الغرض...';
          }

          if (status === 'completed') {
            if (hint) hint.textContent = 'تم استخدام الغرض.';
            return true;
          }

          if (status === 'rejected') {
            const message = data?.request?.errorMessage || 'فشل استخدام الغرض.';
            throw new Error(message);
          }
        }

        throw new Error('تأخر تنفيذ استخدام الغرض. جرّب تحديث الصفحة.');
      }

      async function useInventoryItemFromProfileV1(item, button, hint) {
        const name = String(item?.name || '').trim();
        const qty = Math.max(1, Math.floor(Number(item?.qty || 1)));

        if (!name) {
          if (hint) hint.textContent = 'اسم الغرض غير معروف.';
          return;
        }

        const allowed = await isProfileOwnerV36(state.activeUser);
        if (!allowed) {
          await syncOwnerControlsV36(state.activeUser);
          if (hint) hint.textContent = 'ما تقدر تستخدم أغراض حساب غيرك.';
          return;
        }

        const oldText = button?.textContent || 'استخدام';

        try {
          if (button) {
            button.disabled = true;
            button.textContent = 'جاري الاستخدام...';
          }

          if (hint) {
            hint.textContent = 'جاري إرسال طلب الاستخدام إلى Streamer.bot...';
          }

          const tnxUseItemNameForApi = String((typeof apiItemName !== 'undefined' ? apiItemName : name) || '').trim();
          const tnxUseQtyForApi = Math.max(1, Math.floor(Number(typeof qty !== 'undefined' ? qty : 1)));

          const tnxUseInputText = await tnxResolveInventoryUseInputText(tnxUseItemNameForApi);

          if (tnxUseInputText === null) {
            if (hint) hint.textContent = 'تم إلغاء الاستخدام.';
            if (button) {
              button.disabled = false;
              button.textContent = 'استخدام';
            }
            return;
          }

          const tnxUsePayload = {
            itemName: tnxUseItemNameForApi,
            quantity: tnxUseQtyForApi,
          };

          if (tnxUseInputText) {
            tnxUsePayload.inputText = tnxUseInputText;
          }

          const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/use', {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(tnxUsePayload),
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok || data.ok === false) {
            const error = String(data.error || data.message || '');

            if (res.status === 401 || error === 'unauthorized') {
              throw new Error('لازم تسجل دخولك بتويتش قبل استخدام الغرض.');
            }

            if (res.status === 403 || error === 'forbidden') {
              throw new Error('ما تقدر تستخدم أغراض حساب غيرك.');
            }

            if (error === 'item_not_found' || error === 'not_enough_quantity') {
              throw new Error('الغرض غير موجود في حقيبتك أو الكمية غير كافية.');
            }

            if (error === 'use_unavailable_bridge_offline' || error === 'use_unavailable_streamerbot_offline') {
              throw new Error('خدمة الاستخدام معلّقة مؤقتًا. تأكد أن الجسر و Streamer.bot شغالين.');
            }

            throw new Error(error || `فشل الاستخدام: ${res.status}`);
          }

          if (button) {
            button.textContent = 'تم الإرسال';
          }

          if (hint) {
            hint.textContent = 'تم إرسال طلب الاستخدام. راقب البث أو الشات للتنفيذ.';
          }
          return await waitForProfileUseRequestCompletion(data?.requestId, hint);
        } catch (error) {
          console.error('[Inventory Use] Failed:', error);

          if (button) {
            button.disabled = false;
            button.textContent = oldText;
          }

          if (hint) {
            hint.textContent = error?.message || 'فشل استخدام الغرض.';
          }

          return false;
        }
      }
      function openItemDetailModalV3(item) {
        const name = String(item.name || 'غرض').trim();
        const meta = itemMetaForDetail(name);
        const qty = Math.max(1, Math.floor(Number(item.qty || 1)));
        const rarity = String(meta?.rarity || meta?.cat || item.rarity || 'Common').trim() || 'Common';
        const icon = String(item.icon || meta?.icon || '📦').trim() || '📦';
        const desc = itemDetailDescription(item, meta);
        const price = itemDetailSellPrice(meta);
        const saleDisabled = itemDetailIsSaleDisabled(meta) || price <= 0;
        const useDisabled = (() => {
          try {
            return typeof isUseDisabled === 'function' ? isUseDisabled(meta, item) : false;
          } catch {
            return false;
          }
        })();

        closeItemDetailModalV3();

        const modal = document.createElement('div');
        modal.className = 'item-detail-v3';
        modal.innerHTML = `
          <div class="item-detail-v3-box" role="dialog" aria-modal="true">
            <div class="item-detail-v3-head">
              <h3>${esc(name)}</h3>
              <button class="item-detail-v3-close" type="button" data-item-detail-close>×</button>
            </div>

            <div class="item-detail-v3-body">
              <div class="item-detail-v3-hero">
                <div class="item-detail-v3-icon">${esc(icon)}</div>
                <div class="item-detail-v3-title">
                  <strong>${esc(name)}</strong>
                  <div class="item-detail-v3-meta">
                    <span class="item-detail-v3-chip gold">x${formatNumber(qty)}</span>
                    <span class="item-detail-v3-chip ${itemDetailRarityClass(rarity)}">${esc(rarity)}</span>
                    <span class="item-detail-v3-chip">${saleDisabled ? 'غير قابل للبيع' : 'بيع: ' + formatNumber(price) + ' نقطة'}</span>
                  </div>
                </div>
              </div>

              <div class="item-detail-v3-section">
                <small>الوصف</small>
                <p>${esc(desc)}</p>
              </div>

              <div class="item-detail-v3-actions">
                <button class="item-detail-v3-action primary ${useDisabled ? 'is-disabled' : ''}" type="button" data-v3-action="use" ${useDisabled ? 'disabled aria-disabled="true"' : ''}>${useDisabled ? 'لا يمكن استخدامه' : 'استخدام'}</button>
                <button class="item-detail-v3-action" type="button" data-v3-action="gift">إهداء</button>
                <button class="item-detail-v3-action sell" type="button" data-v3-action="sell" ${saleDisabled ? 'disabled' : ''}>بيع</button>
                <button class="item-detail-v3-action" type="button" data-v3-action="market">عرض في السوق</button>
              </div>
<div class="item-detail-v3-hint" data-v3-hint>${esc(itemDetailHint('sell', item, meta))}</div>
            </div>
          </div>
        `;

        const close = () => modal.remove();

        modal.querySelectorAll('[data-item-detail-close]').forEach((button) => {
          addListener(button, 'click', close);
        });

        addListener(modal, 'click', (event) => {
          if (event.target === modal) close();
        });

        modal.querySelectorAll('[data-v3-action]').forEach((button) => {
          addListener(button, 'click', async () => {
            const action = button.dataset.v3Action;
            const hint = modal.querySelector('[data-v3-hint]');

            if (action === 'use') {
              if (useDisabled) {
                if (hint) hint.textContent = 'هذا الغرض غير قابل للاستخدام.';
                return;
              }

              const used = await useInventoryItemFromProfileV1(item, button, hint);

              if (used) {
                close();
              }
              return;
            }

            if (action === 'sell') {
              if (saleDisabled) {
                if (hint) hint.textContent = 'هذا الغرض غير قابل للبيع.';
                return;
              }

              close();

              try {
                openInventorySellModal(item, meta, window.__tnxInventoryFullList || []);
              } catch {
                openInventorySellModal(item, meta);
              }

              return;
            }

            if (action === 'market') {
              try {
                mkOpenListModal(item, modal);
              } catch (error) {
                console.warn('[Market] list modal failed', error);
                if (hint) hint.textContent = 'تعذر فتح مودال السوق، جرّب مرة أخرى.';
              }
              return;
            }

            if (hint) {
              hint.textContent = itemDetailHint(action, item, meta);
            }
          });
        });

        document.body.appendChild(modal);
      }

      function installItemDetailModalV3() {
        if (window.__tnxItemDetailModalV3Installed) {
          return;
        }

        window.__tnxItemDetailModalV3Installed = true;

        document.addEventListener('click', (event) => {
          const card = event.target.closest('#inventory .item');

          if (!card) {
            return;
          }

          if (event.target.closest('.inventory-sell-btn')) {
            return;
          }

          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();

          openItemDetailModalV3(readItemFromInventoryCard(card));
        }, true);

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeItemDetailModalV3();
          }
        });
      }

      installItemDetailModalV3();

      /* Aggressive legacy item modal remover */
      function removeLegacyItemDetailModalAggressive() {
        const nodes = Array.from(document.body.querySelectorAll("div,[role='dialog']"));

        for (const node of nodes) {
          if (node.classList && node.classList.contains("item-detail-v3")) continue;
          if (node.closest && node.closest(".item-detail-v3")) continue;

          const text = String(node.textContent || "");

          const isLegacyItemModal =
            text.includes("استخدام") &&
            text.includes("إهداء") &&
            text.includes("عرض في السوق") &&
            text.includes("Streamer.bot");

          if (!isLegacyItemModal) continue;

          let root = node;

          for (let cur = node; cur && cur !== document.body; cur = cur.parentElement) {
            const style = window.getComputedStyle(cur);

            if (style.position === "fixed" || cur.getAttribute("role") === "dialog") {
              root = cur;
            }
          }

          root.remove();
        }
      }

      document.addEventListener("click", () => {
        setTimeout(removeLegacyItemDetailModalAggressive, 0);
        setTimeout(removeLegacyItemDetailModalAggressive, 250);
      }, true);

      // مراقبة خفيفة: نشغّل التنظيف فقط عند إضافة عقدة تحمل بصمة المودال القديم ("Streamer.bot")،
      // بدل مسح كل عناصر الصفحة مع كل تغيير أو كل 500ms — ذلك كان يثقل الـ main thread
      // ويسبب عدم سلاسة التمرير (نزول/صعود).
      new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            if (node && node.nodeType === 1 && String(node.textContent || "").indexOf("Streamer.bot") >= 0) {
              removeLegacyItemDetailModalAggressive();
              return;
            }
          }
        }
      }).observe(document.body, {
        childList: true,
        subtree: true
      });

      removeLegacyItemDetailModalAggressive();


      /* Remove item detail after sell modal closes */
      function removeItemDetailModalsAfterSell() {
        document.querySelectorAll('.item-detail-v3').forEach((node) => node.remove());

        const nodes = Array.from(document.body.querySelectorAll('div,[role="dialog"]'));

        for (const node of nodes) {
          const text = String(node.textContent || '');

          const looksLikeItemDetails =
            text.includes('استخدام') &&
            text.includes('إهداء') &&
            text.includes('عرض في السوق');

          if (!looksLikeItemDetails) continue;

          let root = node;

          for (let cur = node; cur && cur !== document.body; cur = cur.parentElement) {
            const style = window.getComputedStyle(cur);

            if (style.position === 'fixed' || cur.getAttribute('role') === 'dialog') {
              root = cur;
            }
          }

          root.remove();
        }
      }

      function modalRootFromNode(node) {
        let root = node;

        for (let cur = node; cur && cur !== document.body; cur = cur.parentElement) {
          const style = window.getComputedStyle(cur);

          if (style.position === 'fixed' || cur.getAttribute('role') === 'dialog') {
            root = cur;
          }
        }

        return root;
      }

      function findSellModalRoot() {
        const nodes = Array.from(document.body.querySelectorAll('div,[role="dialog"]'));

        for (const node of nodes) {
          const text = String(node.textContent || '');

          if (!text.includes('بيع')) continue;
          if (text.includes('استخدام') && text.includes('إهداء')) continue;

          const root = modalRootFromNode(node);
          const style = window.getComputedStyle(root);

          if (style.position === 'fixed' || root.getAttribute('role') === 'dialog') {
            return root;
          }
        }

        return null;
      }

      function watchSellModalCloseAndCleanDetails() {
        let sellRoot = null;
        const startedAt = Date.now();
        let missCount = 0;

        setTimeout(removeItemDetailModalsAfterSell, 0);
        setTimeout(removeItemDetailModalsAfterSell, 120);

        const timer = setInterval(() => {
          if (!sellRoot || !document.body.contains(sellRoot)) {
            sellRoot = findSellModalRoot();
          }

          removeItemDetailModalsAfterSell();

          if (sellRoot && !document.body.contains(sellRoot)) {
            setTimeout(removeItemDetailModalsAfterSell, 0);
            setTimeout(removeItemDetailModalsAfterSell, 120);
            clearInterval(timer);
            return;
          }

          // إيقاف مبكر: إن لم يُعثر على مودال البيع خلال ثوانٍ قليلة، أوقف الفحص.
          // (سابقًا كان يفحص كل عناصر الصفحة كل 150ms حتى 10 دقائق — سبب رئيسي لثقل التمرير.)
          if (!sellRoot) {
            missCount += 1;
            if (missCount >= 12) {
              clearInterval(timer);
              return;
            }
          } else {
            missCount = 0;
          }

          if (Date.now() - startedAt > 20000) {
            clearInterval(timer);
          }
        }, 400);
      }

      document.addEventListener('click', (event) => {
        const sellButton = event.target.closest('.item-detail-v3 [data-v3-action="sell"]');

        if (!sellButton) return;

        watchSellModalCloseAndCleanDetails();
      }, true);


      /* Kill legacy item modal */
      function killLegacyItemModal() {
        const nodes = Array.from(document.body.querySelectorAll("div"));

        for (const node of nodes) {
          const text = String(node.textContent || "");

          if (!text.includes("Streamer.bot")) continue;
          if (!text.includes("المتعلقة بالنظام") && !text.includes("مخزونك")) continue;

          let root = node;

          for (let cur = node; cur && cur !== document.body; cur = cur.parentElement) {
            const style = window.getComputedStyle(cur);

            if (style.position === "fixed" || cur.getAttribute("role") === "dialog") {
              root = cur;
            }
          }

          root.remove();
        }
      }

      document.addEventListener("click", () => {
        setTimeout(killLegacyItemModal, 0);
        setTimeout(killLegacyItemModal, 250);
      }, true);

      // خفيفة: تُشغّل فقط عند إضافة عقدة تحمل بصمة المودال القديم، بدل مسح كل الـ divs مع كل تغيير.
      new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            if (node && node.nodeType === 1 && String(node.textContent || "").indexOf("Streamer.bot") >= 0) {
              killLegacyItemModal();
              return;
            }
          }
        }
      }).observe(document.body, {
        childList: true,
        subtree: true
      });

      killLegacyItemModal();




      function renderBadges(badges) {
        const box = $('badges')
        if (!box) return

        if (!badges.length) {
          box.innerHTML = `<div class="empty">ما فيه بادجات ظاهرة.</div>`
          return
        }

        box.innerHTML = badges.slice(0, 15).map((badge) => {
          const name = badgeName(badge)
          const image = badgeImage(badge)

          const rarity = badgeRarity(badge)
          const xp = badgeXp(badge)

          return `
            <div class="badge" title="${esc(name)} - ${esc(rarity)} - ${formatNumber(xp)} XP">
              ${image ? `<img src="${esc(image)}" alt="${esc(name)}" loading="lazy" />` : `<div class="badge-icon">🏅</div>`}
              <div class="badge-name">${esc(name)}</div>
            </div>
          `
        }).join('')
      }


      /* Clean badge picker v29: single source, new localStorage key, no legacy picker */
      const BP29_LIMIT = 3
      const BP29_STORAGE_PREFIX = 'tnx_profile_featured_badges_clean_v29:'

      function bp29Scope(user = state.activeUser) {
        const id = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const login = normalize(userLogin(user) || userName(user) || '')
        return id || login || 'unknown'
      }

      function bp29Key(badge) {
        const explicit = String(get(badge, ['id', 'badgeId', 'key', 'code'], '')).trim()
        const name = badgeName(badge)
        const image = badgeImage(badge)
        return explicit || `${normalize(name)}::${image}`
      }

      function bp29ShortName(name) {
        const clean = String(name || '').trim()
        if (!clean) return 'BADGE'
        return clean.length > 18 ? clean.slice(0, 18) + '…' : clean
      }

      function bp29IsRole(badge) {
        const n = normalize(badgeName(badge))
        return (
          n === 'mod' ||
          n.includes('moderator') ||
          n.includes('مشرف') ||
          n === 'vip' ||
          n.includes('vip+') ||
          n.includes('في اي بي') ||
          n.includes('في آي بي')
        )
      }

      function bp29Tier(badge) {
        if (bp29IsRole(badge)) return 'role'

        const raw = String(badgeName(badge) || '')
        const n = normalize(raw)

        if (/\d+\s*k\b/i.test(raw) || /\d+\s*m\b/i.test(raw) || n.includes('النقاط') || n.includes('صيد')) return 'k'
        return 'q'
      }

      function bp29Category(badge) {
        if (bp29IsRole(badge)) return 'ثابت'
        return bp29Tier(badge) === 'k' ? 'النقاط' : 'الأسئلة'
      }

      function bp29Fallback(badge) {
        if (bp29IsRole(badge)) return '★'
        return bp29Tier(badge) === 'k' ? 'K' : 'Q'
      }

      function bp29Badges(user = state.activeUser) {
        return Array.isArray(user?.badges) ? user.badges : []
      }

      function bp29Read(user = state.activeUser) {
        try {
          const raw = localStorage.getItem(BP29_STORAGE_PREFIX + bp29Scope(user))
          const parsed = JSON.parse(raw || '[]')
          return Array.isArray(parsed) ? parsed.map((x) => String(x)).filter(Boolean).slice(0, BP29_LIMIT) : []
        } catch {
          return []
        }
      }

      function bp29Write(user = state.activeUser, keys = []) {
        try {
          const clean = [...new Set((Array.isArray(keys) ? keys : []).map((x) => String(x)).filter(Boolean))]
            .slice(0, BP29_LIMIT)
          localStorage.setItem(BP29_STORAGE_PREFIX + bp29Scope(user), JSON.stringify(clean))
          return clean
        } catch {
          return []
        }
      }

      function bp29SelectedBadges(user = state.activeUser) {
        const badges = bp29Badges(user)
        const map = new Map(badges.map((badge) => [bp29Key(badge), badge]))
        const valid = bp29Read(user)
          .filter((key) => map.has(key) && !bp29IsRole(map.get(key)))
          .slice(0, BP29_LIMIT)
        return valid.map((key) => map.get(key)).filter(Boolean)
      }

      function bp29CleanupOldUi() {
        document
          .querySelectorAll('.featured-badge-modal-test, .featured-badge-toast, .tnxbp-shell, .tnxbp-toast, .bp29-shell, .bp29-toast')
          .forEach((el) => el.remove())
      }

      function bp29MiniHtml(badge) {
        const name = badgeName(badge)
        const image = badgeImage(badge)
        return `
          <span class="bp29-mini" title="${esc(name)}">
            ${image ? `<img src="${esc(image)}" alt="${esc(name)}" loading="lazy" />` : `<span>${esc(bp29Fallback(badge))}</span>`}
          </span>
        `
      }

      function renderFeaturedBadgesCleanV29(user = state.activeUser) {
        const box = $('featuredBadges')
        if (!box || !user) return

        bp29CleanupOldUi()

        const badges = bp29Badges(user)
        const roles = badges.filter(bp29IsRole)
        const selected = bp29SelectedBadges(user)

        if (!badges.length) {
          box.classList.add('hidden')
          box.innerHTML = ''
          return
        }

        box.classList.remove('hidden')
        box.innerHTML = [
          ...roles.map(bp29MiniHtml),
          ...selected.map(bp29MiniHtml),
        ].join('')

        isProfileOwnerV36(user).then((allowed) => {
          if (!box || state.activeUser !== user) return
          if (!allowed) return

          box.querySelectorAll('.bp29-plus, .profile-featured-badge-add, #featuredBadgePlusTest, .featured-badge-plus-test, [data-featured-badge-add-v22], [data-tnxbp-add-v24]').forEach((el) => el.remove())

          const add = document.createElement('button')
          add.type = 'button'
          add.className = 'bp29-plus'
          add.setAttribute('aria-label', 'اختيار البادجات')
          add.innerHTML = '<span>+</span>'
          add.addEventListener('click', async (event) => {
            event.preventDefault()
            event.stopPropagation()
            await openBadgePickerCleanV29(state.activeUser || user)
          })

          box.appendChild(add)
        }).catch(() => {})
      }

      function bp29Toast(message) {
        let toast = document.querySelector('.bp29-toast')
        if (!toast) {
          toast = document.createElement('div')
          toast.className = 'bp29-toast'
          document.body.appendChild(toast)
        }

        toast.textContent = message
        toast.classList.add('show')

        window.clearTimeout(window.__bp29ToastTimer)
        window.__bp29ToastTimer = window.setTimeout(() => {
          toast?.classList.remove('show')
        }, 1700)
      }

      async function openBadgePickerCleanV29(user = state.activeUser) {
        if (!user) return

        const allowed = await isProfileOwnerV36(user)
        if (!allowed) {
          await syncOwnerControlsV36(user)
          return
        }

        bp29CleanupOldUi()

        const badges = bp29Badges(user)
        const selectable = badges.filter((badge) => !bp29IsRole(badge))
        const roles = badges.filter(bp29IsRole)
        const all = [...roles, ...selectable]

        let filter = 'all'
        let query = ''
        let selected = bp29Read(user)
          .filter((key) => selectable.some((badge) => bp29Key(badge) === key))
          .slice(0, BP29_LIMIT)
        let saved = [...selected]

        const shell = document.createElement('div')
        shell.className = 'bp29-shell'
        shell.setAttribute('role', 'dialog')
        shell.setAttribute('aria-label', 'اختيار البادجات')

        shell.innerHTML = `
          <button class="bp29-backdrop" type="button" aria-label="إغلاق"></button>
          <div class="bp29-modal">
            <div class="bp29-head">
              <div class="bp29-head-top">
                <div>
                  <div class="bp29-title">اختيار البادجات</div>
                  <div class="bp29-subtitle">اختر حتى <b>3 بادجات</b> من مخزونك — بادجات <b>MOD / VIP</b> لا تُحسب من الحد.</div>
                </div>
                <button class="bp29-close" type="button" aria-label="إغلاق">×</button>
              </div>
              <div class="bp29-counter">
                <div class="bp29-pips" data-bp29-pips></div>
                <div class="bp29-count"><b data-bp29-count>0</b> / ${BP29_LIMIT}</div>
              </div>
            </div>

            <div class="bp29-tools">
              <label class="bp29-search">
                <span>⌕</span>
                <input data-bp29-search placeholder="ابحث عن بادج…" autocomplete="off" />
              </label>

              <div class="bp29-seg" data-bp29-seg>
                <button class="act" type="button" data-bp29-filter="all">الكل</button>
                <button type="button" data-bp29-filter="q">الأسئلة</button>
                <button type="button" data-bp29-filter="k">النقاط</button>
              </div>
            </div>

            <div class="bp29-tray" data-bp29-tray>
              <span class="bp29-tray-label">المختارة الآن</span>
              <div class="bp29-chips" data-bp29-chips></div>
              <button class="bp29-clear" type="button" data-bp29-clear>مسح الاختيار</button>
            </div>

            <div class="bp29-scroller">
              <div class="bp29-grid" data-bp29-grid></div>
            </div>

            <div class="bp29-foot">
              <button class="bp29-save" type="button" data-bp29-save disabled>احفظ الاختيار</button>
              <button class="bp29-cancel" type="button" data-bp29-cancel>إلغاء</button>
            </div>
          </div>
        `

        document.body.appendChild(shell)
        document.body.style.overflow = 'hidden'

        const close = () => {
          shell.remove()
          document.body.style.overflow = ''
        }

        const changed = () => JSON.stringify([...selected].sort()) !== JSON.stringify([...saved].sort())
        const byKey = (key) => selectable.find((badge) => bp29Key(badge) === key) || null

        const updateSelectionState = (changedKey = null, previousCount = selected.length) => {
          const selectedSet = new Set(selected)
          const full = selected.length >= BP29_LIMIT
          const mustRefreshLocks = changedKey === null || previousCount >= BP29_LIMIT || selected.length >= BP29_LIMIT

          if (mustRefreshLocks) {
            shell.querySelectorAll('[data-bp29-key]').forEach((card) => {
              const key = card.dataset.bp29Key || ''
              const role = card.dataset.bp29Role === '1'
              const isSelected = role || selectedSet.has(key)
              const locked = !role && full && !isSelected

              card.classList.toggle('sel', isSelected)
              card.classList.toggle('lock', locked)
              card.setAttribute('aria-pressed', isSelected ? 'true' : 'false')
            })
          } else if (changedKey) {
            shell.querySelectorAll('[data-bp29-key]').forEach((card) => {
              if ((card.dataset.bp29Key || '') !== changedKey) return

              const role = card.dataset.bp29Role === '1'
              const isSelected = role || selectedSet.has(changedKey)

              card.classList.toggle('sel', isSelected)
              card.classList.remove('lock')
              card.setAttribute('aria-pressed', isSelected ? 'true' : 'false')
            })
          }

          const pips = shell.querySelector('[data-bp29-pips]')
          if (pips) {
            if (!pips.children.length) {
              pips.innerHTML = Array.from({ length: BP29_LIMIT }, () => `<span class="bp29-pip"></span>`).join('')
            }

            Array.from(pips.children).forEach((pip, index) => {
              pip.classList.toggle('on', index < selected.length)
            })
          }

          const count = shell.querySelector('[data-bp29-count]')
          if (count) count.textContent = String(selected.length)

          const tray = shell.querySelector('[data-bp29-tray]')
          if (tray) tray.classList.toggle('show', selected.length > 0)

          const chips = shell.querySelector('[data-bp29-chips]')
          if (chips) {
            chips.innerHTML = selected.map((key) => {
              const badge = byKey(key)
              if (!badge) return ''

              const image = badgeImage(badge)
              const name = badgeName(badge)

              return `
                <button class="bp29-chip" type="button" data-bp29-remove="${esc(key)}" title="إزالة ${esc(name)}">
                  <span class="dot">${image ? `<img src="${esc(image)}" alt="" />` : esc(bp29Fallback(badge))}</span>
                  <code>${esc(bp29ShortName(name))}</code>
                  <span class="x">×</span>
                </button>
              `
            }).join('')
          }

          const clear = shell.querySelector('[data-bp29-clear]')
          if (clear) clear.disabled = selected.length === 0

          const save = shell.querySelector('[data-bp29-save]')
          if (save) {
            save.disabled = !changed()
            save.textContent = !changed()
              ? (selected.length ? 'لا توجد تغييرات' : 'احفظ الاختيار')
              : `احفظ الاختيار (${selected.length})`
          }
        }


        const render = () => {
          const normalizedQuery = normalize(query)
          const full = selected.length >= BP29_LIMIT

          const list = all.filter((badge) => {
            const tier = bp29Tier(badge)
            const matchesFilter = filter === 'all' || tier === filter
            const matchesSearch = !normalizedQuery || normalize(badgeName(badge)).includes(normalizedQuery) || normalize(bp29Category(badge)).includes(normalizedQuery)
            return matchesFilter && matchesSearch
          })

          const grid = shell.querySelector('[data-bp29-grid]')
          if (grid) {
            grid.innerHTML = list.length
              ? list.map((badge) => {
                  const key = bp29Key(badge)
                  const role = bp29IsRole(badge)
                  const isSelected = role || selected.includes(key)
                  const locked = !role && full && !isSelected
                  const image = badgeImage(badge)
                  const name = badgeName(badge)
                  const tier = bp29Tier(badge)

                  return `
                    <button
                      type="button"
                      class="bp29-card tier-${tier} ${isSelected ? 'sel' : ''} ${locked ? 'lock' : ''}"
                      data-bp29-key="${esc(key)}"
                      data-bp29-role="${role ? '1' : '0'}"
                      aria-pressed="${isSelected ? 'true' : 'false'}"
                      title="${esc(name)}"
                    >
                      <span class="bp29-info">i</span>
                      <span class="bp29-tick">✓</span>
                      <span class="bp29-medal">
                        <span class="bp29-ring"></span>
                        <span class="bp29-core">${image ? `<img src="${esc(image)}" alt="${esc(name)}" loading="lazy" />` : esc(bp29Fallback(badge))}</span>
                      </span>
                      <span class="bp29-name">${esc(bp29ShortName(name))}</span>
                      <span class="bp29-cat">${esc(role ? 'ثابت ولا يُحسب' : bp29Category(badge))}</span>
                      <span class="bp29-hint">وصلت للحد ٣</span>
                    </button>
                  `
                }).join('')
              : `<div class="bp29-empty">ما فيه بادج بهذا الاسم — جرّب كلمة ثانية.</div>`
          }

          updateSelectionState(null)
        }

        shell.addEventListener('click', (event) => {
          const target = event.target

          if (target.closest('.bp29-backdrop') || target.closest('.bp29-close') || target.closest('[data-bp29-cancel]')) {
            close()
            return
          }

          const filterButton = target.closest('[data-bp29-filter]')
          if (filterButton) {
            filter = filterButton.dataset.bp29Filter || 'all'
            shell.querySelectorAll('[data-bp29-filter]').forEach((button) => {
              button.classList.toggle('act', button === filterButton)
            })
            render()
            return
          }

          if (target.closest('[data-bp29-clear]')) {
            const previousCount = selected.length
            selected = []
            updateSelectionState(null, previousCount)
            return
          }

          const remove = target.closest('[data-bp29-remove]')
          if (remove) {
            const keyToRemove = remove.dataset.bp29Remove
            const previousCount = selected.length
            selected = selected.filter((key) => key !== keyToRemove)
            updateSelectionState(keyToRemove, previousCount)
            return
          }

          const save = target.closest('[data-bp29-save]')
          if (save && !save.disabled) {
            saved = bp29Write(user, selected)
            selected = [...saved]
            renderFeaturedBadgesCleanV29(user)
            close()
            bp29Toast(`تم حفظ ${selected.length} بادجات ✓`)
            return
          }

          const option = target.closest('[data-bp29-key]')
          if (!option) return

          if (option.dataset.bp29Role === '1') {
            bp29Toast('هذا بادج ثابت ولا يُحسب من الحد')
            return
          }

          const key = option.dataset.bp29Key || ''

          if (selected.includes(key)) {
            const previousCount = selected.length
            selected = selected.filter((item) => item !== key)
            updateSelectionState(key, previousCount)
            return
          }

          if (selected.length >= BP29_LIMIT) {
            bp29Toast('وصلت للحد ٣')
            return
          }

          const previousCount = selected.length
          selected = [...selected, key]
          updateSelectionState(key, previousCount)
        })

        let searchTimer = 0
        shell.querySelector('[data-bp29-search]')?.addEventListener('input', (event) => {
          query = event.target.value || ''
          window.clearTimeout(searchTimer)
          searchTimer = window.setTimeout(render, 80)
        })

        shell.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') close()
        })

        render()
        shell.querySelector('[data-bp29-search]')?.focus({ preventScroll: true })
      }

      function mailItems(user) {
        const mail = Array.isArray(user.mailbox) ? [...user.mailbox] : []
        return mail.sort((a, b) => new Date(get(b, ['date', 'createdAt'], 0)) - new Date(get(a, ['date', 'createdAt'], 0)))
      }

      
      function mailboxMessageId(message) {
        return String(get(message, ['id', 'messageId', 'message_id'], '')).trim()
      }

      function mailboxGiftStatus(message) {
        return String(get(message, ['giftStatus', 'gift_status'], '') || '').trim().toLowerCase()
      }

      function mailboxMessageType(message) {
        return String(get(message, ['type', 'messageType', 'message_type'], '') || '').trim().toLowerCase()
      }

      function mailboxItemName(message) {
        return String(get(message, ['itemName', 'item_name'], '') || '').trim()
      }

      function mailboxItemAmount(message) {
        return Math.max(1, num(get(message, ['itemAmount', 'item_amount', 'quantity'], 1)))
      }

      function normalizeD1MailboxMessages(payload) {
        const rows = Array.isArray(payload?.messages) ? payload.messages : []

        return rows.map((row) => {
          const id = mailboxMessageId(row)
          const fromDisplayName = get(row, ['fromDisplayName', 'from_display_name', 'from', 'fromName'], '')
          const fromLogin = get(row, ['fromLogin', 'from_user_login', 'fromUserLogin'], '')
          const type = mailboxMessageType(row)
          const giftStatus = mailboxGiftStatus(row)
          const itemName = mailboxItemName(row)
          const itemAmount = mailboxItemAmount(row)

          return {
            ...row,
            id,
            messageId: id,
            from: fromDisplayName || fromLogin || 'النظام',
            fromDisplayName: fromDisplayName || fromLogin || 'النظام',
            fromLogin,
            text: get(row, ['message', 'text'], ''),
            message: get(row, ['message', 'text'], ''),
            type,
            giftStatus,
            gift_status: giftStatus,
            itemName,
            item_name: itemName,
            itemAmount,
            item_amount: itemAmount,
            createdAt: get(row, ['createdAt', 'created_at', 'date'], ''),
            date: get(row, ['createdAt', 'created_at', 'date'], ''),
          }
        }).sort((a, b) => new Date(get(b, ['createdAt', 'date'], 0)) - new Date(get(a, ['createdAt', 'date'], 0)))
      }

      function sameProfileUser(profileUser, apiUser) {
        const profileId = String(get(profileUser, ['userId', 'id', 'twitchId', 'twitch_id'], '') || '').trim()
        const apiId = String(get(apiUser, ['userId', 'id', 'twitchId', 'twitch_id'], '') || '').trim()

        if (profileId && apiId && profileId === apiId) {
          return true
        }

        const profileLogin = String(userLogin(profileUser) || '').trim().toLowerCase()
        const apiLogin = String(get(apiUser, ['userLogin', 'login', 'user_login'], '') || '').trim().toLowerCase()

        return Boolean(profileLogin && apiLogin && profileLogin === apiLogin)
      }


      function prewarmMailboxForProfile(user) {
        if (!user || window.__tnxMailboxPrewarmed) return

        window.__tnxMailboxPrewarmed = true

        const run = () => {
          try {
            if (typeof loadD1MailboxForProfile === 'function') {
              loadD1MailboxForProfile(user, true)
            }
          } catch (error) {
            console.warn('[mail prewarm]', error)
          }
        }

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(run, { timeout: 1800 })
        } else {
          window.setTimeout(run, 700)
        }
      }

      async function tnxFetchJsonWithTimeout(url, options = {}, timeoutMs = 15000) {
        const controller = typeof AbortController !== 'undefined' ? new AbortController() : null
        const timeout = Math.max(1000, Number(timeoutMs || 15000))
        let timer = null

        try {
          const fetchOptions = { ...options }

          if (controller) {
            fetchOptions.signal = controller.signal
            timer = window.setTimeout(() => {
              try { controller.abort() } catch {}
            }, timeout)
          }

          const response = await fetch(url, fetchOptions)
          const data = await response.json().catch(() => null)

          return { response, data }
        } catch (error) {
          if (error?.name === 'AbortError') {
            const timeoutError = new Error('request_timeout')
            timeoutError.code = 'request_timeout'
            throw timeoutError
          }

          throw error
        } finally {
          if (timer) window.clearTimeout(timer)
        }
      }

      async function loadD1MailboxForProfile(user, force = false) {
        if (!user) return

        if (state.d1MailboxLoading && !force) {
          return
        }

        state.d1MailboxLoading = true

        try {
          const result = await tnxFetchJsonWithTimeout(TNX_API_ORIGIN + '/api/me/mailbox?limit=50&v=' + Date.now(), {
            credentials: 'include',
            cache: 'no-store',
            headers: {
              Accept: 'application/json',
            },
          }, 15000)
          const res = result.response
          const data = result.data

          if (!res.ok || !data || data.ok !== true) {
            throw new Error((data && (data.error || data.message)) || 'mailbox_load_failed')
          }

          // identity guard: تحقّق فقط إذا الـ API فعليًا رجّع user
          if (data.user && !sameProfileUser(user, data.user)) {
            return
          }

          const messages = normalizeD1MailboxMessages(data)

          user.mailbox = messages

          if (state.activeUser && sameProfileUser(state.activeUser, user)) {
            state.activeUser.mailbox = messages
          }

          setText('mailCount', messages.length)
          setText('messages', formatNumber(messages.length))
          syncMailboxUpgradeUsedFromMessages(messages)

          try {
            const root = document.querySelector('.mail-pro')

            if (root) {
              root.dataset.mbv2DirectFetching = '0'
              root.dataset.mbv2EmptyConfirmed = messages.length ? '0' : '1'
            }
          } catch {}

          // اهتزاز زر البريد عند وصول رسالة جديدة
          try { tnxNotifyNewMail(messages) } catch {}

          renderMail(messages)
        } catch (error) {
          console.warn('[Mailbox] Failed to load current user mailbox:', error)

          try {
            const root = document.querySelector('.mail-pro')

            if (
              root &&
              typeof mbV2RenderMailboxError === 'function' &&
              (root.dataset.mbv2RenderState === 'loading' || root.dataset.mbv2DirectFetching === '1')
            ) {
              mbV2RenderMailboxError(root, mbV2MailboxLoadErrorText(error))
            }
          } catch {}
        } finally {
          state.d1MailboxLoading = false
        }
      }

      function mailboxGiftStatusLabel(status) {
        if (status === 'pending') return 'معلقة'
        if (status === 'accepted') return 'مقبولة'
        if (status === 'rejected') return 'مرفوضة'
        return status || ''
      }

      // ينتظر تغيّر حالة الهدية فعليًا في D1 بعد ما ينفذها الـ Bridge
      async function mbV2WaitGiftResult(messageId, timeoutMs = 24000) {
        const startedAt = Date.now()

        while (Date.now() - startedAt < timeoutMs) {
          await new Promise((resolve) => setTimeout(resolve, 2500))

          try {
            const res = await fetch(TNX_API_ORIGIN + '/api/me/mailbox?limit=50&v=' + Date.now(), {
              credentials: 'include',
              cache: 'no-store',
            })

            const data = await res.json().catch(() => null)

            if (!res.ok || !data || data.ok !== true) continue

            const messages = normalizeD1MailboxMessages(data)
            const found = messages.find((entry) => mailboxMessageId(entry) === messageId)

            if (!found) {
              return { done: true, messages, status: '' }
            }

            const status = mailboxGiftStatus(found)

            if (status && status !== 'pending') {
              return { done: true, messages, status }
            }
          } catch {}
        }

        return { done: false }
      }

      async function submitMailboxGiftAction(message, action, button) {
        const messageId = mailboxMessageId(message)

        if (!messageId || !action) {
          return
        }

        const isAccept = action === 'accept'
        const card = button?.closest?.('[data-mail-card]') || button?.closest?.('.mail-message') || null
        const actionsBox = card?.querySelector?.('.mbv2-card-actions') || null

        card?.classList?.add('mbv2-busy')

        card?.querySelectorAll?.('[data-mail-gift-action]').forEach((btn) => {
          btn.disabled = true
          btn.setAttribute('aria-disabled', 'true')
        })

        const setInline = (kind, text) => {
          if (!actionsBox) return

          actionsBox.innerHTML =
            '<span class="mbv2-inline-state is-' + kind + '">' +
              (kind === 'loading' ? '<span class="mbv2-spin"></span>' : '') +
              mbV2Escape(text) +
            '</span>'
        }

        const restoreButtons = (errorText) => {
          card?.classList?.remove('mbv2-busy')

          if (!actionsBox) return

          actionsBox.innerHTML =
            '<button class="mbv2-accept" type="button" data-mail-gift-accept data-mail-gift-action="accept" data-message-id="' + mbV2Escape(messageId) + '">' + mbV2IconSvg('check', 14) + 'قبول الهدية</button>' +
            '<button class="mbv2-reject" type="button" data-mail-gift-reject data-mail-gift-action="reject" data-message-id="' + mbV2Escape(messageId) + '">رفض</button>' +
            (errorText ? '<span class="mbv2-inline-state is-error">' + mbV2Escape(errorText) + '</span>' : '')
        }

        setInline('loading', isAccept ? 'جاري قبول الهدية...' : 'جاري رفض الهدية...')

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/me/mailbox/gift-action', {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              messageId,
              action,
            }),
          })

          const data = await res.json().catch(() => null)

          if (!res.ok || !data || data.ok !== true) {
            throw new Error((data && (data.error || data.message)) || 'gift_action_failed')
          }

          setInline('loading', isAccept ? 'تم الإرسال، جاري تنفيذ القبول...' : 'تم الإرسال، جاري تنفيذ الرفض...')

          const result = await mbV2WaitGiftResult(messageId)

          card?.classList?.remove('mbv2-busy')

          if (result.done) {
            // flash أخضر عند القبول / أحمر عند الرفض بعد إعادة الرندر
            window.__mbV2FlashId = messageId
            window.__mbV2FlashKind = result.status === 'rejected' ? 'no' : 'ok'

            if (state.activeUser) {
              state.activeUser.mailbox = result.messages
            }

            renderMail(result.messages)
          } else {
            setInline('loading', 'التنفيذ متأخر شوي... بيتحدث تلقائيًا')
            window.setTimeout(() => loadD1MailboxForProfile(state.activeUser, true), 6000)
          }
        } catch (error) {
          restoreButtons('تعذر تنفيذ العملية، جرّب مرة ثانية')
        }
      }

      async function deleteMailboxMessage(message, button) {
        const messageId = mailboxMessageId(message)
        const row = button?.closest?.('[data-mail-card]') || button?.closest?.('.mail-message')
        const statusBox = row?.querySelector?.('[data-mail-inline-status]') || row?.querySelector?.('[data-mail-gift-status]')

        if (mailboxMessageType(message) === 'gift_item' && mailboxGiftStatus(message) === 'pending') {
          if (statusBox) statusBox.textContent = 'اقبل أو ارفض الهدية أولًا قبل حذفها.'
          return
        }

        if (button) {
          button.disabled = true
          button.setAttribute('aria-disabled', 'true')
        }

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/me/mailbox/delete', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messageId }),
          })

          const data = await res.json().catch(() => null)

          if (!res.ok || !data || data.ok !== true) {
            throw new Error((data && data.error) || 'delete_failed')
          }

          // انميشن اختفاء قبل الحذف من القائمة
          try {
            row?.classList?.add('mbv2-removing')
            await new Promise((resolve) => setTimeout(resolve, 240))
          } catch {}

          row?.remove?.()
          const root = row?.closest?.('.mail-pro[data-mailbox-v2="true"]') || null
          const currentMessages = (state.activeUser && Array.isArray(state.activeUser.mailbox)) ? state.activeUser.mailbox : []
          const optimisticMessages = currentMessages.filter((entry) => mailboxMessageId(entry) !== messageId)

          if (state.activeUser && optimisticMessages.length !== currentMessages.length) {
            state.activeUser.mailbox = optimisticMessages
            setText('mailCount', optimisticMessages.length)
            setText('messages', formatNumber(optimisticMessages.length))
            syncMailboxUpgradeUsedFromMessages(optimisticMessages)
          }

          mbV2ResetRenderCache(root)
          await loadD1MailboxForProfile(state.activeUser, true)
        } catch (error) {
          if (button) {
            button.disabled = false
            button.removeAttribute('aria-disabled')
          }

          if (statusBox) {
            statusBox.textContent = 'تعذر حذف الرسالة: ' + (error?.message || 'خطأ غير معروف')
          }
        }
      }

