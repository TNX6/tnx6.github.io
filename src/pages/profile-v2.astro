            : Array.isArray(items)
              ? items
              : [];

          const currentSellable = getSellAllEligibleInventoryItems(sourceItems);

          if (!currentSellable.length) {
            button.disabled = true;
            meta.textContent = 'ما فيه أغراض قابلة للبيع';
            return;
          }

          const currentTotal = currentSellable.reduce((sum, row) => sum + row.total, 0);

          const confirmed = window.confirm(
            'تأكيد بيع الكل\n\n' +
            'سيتم بيع كل الأغراض القابلة للبيع من حقيبتك.\n' +
            'عدد الأنواع: ' + formatNumber(currentSellable.length) + '\n' +
            'الإجمالي المتوقع: ' + formatNumber(currentTotal) + ' نقطة'
          );

          if (!confirmed) return;

          const oldText = button.textContent;
          button.disabled = true;
          button.textContent = 'جاري البيع...';
          meta.textContent = 'جاري إرسال طلبات البيع...';

          let sold = 0;
          let failed = 0;

          for (const row of currentSellable) {
            try {
              const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell', {
                method: 'POST',
                credentials: 'include',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  itemName: row.name,
                  quantity: row.qty,
                }),
              });

              const data = await res.json().catch(() => ({}));

              if (!res.ok || data?.ok === false) {
                throw new Error(String(data?.message || data?.error || res.status || 'sell_failed'));
              }

              sold += 1;
              applyLocalSellToInventory(sourceItems, row.name, row.qty);
            } catch (error) {
              failed += 1;
              console.error('[Sell All] Failed:', row.name, error);
            }
          }

          renderInventory(sourceItems);

          requestAnimationFrame(() => {
            enhanceInventorySellButtons(sourceItems);
          });

          if (failed > 0) {
            window.alert('تم إرسال ' + formatNumber(sold) + ' طلب بيع، وفشل ' + formatNumber(failed) + '.');
          }
        });
      }


      function tnxSellAllEligibleV2(items) {
        const list = Array.isArray(items) ? items : [];

        return list
          .map((item) => {
            const name = String(item?.name || item?.text || item?.itemName || '').trim();
            const qty = Math.max(0, Math.floor(Number(item?.qty ?? item?.quantity ?? 0)));

            if (!name || qty <= 0) return null;

            const meta = typeof itemMetaForDetail === 'function'
              ? itemMetaForDetail(name)
              : (typeof findCatalogItemByName === 'function' ? findCatalogItemByName(name) : null);

            const disabled = typeof itemDetailIsSaleDisabled === 'function'
              ? itemDetailIsSaleDisabled(meta)
              : false;

            if (disabled) return null;

            const price = typeof itemDetailSellPrice === 'function'
              ? itemDetailSellPrice(meta)
              : 0;

            if (!Number.isFinite(price) || price <= 0) return null;

            return {
              item,
              name,
              qty,
              price,
              total: price * qty,
            };
          })
          .filter(Boolean);
      }


      async function tnxWaitSellRequestCompleteV2(requestId) {
        const id = String(requestId || '').trim();

        if (!id) return false;

        const startedAt = Date.now();
        const timeoutMs = 45000;
        const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

        while (Date.now() - startedAt < timeoutMs) {
          await delay(900);

          const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell-status?id=' + encodeURIComponent(id), {
            method: 'GET',
            credentials: 'include',
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok || !data?.ok) {
            continue;
          }

          const status = String(data?.request?.status || '').toLowerCase();

          if (status === 'completed') {
            return true;
          }

          if (status === 'rejected') {
            throw new Error(data?.request?.errorMessage || 'فشل بيع أحد الأغراض.');
          }
        }

        throw new Error('تأخر تنفيذ بيع الكل. جرّب تحديث الصفحة.');
      }

      function tnxGetSellAllLockHost() {
        const inventoryBox = document.getElementById('inventory');

        if (!inventoryBox) {
          return null;
        }

        let current = inventoryBox.parentElement;
        let best = inventoryBox.parentElement || inventoryBox;

        for (let i = 0; current && i < 8; i++) {
          const text = String(current.textContent || '');
          const hasInventory = current.contains(inventoryBox);
          const hasSellAllButton = !!current.querySelector('.tnx-sell-all-row');
          const hasInventoryTitle = text.includes('الحقيبة');

          if (hasInventory && hasSellAllButton && hasInventoryTitle) {
            return current;
          }

          best = current;
          current = current.parentElement;
        }

        return inventoryBox.parentElement?.parentElement || best || inventoryBox;
      }
      function tnxSetSellAllInventoryLock(message, subMessage = '') {
