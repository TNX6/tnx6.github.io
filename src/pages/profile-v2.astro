      function itemDetailHint(action, item, meta) {
        const name = String(item.name || 'الغرض');
        const price = itemDetailSellPrice(meta);

        if (action === 'use') {
          return 'استخدم هذا الغرض من خلال Streamer.bot حسب نظام الأغراض الحالي.';
        }

        if (action === 'gift') {
          return 'الإهداء لاحقًا بيحتاج اختيار العضو المستلم. حالياً نعرض المعلومة فقط.';
        }

        if (action === 'market') {
          return 'عرض السوق يحتاج نظام سوق مستقل. حالياً غير مربوط.';
        }

        if (action === 'sell') {
          if (itemDetailIsSaleDisabled(meta)) {
            return 'هذا الغرض غير قابل للبيع.';
          }

          return 'بيع ' + name + ' يعطيك ' + formatNumber(price) + ' نقطة لكل قطعة.';
