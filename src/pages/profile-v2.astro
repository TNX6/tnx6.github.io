      function mkListErrorText(error, data) {
        const value = String(error || '').toLowerCase()
        if (value.includes('missing_item')) return 'الكمية المطلوبة غير متوفرة في حقيبتك.'
        if (value.includes('listing_limit_reached')) return 'وصلت الحد الأعلى للعروض المتزامنة (' + ((data && data.limit) || 3) + ').'
        if (value.includes('invalid_price')) return 'السعر لازم يكون ' + formatNumber((data && data.minPrice) || 500) + ' نقطة أو أكثر.'
        if (value.includes('not_enough_points_fee')) return 'نقاطك ما تكفي لرسوم المدة المختارة.'
        if (value.includes('inventory_parse_failed')) return 'صار خطأ في بيانات الحقيبة، تواصل مع الإدارة.'
        if (value.includes('invalid_duration')) return 'اختر مدة عرض صحيحة.'
        if (value.includes('timeout')) return 'تأخر النشر، جرّب بعد قليل.'
        return 'حدث خطأ، جرّب بعد قليل.'
      }

      async function mkPollListing(listingId, timeoutMs = 45000) {
        const startedAt = Date.now()

        while (Date.now() - startedAt < timeoutMs) {
          await new Promise((resolve) => setTimeout(resolve, 2500))

          try {
            const res = await fetch(TNX_API_ORIGIN + '/api/me/market/my-listings?v=' + Date.now(), {
              credentials: 'include',
              cache: 'no-store',
            })

            const data = await res.json().catch(() => null)

            if (!res.ok || !data || data.ok !== true) continue

            const found = (data.listings || []).find((entry) => entry.listingId === listingId)

            if (!found) continue
            if (found.status === 'active') return { ok: true }
            if (found.status === 'error') return { error: found.errorMessage || 'list_failed' }
          } catch {}
        }

        return { timeout: true }
      }

      function mkOpenListModal(item, parentModal) {
        mkEnsureStyle()
        document.querySelectorAll('[data-mk-modal]').forEach((el) => el.remove())

        const ownedQty = Math.max(1, Math.floor(Number(item.qty || item.quantity || 1)))

        const modal = document.createElement('div')
        modal.className = 'mk-modal'
        modal.setAttribute('data-mk-modal', 'true')

        modal.innerHTML =
          '<div class="mk-dialog" role="dialog" aria-modal="true" aria-label="عرض في السوق">' +
            '<button class="mk-close" type="button" data-mk-close aria-label="إغلاق">×</button>' +
            '<div class="mk-head">' +
              '<div class="mk-head-icon">🏷️</div>' +
              '<div><h3>عرض في السوق</h3><p>' + esc(item.name) + ' — تملك ×' + formatNumber(ownedQty) + '</p></div>' +
            '</div>' +

            '<div class="mk-field">' +
              '<label class="mk-label">الكمية</label>' +
              '<input class="mk-input" type="number" data-mk-qty min="1" max="' + ownedQty + '" value="1" inputmode="numeric">' +
            '</div>' +

            '<div class="mk-field">' +
              '<label class="mk-label">السعر المطلوب (بالنقاط)</label>' +
              '<input class="mk-input" type="number" data-mk-price min="500" step="100" placeholder="500 نقطة أو أكثر" inputmode="numeric">' +
            '</div>' +

            '<div class="mk-field">' +
              '<label class="mk-label">مدة العرض</label>' +
              '<div class="mk-durations">' +
                MK_DURATIONS.map((d, i) =>
                  '<button type="button" class="mk-dur' + (i === 0 ? ' sel' : '') + '" data-mk-dur="' + d.seconds + '">' +
                    '<b>' + d.label + '</b>' +
                    '<span>' + (d.fee ? formatNumber(d.fee) + ' نقطة' : 'مجانًا') + '</span>' +
                  '</button>'
                ).join('') +
              '</div>' +
            '</div>' +

            '<div class="mk-state" data-mk-state></div>' +

            '<div class="mk-actions" data-mk-actions>' +
              '<button class="mk-submit" type="button" data-mk-submit>نشر العرض</button>' +
              '<button class="mk-cancel" type="button" data-mk-close>إلغاء</button>' +
            '</div>' +
          '</div>'

        document.body.appendChild(modal)

        const stateEl = modal.querySelector('[data-mk-state]')

        const setState = (kind, text) => {
          if (!stateEl) return
          stateEl.className = 'mk-state' + (kind ? ' is-' + kind : '')
          stateEl.textContent = text || ''
        }

        modal.addEventListener('click', (event) => {
          const target = event.target
          if (!(target instanceof Element)) return

          if (target === modal || target.closest('[data-mk-close]')) {
            modal.remove()
            return
          }

          const durButton = target.closest('[data-mk-dur]')
          if (durButton) {
            modal.querySelectorAll('[data-mk-dur]').forEach((btn) => btn.classList.remove('sel'))
            durButton.classList.add('sel')
            return
          }

          const submitButton = target.closest('[data-mk-submit]')
          if (submitButton) {
            submitList(submitButton)
          }
        })

        async function submitList(button) {
          const quantity = Math.floor(Number(modal.querySelector('[data-mk-qty]')?.value || 0))
          const price = Math.floor(Number(modal.querySelector('[data-mk-price]')?.value || 0))
          const durEl = modal.querySelector('[data-mk-dur].sel')
          const durationSeconds = Number(durEl?.getAttribute('data-mk-dur') || 21600)

          if (!Number.isFinite(quantity) || quantity < 1 || quantity > ownedQty) {
            setState('error', 'الكمية لازم تكون بين 1 و' + formatNumber(ownedQty) + '.')
            return
          }

          if (!Number.isFinite(price) || price < 500) {
            setState('error', 'السعر لازم يكون 500 نقطة أو أكثر.')
            return
          }

          button.disabled = true
          button.innerHTML = '<span class="mk-spin"></span>جاري نشر العرض...'
          setState('loading', 'جاري إرسال العرض...')

          try {
            const res = await fetch(TNX_API_ORIGIN + '/api/me/market/list', {
              method: 'POST',
              credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ itemName: item.name, quantity, price, durationSeconds }),
            })

            const data = await res.json().catch(() => null)

            if (!res.ok || !data || data.ok !== true) {
              setState('error', mkListErrorText((data && data.error) || 'list_failed', data))
              button.disabled = false
              button.textContent = 'نشر العرض'
              return
            }

            // نجح الطلب: ما ننتظر رد الجسر — تأكيد فوري وأسرع.
            // العرض بيظهر "قيد النشر" ثم "نشط" تلقائيًا في السوق/عروضي.
            setState('ok', 'تم إرسال العرض ✓ بيظهر في السوق خلال ثوانٍ')

            const actions = modal.querySelector('[data-mk-actions]')
            if (actions) {
              actions.innerHTML =
                '<a class="mk-link" href="/market">شوف السوق</a>' +
                '<button class="mk-cancel" type="button" data-mk-close>تم</button>'
            }

            try { wsRefreshInventory() } catch {}
            try { if (parentModal && parentModal.remove) parentModal.remove() } catch {}
            return
          } catch {
            setState('error', 'حدث خطأ، جرّب بعد قليل.')
            button.disabled = false
            button.textContent = 'نشر العرض'
          }
        }
      }

      /* ============================================================
         الورشة (Workshop V1)
         مصدر الوقت الحقيقي: finish_at من الـ API — الواجهة countdown فقط.
         بعد start/claim: refetch inventory + recipes + jobs.
         ============================================================ */

      const wsState = {
        recipes: [],
        hasActiveJob: false,
        jobs: { active: [], ready: [], history: [] },
        tab: 'available',
        selectedId: '',
        view: 'craft',
        loading: false,
        visible: false,
        timer: null,
        pollTimer: null,
        reloadQueued: false,
        pendingInvRefresh: false,
        reveal: null,
        notice: null,
      }

      function wsBox() { return document.getElementById('wsModalBody') }
      function wsCard() { return document.getElementById('workshopEntry') }
      function wsModalEl() { return document.getElementById('wsModal') }
      function wsModalOpen() { return Boolean(document.getElementById('wsModal')) }
      function wsEntryEl() { return document.getElementById('workshopEntry') }

      // زر الورشة داخل هيدر الحقيبة نفسه — بجانب عداد الأغراض
      function wsRenderEntry() {
        const entry = wsEntryEl()
        if (!entry) return

        const activeJob = wsState.jobs.active[0] || null
        const readyJob = wsState.jobs.ready[0] || null

        // مؤشر الحالة على الزر نفسه:
        // أخضر (جاهز للكشف) > نقطة ذهبية تنبض (قيد التصنيع) > بدون
        let indicatorHtml = ''

        if (readyJob) {
          indicatorHtml = '<span class="ws-open-badge">1</span>'
        } else if (activeJob) {
          indicatorHtml = '<span class="ws-open-dot"></span>'
        }

        const title = readyJob
