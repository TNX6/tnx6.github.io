      -webkit-backdrop-filter: blur(12px);
    }

    .inventory-sell-box {
      --sell-paper-1: #1c1711;
      --sell-paper-2: #12100c;
      --sell-gold-hi: #ffe9a8;
      --sell-gold: #e7bf5f;
      --sell-gold-deep: #a67931;
      --sell-cream: #f4ead4;
      --sell-muted: rgba(244,234,212,.62);
      --sell-dim: rgba(244,234,212,.42);
      --sell-line: rgba(231,191,95,.18);
      position: relative;
      width: min(430px, 100%);
      border-radius: 25px;
      border: 1px solid var(--sell-line);
      background:
        radial-gradient(120% 90% at 50% -22%, rgba(231,191,95,.12), transparent 48%),
        linear-gradient(165deg, var(--sell-paper-1), var(--sell-paper-2));
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.055),
        inset 0 0 70px rgba(231,191,95,.035),
        0 38px 95px -30px rgba(0,0,0,.90);
      color: var(--sell-cream);
      direction: rtl;
      overflow: hidden;
      animation: inventorySellRise .32s cubic-bezier(.22,1,.36,1) both;
    }

    @keyframes inventorySellRise {
      from { opacity: 0; transform: translateY(14px) scale(.98); }
      to { opacity: 1; transform: none; }
    }

    .inventory-sell-box::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        repeating-radial-gradient(circle at 16% 10%, rgba(231,191,95,.045) 0 1px, transparent 1px 14px),
        repeating-linear-gradient(115deg, rgba(231,191,95,.022) 0 1px, transparent 1px 9px);
      mask: linear-gradient(180deg, #000, transparent 62%);
      opacity: .65;
    }

    .inventory-sell-close {
      position: absolute;
      inset-inline-start: 16px;
      top: 16px;
      z-index: 5;
      width: 34px;
      height: 34px;
      border-radius: 11px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(0,0,0,.28);
      color: rgba(255,255,255,.82);
      font-size: 22px;
      font-weight: 900;
      line-height: 1;
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, color .18s ease;
    }

    .inventory-sell-close:hover {
      transform: rotate(90deg);
      background: rgba(0,0,0,.45);
