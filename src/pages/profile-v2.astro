        const close = () => modal.remove()
        const qtyInput = modal.querySelector('#inventorySellQty')
        const total = modal.querySelector('[data-sell-total]')
        const formula = modal.querySelector('[data-sell-formula]')
        const msg = modal.querySelector('[data-sell-message]')
        const submit = modal.querySelector('[data-sell-submit]')
        const stamp = modal.querySelector('[data-sell-stamp]')
        const qtyButtons = () => [...modal.querySelectorAll('[data-sell-qty-pick], [data-sell-qty-step]')]
        let selectedQty = 1
        let displayedPayout = priceEach
        let payoutAnimationFrame = 0

        const clampQty = (value) => {
          const number = Math.floor(Number(value || 1))
          if (!Number.isFinite(number)) return 1
          return Math.max(1, Math.min(owned, number))
        }

        const animatePayoutTotal = (nextValue) => {
          const target = Math.max(0, Math.floor(Number(nextValue || 0)))

          if (payoutAnimationFrame) {
            cancelAnimationFrame(payoutAnimationFrame)
          }

          const start = Math.max(0, Math.floor(Number(displayedPayout || 0)))
          const startedAt = performance.now()
          const duration = 420

          if (start === target) {
            displayedPayout = target
            total.textContent = formatNumber(target)
            return
          }

          const step = (now) => {
            const progress = Math.min(1, (now - startedAt) / duration)
            const eased = 1 - Math.pow(1 - progress, 3)
            const current = Math.round(start + ((target - start) * eased))

            displayedPayout = current
            total.textContent = formatNumber(current)

            if (progress < 1) {
              payoutAnimationFrame = requestAnimationFrame(step)
            } else {
              displayedPayout = target
              total.textContent = formatNumber(target)
              payoutAnimationFrame = 0
            }
          }

          payoutAnimationFrame = requestAnimationFrame(step)
        }

        const setQty = (value) => {
          selectedQty = clampQty(value)

          if (qtyInput) {
            qtyInput.value = String(selectedQty)
          }

          modal.querySelectorAll('[data-sell-qty-pick]').forEach((button) => {
            const picked = clampQty(button.dataset.sellQtyPick)
            const isActive = picked === selectedQty && !button.classList.contains('all')
            button.classList.toggle('is-active', isActive)
          })

          formula.textContent = `${formatNumber(priceEach)} × ${formatNumber(selectedQty)}`
          animatePayoutTotal(selectedQty * priceEach)
        }

