          if (!allowed) {
            await syncOwnerControlsV36(state.activeUser)
            return
          }

          const name = button.dataset.sellItem || ''
          const qty = Math.max(1, Math.floor(Number(button.dataset.sellQty || 1)))
          const item = findInventoryItemByName(items, name) || { name, qty }
          const meta = findCatalogItemByName(name)

          openInventorySellModal(item, meta, items)
        })
      }


      function getSellAllEligibleInventoryItems(items) {
        const list = Array.isArray(items) ? items : [];

        return list
          .map((item) => {
            const name = String(item?.name || item?.text || item?.itemName || '').trim();
            const qty = Math.max(0, Math.floor(Number(item?.qty ?? item?.quantity ?? 0)));

            if (!name || qty <= 0) return null;

            const meta = itemMetaForDetail(name);

            if (itemDetailIsSaleDisabled(meta)) return null;

            const price = itemDetailSellPrice(meta);

            if (!Number.isFinite(price) || price <= 0) return null;

            return {
              item,
              name,
              qty,
              price,
              total: price * qty,
            };
          })
          .filter(Boolean);
      }

      function renderInventorySellAllButton(items, canSell) {
