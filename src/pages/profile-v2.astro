      function d1InventoryCacheKey(user) {
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()
        return viewedId || viewedLogin || ''
      }

      async function loadInventoryFromD1(user) {
        const cacheKey = d1InventoryCacheKey(user)
        if (!cacheKey) return null

        if (state.d1InventoryCache[cacheKey]) {
          return state.d1InventoryCache[cacheKey]
        }

        const params = new URLSearchParams()
        const viewedId = String(userId(user) || get(user, ['twitchId', 'twitch_id'], '') || '').trim()
        const viewedLogin = String(userLogin(user) || get(user, ['login', 'userLogin'], '') || '').trim().toLowerCase()

        if (viewedId) params.set('twitchId', viewedId)
        else if (viewedLogin) params.set('login', viewedLogin)
        else return null

        try {
          const res = await fetch(TNX_API_ORIGIN + '/api/profile/inventory?' + params.toString(), {
            cache: 'no-store',
          })

          if (!res.ok) return null

          const data = await res.json().catch(() => null)

          if (!data?.ok || !Array.isArray(data.items)) return null

          state.d1InventoryCache[cacheKey] = data
          return data
        } catch {
          return null
        }
      }

      async function userWithD1Inventory(user) {
