        })
      }


      async function watchInventorySellFinalStatus(requestId, lockId) {
        const id = String(requestId || '').trim();

        if (!id) {
          return false;
        }

        const startedAt = Date.now();
        const timeoutMs = 30000;
        const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

        while (Date.now() - startedAt < timeoutMs) {
          await delay(700);

          try {
            const res = await fetch(TNX_API_ORIGIN + '/api/me/inventory/sell-status?id=' + encodeURIComponent(id), {
              method: 'GET',
              credentials: 'include',
            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok || !data?.ok) {
              continue;
            }

            const status = String(data?.request?.status || '').toLowerCase();

            if (status === 'completed') {
              removeInventorySellLock(lockId);
              await refreshActiveProfileFromD1();
              return true;
            }

            if (status === 'rejected') {
              removeInventorySellLock(lockId);
              await refreshActiveProfileFromD1();

              const msg = String(data.request?.errorMessage || data.errorMessage || 'تم رفض البيع ورجع الغرض للحقيبة.');
              console.warn('[Inventory Sell] Rejected:', msg);

              return false;
            }
          } catch (error) {
            console.warn('Failed to check sell status:', error);
          }
        }

        removeInventorySellLock(lockId);
        await refreshActiveProfileFromD1();
        return false;
      }

