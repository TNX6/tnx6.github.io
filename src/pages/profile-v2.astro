    .bp29-count b {
      color: #f0c45a;
    }

    .bp29-tools {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 12px;
      padding: 16px 26px 6px;
      align-items: center;
      flex-wrap: wrap;
    }

    .bp29-search {
      flex: 1;
      min-width: 200px;
      position: relative;
    }

    .bp29-search span {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #857a66;
      font-weight: 900;
    }

    .bp29-search input {
      width: 100%;
      height: 46px;
      background: #0f0b06;
      border: 1px solid #2c2316;
      border-radius: 13px;
      color: #f4ecdc;
      font: inherit;
      font-size: 14.5px;
      font-weight: 700;
      padding: 12px 44px 12px 14px;
      outline: none;
      transition: .18s;
    }

    .bp29-search input::placeholder {
      color: #857a66;
    }

    .bp29-search input:focus {
      border-color: #b8862e;
      box-shadow: 0 0 0 3px #f0c45a1f;
    }

    .bp29-seg {
      display: flex;
      background: #0f0b06;
      border: 1px solid #2c2316;
      border-radius: 13px;
      padding: 4px;
      gap: 2px;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .bp29-seg::-webkit-scrollbar { display: none; }

    .bp29-seg button {
      border: 0;
      background: transparent;
      color: #b9ad97;
      font: inherit;
      font-weight: 700;
      font-size: 13.5px;
      padding: 8px 15px;
      border-radius: 9px;
      cursor: pointer;
      transition: .16s;
      white-space: nowrap;
    }

    .bp29-seg button:hover {
      color: #f4ecdc;
    }

    .bp29-seg button.act {
      background: linear-gradient(180deg,#f0c45a,#b8862e);
      color: #2a1f08;
      box-shadow: 0 4px 14px -4px #f0c45a99;
    }

    .bp29-tray {
      position: relative;
      z-index: 1;
      padding: 4px 26px 0;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      min-height: 0;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height .3s ease, opacity .25s ease, padding .3s ease;
    }

    .bp29-tray.show {
      max-height: 120px;
      opacity: 1;
      padding: 14px 26px 2px;
    }

    .bp29-tray-label {
      color: #857a66;
      font-size: 12.5px;
      font-weight: 700;
    }

    .bp29-chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      flex: 1;
    }

    .bp29-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #241a0c;
      border: 1px solid #4a3a1c;
      border-radius: 11px;
      padding: 6px 8px 6px 11px;
      font-size: 13px;
      font-weight: 700;
      color: #f4ecdc;
      cursor: pointer;
    }

    .bp29-chip .dot {
      width: 18px;
      height: 18px;
      border-radius: 6px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg,#f0c45a,#b8862e);
      color: #2a1f08;
      font-size: 10px;
      overflow: hidden;
    }

    .bp29-chip .dot img {
      width: 15px;
      height: 15px;
      object-fit: contain;
    }

    .bp29-chip code {
      font-family: Oxanium, Tajawal, system-ui, sans-serif;
      font-weight: 700;
      letter-spacing: .3px;
      direction: ltr;
    }

    .bp29-chip .x {
      width: 18px;
      height: 18px;
      border-radius: 6px;
      background: #ffffff10;
      color: #b9ad97;
      display: grid;
      place-items: center;
      font-size: 14px;
      line-height: 1;
    }

    .bp29-chip:hover .x {
      background: #e0795f;
      color: #fff;
    }

    .bp29-clear {
      margin-inline-start: auto;
      background: transparent;
      border: 1px solid #2c2316;
      color: #b9ad97;
      font: inherit;
      font-weight: 700;
      font-size: 12.5px;
      padding: 7px 13px;
      border-radius: 10px;
      cursor: pointer;
      transition: .15s;
    }

    .bp29-clear:hover:not(:disabled) {
      border-color: #e0795f;
      color: #e0795f;
    }

    .bp29-clear:disabled {
      opacity: .35;
      cursor: default;
    }

    .bp29-scroller {
      position: relative;
      z-index: 1;
      overflow-y: auto;
      padding: 18px 26px 22px;
      flex: 1;
      scrollbar-width: thin;
      scrollbar-color: #3a2e1a transparent;
    }

    .bp29-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill,minmax(150px,1fr));
      gap: 14px;
    }

    .bp29-card {
      position: relative;
      background: linear-gradient(180deg,#221a0f,#191309);
      border: 1.5px solid #2c2316;
      border-radius: 18px;
      padding: 18px 12px 14px;
      cursor: pointer;
      text-align: center;
      transition: transform .22s cubic-bezier(.34,1.3,.5,1), border-color .2s, box-shadow .25s, background .2s, opacity .2s;
      user-select: none;
      min-height: 154px;
      color: #f4ecdc;
    }

    .bp29-card:hover {
      transform: translateY(-4px);
      border-color: #54421f;
      box-shadow: 0 16px 30px -18px #000;
    }

    .bp29-medal {
      position: relative;
      width: 74px;
      height: 74px;
      margin: 2px auto 12px;
      display: grid;
      place-items: center;
    }

    .bp29-ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: conic-gradient(from 220deg,#5a451f,#caa14e,#7a5e29,#e7c061,#5a451f);
      padding: 3px;
      -webkit-mask: radial-gradient(circle,transparent 58%,#000 60%);
      mask: radial-gradient(circle,transparent 58%,#000 60%);
      opacity: .85;
    }

    .bp29-core {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: radial-gradient(circle at 35% 30%,#2c2110,#140d05);
      border: 1px solid #3a2c14;
      box-shadow: inset 0 2px 6px #00000088;
      color: #f0c45a;
      overflow: hidden;
      font-family: Oxanium, Tajawal, system-ui, sans-serif;
      font-size: 18px;
      font-weight: 900;
      direction: ltr;
    }

    .bp29-core img {
      width: 34px;
      height: 34px;
      object-fit: contain;
    }

    .bp29-card.tier-k .bp29-ring {
      background: conic-gradient(from 200deg,#6a3c22,#e0a85a,#8a4e2a,#f6cf86,#6a3c22);
    }

    .bp29-card.tier-role .bp29-ring {
      background: conic-gradient(from 200deg,#4d2a7a,#b586ff,#6f43ad,#dcc6ff,#4d2a7a);
    }

    .bp29-name {
      display: block;
      font-family: Oxanium, Tajawal, system-ui, sans-serif;
      font-weight: 700;
      font-size: 18px;
      letter-spacing: .5px;
      color: #f4ecdc;
      direction: ltr;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 120px;
      margin: 0 auto;
    }

    .bp29-cat {
      display: block;
      font-size: 11.5px;
      color: #857a66;
      margin-top: 3px;
      font-weight: 500;
    }

    .bp29-info {
      position: absolute;
      top: 9px;
      inset-inline-start: 9px;
      width: 24px;
      height: 24px;
      border-radius: 8px;
      background: #ffffff0c;
      border: 1px solid #2c2316;
      color: #857a66;
      display: grid;
      place-items: center;
      font-family: Oxanium, Tajawal, system-ui, sans-serif;
      font-weight: 700;
      font-size: 12px;
      z-index: 3;
      font-style: normal;
    }

    .bp29-tick {
      position: absolute;
      top: 9px;
      inset-inline-end: 9px;
      width: 26px;
      height: 26px;
      border-radius: 9px;
      background: linear-gradient(180deg,#f0c45a,#b8862e);
      display: grid;
      place-items: center;
      transform: scale(0);
      transition: transform .28s cubic-bezier(.34,1.3,.5,1);
      box-shadow: 0 4px 12px -3px #f0c45a;
      z-index: 3;
      color: #2a1f08;
      font-weight: 1000;
    }

    .bp29-card.sel {
      border-color: #f0c45a;
      background: linear-gradient(180deg,#2a2010,#1c1409);
      box-shadow: 0 0 0 1px #f0c45a55, 0 14px 34px -16px #f0c45a66;
    }

    .bp29-card.sel .bp29-tick {
      transform: scale(1);
    }

    .bp29-card.sel .bp29-ring {
      animation: spin 9s linear infinite;
    }

    .bp29-card.lock {
      opacity: .4;
      cursor: not-allowed;
      filter: saturate(.5);
    }

    .bp29-hint {
      position: absolute;
      inset: auto 0 12px;
      font-size: 11px;
      font-weight: 700;
      color: #f0c45a;
      opacity: 0;
      transition: .18s;
      pointer-events: none;
    }

    .bp29-card.lock:hover .bp29-hint {
      opacity: 1;
    }

    .bp29-card.lock:hover .bp29-cat {
      opacity: 0;
    }

    .bp29-empty {
      grid-column: 1/-1;
      text-align: center;
      color: #857a66;
      padding: 46px 0;
      font-size: 14.5px;
      font-weight: 700;
    }

    .bp29-foot {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 12px;
      padding: 16px 26px;
      border-top: 1px solid #241c12;
      background: linear-gradient(180deg,transparent,#0d0905);
    }

    .bp29-save,
    .bp29-cancel {
      border-radius: 14px;
      padding: 15px 24px;
      font: inherit;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: .2s;
    }

    .bp29-save {
      flex: 1;
      border: 0;
      color: #2a1f08;
      background: linear-gradient(180deg,#f0c45a,#b8862e);
      box-shadow: 0 10px 26px -10px #f0c45ac0;
    }

    .bp29-save:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 16px 32px -10px #f0c45a;
    }

    .bp29-save:disabled {
      background: #221a10;
      color: #857a66;
      box-shadow: none;
      cursor: default;
    }

    .bp29-cancel {
      border: 1px solid #2c2316;
      background: #ffffff08;
      color: #b9ad97;
    }

    .bp29-cancel:hover {
      background: #ffffff12;
      color: #f4ecdc;
    }

    .bp29-toast {
      position: fixed;
      bottom: 26px;
      left: 50%;
      transform: translateX(-50%) translateY(12px) scale(.98);
      background: #241a0c;
      border: 1px solid #4a3a1c;
      color: #f4ecdc;
      padding: 11px 18px;
      border-radius: 12px;
      font-family: Tajawal, system-ui, sans-serif;
      font-weight: 700;
      font-size: 14px;
      z-index: 100001;
      box-shadow: 0 12px 30px -10px #000;
      opacity: 0;
      pointer-events: none;
      transition: .18s ease;
    }

    .bp29-toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }

    @media (max-width:560px) {
      .bp29-shell {
        align-items: end;
        padding: 0;
      }

      .bp29-modal {
        width: 100vw;
        max-height: 92vh;
        border-radius: 24px 24px 0 0;
      }

      .bp29-head,
      .bp29-tools,
      .bp29-tray.show,
      .bp29-scroller,
      .bp29-foot {
        padding-inline: 18px;
      }

      .bp29-title {
        font-size: 19px;
      }

      .bp29-grid {
        grid-template-columns: repeat(auto-fill,minmax(130px,1fr));
        gap: 11px;
      }

      .bp29-card {
        min-height: 140px;
      }
    }


    /* BP30 smooth picker performance overrides */
    .bp29-modal,
    .bp29-scroller,
    .bp29-grid {
      contain: layout paint;
    }

    .bp29-card {
      contain: layout paint style;
      will-change: transform;
      transform: translateZ(0);
      backface-visibility: hidden;
      transition: transform .14s ease, border-color .14s ease, background .14s ease, opacity .14s ease;
    }

    .bp29-card:hover {
      transform: translate3d(0, -2px, 0);
      box-shadow: none;
    }

    .bp29-card.sel {
      box-shadow: 0 0 0 1px rgba(240,196,90,.34);
    }

    .bp29-card.sel .bp29-ring {
      animation: none !important;
    }

    .bp29-card.lock {
      filter: none !important;
      opacity: .45;
    }

    .bp29-tick {
      transition: transform .16s ease;
    }

    .bp29-chip,
    .bp29-pip,
    .bp29-save,
    .bp29-clear {
      transition-duration: .12s;
    }


    /* BP31_ULTRA_SMOOTH */
