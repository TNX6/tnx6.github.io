---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Badges — TNX6',
  ignoreTitleTemplate: true,
  description: 'صفحة بادجات مجتمع TNX6.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-badges-page" dir="rtl">
    <div class="tnx-badges-bg"></div>
    <div class="tnx-badges-grid-bg"></div>

    <section class="tnx-badges-shell">
      <header class="tnx-badges-hero">
        <div class="tnx-badges-eyebrow">
          <span></span>
          TNX6 BADGE VAULT
        </div>

        <h1>خزنة البادجات</h1>

        <p>
          البادجات إنجازات تفتحها من الحضور، النقاط، الكويز، التفاعل، أو أحداث المجتمع.
          هنا تعرف وش كل بادج، كيف تحصل عليه، وتشوف بطاقة أي عضو وتقدمه.
        </p>

        <div class="tnx-badges-hero-stats">
          <div class="glass-panel">
            <strong id="statTotalBadges">0</strong>
            <span>إجمالي البادجات</span>
          </div>

          <div class="glass-panel">
            <strong id="statCategories">0</strong>
            <span>تصنيف مختلف</span>
          </div>

          <div class="glass-panel">
            <strong id="statRareBadges">0</strong>
            <span>نادر / خاص</span>
          </div>
        </div>
      </header>

      <section class="tnx-start-guide glass-panel">
        <div class="tnx-section-head">
          <span>للمشاهد الجديد</span>
          <h2>من وين أبدأ؟</h2>
          <p>هذه أسهل مسارات تبدأ فيها قبل البادجات الثقيلة والنادرة.</p>
        </div>

        <div class="tnx-guide-grid">
          <button type="button" class="tnx-guide-card hover-glow" data-guide-filter="attendance">
            <div class="tnx-guide-icon">15</div>
            <div>
              <strong>ابدأ بالحضور</strong>
              <p>سجّل حضورك وابدأ من بادجات 15D ثم 30D وبعدها تكمل.</p>
            </div>
          </button>

          <button type="button" class="tnx-guide-card hover-glow" data-guide-filter="points">
            <div class="tnx-guide-icon">K</div>
            <div>
              <strong>اجمع نقاط</strong>
              <p>بادجات 100K وما بعدها تعتمد على رصيدك وتفاعلك بالبث.</p>
            </div>
          </button>

          <button type="button" class="tnx-guide-card hover-glow" data-guide-filter="quiz">
            <div class="tnx-guide-icon">Q</div>
            <div>
              <strong>جاوب بالكويز</strong>
              <p>كل ما زادت إجاباتك الصحيحة تفتح بادجات كويز أعلى.</p>
            </div>
          </button>
        </div>
      </section>

      <section class="tnx-vault glass-panel">
        <div class="tnx-vault-top">
          <div class="tnx-section-head">
            <span>كل البادجات</span>
            <h2>استعرض البادجات</h2>
            <p>اضغط على أي بادج عشان تشوف تفاصيله، طريقة الحصول عليه، ورابطه المباشر.</p>
          </div>

          <div class="tnx-badge-search glass-input">
            <span>⌕</span>
            <input
              id="badgeSearch"
              type="search"
              autocomplete="off"
              placeholder="ابحث: VIP، 100K، حضور، كويز..."
            />
            <button type="button" id="clearBadgeSearch">×</button>
          </div>
        </div>

        <div class="tnx-filter-row" id="badgeFilters">
          <button type="button" class="is-active" data-badge-filter="all">
            <span>الكل</span>
            <small id="count-all">0</small>
          </button>
          <button type="button" data-badge-filter="attendance">
            <span>الحضور</span>
            <small id="count-attendance">0</small>
          </button>
          <button type="button" data-badge-filter="points">
            <span>النقاط</span>
            <small id="count-points">0</small>
          </button>
          <button type="button" data-badge-filter="quiz">
            <span>الكويز</span>
            <small id="count-quiz">0</small>
          </button>
          <button type="button" data-badge-filter="status">
            <span>المكانة</span>
            <small id="count-status">0</small>
          </button>
          <button type="button" data-badge-filter="law">
            <span>المحكمة</span>
            <small id="count-law">0</small>
          </button>
          <button type="button" data-badge-filter="awards">
            <span>الجوائز</span>
            <small id="count-awards">0</small>
          </button>
          <button type="button" data-badge-filter="special">
            <span>خاص</span>
            <small id="count-special">0</small>
          </button>
        </div>

        <div class="tnx-vault-layout">
          <div>
            <div id="badgeGrid" class="tnx-badge-grid"></div>
            <div id="badgeEmpty" class="tnx-empty hidden">
              <div class="empty-icon">👻</div>
              <strong>ما لقيت بادج مطابق</strong>
              <span>جرّب تبحث باسم أبسط.</span>
            </div>
          </div>

          <aside id="badgeFocusPanel" class="tnx-badge-focus glass-panel">
            <div class="tnx-focus-placeholder">
              <div class="tnx-focus-icon">⬟</div>
              <h3>اختر بادج</h3>
              <p>اضغط على أي بادج من القائمة عشان تظهر تفاصيله هنا.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="tnx-user-cards glass-panel">
        <div class="tnx-section-head tnx-section-head--center">
          <span>بطاقات الأعضاء</span>
          <h2>اعرض بطاقة مستخدم</h2>
          <p>ابحث باسم العضو وشوف بطاقته، وظيفته، نقاطه، البادجات اللي فاتحها واللي باقي له.</p>
        </div>

        <div class="tnx-user-search">
          <div class="tnx-badge-search glass-input">
            <span>⌕</span>
            <input
              id="userSearch"
              type="search"
              autocomplete="off"
              placeholder="ابحث عن مستخدم (الاسم أو اليوزر)..."
            />
            <button type="button" id="clearUserSearch">×</button>
          </div>
          <div id="userResults" class="tnx-user-results"></div>
        </div>

        <div id="userCardContainer" class="tnx-user-card-container"></div>
      </section>
    </section>
  </main>

  <style is:global>
    :root {
      --primary-gold: #ffda6a;
      --primary-gold-dim: rgba(255, 218, 106, 0.15);
      --bg-dark: #07050b;
      --glass-bg: rgba(16, 14, 23, 0.6);
      --glass-border: rgba(255, 218, 106, 0.12);
    }

    .hidden { display: none !important; }

    .tnx-badges-page {
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
      background: var(--bg-dark);
      color: white;
      font-family: 'Poppins', system-ui, sans-serif;
    }

    /* --- Backgrounds & Gradients --- */
    .tnx-badges-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 15% 0%, rgba(255, 218, 106, 0.12), transparent 40%),
        radial-gradient(circle at 85% 20%, rgba(194, 146, 0, 0.08), transparent 40%),
        radial-gradient(circle at 50% 100%, rgba(124, 58, 237, 0.08), transparent 50%),
        linear-gradient(180deg, var(--bg-dark) 0%, #0a0812 100%);
    }

    .tnx-badges-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.04;
      background-image:
        linear-gradient(var(--primary-gold) 1px, transparent 1px),
        linear-gradient(90deg, var(--primary-gold) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse at center, black 0%, transparent 80%);
    }

    /* --- Common Glassmorphism Utility --- */
    .glass-panel {
      border: 1px solid var(--glass-border);
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 1.5rem;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .hover-glow {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hover-glow:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 218, 106, 0.4);
      box-shadow: 0 12px 30px rgba(255, 218, 106, 0.1);
      background: rgba(255, 218, 106, 0.05);
    }

    /* --- Layout Shell --- */
    .tnx-badges-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1280px);
      margin: 0 auto;
      padding: 6rem 1.5rem 5rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    /* --- Hero Section --- */
    .tnx-badges-hero {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }

    .tnx-badges-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      border: 1px solid var(--glass-border);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.5);
      color: var(--primary-gold);
      padding: 0.5rem 1rem;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      box-shadow: 0 0 20px var(--primary-gold-dim);
    }

    .tnx-badges-eyebrow span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--primary-gold);
      box-shadow: 0 0 10px var(--primary-gold);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% { opacity: 0.6; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
      100% { opacity: 0.6; transform: scale(0.8); }
    }

    .tnx-badges-hero h1 {
      margin: 1.5rem 0 1rem;
      background: linear-gradient(135deg, #fff, var(--primary-gold));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 900;
      line-height: 1.1;
      text-shadow: 0 0 40px rgba(255, 218, 106, 0.2);
    }

    .tnx-badges-hero p {
      color: #9ca3af;
      font-size: 1.1rem;
      line-height: 1.8;
      max-width: 600px;
      margin: 0 auto;
    }

    .tnx-badges-hero-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 2.5rem;
    }

    .tnx-badges-hero-stats .glass-panel {
      padding: 1.5rem;
      text-align: center;
    }

    .tnx-badges-hero-stats strong {
      display: block;
      color: var(--primary-gold);
      font-size: 2.2rem;
      font-weight: 800;
    }

    .tnx-badges-hero-stats span {
      color: #9ca3af;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 0.5rem;
      display: block;
    }

    /* --- Sections Shared --- */
    .tnx-start-guide, .tnx-vault, .tnx-user-cards {
      padding: 2.5rem;
    }

    .tnx-section-head { margin-bottom: 2rem; }
    .tnx-section-head span {
      color: var(--primary-gold);
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .tnx-section-head h2 {
      color: #fff;
      font-size: 2.2rem;
      font-weight: 800;
      margin: 0.5rem 0;
    }
    .tnx-section-head p { color: #9ca3af; font-size: 0.95rem; line-height: 1.6; }
    .tnx-section-head--center { text-align: center; }

    /* --- Guide Cards --- */
    .tnx-guide-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .tnx-guide-card {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--glass-border);
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: right;
      cursor: pointer;
    }

    .tnx-guide-icon {
      flex-shrink: 0;
      width: 3.5rem;
      height: 3.5rem;
      display: grid;
      place-items: center;
      background: var(--primary-gold-dim);
      border: 1px solid rgba(255, 218, 106, 0.3);
      color: var(--primary-gold);
      border-radius: 1rem;
      font-size: 1.2rem;
      font-weight: 800;
    }

    .tnx-guide-card strong { color: #fff; font-size: 1.1rem; display: block; margin-bottom: 0.3rem;}
    .tnx-guide-card p { color: #9ca3af; font-size: 0.85rem; line-height: 1.5; margin: 0; }

    /* --- Vault & Filters --- */
    .tnx-vault-top {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-end;
      gap: 2rem;
      border-bottom: 1px solid var(--glass-border);
      padding-bottom: 1.5rem;
    }

    .glass-input {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid var(--glass-border);
      border-radius: 1rem;
      padding: 0.8rem 1.2rem;
      flex-grow: 1;
      max-width: 450px;
      transition: border-color 0.3s;
    }
    .glass-input:focus-within { border-color: var(--primary-gold); }
    .glass-input span { color: var(--primary-gold); font-size: 1.5rem; }
    .glass-input input {
      background: transparent;
      border: none;
      color: #fff;
      width: 100%;
      outline: none;
      font-family: inherit;
    }
    .glass-input button {
      background: transparent;
      border: none;
      color: #6b7280;
      cursor: pointer;
      font-size: 1.2rem;
      padding: 0;
    }
    .glass-input button:hover { color: #fff; }

    .tnx-filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin: 2rem 0;
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--glass-border);
      border-radius: 2rem;
      padding: 0.6rem 1.2rem;
      color: #d1d5db;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .tnx-filter-row button:hover { background: rgba(255, 255, 255, 0.08); }
    .tnx-filter-row button.is-active {
      background: var(--primary-gold-dim);
      border-color: var(--primary-gold);
      color: var(--primary-gold);
    }
    .tnx-filter-row small {
      background: rgba(0, 0, 0, 0.5);
      padding: 0.1rem 0.5rem;
      border-radius: 1rem;
      font-size: 0.75rem;
    }

    /* --- Badge Grid --- */
    .tnx-vault-layout {
      display: grid;
      grid-template-columns: 1fr 350px;
      gap: 2rem;
      align-items: start;
    }

    .tnx-badge-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.2rem;
    }

    .tnx-badge-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--glass-border);
      border-radius: 1.2rem;
      padding: 1.2rem;
      text-align: center;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      transition: all 0.3s ease;
    }

    .tnx-badge-card:hover, .tnx-badge-card.is-selected {
      background: rgba(255, 218, 106, 0.05);
      border-color: rgba(255, 218, 106, 0.5);
      transform: translateY(-4px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .tnx-badge-card.is-rare::before {
      content: '';
      position: absolute;
      inset: -50%;
      background: conic-gradient(from 180deg, transparent, rgba(255, 218, 106, 0.2), transparent 40%);
      animation: tnxBadgeShine 6s linear infinite;
      pointer-events: none;
    }
    @keyframes tnxBadgeShine { to { transform: rotate(360deg); } }

    .tnx-badge-img-wrap {
      width: 90px;
      height: 90px;
      display: grid;
      place-items: center;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.05);
      z-index: 1;
    }

    .tnx-badge-img-wrap img {
      width: 60px;
      height: 60px;
      object-fit: contain;
      filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.5));
    }

    .tnx-badge-card-content { z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; }
    .tnx-badge-tag {
      background: rgba(255, 255, 255, 0.1);
      padding: 0.2rem 0.6rem;
      border-radius: 1rem;
      font-size: 0.7rem;
      color: #d1d5db;
    }
    .tnx-badge-card strong { font-size: 1rem; color: #fff; }
    .tnx-badge-card p { font-size: 0.8rem; color: #6b7280; margin: 0; }

    /* --- Focus Panel (Sidebar) --- */
    .tnx-badge-focus {
      position: sticky;
      top: 6rem;
      padding: 2rem;
      text-align: center;
    }

    .tnx-focus-image {
      width: 140px;
      height: 140px;
      margin: 0 auto 1.5rem;
      background: radial-gradient(circle, var(--primary-gold-dim), transparent);
      border-radius: 50%;
      display: grid;
      place-items: center;
    }
    .tnx-focus-image img { width: 100px; filter: drop-shadow(0 15px 25px rgba(0,0,0,0.6)); }
    .tnx-focus-card h3 { font-size: 1.8rem; margin: 0.5rem 0; color: #fff; }
    .tnx-focus-card > p { color: #9ca3af; font-size: 0.95rem; margin-bottom: 1.5rem; line-height: 1.6;}

    .tnx-focus-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
      text-align: right;
      margin-bottom: 1.5rem;
    }
    .tnx-focus-meta div {
      background: rgba(0,0,0,0.3);
      padding: 0.8rem;
      border-radius: 0.8rem;
      border: 1px solid var(--glass-border);
    }
    .tnx-focus-meta span { display: block; font-size: 0.75rem; color: #9ca3af; margin-bottom: 0.2rem; }
    .tnx-focus-meta strong { color: var(--primary-gold); font-size: 0.9rem; }

    .tnx-focus-copy {
      width: 100%;
      padding: 1rem;
      background: var(--primary-gold-dim);
      border: 1px solid var(--primary-gold);
      color: var(--primary-gold);
      border-radius: 0.8rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s;
    }
    .tnx-focus-copy:hover { background: var(--primary-gold); color: #000; }
    .tnx-focus-copy.is-copied { background: #10b981; border-color: #10b981; color: #fff; }

    /* --- User Search & Cards --- */
    .tnx-user-search { max-width: 600px; margin: 0 auto 2rem; }
    .tnx-user-results { display: grid; gap: 0.5rem; margin-top: 0.5rem; }
    .tnx-user-result {
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--glass-border);
      padding: 1rem;
      border-radius: 0.8rem;
      color: #fff;
      text-align: right;
      cursor: pointer;
      transition: all 0.2s;
    }
    .tnx-user-result:hover { border-color: var(--primary-gold); background: var(--primary-gold-dim); }

    /* REFACTORED USER CARD CSS (Flexbox inside) */
    .tnx-user-card-container {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
    }

    .tnx-user-card-preview {
      width: 100%;
      max-width: 800px;
      background: #111;
      border-radius: 1.5rem;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0,0,0,0.5);
      border: 1px solid rgba(255,255,255,0.1);
      animation: fadeIn 0.4s ease forwards;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .tnx-card-banner {
      width: 100%;
      height: 180px;
      background-size: cover;
      background-position: center;
    }

    .tnx-card-profile-section {
      display: flex;
      flex-direction: row;
      align-items: flex-end;
      gap: 1.5rem;
      padding: 0 2rem 1.5rem;
      margin-top: -60px; /* Pulls content up over banner */
      direction: ltr; /* Keeping LTR for username display naturally */
    }

    .tnx-profile-left {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
    }

    .tnx-card-profile-picture {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      border: 6px solid #1a1a1a; /* Acts as mask over banner */
      background-size: cover;
      background-position: center;
      background-color: var(--profile-border, #423fff);
      z-index: 2;
    }

    .tnx-card-job-info {
      margin-top: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      color: #fff;
      font-weight: 700;
      font-size: 1.1rem;
      background: rgba(0,0,0,0.6);
      padding: 0.3rem 0.8rem;
      border-radius: 1rem;
    }

    .tnx-card-stats-row {
      display: flex;
      gap: 1rem;
      margin-top: 0.5rem;
    }
    .tnx-card-points, .tnx-card-gold {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .tnx-card-points { color: #fff; }
    .tnx-card-gold { color: #ffd700; }

    .tnx-profile-right {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding-bottom: 0.5rem;
    }

    .tnx-card-username {
      font-size: 2.2rem;
      font-weight: 800;
      color: #fff;
      text-shadow: 0 4px 10px rgba(0,0,0,0.8);
      margin-bottom: 0.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tnx-card-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }
    .tnx-card-badges img {
      width: 50px;
      height: 50px;
      object-fit: contain;
      filter: drop-shadow(0 4px 8px rgba(0,0,0,0.4));
      background: rgba(0,0,0,0.2);
      border-radius: 0.5rem;
      padding: 0.2rem;
      border: 1px solid rgba(255,255,255,0.05);
    }

    /* Progress Section Below Card */
    .tnx-progress-panel { margin-top: 2rem; border: none; background: transparent; padding: 0;}
    .tnx-progress-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .tnx-progress-stat {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--glass-border);
      padding: 1.2rem;
      border-radius: 1rem;
      text-align: center;
    }
    .tnx-progress-stat span { color: #9ca3af; font-size: 0.8rem; display: block; margin-bottom: 0.5rem;}
    .tnx-progress-stat strong { color: #fff; font-size: 1.2rem; font-weight: 700; display: block;}
    .tnx-progress-stat small { color: var(--primary-gold); font-size: 0.75rem; margin-top: 0.3rem; display: block;}

    .tnx-paths-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
    .tnx-path-card { background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); border-radius: 1.2rem; padding: 1.5rem; }
    .tnx-path-card h4 { color: var(--primary-gold); font-size: 1.1rem; margin-bottom: 0.5rem; }
    .tnx-path-card p { color: #9ca3af; font-size: 0.85rem; margin-bottom: 1.5rem; }
    
    .tnx-path-steps { display: flex; flex-direction: column; gap: 0.8rem; }
    .tnx-path-step { background: rgba(255,255,255,0.02); padding: 1rem; border-radius: 0.8rem; border: 1px solid transparent; }
    .tnx-path-step.is-open { border-color: rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.05); }
    .tnx-path-step.is-next { border-color: rgba(255, 218, 106, 0.4); background: rgba(255, 218, 106, 0.05); }
    .tnx-step-top { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
    .tnx-step-bar { height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden; }
    .tnx-step-bar i { display: block; height: 100%; width: var(--progress); background: linear-gradient(90deg, #c29200, var(--primary-gold)); }

    /* Responsive adjustments */
    @media (max-width: 1024px) {
      .tnx-vault-layout { grid-template-columns: 1fr; }
      .tnx-badge-focus { position: relative; top: 0; }
    }
    @media (max-width: 640px) {
      .tnx-badges-shell { padding-top: 4rem; }
      .tnx-card-profile-section { flex-direction: column; align-items: center; text-align: center; margin-top: -70px; }
      .tnx-card-badges { justify-content: center; }
      .tnx-card-username { font-size: 1.8rem; white-space: normal; }
    }
  </style>

  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxBadgesPageCleanup'
      if (window[cleanupKey]) window[cleanupKey]()

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach(c => c())
        listeners.length = 0
        timers.forEach(id => window.clearTimeout(id))
        timers.length = 0
      }

      const CATEGORY_META = {
        attendance: { label: 'الحضور', icon: 'D' },
        points: { label: 'النقاط', icon: 'K' },
        quiz: { label: 'الكويز', icon: 'Q' },
        status: { label: 'المكانة', icon: '◆' },
        law: { label: 'المحكمة', icon: '⚖' },
        awards: { label: 'الجوائز', icon: '★' },
        special: { label: 'خاص', icon: '⬟' },
      }

      const BADGE_META = {
        king: { title: 'ملك القناة', category: 'status', how: 'يفتح من نظام King of Channel Points.', rarity: 'نادر جدًا', duration: 'دائم', difficulty: 'صعب' },
        Vip: { title: 'VIP', category: 'status', how: 'منحة خاصة حسب تفاعل العضو ومكانته.', rarity: 'مميز', duration: 'مؤقت أو دائم', difficulty: 'متوسط' },
        '15D': { title: 'حضور 15 يوم', category: 'attendance', how: 'سجّل حضورك اليومي.', rarity: 'أساسي', duration: 'دائم', difficulty: 'سهل' },
        '30D': { title: 'حضور 30 يوم', category: 'attendance', how: 'سجّل حضورك اليومي.', rarity: 'أساسي', duration: 'دائم', difficulty: 'متوسط' },
        LAW: { title: 'رخصة محامي', category: 'law', how: 'تحصل عليه عند تفعيل دور المحامي.', rarity: 'مميز', duration: 'دائم', difficulty: 'صعب' },
        '100K': { title: 'رصيد 100K', category: 'points', how: 'اجمع 100,000 نقطة.', rarity: 'أساسي', duration: 'دائم', difficulty: 'سهل' },
      }

      const BADGE_PATHS = [
        { key: 'points', title: 'مسار النقاط', description: 'يعتمد على رصيد نقاطك الحالي.', unit: 'نقطة', metricKeys: ['points', 'totalPoints'], steps: [{ name: '100K', value: 100000 }, { name: '250K', value: 250000 }, { name: '500K', value: 500000 }, { name: '1M', value: 1000000 }] },
        { key: 'attendance', title: 'مسار الحضور', description: 'يعتمد على عدد أيام الحضور المسجلة.', unit: 'يوم', metricKeys: ['checkins', 'checkIns', 'attendanceDays'], steps: [{ name: '15D', value: 15 }, { name: '30D', value: 30 }, { name: '60D', value: 60 }, { name: '100D', value: 100 }] },
        { key: 'quiz', title: 'مسار الكويز', description: 'يعتمد على عدد الإجابات الصحيحة.', unit: 'إجابة', metricKeys: ['quizCorrect', 'correctAnswers'], steps: [{ name: '50Q', value: 50 }, { name: '150Q', value: 150 }, { name: '300Q', value: 300 }] }
      ]

      const JOB_ICONS = window.JOB_ICONS || { tier1_Citizen: 'mdi:account', tier3_Merchant: 'mdi:store' }
      window.JOB_ICONS = JOB_ICONS

      const state = { badges: [], users: [], filter: 'all', search: '', selectedBadgeName: '' }

      // Utility Functions
      const esc = v => String(v ?? '').replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[m])
      const safeUrl = v => { const u = String(v||'').trim(); return (/^https?:\/\//i.test(u) || u.startsWith('/')) ? u.replace(/["'()\\]/g, '') : '' }
      const safeColor = (v, f = '#423fff') => /^#[0-9a-fA-F]{6}$/.test(String(v||'').trim()) ? v : f
      const normalize = v => String(v||'').toLowerCase().replace(/[ًٌٍَُِّْـ]/g, '').replace(/[أإآ]/g, 'ا').replace(/ة/g, 'ه').replace(/ى/g, 'ي').trim()
      const badgeKey = v => normalize(v).replace(/\s+/g, '')
      const formatNumber = n => Number(n || 0).toLocaleString('en-US')
      const parseNumber = v => { const c = String(v).replace(/[^\d.-]/g, ''); return c ? Number(c) : null }
      
      const badgeSlug = name => `badge-${String(name||'').trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/gi, '')}`

      function getBadgeMeta(name) { return BADGE_META[name] || { title: name, category: 'special', how: 'بادج خاص.', rarity: 'خاص', duration: 'دائم', difficulty: 'غير محدد' } }

      function enrichBadge(badge, index) {
        const name = String(badge?.name || '').trim()
        const meta = getBadgeMeta(name)
        const category = CATEGORY_META[meta.category] ? meta.category : 'special'
        const hashId = badgeSlug(name)
        return {
          index, name, hashId, image: safeUrl(badge?.image), title: meta.title, category,
          categoryLabel: CATEGORY_META[category]?.label || 'خاص', how: meta.how, rarity: meta.rarity,
          difficulty: meta.difficulty, duration: meta.duration,
          searchText: normalize(`${name} ${meta.title} ${meta.category} ${hashId}`),
          isRare: ['نادر', 'جائزة', 'خاص'].some(w => String(meta.rarity).includes(w))
        }
      }

      function updateStats() {
        document.getElementById('statTotalBadges').textContent = state.badges.length
        document.getElementById('statCategories').textContent = new Set(state.badges.map(b => b.category)).size
        document.getElementById('statRareBadges').textContent = state.badges.filter(b => b.isRare).length
        
        const counts = { all: state.badges.length }
        state.badges.forEach(b => counts[b.category] = (counts[b.category] || 0) + 1)
        Object.keys(CATEGORY_META).concat(['all']).forEach(k => {
          const el = document.getElementById(`count-${k}`)
          if(el) el.textContent = counts[k] || 0
        })
      }

      function renderBadges() {
        const grid = document.getElementById('badgeGrid')
        if (!grid) return
        
        const filtered = state.badges.filter(b => (state.filter === 'all' || b.category === state.filter) && (!state.search || b.searchText.includes(normalize(state.search))))
        document.getElementById('badgeEmpty').classList.toggle('hidden', filtered.length > 0)
        
        grid.innerHTML = filtered.map(b => `
          <button type="button" id="${esc(b.hashId)}" class="tnx-badge-card ${b.name === state.selectedBadgeName ? 'is-selected' : ''} ${b.isRare ? 'is-rare' : ''}" data-badge-name="${esc(b.name)}">
            <div class="tnx-badge-img-wrap"><img src="${esc(b.image)}" alt="${esc(b.name)}" loading="lazy"/></div>
            <div class="tnx-badge-card-content">
              <span class="tnx-badge-tag">${esc(b.categoryLabel)}</span>
              <strong>${esc(b.title)}</strong>
              <p>${esc(b.rarity)}</p>
            </div>
          </button>
        `).join('')
      }

      function renderBadgeFocus(badge) {
        const panel = document.getElementById('badgeFocusPanel')
        if(!panel || !badge) return
        panel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-image"><img src="${esc(badge.image)}" alt="${esc(badge.name)}"/></div>
            <span class="tnx-badge-tag" style="margin:0 auto 1rem;">${esc(badge.categoryLabel)}</span>
            <h3>${esc(badge.title)}</h3>
            <p>${esc(badge.how)}</p>
            <div class="tnx-focus-meta">
              <div><span>الندرة</span><strong>${esc(badge.rarity)}</strong></div>
              <div><span>الصعوبة</span><strong>${esc(badge.difficulty)}</strong></div>
              <div><span>المدة</span><strong>${esc(badge.duration)}</strong></div>
              <div><span>الاسم التقني</span><strong>${esc(badge.name)}</strong></div>
            </div>
            <button type="button" class="tnx-focus-copy" data-copy-badge="${esc(badge.hashId)}">نسخ رابط البادج</button>
          </div>
        `
      }

      function selectBadge(name) {
        const badge = state.badges.find(b => b.name === name)
        if(!badge) return
        state.selectedBadgeName = badge.name
        renderBadges()
        renderBadgeFocus(badge)
      }

      // User Card Rendering (REWRITTEN HTML STRUCTURE FOR FLEXBOX)
      function renderUserCard(user) {
        const container = document.getElementById('userCardContainer')
        if(!container || !user) return

        const baseColor = safeColor(user.backgroundColor || '#423fff')
        const bgStyle = `background-color: #1a1a24;` // Removed hard gradient to keep it clean, relying on CSS
        
        const name = user.userName || 'Unknown'
        const login = user.userLogin || ''
        const displayLabel = normalize(name) !== normalize(login) && login ? `${name} (${login})` : name
        
        const jobIcon = JOB_ICONS[user.jobId] || 'mdi:account'
        const badgesHtml = (user.badges || []).filter(b => b.equipped).slice(0, 6)
          .map(b => `<img src="${esc(safeUrl(b.url))}" title="${esc(b.name)}" loading="lazy"/>`).join('')

        const bannerUrl = safeUrl(user.bannerImage) ? `url('${safeUrl(user.bannerImage)}')` : 'none'
        const profileUrl = safeUrl(user.profileImageUrl) ? `url('${safeUrl(user.profileImageUrl)}')` : 'none'

        container.innerHTML = `
          <div class="tnx-user-card-preview" style="--profile-border: ${baseColor}; ${bgStyle}">
            <div class="tnx-card-banner" style="background-image: ${bannerUrl}; background-color: rgba(0,0,0,0.5)"></div>
            <div class="tnx-card-profile-section">
              <div class="tnx-profile-left">
                <div class="tnx-card-profile-picture" style="background-image: ${profileUrl};"></div>
                <div class="tnx-card-job-info"><iconify-icon icon="${esc(jobIcon)}"></iconify-icon> ${esc(user.jobName || 'Citizen')}</div>
                <div class="tnx-card-stats-row">
                  <div class="tnx-card-points"><iconify-icon icon="mdi:star-four-points-circle"></iconify-icon>${formatNumber(user.points)}</div>
                  <div class="tnx-card-gold"><iconify-icon icon="mdi:gold"></iconify-icon>${formatNumber(user.gold)}</div>
                </div>
              </div>
              <div class="tnx-profile-right">
                <div class="tnx-card-username" title="${esc(displayLabel)}">${esc(displayLabel)}</div>
                <div class="tnx-card-badges">${badgesHtml}</div>
              </div>
            </div>
          </div>
          
          <div class="tnx-progress-panel">
            <div class="tnx-progress-summary">
              <div class="tnx-progress-stat"><span>النقاط</span><strong>${formatNumber(user.points)}</strong></div>
              <div class="tnx-progress-stat"><span>البادجات المفتوحة</span><strong>${(user.badges||[]).length}</strong></div>
            </div>
          </div>
        `
      }

      // Event Listeners Setup
      addListener(document.getElementById('badgeGrid'), 'click', e => {
        const btn = e.target.closest('.tnx-badge-card')
        if(btn) selectBadge(btn.dataset.badgeName)
      })

      addListener(document.getElementById('badgeSearch'), 'input', e => {
        state.search = e.target.value
        renderBadges()
      })

      document.querySelectorAll('[data-badge-filter]').forEach(btn => {
        addListener(btn, 'click', () => {
          document.querySelectorAll('[data-badge-filter]').forEach(b => b.classList.remove('is-active'))
          btn.classList.add('is-active')
          state.filter = btn.dataset.badgeFilter
          renderBadges()
        })
      })

      addListener(document.getElementById('userSearch'), 'input', e => {
        const q = normalize(e.target.value)
        const res = document.getElementById('userResults')
        if(!q) { res.innerHTML = ''; return }
        
        const matches = state.users.filter(u => normalize(u.userName).includes(q) || normalize(u.userLogin).includes(q)).slice(0,5)
        res.innerHTML = matches.map((u,i) => `<div class="tnx-user-result" data-idx="${i}">${esc(u.userName)}</div>`).join('')
        
        res.querySelectorAll('.tnx-user-result').forEach(btn => {
          addListener(btn, 'click', () => {
            renderUserCard(matches[btn.dataset.idx])
            res.innerHTML = ''
            document.getElementById('userSearch').value = ''
          })
        })
      })

      // Fetch Data
      async function init() {
        try {
          const resB = await fetch('/api/badges.json').catch(()=>({ok:false}))
          if(resB.ok) {
            const data = await resB.json()
            state.badges = data.map(enrichBadge)
            updateStats()
            renderBadges()
            if(state.badges.length) selectBadge(state.badges[0].name)
          }
          
          const resU = await fetch('/api/user_badges.json').catch(()=>({ok:false}))
          if(resU.ok) state.users = await resU.json()
        } catch(e) { console.error('Data load error', e) }
      }
      
      init()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
