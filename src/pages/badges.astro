    .tnx-next-hero {
      display: grid;
      grid-template-columns: 148px minmax(0, 1fr);
      gap: 1.35rem;
      align-items: center;
      width: min(100%, 900px);
      margin-inline: auto;
      border: 1px solid rgba(255, 218, 106, 0.38);
      border-radius: 1.65rem;
      background:
        radial-gradient(circle at 10% 50%, rgba(255, 218, 106, 0.25), transparent 48%),
        radial-gradient(circle at 88% 14%, rgba(255, 218, 106, 0.13), transparent 36%),
        linear-gradient(135deg, rgba(255, 218, 106, 0.11), rgba(0, 0, 0, 0.48) 66%);
      padding: 1.35rem 1.45rem;
      color: white;
      text-align: right;
      cursor: pointer;
      transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1), border-color 220ms ease, box-shadow 220ms ease;
      will-change: transform;
      box-shadow:
        0 26px 70px rgba(0, 0, 0, 0.46),
        0 0 38px rgba(255, 218, 106, 0.13),
        inset 0 0 0 1px rgba(255, 255, 255, 0.03);
      position: relative;
      overflow: hidden;
    }

    .tnx-next-hero::before {
      content: '';
      position: absolute;
      inset: -50%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 218, 106, 0.12), transparent 30%);
      animation: tnxNextShine 6s linear infinite;
      pointer-events: none;
    }

    .tnx-next-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255, 218, 106, 0.08), transparent 32%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 44%);
