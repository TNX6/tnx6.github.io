            remaining: null,
            unit: '',
            label: 'مقفل',
            hint: badge.how,
          }
        }

        const metric = getMetric(user, pathStep.path.metricKeys)

        if (metric === null) {
          return {
            status: 'locked',
            progress: null,
            remaining: null,
            unit: pathStep.path.unit,
            label: 'مقفل',
            hint: badge.how,
          }
        }

        const progress = Math.max(0, Math.min(100, (metric / pathStep.step.value) * 100))
        const remaining = Math.max(0, pathStep.step.value - metric)

        if (metric >= pathStep.step.value) {
          return {
            status: 'eligible',
            progress: 100,
            remaining: 0,
            unit: pathStep.path.unit,
            label: 'مؤهل',
            hint: 'حققت الشرط الرقمي. يحتاج ينضاف لك البادج من النظام.',
          }
        }

        return {
          status: 'locked',
          progress,
          remaining,
          unit: pathStep.path.unit,
          label: 'مقفل',
          hint: `باقي ${formatNumber(remaining)} ${pathStep.path.unit}`,
        }
      }

      function enrichBadge(badge, index) {
        const name = String(badge?.name || '').trim()
        const meta = getBadgeMeta(name)
        const category = CATEGORY_META[meta.category] ? meta.category : 'special'
        const hashId = badgeSlug(name)

        const searchText = normalize([
          name,
          meta.title,
          meta.category,
          meta.how,
          meta.rarity,
          meta.duration,
          meta.difficulty,
          CATEGORY_META[category]?.label,
          hashId,
        ].join(' '))

        return {
          index,
          name,
          hashId,
          image: safeUrl(badge?.image),
          title: meta.title,
          category,
          categoryLabel: CATEGORY_META[category]?.label || 'خاص',
          categoryIcon: CATEGORY_META[category]?.icon || '⬟',
          how: meta.how,
          rarity: meta.rarity,
          duration: meta.duration,
          difficulty: meta.difficulty,
          searchText,
          isRare: ['نادر', 'نادر جدًا', 'جائزة', 'خاص'].some((word) => String(meta.rarity).includes(word)),
        }
      }

      function updateStats() {
        const categories = new Set(state.badges.map((b) => b.category))
        const rare = state.badges.filter((b) => b.isRare).length

        if (statTotalBadges) statTotalBadges.textContent = String(state.badges.length)
        if (statCategories) statCategories.textContent = String(categories.size)
        if (statRareBadges) statRareBadges.textContent = String(rare)

        const counts = {
          all: state.badges.length,
          attendance: 0,
          points: 0,
          quiz: 0,
          status: 0,
          law: 0,
          awards: 0,
          special: 0,
        }

        state.badges.forEach((badge) => {
          counts[badge.category] = (counts[badge.category] || 0) + 1
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function getFilteredBadges() {
        return state.badges.filter((badge) => {
          const filterMatch = state.filter === 'all' || badge.category === state.filter
          const searchMatch = !state.search || badge.searchText.includes(normalize(state.search))
          return filterMatch && searchMatch
        })
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.badgeFilter === state.filter)
        })
      }

      function renderBadges() {
        const badges = getFilteredBadges()

        if (!badgeGrid) return

        badgeEmpty?.classList.toggle('hidden', badges.length > 0)

        badgeGrid.innerHTML = badges.map((badge, index) => {
          const selected = badge.name === state.selectedBadgeName ? ' is-selected' : ''
          const linked = window.location.hash === `#${badge.hashId}` ? ' is-linked' : ''
          const rare = badge.isRare ? ' is-rare' : ''

          return `
            <button
              type="button"
              id="${esc(badge.hashId)}"
              class="tnx-badge-card${selected}${linked}${rare}"
              style="--stagger:${index}"
              data-badge-name="${esc(badge.name)}"
              data-badge-hash="${esc(badge.hashId)}"
            >
              <div class="tnx-badge-img-wrap">
                <img src="${esc(badge.image)}" alt="${esc(badge.name)}" loading="lazy" />
              </div>

              <div class="tnx-badge-card-content">
                <span class="tnx-badge-tag">${esc(badge.categoryLabel)}</span>
                <strong>${esc(badge.title)}</strong>
                <p>${esc(badge.rarity)} · ${esc(badge.difficulty)}</p>
              </div>
            </button>
          `
        }).join('')
      }

      function renderBadgeFocus(badge) {
        if (!badgeFocusPanel || !badge) return

        badgeFocusPanel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-image">
              <img src="${esc(badge.image)}" alt="${esc(badge.name)}" loading="lazy" />
            </div>

            <div>
              <span class="tnx-badge-tag">${esc(badge.categoryLabel)}</span>
              <h3>${esc(badge.title)}</h3>
            </div>

            <p>${esc(badge.how)}</p>

            <div class="tnx-focus-meta">
              <div>
                <span>الندرة</span>
                <strong>${esc(badge.rarity)}</strong>
              </div>

              <div>
                <span>الصعوبة</span>
                <strong>${esc(badge.difficulty)}</strong>
              </div>

              <div>
                <span>المدة</span>
                <strong>${esc(badge.duration)}</strong>
              </div>

              <div>
                <span>الاسم التقني</span>
                <strong>${esc(badge.name)}</strong>
              </div>
            </div>

            <button type="button" class="tnx-focus-copy" data-copy-badge-link="${esc(badge.hashId)}">
              نسخ رابط البادج
            </button>
          </div>
        `
      }

      function selectBadge(name, options = {}) {
        const badge = state.badges.find((item) => item.name === name)
        if (!badge) return

        state.selectedBadgeName = badge.name

        if (options.updateHash !== false) {
          history.replaceState(null, '', `#${badge.hashId}`)
        }

        renderBadges()
        renderBadgeFocus(badge)

        if (options.scrollToBadge) {
          addTimer(window.setTimeout(() => {
            const card = document.getElementById(badge.hashId)
            card?.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }, 80))
        }
      }

      function openBadgeFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('badge-')) return false

        const badge = state.badges.find((item) => item.hashId === hash)
        if (!badge) return false

        state.filter = 'all'
        state.search = ''

        if (badgeSearch) badgeSearch.value = ''

        renderFilterButtons()
        selectBadge(badge.name, { updateHash: false, scrollToBadge: options.scrollToBadge !== false })

        document.querySelector('.tnx-vault')?.scrollIntoView({
          behavior: options.instant ? 'auto' : 'smooth',
          block: 'start',
        })

        return true
      }

      function getBadgeLink(hashId) {
        return `${window.location.origin}${window.location.pathname}${window.location.search}#${hashId}`
      }

      function getUserLink(user) {
        const username = String(user?.userLogin || user?.userName || '').trim()
        const url = new URL(window.location.href)
        url.searchParams.set('user', username)
        url.hash = ''
        return url.toString()
      }

      function setUserQuery(user) {
        const username = String(user?.userLogin || user?.userName || '').trim()
        if (!username) return

        const url = new URL(window.location.href)
        url.searchParams.set('user', username)
        url.hash = ''
        history.replaceState(null, '', `${url.pathname}${url.search}`)
      }

      function openUserFromQuery() {
        const params = new URLSearchParams(window.location.search)
        const rawUser = params.get('user')
        if (!rawUser) return false

        const key = normalize(rawUser)
        let user = state.users.find((item) => normalize(item.userLogin) === key)
        if (!user) user = state.users.find((item) => normalize(item.userName) === key)
        if (!user) user = state.users.find((item) => normalize(item.userLogin).includes(key) || normalize(item.userName).includes(key))
        if (!user) return false

        renderUserCard(user, { resetVaultPage: true })

        addTimer(window.setTimeout(() => {
          document.querySelector('.tnx-users')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        }, 180))

        return true
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent

        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
            button.classList.remove('is-copied')
          }, 1000))
        } catch {
          button.textContent = text

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
          }, 1300))
        }
      }

      async function loadBadges() {
        try {
          const res = await fetch('/api/badges.json')
          if (!res.ok) throw new Error(`Badges request failed: ${res.status}`)

          const rawBadges = await res.json()
          const list = Array.isArray(rawBadges) ? rawBadges : []

          state.badges = list
            .map(enrichBadge)
            .filter((badge) => badge.name && badge.image)

          updateStats()
          renderFilterButtons()
          renderBadges()

          const openedFromHash = openBadgeFromHash({ instant: true, scrollToBadge: true })

          if (!openedFromHash && state.badges.length > 0) {
            selectBadge(state.badges[0].name, { updateHash: false })
          }
        } catch (error) {
          console.error('Failed to load badges.json', error)

          if (badgeGrid) {
            badgeGrid.innerHTML = `
              <div class="tnx-empty">
                <strong>تعذر تحميل البادجات</strong>
                <span>تأكد من وجود الملف في public/api/badges.json</span>
              </div>
            `
          }
        }
      }

      function renderUserResults(query) {
        if (!userResults) return

        const q = normalize(query)

        userResults.innerHTML = ''

        if (!q) return

        const matches = state.users
          .map((user, index) => ({ user, index }))
          .filter(({ user }) => {
            return normalize(user.userName).includes(q) || normalize(user.userLogin).includes(q)
          })
          .slice(0, 10)

        if (matches.length === 0) {
          userResults.innerHTML = `
            <div class="tnx-empty">
              <strong>مافيه نتائج</strong>
              <span>تأكد من كتابة اسم المستخدم بشكل صحيح.</span>
            </div>
          `
          return
        }

        userResults.innerHTML = matches.map(({ user, index }) => {
          const userName = String(user.userName || '')
          const userLogin = String(user.userLogin || '')
          const label = normalize(userName) !== normalize(userLogin)
            ? `${userName} (${userLogin})`
            : userName

          return `
            <button type="button" class="tnx-user-result" data-user-index="${index}">
              ${esc(label)}
            </button>
          `
        }).join('')
      }

      function getNextBadgeForUser(user, unlockedSet) {
        const candidates = []

        BADGE_PATHS.forEach((path) => {
          const metric = getMetric(user, path.metricKeys)
          if (metric === null) return

          path.steps.forEach((step) => {
            if (unlockedSet.has(badgeKey(step.name))) return

            const badge = getBadgeByName(step.name)
            if (!badge) return

            const remaining = Math.max(0, step.value - metric)
            const progress = Math.max(0, Math.min(100, (metric / step.value) * 100))
            const eligible = metric >= step.value

            candidates.push({
              badge,
              remaining,
              progress: eligible ? 100 : progress,
              unit: path.unit,
              eligible,
              fallback: false,
            })
          })
        })

        if (candidates.length > 0) {
          candidates.sort((a, b) => {
            if (a.eligible && !b.eligible) return -1
            if (!a.eligible && b.eligible) return 1
            return (b.progress || 0) - (a.progress || 0)
          })

          return candidates[0]
        }

        const fallbackNames = ['15D', '100K', '50Q']
        for (const name of fallbackNames) {
          const badge = getBadgeByName(name)
          if (badge && !unlockedSet.has(badgeKey(badge.name))) {
            return { badge, remaining: null, progress: null, unit: '', eligible: false, fallback: true }
          }
        }

        const firstLocked = state.badges.find((badge) => !unlockedSet.has(badgeKey(badge.name)))
        if (firstLocked) {
          return { badge: firstLocked, remaining: null, progress: null, unit: '', eligible: false, fallback: true }
        }

        return null
      }

      function renderNextBadgeBlock(nextBadge) {
        if (!nextBadge) {
          return `
            <div class="tnx-next-hero tnx-next-hero--done">
              <div class="tnx-next-icon-done">✓</div>
              <div>
                <strong>أحسنت! كل البادجات الرقمية مفتوحة.</strong>
                <p>الباقي تكريمي أو خاص ويعطى من إدارة المجتمع.</p>
              </div>
            </div>
          `
        }

        const badge = nextBadge.badge
        const progress = nextBadge.progress !== null ? Math.round(nextBadge.progress) : null
        const pathInfo = getPathStepForBadge(badge.name)

        const remainingHtml = nextBadge.eligible
          ? 'أنت مؤهل لهذا البادج. باقي فقط ينضاف لك من النظام.'
          : nextBadge.remaining !== null
            ? `باقي عليك <b>${formatNumber(nextBadge.remaining)} ${esc(nextBadge.unit)}</b> فقط.`
            : esc(badge.how)

        const label = nextBadge.eligible ? '⚠️ جاهز للاستلام' : '🎯 أقرب بادج لك'
        const chipPath = pathInfo ? pathInfo.path.title : badge.categoryLabel
        const chipTarget = pathInfo ? `${formatNumber(pathInfo.step.value)} ${pathInfo.path.unit}` : badge.rarity

        const progressHtml = progress !== null
          ? `
            <div class="tnx-next-progress-wrap">
              <div class="tnx-next-progress">
                <div class="tnx-next-fill" style="--target-width: ${progress}%;"></div>
              </div>
              <span class="tnx-next-percent">${progress}%</span>
            </div>
          `
          : `<span class="tnx-next-hint">${esc(badge.how)}</span>`

        return `
          <button type="button" class="tnx-next-hero" data-badge-jump="${esc(badge.hashId)}">
            <div class="tnx-next-img-wrap">
              <img src="${esc(badge.image)}" alt="${esc(badge.title)}" loading="lazy" />
            </div>

            <div class="tnx-next-content">
              <div class="tnx-next-label">${label}</div>
              <strong class="tnx-next-title">${esc(badge.title)}</strong>
              <p class="tnx-next-desc">${remainingHtml}</p>

              <div class="tnx-next-chip-row">
                <span class="tnx-next-chip">المسار: <strong>${esc(chipPath)}</strong></span>
                <span class="tnx-next-chip">الهدف: <strong>${esc(chipTarget)}</strong></span>
                <span class="tnx-next-chip">اضغط لعرض التفاصيل</span>
              </div>

              ${progressHtml}
            </div>
          </button>
        `
      }

      function renderVaultGrid(user, unlockedSet) {
        const order = { owned: 0, eligible: 1, locked: 2 }
        const perPage = 20

        const sortedItems = state.badges
          .map((badge) => {
            const info = getBadgeProgressInfo(user, badge, unlockedSet)
            return { badge, info }
          })
          .sort((a, b) => {
            const statusDiff = order[a.info.status] - order[b.info.status]
            if (statusDiff !== 0) return statusDiff
            return a.badge.index - b.badge.index
          })

        const totalPages = Math.max(1, Math.ceil(sortedItems.length / perPage))
        state.vaultPage = Math.min(Math.max(1, state.vaultPage || 1), totalPages)

        const start = (state.vaultPage - 1) * perPage
        const pageItems = sortedItems.slice(start, start + perPage)

        const items = pageItems.map(({ badge, info }, index) => {
          const iconHtml =
            info.status === 'owned'
              ? `<span class="tnx-vault-check">✓</span>`
              : info.status === 'eligible'
                ? `<span class="tnx-vault-ready">!</span>`
                : `<span class="tnx-vault-lock">🔒</span>`

          const statusClass =
            info.status === 'owned'
              ? 'is-owned'
              : info.status === 'eligible'
                ? 'is-eligible'
                : 'is-locked'

          const hint = info.status === 'eligible'
            ? 'أنت مؤهل لهذا البادج، يحتاج ينضاف لك من النظام.'
            : info.hint

          return `
            <button
              type="button"
              class="tnx-vault-badge ${statusClass}"
              style="--stagger:${index}"
              data-badge-jump="${esc(badge.hashId)}"
              title="${esc(hint)}"
            >
              <div class="tnx-vault-badge-img">
                <img src="${esc(badge.image)}" alt="${esc(badge.title)}" loading="lazy" />
                ${iconHtml}
              </div>

              <span class="tnx-vault-name">${esc(badge.title)}</span>
              <span class="tnx-vault-hint">${esc(hint)}</span>
            </button>
          `
        }).join('')

        const pagination = totalPages > 1
          ? `
            <div class="tnx-vault-pagination">
              <button type="button" class="tnx-vault-page-btn" data-vault-page="prev" ${state.vaultPage <= 1 ? 'disabled' : ''}>
                السابق
              </button>

              <span class="tnx-vault-page-label">صفحة ${formatNumber(state.vaultPage)} / ${formatNumber(totalPages)}</span>

              <button type="button" class="tnx-vault-page-btn" data-vault-page="next" ${state.vaultPage >= totalPages ? 'disabled' : ''}>
                التالية
              </button>
            </div>
          `
          : ''

        return `
          <div class="tnx-vault-grid">
            ${items}
          </div>
          ${pagination}
        `
      }

      function renderUserProgress(user, equippedBadges) {
        const unlockedSet = getUserBadgeSet(user)

        const unlockedBadges = state.badges.filter((b) => unlockedSet.has(badgeKey(b.name)))
        const eligibleBadges = state.badges.filter((b) => {
          const info = getBadgeProgressInfo(user, b, unlockedSet)
          return info.status === 'eligible'
        })
        const lockedBadges = state.badges.filter((b) => {
          const info = getBadgeProgressInfo(user, b, unlockedSet)
          return info.status === 'locked'
        })

        const unlockedCount = unlockedBadges.length
        const eligibleCount = eligibleBadges.length
        const lockedCount = lockedBadges.length
        const totalCount = state.badges.length
        const percent = totalCount > 0 ? Math.round((unlockedCount / totalCount) * 100) : 0
        const nextBadge = getNextBadgeForUser(user, unlockedSet)

        return `
          <section class="tnx-progress-panel">
            <div class="tnx-overall">
              <div class="tnx-overall-text">
                <div>
                  <strong>${formatNumber(unlockedCount)} من ${formatNumber(totalCount)} بادج</strong>
                  <span>${percent}% مكتمل</span>
                </div>

                <button type="button" class="tnx-share-card-link" data-copy-user-link="${esc(user.userLogin || user.userName || '')}">
                  مشاركة البطاقة
                </button>
              </div>

              <div class="tnx-overall-track">
                <div class="tnx-overall-fill" style="--target-width: ${percent}%;"></div>
              </div>
            </div>

            ${renderNextBadgeBlock(nextBadge)}

            <div class="tnx-vault-section">
              <div class="tnx-vault-section-head">
                <strong>خزينتك</strong>
                <span>
                  <b>${formatNumber(unlockedCount)}</b> مفتوحة ·
                  <i>${formatNumber(eligibleCount)}</i> مؤهل ·
                  <em>${formatNumber(lockedCount)}</em> باقية
                </span>
              </div>

              ${renderVaultGrid(user, unlockedSet)}
            </div>
          </section>
        `
      }

      function renderUserCard(details, options = {}) {
        if (!userCardContainer || !details) return

        state.currentUser = details
        if (options.resetVaultPage !== false) state.vaultPage = 1

        const baseColor = safeColor(details.backgroundColor || '#423fff')
        const darkColor = shade(baseColor, -20)

        const displayName = String(details.userName || '')
        const login = String(details.userLogin || '')
        const username = normalize(displayName) !== normalize(login)
          ? `${displayName} (${login})`
          : displayName

        const jobIcon = JOB_ICONS[details.jobId] || 'mdi:account'
        const equippedBadges = Array.isArray(details.badges)
          ? details.badges.filter((badge) => badge.equipped).slice(0, 6)
          : []

        const badgeHtml = equippedBadges.map((badge) => {
          return `<img src="${esc(safeUrl(badge.url))}" alt="${esc(badge.name)}" loading="lazy" />`
        }).join('')

        const bannerUrl = safeUrl(details.bannerImage || '')
        const profileUrl = safeUrl(details.profileImageUrl || '')
        const bannerImage = cssUrl(bannerUrl)
        const profileImage = cssUrl(profileUrl)

        userCardContainer.innerHTML = `
          <div class="tnx-card-wrap">
            <div
              class="tnx-user-card-preview"
              dir="ltr"
              style="background: linear-gradient(to bottom, ${baseColor} 70%, ${darkColor} 100%); --profile-border: ${baseColor};"
            >
              <div
                class="tnx-card-banner"
                style="background-image: ${bannerImage};"
              ></div>

              <div class="tnx-card-profile-section">
                <div class="tnx-card-picture-points">
                  <div
                    class="tnx-card-profile-picture"
                    style="background-image: ${profileImage};"
                  ></div>

                  <div class="tnx-card-job-info">
                    <iconify-icon icon="${esc(jobIcon)}"></iconify-icon>
                    ${esc(details.jobName || 'Citizen')}
                  </div>

                  <div class="tnx-card-stats-row">
                    <div class="tnx-card-points">
                      <iconify-icon icon="mdi:star-four-points-circle"></iconify-icon>
                      ${formatNumber(details.points)}
                    </div>

                    <div class="tnx-card-gold">
                      <iconify-icon icon="mdi:gold"></iconify-icon>
                      ${formatNumber(details.gold)}
                    </div>
                  </div>
                </div>

                <div class="tnx-card-username">${esc(username)}</div>

                <div class="tnx-card-badges">
                  ${badgeHtml}
                </div>
              </div>
            </div>
          </div>

          ${renderUserProgress(details, equippedBadges)}
        `
      }

      async function loadUsers() {
        try {
          const res = await fetch('/api/user_badges.json')
          if (!res.ok) throw new Error(`Users request failed: ${res.status}`)

          const users = await res.json()
          state.users = Array.isArray(users) ? users : []
        } catch (error) {
          console.error('Failed to load user_badges.json', error)
          state.users = []
        }
      }


      function handleBackToTopVisibility() {
        if (!backToTop) return
        backToTop.classList.toggle('is-visible', window.scrollY > 520)
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth',
        })
      })

      addListener(window, 'scroll', handleBackToTopVisibility, { passive: true })

      addListener(badgeGrid, 'click', (event) => {
        const card = event.target.closest('[data-badge-name]')
        if (!card) return

        selectBadge(card.dataset.badgeName)
      })

      addListener(document, 'click', (event) => {
        const userLinkButton = event.target.closest('[data-copy-user-link]')

        if (userLinkButton) {
          const username = userLinkButton.dataset.copyUserLink || ''
          const user = state.users.find((item) => normalize(item.userLogin) === normalize(username) || normalize(item.userName) === normalize(username))

          if (user) {
            copyText(getUserLink(user), userLinkButton, 'تم نسخ الرابط')
          }

          return
        }

        const vaultPageButton = event.target.closest('[data-vault-page]')

        if (vaultPageButton && state.currentUser) {
          const dir = vaultPageButton.dataset.vaultPage
          if (dir === 'next') state.vaultPage += 1
          if (dir === 'prev') state.vaultPage -= 1
          renderUserCard(state.currentUser, { resetVaultPage: false })
          return
        }

        const linkButton = event.target.closest('[data-copy-badge-link]')

        if (linkButton) {
          const hashId = linkButton.dataset.copyBadgeLink || ''
          copyText(getBadgeLink(hashId), linkButton, 'تم نسخ الرابط')
          return
        }

        const jumpButton = event.target.closest('[data-badge-jump]')

        if (jumpButton) {
          const hashId = jumpButton.dataset.badgeJump || ''
          const badge = state.badges.find((b) => b.hashId === hashId)

          if (badge) {
            state.filter = 'all'
            state.search = ''

            if (badgeSearch) badgeSearch.value = ''

            renderFilterButtons()
            selectBadge(badge.name, { updateHash: true, scrollToBadge: true })

            document.querySelector('.tnx-vault')?.scrollIntoView({
              behavior: 'smooth',
              block: 'start',
            })
          }
        }
      })

      addListener(window, 'hashchange', () => {
        openBadgeFromHash({ scrollToBadge: true })
      })

      addListener(badgeSearch, 'input', () => {
        state.search = badgeSearch.value
        renderBadges()
      })

      addListener(clearBadgeSearch, 'click', () => {
        if (!badgeSearch) return

        badgeSearch.value = ''
        state.search = ''
        badgeSearch.focus()
        renderBadges()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.badgeFilter || 'all'
          renderFilterButtons()
          renderBadges()
        })
      })

      guideButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.guideFilter || 'all'
          state.search = ''

          if (badgeSearch) badgeSearch.value = ''

          renderFilterButtons()
          renderBadges()

          document.querySelector('.tnx-vault')?.scrollIntoView({
            behavior: 'smooth',
            block: 'start',
          })
        })
      })

      addListener(userSearch, 'input', () => {
        renderUserResults(userSearch.value)
      })

      addListener(clearUserSearch, 'click', () => {
        if (!userSearch) return

        userSearch.value = ''
        userResults.innerHTML = ''
        userSearch.focus()
      })

      addListener(userResults, 'click', (event) => {
        const button = event.target.closest('[data-user-index]')
        if (!button) return

        const index = Number(button.dataset.userIndex)
        const user = state.users[index]

        if (!user) return

        if (userSearch) userSearch.value = ''
        if (userResults) userResults.innerHTML = ''

        setUserQuery(user)
        renderUserCard(user, { resetVaultPage: true })
      })

      await loadBadges()
      await loadUsers()
      openUserFromQuery()
      handleBackToTopVisibility()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
