---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Badges — TNX6',
  ignoreTitleTemplate: true,
  description: 'صفحة بادجات مجتمع TNX6.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-badges-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <section class="tnx-shell">
      <header class="tnx-hero">
        <div class="tnx-eyebrow">
          <span></span>
          TNX6 BADGE VAULT
        </div>

        <h1>خزنة البادجات</h1>

        <p>
          اعرف وش البادجات الموجودة، كيف تفتحها، وشف تقدم أي عضو في النقاط والحضور والكويز.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statTotalBadges">0</strong>
            <span>بادج</span>
          </div>
          <div>
            <strong id="statCategories">0</strong>
            <span>تصنيف</span>
          </div>
          <div>
            <strong id="statRareBadges">0</strong>
            <span>نادر / خاص</span>
          </div>
        </div>
      </header>

      <section class="tnx-start">
        <div class="tnx-section-head">
          <span>للمشاهد الجديد</span>
          <h2>وش أبدأ أفتح؟</h2>
          <p>ابدأ بالمسارات الأساسية. حضور، نقاط، ثم كويز.</p>
        </div>

        <div class="tnx-start-grid">
          <button type="button" class="tnx-start-card" data-guide-filter="attendance">
            <b>15</b>
            <div>
              <strong>ابدأ بالحضور</strong>
              <p>سجّل حضورك وابدأ من 15D ثم كمل للمراحل الأعلى.</p>
            </div>
          </button>

          <button type="button" class="tnx-start-card" data-guide-filter="points">
            <b>K</b>
            <div>
              <strong>اجمع نقاط</strong>
              <p>كل ما زاد رصيدك تفتح بادجات 100K وما بعدها.</p>
            </div>
          </button>

          <button type="button" class="tnx-start-card" data-guide-filter="quiz">
            <b>Q</b>
            <div>
              <strong>جاوب بالكويز</strong>
              <p>الإجابات الصحيحة تفتح بادجات 50Q إلى 1000Q.</p>
            </div>
          </button>
        </div>
      </section>

      <section class="tnx-vault">
        <div class="tnx-vault-top">
          <div class="tnx-section-head">
            <span>كل البادجات</span>
            <h2>استعرض البادجات</h2>
            <p>اضغط على أي بادج عشان تشوف تفاصيله ورابطه المباشر.</p>
          </div>

          <div class="tnx-search">
            <span>⌕</span>
            <input
              id="badgeSearch"
              type="search"
              autocomplete="off"
              placeholder="ابحث: VIP، 100K، حضور، كويز، LAW..."
            />
            <button type="button" id="clearBadgeSearch">×</button>
          </div>
        </div>

        <div class="tnx-filter-row" id="badgeFilters">
          <button type="button" class="is-active" data-badge-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-badge-filter="attendance"><span>الحضور</span><small id="count-attendance">0</small></button>
          <button type="button" data-badge-filter="points"><span>النقاط</span><small id="count-points">0</small></button>
          <button type="button" data-badge-filter="quiz"><span>الكويز</span><small id="count-quiz">0</small></button>
          <button type="button" data-badge-filter="status"><span>المكانة</span><small id="count-status">0</small></button>
          <button type="button" data-badge-filter="law"><span>المحكمة</span><small id="count-law">0</small></button>
          <button type="button" data-badge-filter="awards"><span>الجوائز</span><small id="count-awards">0</small></button>
          <button type="button" data-badge-filter="special"><span>خاص</span><small id="count-special">0</small></button>
        </div>

        <div class="tnx-vault-layout">
          <div>
            <div id="badgeGrid" class="tnx-badge-grid"></div>

            <div id="badgeEmpty" class="tnx-empty hidden">
              <strong>ما لقيت بادج مطابق</strong>
              <span>جرّب تبحث باسم أبسط مثل: 100K، VIP، حضور، كويز.</span>
            </div>
          </div>

          <aside id="badgeFocusPanel" class="tnx-focus-panel">
            <div class="tnx-focus-placeholder">
              <div>⬟</div>
              <h3>اختر بادج</h3>
              <p>اضغط على أي بادج من القائمة عشان تظهر تفاصيله هنا.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="tnx-users">
        <div class="tnx-section-head tnx-center">
          <span>بطاقات الأعضاء</span>
          <h2>اعرض بطاقة مستخدم</h2>
          <p>ابحث باسم العضو وشوف بطاقته، نقاطه، حضوره، إجابات الكويز، وأقرب بادج له.</p>
        </div>

        <div class="tnx-user-search">
          <div class="tnx-search">
            <span>⌕</span>
            <input id="userSearch" type="search" autocomplete="off" placeholder="ابحث عن مستخدم..." />
            <button type="button" id="clearUserSearch">×</button>
          </div>

          <div id="userResults" class="tnx-user-results"></div>
        </div>

        <div id="userCardContainer" class="tnx-user-card-container"></div>
      </section>
    </section>
  </main>

  <style is:global>
    .hidden {
      display: none !important;
    }

    .tnx-badges-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.18), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.16), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.12), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.07;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.4) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-hero {
      max-width: 920px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.28);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.36);
      color: #ffda6a;
      padding: 0.55rem 0.9rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.18em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
    }

    .tnx-hero h1 {
      margin: 1.15rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.2rem, 8vw, 6.8rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.06em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.03rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 720px;
      margin: 1.25rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-start,
    .tnx-vault,
    .tnx-users,
    .tnx-focus-panel,
    .tnx-progress-panel {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)),
        rgba(6, 6, 8, 0.78);
      box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.44),
        inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 1rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.8rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.8rem;
      font-weight: 850;
    }

    .tnx-start,
    .tnx-vault,
    .tnx-users {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.3rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.5rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-center {
      text-align: center;
    }

    .tnx-start-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .tnx-start-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.85rem;
      min-height: 138px;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.25rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.07), transparent 42%),
        rgba(0, 0, 0, 0.3);
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tnx-start-card:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 218, 106, 0.5);
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 42%),
        rgba(0, 0, 0, 0.38);
    }

    .tnx-start-card b {
      display: grid;
      place-items: center;
      width: 3rem;
      height: 3rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 1rem;
      background:
        radial-gradient(circle at 35% 25%, rgba(255, 218, 106, 0.18), transparent 62%),
        rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1rem;
      font-weight: 950;
    }

    .tnx-start-card strong {
      display: block;
      color: white;
      font-size: 1.1rem;
      font-weight: 950;
      line-height: 1.35;
    }

    .tnx-start-card p {
      margin: 0.45rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.7;
    }

    .tnx-vault-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
      gap: 1rem;
      align-items: end;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 218, 106, 0.12);
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem 0;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.07), transparent 40%),
        rgba(7, 5, 11, 0.9);
      padding: 0.7rem;
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.35);
      backdrop-filter: blur(14px);
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.62rem 0.8rem;
      font-size: 0.82rem;
      font-weight: 950;
      cursor: pointer;
      transition: 0.16s ease;
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.68rem;
    }

    .tnx-vault-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
    }

    .tnx-badge-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .tnx-badge-card {
      position: relative;
      display: grid;
      gap: 0.8rem;
      border: 1px solid rgba(255, 218, 106, 0.15);
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.055), transparent 42%),
        rgba(0, 0, 0, 0.3);
      color: white;
      padding: 0.95rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
      overflow: hidden;
      scroll-margin-top: 11rem;
    }

    .tnx-badge-card:hover,
    .tnx-badge-card.is-selected {
      transform: translateY(-2px);
      border-color: rgba(255, 218, 106, 0.56);
      box-shadow: 0 0 28px rgba(255, 218, 106, 0.13);
    }

    .tnx-badge-card.is-linked {
      border-color: rgba(255, 218, 106, 0.82);
      box-shadow:
        0 0 0 1px rgba(255, 218, 106, 0.28),
        0 0 34px rgba(255, 218, 106, 0.18);
    }

    .tnx-badge-card.is-rare::before {
      content: '';
      position: absolute;
      inset: -35%;
      background: conic-gradient(from 180deg, transparent, rgba(255, 218, 106, 0.16), transparent 35%);
      opacity: 0.7;
      animation: tnxBadgeShine 5s linear infinite;
      pointer-events: none;
    }

    @keyframes tnxBadgeShine {
      to {
        transform: rotate(360deg);
      }
    }

    .tnx-badge-img-wrap {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      min-height: 112px;
      border: 1px solid rgba(255, 218, 106, 0.11);
      border-radius: 1.05rem;
      background:
        radial-gradient(circle at center, rgba(255, 218, 106, 0.1), transparent 58%),
        rgba(255, 255, 255, 0.025);
    }

    .tnx-badge-img-wrap img {
      width: 82px;
      height: 82px;
      object-fit: contain;
      filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.45));
    }

    .tnx-badge-card-content {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 0.45rem;
    }

    .tnx-badge-tag {
      width: fit-content;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.07);
      color: #f7e6ac;
      padding: 0.32rem 0.55rem;
      font-size: 0.68rem;
      font-weight: 950;
    }

    .tnx-badge-card strong {
      color: white;
      font-size: 1rem;
      font-weight: 950;
      line-height: 1.35;
    }

    .tnx-badge-card p {
      margin: 0;
      color: rgb(156, 163, 175);
      font-size: 0.76rem;
      font-weight: 800;
      line-height: 1.55;
    }

    .tnx-focus-panel {
      position: sticky;
      top: 11rem;
      min-height: 420px;
      border-radius: 1.5rem;
      padding: 1rem;
    }

    .tnx-focus-placeholder {
      display: grid;
      place-items: center;
      min-height: 360px;
      text-align: center;
    }

    .tnx-focus-placeholder div {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 4rem;
      border-radius: 1.25rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      background: rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1.6rem;
      margin-bottom: 0.85rem;
    }

    .tnx-focus-placeholder h3 {
      margin: 0;
      color: #f7e6ac;
      font-size: 1.45rem;
      font-weight: 950;
    }

    .tnx-focus-placeholder p {
      max-width: 240px;
      margin: 0.55rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-focus-card {
      display: grid;
      gap: 0.9rem;
    }

    .tnx-focus-image {
      display: grid;
      place-items: center;
      min-height: 180px;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1.25rem;
      background:
        radial-gradient(circle at center, rgba(255, 218, 106, 0.14), transparent 56%),
        rgba(0, 0, 0, 0.28);
    }

    .tnx-focus-image img {
      width: 130px;
      height: 130px;
      object-fit: contain;
      filter: drop-shadow(0 18px 24px rgba(0, 0, 0, 0.55));
    }

    .tnx-focus-card h3 {
      margin: 0;
      color: white;
      font-size: 1.7rem;
      font-weight: 950;
      line-height: 1.2;
    }

    .tnx-focus-card p {
      margin: 0;
      color: rgb(209, 213, 219);
      font-size: 0.9rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-focus-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.6rem;
    }

    .tnx-focus-meta div {
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.26);
      padding: 0.75rem;
    }

    .tnx-focus-meta span {
      display: block;
      color: rgb(148, 163, 184);
      font-size: 0.72rem;
      font-weight: 900;
      margin-bottom: 0.25rem;
    }

    .tnx-focus-meta strong {
      color: #ffda6a;
      font-size: 0.86rem;
      font-weight: 950;
    }

    .tnx-focus-copy {
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.78rem 1rem;
      font-size: 0.86rem;
      font-weight: 950;
      cursor: pointer;
      transition: 0.16s ease;
    }

    .tnx-focus-copy:hover,
    .tnx-focus-copy.is-copied {
      border-color: rgba(52, 211, 153, 0.55);
      background: rgba(52, 211, 153, 0.14);
      color: rgb(167, 243, 208);
    }

    .tnx-empty {
      display: grid;
      place-items: center;
      gap: 0.35rem;
      border-radius: 1.5rem;
      padding: 2rem;
      text-align: center;
      min-height: 220px;
    }

    .tnx-empty strong {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .tnx-user-search {
      max-width: 620px;
      margin: 1rem auto 0;
    }

    .tnx-user-results {
      display: grid;
      gap: 0.5rem;
      margin-top: 0.7rem;
    }

    .tnx-user-result {
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 0.9rem;
      background: rgba(0, 0, 0, 0.32);
      color: #f7e6ac;
      padding: 0.75rem 0.9rem;
      text-align: right;
      font-weight: 900;
      cursor: pointer;
      transition: 0.16s ease;
    }

    .tnx-user-result:hover {
      border-color: rgba(255, 218, 106, 0.45);
      background: rgba(255, 218, 106, 0.09);
      color: #ffda6a;
    }

