      }

      const BADGE_PATHS = [
        {
          key: 'points',
          title: 'مسار النقاط',
          description: 'يعتمد على رصيد النقاط الحالي.',
          unit: 'نقطة',
          metricKeys: ['points', 'totalPoints', 'score'],
          steps: [
            { name: '100K', value: 100000 },
            { name: '250K', value: 250000 },
            { name: '500K', value: 500000 },
            { name: '1M', value: 1000000 },
            { name: '3M', value: 3000000 },
          ],
        },
        {
          key: 'attendance',
          title: 'مسار الحضور',
          description: 'يعتمد على تسجيل الدخول اليومي.',
          unit: 'يوم',
          metricKeys: ['checkins', 'checkIns', 'dailyCheckIns', 'attendanceDays', 'totalCheckins', 'totalCheckIns', 'streak'],
          steps: [
            { name: '15D', value: 15 },
            { name: '30D', value: 30 },
            { name: '60D', value: 60 },
            { name: '100D', value: 100 },
            { name: '150D', value: 150 },
          ],
        },
        {
          key: 'quiz',
          title: 'مسار الكويز',
          description: 'يعتمد على عدد الإجابات الصحيحة.',
          unit: 'إجابة',
          metricKeys: ['quizCorrect', 'quiz_correct', 'correctAnswers', 'quizCorrectAnswers', 'correctQuizAnswers', 'quizWins', 'answersCorrect'],
          steps: [
            { name: '50Q', value: 50 },
            { name: '150Q', value: 150 },
            { name: '300Q', value: 300 },
            { name: '600Q', value: 600 },
            { name: '1000Q', value: 1000 },
          ],
        },
      ]

      const JOB_ICONS = window.JOB_ICONS || {
        tier1_Citizen: 'mdi:account',
        tier3_Merchant: 'mdi:store',
      }

      window.JOB_ICONS = JOB_ICONS

      const state = {
        badges: [],
        users: [],
        filter: 'all',
        search: '',
        selectedBadgeName: '',
      }

      const badgeGrid = document.getElementById('badgeGrid')
      const badgeEmpty = document.getElementById('badgeEmpty')
      const badgeSearch = document.getElementById('badgeSearch')
      const clearBadgeSearch = document.getElementById('clearBadgeSearch')
      const badgeFocusPanel = document.getElementById('badgeFocusPanel')
      const filterButtons = Array.from(document.querySelectorAll('[data-badge-filter]'))
      const guideButtons = Array.from(document.querySelectorAll('[data-guide-filter]'))

      const statTotalBadges = document.getElementById('statTotalBadges')
      const statCategories = document.getElementById('statCategories')
      const statRareBadges = document.getElementById('statRareBadges')

      const userSearch = document.getElementById('userSearch')
      const clearUserSearch = document.getElementById('clearUserSearch')
      const userResults = document.getElementById('userResults')
      const userCardContainer = document.getElementById('userCardContainer')

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        if (!/^https?:\/\//i.test(url) && !url.startsWith('/')) return ''
        return url.replace(/["'()\\]/g, '')
      }

      function cssUrl(value) {
        const url = safeUrl(value)
        if (!url) return 'none'
        return `url('${url}')`
      }

      function safeColor(value, fallback = '#423fff') {
        const color = String(value || '').trim()
        return /^#[0-9a-fA-F]{6}$/.test(color) ? color : fallback
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function badgeKey(value) {
        return normalize(value).replace(/\s+/g, '')
      }

      function formatNumber(n) {
        return Number(n || 0).toLocaleString('de-DE')
      }

      function parseNumber(value) {
        if (value === null || value === undefined) return null
        if (typeof value === 'number' && Number.isFinite(value)) return value

        const cleaned = String(value).replace(/[^\d.-]/g, '')
        if (!cleaned) return null

        const n = Number(cleaned)
        return Number.isFinite(n) ? n : null
      }

      function getMetric(user, keys) {
        for (const key of keys) {
          const value = parseNumber(user?.[key])
          if (value !== null) return value
        }

        return null
      }

      function getUserBadgeName(badge) {
        return String(
          badge?.name ||
          badge?.badgeName ||
          badge?.id ||
          badge?.code ||
          badge?.title ||
          ''
        ).trim()
      }

      function getUserBadgeSet(user) {
        const set = new Set()

        if (!Array.isArray(user?.badges)) return set

        user.badges.forEach((badge) => {
          const name = getUserBadgeName(badge)
          if (name) set.add(badgeKey(name))
        })

        return set
      }

      function badgeSlug(name) {
        return `badge-${String(name || '')
          .trim()
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')}`
      }

      function hexToRgb(hex) {
        const clean = safeColor(hex).replace('#', '')
        const v = parseInt(clean, 16)
        return [(v >> 16) & 255, (v >> 8) & 255, v & 255]
      }

      function shade(hex, percent) {
        const [r, g, b] = hexToRgb(hex)
        const shift = Math.floor(2.55 * percent)
        const fmt = (c) => ('0' + Math.max(0, Math.min(255, c + shift)).toString(16)).slice(-2)
        return '#' + fmt(r) + fmt(g) + fmt(b)
      }

      function getBadgeMeta(name) {
        const fallback = {
          title: name,
          category: 'special',
          how: 'بادج خاص. طريقة الحصول عليه حسب نظام البث.',
          rarity: 'خاص',
          duration: 'حسب النظام',
          difficulty: 'غير محدد',
        }

        return BADGE_META[name] || fallback
      }

      function enrichBadge(badge, index) {
        const name = String(badge?.name || '').trim()
        const meta = getBadgeMeta(name)
        const category = CATEGORY_META[meta.category] ? meta.category : 'special'
        const hashId = badgeSlug(name)

        const searchText = normalize([
          name,
          meta.title,
          meta.category,
          meta.how,
          meta.rarity,
          meta.duration,
          meta.difficulty,
          CATEGORY_META[category]?.label,
          hashId,
        ].join(' '))

        return {
          index,
          name,
          hashId,
          image: safeUrl(badge?.image),
          title: meta.title,
          category,
          categoryLabel: CATEGORY_META[category]?.label || 'خاص',
          categoryIcon: CATEGORY_META[category]?.icon || '⬟',
          how: meta.how,
          rarity: meta.rarity,
          duration: meta.duration,
          difficulty: meta.difficulty,
          searchText,
          isRare: ['نادر', 'نادر جدًا', 'جائزة', 'خاص'].some((word) => String(meta.rarity).includes(word)),
        }
      }

      function updateStats() {
        const categories = new Set(state.badges.map((b) => b.category))
        const rare = state.badges.filter((b) => b.isRare).length

        if (statTotalBadges) statTotalBadges.textContent = String(state.badges.length)
        if (statCategories) statCategories.textContent = String(categories.size)
        if (statRareBadges) statRareBadges.textContent = String(rare)

        const counts = {
          all: state.badges.length,
          attendance: 0,
          points: 0,
          quiz: 0,
          status: 0,
          law: 0,
          awards: 0,
          special: 0,
        }

        state.badges.forEach((badge) => {
          counts[badge.category] = (counts[badge.category] || 0) + 1
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function getFilteredBadges() {
        return state.badges.filter((badge) => {
          const filterMatch = state.filter === 'all' || badge.category === state.filter
          const searchMatch = !state.search || badge.searchText.includes(normalize(state.search))
          return filterMatch && searchMatch
        })
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.badgeFilter === state.filter)
        })
      }

      function renderBadges() {
        const badges = getFilteredBadges()

        if (!badgeGrid) return

        badgeEmpty?.classList.toggle('hidden', badges.length > 0)

        badgeGrid.innerHTML = badges.map((badge) => {
          const selected = badge.name === state.selectedBadgeName ? ' is-selected' : ''
          const linked = window.location.hash === `#${badge.hashId}` ? ' is-linked' : ''
          const rare = badge.isRare ? ' is-rare' : ''

          return `
            <button
              type="button"
              id="${esc(badge.hashId)}"
              class="tnx-badge-card${selected}${linked}${rare}"
              data-badge-name="${esc(badge.name)}"
              data-badge-hash="${esc(badge.hashId)}"
            >
              <div class="tnx-badge-img-wrap">
                <img src="${esc(badge.image)}" alt="${esc(badge.name)}" loading="lazy" />
              </div>

              <div class="tnx-badge-card-content">
                <span class="tnx-badge-tag">${esc(badge.categoryLabel)}</span>
                <strong>${esc(badge.title)}</strong>
                <p>${esc(badge.rarity)} · ${esc(badge.difficulty)}</p>
              </div>
            </button>
          `
        }).join('')
      }

      function renderBadgeFocus(badge) {
        if (!badgeFocusPanel || !badge) return

        badgeFocusPanel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-image">
              <img src="${esc(badge.image)}" alt="${esc(badge.name)}" loading="lazy" />
            </div>

            <div>
              <span class="tnx-badge-tag">${esc(badge.categoryLabel)}</span>
              <h3>${esc(badge.title)}</h3>
            </div>

            <p>${esc(badge.how)}</p>

            <div class="tnx-focus-meta">
              <div>
                <span>الندرة</span>
                <strong>${esc(badge.rarity)}</strong>
              </div>

              <div>
                <span>الصعوبة</span>
                <strong>${esc(badge.difficulty)}</strong>
              </div>

              <div>
                <span>المدة</span>
                <strong>${esc(badge.duration)}</strong>
              </div>

              <div>
                <span>الاسم التقني</span>
                <strong>${esc(badge.name)}</strong>
              </div>
            </div>

            <button type="button" class="tnx-focus-copy" data-copy-badge-link="${esc(badge.hashId)}">
              نسخ رابط البادج
            </button>
          </div>
        `
      }

      function selectBadge(name, options = {}) {
        const badge = state.badges.find((item) => item.name === name)
        if (!badge) return

        state.selectedBadgeName = badge.name

        if (options.updateHash !== false) {
          history.replaceState(null, '', `#${badge.hashId}`)
        }

        renderBadges()
        renderBadgeFocus(badge)

        if (options.scrollToBadge) {
          addTimer(window.setTimeout(() => {
            const card = document.getElementById(badge.hashId)
            card?.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }, 80))
        }
      }

      function openBadgeFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('badge-')) return false

        const badge = state.badges.find((item) => item.hashId === hash)
        if (!badge) return false

        state.filter = 'all'
        state.search = ''

        if (badgeSearch) badgeSearch.value = ''

        renderFilterButtons()
        selectBadge(badge.name, { updateHash: false, scrollToBadge: options.scrollToBadge !== false })

        document.querySelector('.tnx-vault')?.scrollIntoView({
          behavior: options.instant ? 'auto' : 'smooth',
          block: 'start',
        })

        return true
      }

      function getBadgeLink(hashId) {
        return `${window.location.origin}${window.location.pathname}#${hashId}`
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent

        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
            button.classList.remove('is-copied')
          }, 1000))
        } catch {
          button.textContent = text

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
          }, 1300))
        }
      }

      async function loadBadges() {
        try {
          const res = await fetch('/api/badges.json')
          if (!res.ok) throw new Error(`Badges request failed: ${res.status}`)

          const rawBadges = await res.json()
          const list = Array.isArray(rawBadges) ? rawBadges : []

          state.badges = list
            .map(enrichBadge)
            .filter((badge) => badge.name && badge.image)

          updateStats()
          renderFilterButtons()
          renderBadges()

          const openedFromHash = openBadgeFromHash({ instant: true, scrollToBadge: true })

          if (!openedFromHash && state.badges.length > 0) {
            selectBadge(state.badges[0].name, { updateHash: false })
          }
        } catch (error) {
          console.error('Failed to load badges.json', error)

          if (badgeGrid) {
            badgeGrid.innerHTML = `
              <div class="tnx-empty">
                <strong>تعذر تحميل البادجات</strong>
                <span>تأكد من وجود الملف في public/api/badges.json</span>
              </div>
            `
          }
        }
      }

      function renderUserResults(query) {
        if (!userResults) return

        const q = normalize(query)

        userResults.innerHTML = ''

        if (!q) return

        const matches = state.users
          .map((user, index) => ({ user, index }))
          .filter(({ user }) => {
            return normalize(user.userName).includes(q) || normalize(user.userLogin).includes(q)
          })
          .slice(0, 10)

        if (matches.length === 0) {
          userResults.innerHTML = `
            <div class="tnx-empty">
              <strong>مافيه نتائج</strong>
              <span>تأكد من كتابة اسم المستخدم بشكل صحيح.</span>
            </div>
          `
          return
        }

        userResults.innerHTML = matches.map(({ user, index }) => {
          const userName = String(user.userName || '')
          const userLogin = String(user.userLogin || '')
          const label = normalize(userName) !== normalize(userLogin)
            ? `${userName} (${userLogin})`
            : userName

          return `
            <button type="button" class="tnx-user-result" data-user-index="${index}">
              ${esc(label)}
            </button>
          `
        }).join('')
      }

      function getClosestBadge(user, unlockedSet) {
        const candidates = []

        BADGE_PATHS.forEach((path) => {
          const metric = getMetric(user, path.metricKeys)
          if (metric === null) return

          path.steps.forEach((step) => {
            const isUnlocked = unlockedSet.has(badgeKey(step.name)) || metric >= step.value

            if (isUnlocked) return

            const remaining = Math.max(0, step.value - metric)
            const progress = Math.max(0, Math.min(100, (metric / step.value) * 100))

            candidates.push({
              name: step.name,
              title: getBadgeMeta(step.name).title,
              pathTitle: path.title,
              remaining,
              unit: path.unit,
              progress,
            })
          })
        })

        if (candidates.length === 0) {
          const locked = state.badges.find((badge) => !unlockedSet.has(badgeKey(badge.name)))
          if (!locked) return null

          return {
            name: locked.name,
            title: locked.title,
            pathTitle: locked.categoryLabel,
            remaining: null,
            unit: '',
            progress: null,
          }
        }

        candidates.sort((a, b) => b.progress - a.progress)
        return candidates[0]
      }

      function renderPathCard(path, user, unlockedSet) {
        const metric = getMetric(user, path.metricKeys)

        let nextFound = false

        const stepsHtml = path.steps.map((step) => {
          const meta = getBadgeMeta(step.name)
          const fromMetric = metric !== null && metric >= step.value
          const fromBadge = unlockedSet.has(badgeKey(step.name))
          const isOpen = fromMetric || fromBadge
          const isNext = !isOpen && !nextFound

          if (isNext) nextFound = true

          const progress = metric === null
            ? (isOpen ? 100 : 0)
            : Math.max(0, Math.min(100, (metric / step.value) * 100))

          const remaining = metric === null
            ? null
            : Math.max(0, step.value - metric)

          let status = 'مقفل'
          let note = 'لا توجد بيانات تقدم رقمية لهذا المسار'

          if (isOpen) {
            status = 'مفتوح'
            note = 'تم فتح هذا البادج'
          } else if (remaining !== null) {
            status = isNext ? 'الأقرب' : 'باقي'
            note = `باقي ${formatNumber(remaining)} ${path.unit}`
          }

          return `
            <button type="button" class="tnx-path-step ${isOpen ? 'is-open' : ''} ${isNext ? 'is-next' : ''}" data-progress-badge="${esc(step.name)}">
              <div class="tnx-step-top">
                <strong>${esc(meta.title)}</strong>
                <span>${esc(status)}</span>
              </div>

              <div class="tnx-step-bar" style="--progress:${progress}%">
                <i></i>
              </div>

              <small class="tnx-step-note">${esc(note)}</small>
            </button>
          `
        }).join('')

        const metricText = metric === null
          ? 'الرقم غير متوفر'
          : `${formatNumber(metric)} ${path.unit}`

        return `
          <div class="tnx-path-card">
            <h4>${esc(path.title)}</h4>
            <p>${esc(path.description)} — الحالي: ${esc(metricText)}</p>
            <div class="tnx-path-steps">
              ${stepsHtml}
            </div>
          </div>
        `
      }

      function renderMiniBadgeList(badges, locked = false) {
        if (!badges.length) {
          return `<div class="tnx-empty"><strong>لا يوجد</strong><span>ما فيه بادجات في هذا القسم.</span></div>`
        }

        return `
          <div class="tnx-mini-badge-grid">
            ${badges.map((badge) => `
              <button type="button" class="tnx-mini-badge ${locked ? 'is-locked' : ''}" data-progress-badge="${esc(badge.name)}">
                <img src="${esc(badge.image)}" alt="${esc(badge.name)}" loading="lazy" />
                <span>${esc(badge.title || badge.name)}</span>
              </button>
            `).join('')}
          </div>
        `
      }

      function renderUserProgress(user, equippedBadges) {
        const unlockedSet = getUserBadgeSet(user)

        const unlockedBadges = state.badges.filter((badge) => unlockedSet.has(badgeKey(badge.name)))
        const lockedBadges = state.badges.filter((badge) => !unlockedSet.has(badgeKey(badge.name)))

        const closest = getClosestBadge(user, unlockedSet)
        const unlockedCount = unlockedBadges.length
        const totalCount = state.badges.length
        const equippedCount = equippedBadges.length
        const points = parseNumber(user.points) ?? 0
        const checkins = getMetric(user, ['checkins', 'checkIns', 'dailyCheckIns']) ?? 0
        const quizCorrect = getMetric(user, ['quizCorrect', 'quiz_correct', 'correctAnswers']) ?? 0
        const completionPercent = totalCount > 0 ? Math.round((unlockedCount / totalCount) * 100) : 0

        const closestText = closest
          ? `${closest.title}`
          : 'كل شيء مفتوح'

        const closestNote = closest
          ? closest.remaining === null
            ? 'هذا البادج يحتاج شرط خاص من نظام البث.'
            : `باقي ${formatNumber(closest.remaining)} ${closest.unit}`
          : 'ما بقي شيء واضح حاليًا.'

        return `
          <section class="tnx-progress-panel">
            <div class="tnx-progress-hero-card">
              <div class="tnx-progress-hero-main">
                <div class="tnx-progress-ring" style="--ring-progress:${completionPercent}%">
                  <div>
                    <strong>${formatNumber(completionPercent)}%</strong>
                    <span>مكتمل</span>
                  </div>
                </div>

                <div>
                  <span class="tnx-progress-kicker">BADGE PROGRESS</span>
                  <h3 class="tnx-progress-title">تقدم هذا العضو</h3>
                  <p class="tnx-progress-copy">
                    هنا تشوف المسارات بشكل واضح: النقاط، الحضور، والكويز. اضغط على أي بادج من المسار عشان تعرف تفاصيله.
                  </p>
                </div>
              </div>

              <div class="tnx-next-badge-card">
                <span>أقرب هدف</span>
                <strong>${esc(closestText)}</strong>
                <small>${esc(closestNote)}</small>
              </div>
            </div>

            <div class="tnx-progress-summary">
              <div class="tnx-progress-stat">
                <span>البادجات المفتوحة</span>
                <strong>${formatNumber(unlockedCount)} من ${formatNumber(totalCount)}</strong>
                <small>${formatNumber(completionPercent)}% من الخزنة</small>
              </div>

              <div class="tnx-progress-stat">
                <span>البادجات المركبة</span>
                <strong>${formatNumber(equippedCount)}</strong>
                <small>اللي تظهر في البطاقة</small>
              </div>

              <div class="tnx-progress-stat">
                <span>الحضور</span>
                <strong>${formatNumber(checkins)} يوم</strong>
                <small>مسار تسجيل الدخول</small>
              </div>

              <div class="tnx-progress-stat">
                <span>الكويز</span>
                <strong>${formatNumber(quizCorrect)} إجابة</strong>
                <small>إجابات صحيحة</small>
              </div>
            </div>

            <div class="tnx-paths-grid">
              ${BADGE_PATHS.map((path) => renderPathCard(path, user, unlockedSet)).join('')}
            </div>

            <div class="tnx-owned-section">
              <div class="tnx-owned-box">
                <div class="tnx-owned-head">
                  <h4>البادجات المفتوحة</h4>
                  <span>${formatNumber(unlockedBadges.length)}</span>
                </div>
                ${renderMiniBadgeList(unlockedBadges.slice(0, 15), false)}
              </div>

              <div class="tnx-owned-box">
                <div class="tnx-owned-head">
                  <h4>البادجات الباقية</h4>
                  <span>${formatNumber(lockedBadges.length)}</span>
                </div>
                ${renderMiniBadgeList(lockedBadges.slice(0, 15), true)}
              </div>
            </div>
          </section>
        `
      }

      function renderUserCard(details) {
        if (!userCardContainer || !details) return

        const baseColor = safeColor(details.backgroundColor || '#423fff')
        const darkColor = shade(baseColor, -20)

        const displayName = String(details.userName || '')
        const login = String(details.userLogin || '')
        const username = normalize(displayName) !== normalize(login)
          ? `${displayName} (${login})`
          : displayName

        const jobIcon = JOB_ICONS[details.jobId] || 'mdi:account'
        const equippedBadges = Array.isArray(details.badges)
          ? details.badges.filter((badge) => badge.equipped).slice(0, 6)
          : []

        const badgeHtml = equippedBadges.map((badge) => {
          return `<img src="${esc(safeUrl(badge.url))}" alt="${esc(badge.name)}" loading="lazy" />`
        }).join('')

        const bannerUrl = safeUrl(details.bannerImage || '')
        const profileUrl = safeUrl(details.profileImageUrl || '')
        const bannerImage = cssUrl(bannerUrl)
        const profileImage = cssUrl(profileUrl)

        userCardContainer.innerHTML = `
          <div class="tnx-card-wrap">
            <div
              class="tnx-user-card-preview"
              dir="ltr"
              style="background: linear-gradient(to bottom, ${baseColor} 70%, ${darkColor} 100%); --profile-border: ${baseColor};"
            >
              <div
                class="tnx-card-banner"
                style="background-image: ${bannerImage};"
              ></div>

              <div class="tnx-card-profile-section">
                <div class="tnx-card-picture-points">
                  <div
                    class="tnx-card-profile-picture"
                    style="background-image: ${profileImage};"
                  ></div>

                  <div class="tnx-card-job-info">
                    <iconify-icon icon="${esc(jobIcon)}"></iconify-icon>
                    ${esc(details.jobName || 'Citizen')}
                  </div>

                  <div class="tnx-card-stats-row">
                    <div class="tnx-card-points">
                      <iconify-icon icon="mdi:star-four-points-circle"></iconify-icon>
                      ${formatNumber(details.points)}
                    </div>

                    <div class="tnx-card-gold">
                      <iconify-icon icon="mdi:gold"></iconify-icon>
                      ${formatNumber(details.gold)}
                    </div>
                  </div>
                </div>

                <div class="tnx-card-username">${esc(username)}</div>

                <div class="tnx-card-badges">
                  ${badgeHtml}
                </div>
              </div>
            </div>
          </div>

          ${renderUserProgress(details, equippedBadges)}
        `
      }

      async function loadUsers() {
        try {
          const res = await fetch('/api/user_badges.json')
          if (!res.ok) throw new Error(`Users request failed: ${res.status}`)

          const users = await res.json()
          state.users = Array.isArray(users) ? users : []
        } catch (error) {
          console.error('Failed to load user_badges.json', error)
          state.users = []
        }
      }

      addListener(badgeGrid, 'click', (event) => {
        const card = event.target.closest('[data-badge-name]')
        if (!card) return

        selectBadge(card.dataset.badgeName)
      })

      addListener(document, 'click', (event) => {
        const progressBadgeButton = event.target.closest('[data-progress-badge]')

        if (progressBadgeButton) {
          const badgeName = progressBadgeButton.dataset.progressBadge || ''
          if (badgeName) {
            selectBadge(badgeName, { updateHash: true, scrollToBadge: true })
            document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
          return
        }

        const linkButton = event.target.closest('[data-copy-badge-link]')

        if (linkButton) {
          const hashId = linkButton.dataset.copyBadgeLink || ''
          copyText(getBadgeLink(hashId), linkButton, 'تم نسخ الرابط')
        }
      })

      addListener(window, 'hashchange', () => {
        openBadgeFromHash({ scrollToBadge: true })
      })

      addListener(badgeSearch, 'input', () => {
        state.search = badgeSearch.value
        renderBadges()
      })

      addListener(clearBadgeSearch, 'click', () => {
        if (!badgeSearch) return

        badgeSearch.value = ''
        state.search = ''
        badgeSearch.focus()
        renderBadges()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.badgeFilter || 'all'
          renderFilterButtons()
          renderBadges()
        })
      })

      guideButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.guideFilter || 'all'
          state.search = ''

          if (badgeSearch) badgeSearch.value = ''

          renderFilterButtons()
          renderBadges()

          document.querySelector('.tnx-vault')?.scrollIntoView({
            behavior: 'smooth',
            block: 'start',
          })
        })
      })

      addListener(userSearch, 'input', () => {
        renderUserResults(userSearch.value)
      })

      addListener(clearUserSearch, 'click', () => {
        if (!userSearch) return

        userSearch.value = ''
        userResults.innerHTML = ''
        userSearch.focus()
      })

      addListener(userResults, 'click', (event) => {
        const button = event.target.closest('[data-user-index]')
        if (!button) return

        const index = Number(button.dataset.userIndex)
        const user = state.users[index]

        if (!user) return

        if (userSearch) userSearch.value = ''
        if (userResults) userResults.innerHTML = ''

        renderUserCard(user)
      })

      loadBadges()
      loadUsers()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
