      border-color: rgba(255, 218, 106, 0.65);
      box-shadow:
        0 28px 65px rgba(0, 0, 0, 0.45),
        0 0 40px rgba(255, 218, 106, 0.2);
    }

    .tnx-next-hero--done {
      cursor: default;
    }

    .tnx-next-hero--done::before {
      display: none;
