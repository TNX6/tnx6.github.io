  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxCleanProfileCleanup'
      if (window[cleanupKey]) window[cleanupKey]()

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        timers.forEach((timer) => window.clearTimeout(timer))
      }

      /* ---------------------------------------------------------------
       * CONFIG — كل الأرقام السحرية في مكان واحد للموازنة السهلة
       * ------------------------------------------------------------- */
      const CONFIG = {
        WATCH_MINUTE_WEIGHT: 150,   // كل دقيقة مشاهدة = كم XP
        DAILY_LOGIN_XP: 500,        // كل تسجيل دخول يومي = كم XP
        POINTS_PER_XP: 10,          // كل 10 نقاط = 1 XP
        MAX_LEVEL: 250,
        LEVEL_XP_BASE: 10000,
        LEVEL_XP_EXP: 1.17,
        LEVEL_XP_LINEAR: 2500,
        SEARCH_DEBOUNCE_MS: 150,
        SEARCH_MAX_RESULTS: 10,
        BADGE_XP: {
          Common: 250,
          Rare: 750,
          Epic: 1500,
          Legendary: 3000,
          Mythic: 5000,
        },
      }

      const state = {
        users: [],
        items: [],
        leaderboards: {
          points: [],
          gold: [],
          watchtime: [],
        },
        // فهارس O(1) تُبنى بعد تحميل البيانات
        index: {
          profiles: null,
          inventories: null,
          mailboxes: null,
        },
        rankIndex: null,        // Map(key -> rank)
        activeUser: null,
      }

      const rarityColors = {
        Common: '#b8b8b8',
        Rare: '#5ba7ff',
        Epic: '#b36bff',
        Legendary: '#ffdf8a',
        Mythic: '#ff5d5d',
        status: '#c084fc',
        attacks: '#ff5d5d',
        pvp: '#fb923c',
        luck: '#ffdf8a',
        boxes: '#7CFFB2',
        permits: '#5ba7ff',
        resources: '#b8b8b8',
        rare: '#ffdf8a',
        economy: '#d7a84f',
      }

      const HARD_ITEMS = {
        vip: { icon: '👑', rarity: 'Legendary', cat: 'status' },
        'vip+': { icon: '👑', rarity: 'Legendary', cat: 'status' },
        crown: { icon: '👑', rarity: 'Legendary', cat: 'rare' },
        'ملك': { icon: '👑', rarity: 'Legendary', cat: 'rare' },
        'نيوك': { icon: '💣', rarity: 'Mythic', cat: 'attacks' },
        'محامي': { icon: '⚖️', rarity: 'Rare', cat: 'status' },
        'رخصة محامي': { icon: '⚖️', rarity: 'Rare', cat: 'status' },
        'عريف الفصل': { icon: '🎖️', rarity: 'Rare', cat: 'status' },
        'البريد': { icon: '✉️', rarity: 'Rare', cat: 'economy' },
        'سمعة': { icon: '🔥', rarity: 'Common', cat: 'economy' },
        'عملة الجرأة': { icon: '🪙', rarity: 'Common', cat: 'luck' },
        'صندوق': { icon: '🎁', rarity: 'Common', cat: 'boxes' },
        'صندوق نادر': { icon: '🎁', rarity: 'Epic', cat: 'boxes' },
        'صندوق السمعة': { icon: '🎁', rarity: 'Epic', cat: 'boxes' },
        'خشب': { icon: '🪵', rarity: 'Common', cat: 'resources' },
        'حديد': { icon: '⛓️', rarity: 'Common', cat: 'resources' },
        'ذهب': { icon: '🪙', rarity: 'Legendary', cat: 'rare' },
        'تغيير العنوان': { icon: '✍️', rarity: 'Rare', cat: 'attacks' },
        'تغير العنوان': { icon: '✍️', rarity: 'Rare', cat: 'attacks' },
        'تغيير العنوان مطور': { icon: '✍️', rarity: 'Epic', cat: 'attacks' },
        'أقول لا يكثر': { icon: '🚫', rarity: 'Rare', cat: 'pvp' },
        'اقول لا يكثر': { icon: '🚫', rarity: 'Rare', cat: 'pvp' },
        'تجميد الشاشة': { icon: '❄️', rarity: 'Mythic', cat: 'attacks' },
      }

      const $ = (id) => document.getElementById(id)

      function setText(id, value) {
        const el = $(id)
        if (el) el.textContent = value
      }

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function key(value) {
        return normalize(value).replace(/\s+/g, '')
      }

      function num(value) {
        if (value === null || value === undefined || value === '') return 0

        if (typeof value === 'number') {
          return Number.isFinite(value) ? value : 0
        }

        const cleaned = String(value)
          .replace(/,/g, '')
          .replace(/[٠-٩]/g, (d) => '٠١٢٣٤٥٦٧٨٩'.indexOf(d))
          .replace(/[۰-۹]/g, (d) => '۰۱۲۳۴۵۶۷۸۹'.indexOf(d))
          .trim()

        const direct = Number(cleaned)
        if (Number.isFinite(direct)) return direct

        const match = cleaned.match(/-?\d+(?:\.\d+)?/)
        if (!match) return 0

        const parsed = Number(match[0])
        return Number.isFinite(parsed) ? parsed : 0
      }

      function formatNumber(value) {
        return num(value).toLocaleString('en-US')
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        return /^https?:\/\//i.test(url) || url.startsWith('/') ? url : ''
      }

      // تنظيف رابط قبل حقنه داخل url("...") في CSS لمنع كسر السياق/الحقن
      function cssUrl(value) {
        const url = safeUrl(value)
        if (!url) return ''
        return url.replace(/["'()\\<>\s]/g, (ch) => encodeURIComponent(ch))
      }

      function get(source, names, fallback = '') {
        if (!source) return fallback

        for (const name of names) {
          if (source[name] !== undefined && source[name] !== null && source[name] !== '') return source[name]
        }

        const keys = Object.keys(source)
        for (const name of names) {
          const wanted = String(name).toLowerCase()
          const foundKey = keys.find((key) => String(key).toLowerCase() === wanted)

          if (foundKey && source[foundKey] !== undefined && source[foundKey] !== null && source[foundKey] !== '') {
            return source[foundKey]
          }
        }

        return fallback
      }

      function deepGet(source, names, fallback = '') {
        const direct = get(source, names, null)
        if (direct !== null && direct !== undefined && direct !== '') return direct

        const wanted = names.map((name) => String(name).toLowerCase())
        const seen = new Set()

        function walk(value, depth) {
          if (!value || depth > 5) return null

          if (seen.has(value)) return null
          if (typeof value === 'object') seen.add(value)

          if (Array.isArray(value)) {
            for (const entry of value) {
              if (entry && typeof entry === 'object') {
                const entryName = get(entry, ['name', 'key', 'varName', 'variableName', 'id'], '')
                const entryValue = get(entry, ['value', 'Value', 'val', 'data'], '')

                if (entryName && wanted.includes(String(entryName).toLowerCase()) && entryValue !== '') {
                  return entryValue
                }
              }

              const nested = walk(entry, depth + 1)
              if (nested !== null && nested !== undefined && nested !== '') return nested
            }

            return null
          }

          if (typeof value === 'object') {
            const keys = Object.keys(value)

            for (const name of wanted) {
              const foundKey = keys.find((key) => String(key).toLowerCase() === name)
              if (foundKey && value[foundKey] !== undefined && value[foundKey] !== null && value[foundKey] !== '') {
                return value[foundKey]
              }
            }

            for (const key of keys) {
              const nested = walk(value[key], depth + 1)
              if (nested !== null && nested !== undefined && nested !== '') return nested
            }
          }

          return null
        }

        const found = walk(source, 0)
        return found !== null && found !== undefined && found !== '' ? found : fallback
      }

      function userLogin(user) {
        return String(get(user, ['userLogin', 'UserLogin', 'login', 'userName'], '')).trim()
      }

      function userName(user) {
        return String(get(user, ['userName', 'UserName', 'displayName', 'userLogin'], '')).trim()
      }

      function userId(user) {
        return String(get(user, ['userId', 'UserId', 'id'], '')).trim()
      }

      /* ---------------------------------------------------------------
       * فهرسة المجموعات: تحوّل البحث الخطي O(n) إلى O(1)
       * (كان مصدر بطء O(n²) في mergeUser + levelRankFor)
       * ------------------------------------------------------------- */
      function buildIndex(collection) {
        const byId = new Map()
        const byLogin = new Map()
        const byName = new Map()

        for (const entry of collection) {
          const id = String(get(entry, ['userId', 'UserId', 'id'], '')).trim()
          const login = normalize(get(entry, ['userLogin', 'UserLogin', 'login'], ''))
          const name = normalize(get(entry, ['userName', 'UserName', 'displayName'], ''))

          if (id && !byId.has(id)) byId.set(id, entry)
          if (login && !byLogin.has(login)) byLogin.set(login, entry)
          if (name && !byName.has(name)) byName.set(name, entry)
        }

        return { byId, byLogin, byName }
      }

      function lookupRecord(index, user) {
        if (!index) return null

        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))

        if (id && index.byId.has(id)) return index.byId.get(id)
        if (login && index.byLogin.has(login)) return index.byLogin.get(login)
        if (name && index.byName.has(name)) return index.byName.get(name)
        // مطابقات متقاطعة (login مقابل name والعكس) للحفاظ على سلوك matchUser القديم
        if (login && index.byName.has(login)) return index.byName.get(login)
        if (name && index.byLogin.has(name)) return index.byLogin.get(name)

        return null
      }

      function matchUser(entry, user) {
        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))
        const entryId = String(get(entry, ['userId', 'UserId', 'id'], '')).trim()
        const entryLogin = normalize(get(entry, ['userLogin', 'UserLogin', 'login'], ''))
        const entryName = normalize(get(entry, ['userName', 'UserName', 'displayName'], ''))

        return (
          (id && entryId && id === entryId) ||
          (login && entryLogin && login === entryLogin) ||
          (login && entryName && login === entryName) ||
          (name && entryLogin && name === entryLogin) ||
          (name && entryName && name === entryName)
        )
      }

      function leaderboardEntryName(entry) {
        return String(get(entry, [
          '__name', 'UserName', 'userName', 'displayName', 'name', 'username', 'Name'
        ], '')).trim()
      }

      function leaderboardEntryLogin(entry) {
        return String(get(entry, [
          '__login', 'UserLogin', 'userLogin', 'login', 'username', 'Login'
        ], '')).trim()
      }

      function leaderboardEntryId(entry) {
        return String(get(entry, ['userId', 'UserId', 'id', 'Id', '__id'], '')).trim()
      }

      function leaderboardEntryValue(entry) {
        return get(entry, [
          '__value', 'Value', 'value', 'score', 'Score', 'points', 'Points',
          'total', 'Total', 'amount', 'Amount', 'watchtime', 'Watchtime'
        ], 0)
      }

      function normalizeLeaderboardData(data, boardId) {
        const source = Array.isArray(data?.[boardId]) ? data[boardId] : []

        return source
          .map((entry, index) => {
            const name = leaderboardEntryName(entry)
            const login = leaderboardEntryLogin(entry)
            const id = leaderboardEntryId(entry)
            const value = leaderboardEntryValue(entry)

            return {
              raw: entry,
              boardId,
              id,
              name,
              login,
              value,
              number: num(value),
              rank: index + 1,
            }
          })
          .filter((entry) => entry.name || entry.login || entry.id)
          .sort((a, b) => b.number - a.number)
          .map((entry, index) => ({ ...entry, rank: index + 1 }))
      }

      function findLeaderboardEntry(boardId, user) {
        const board = state.leaderboards?.[boardId] || []
        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))

        if (id) {
          const byId = board.find((entry) => entry.id && String(entry.id) === String(id))
          if (byId) return byId
        }

        if (login) {
          const byLogin = board.find((entry) => normalize(entry.login) === login)
          if (byLogin) return byLogin
        }

        if (name) {
          const byName = board.find((entry) => normalize(entry.name) === name)
          if (byName) return byName
        }

        return null
      }

      // توحيد منطق صياغة الـ watchtime (كان مكرّراً في مكانين)
      function formatWatchtimeFromMinutes(minutes) {
        const total = Math.floor(num(minutes))
        if (total <= 0) return '0 يوم'

        const days = total / 1440
        if (days < 1) return `${days.toFixed(2)} يوم`
        if (days < 10) return `${days.toFixed(1)} يوم`
        return `${Math.floor(days).toLocaleString('en-US')} يوم`
      }

      function applyLeaderboardMetrics(user) {
        const merged = { ...user }

        const pointsEntry = findLeaderboardEntry('points', merged)
        if (pointsEntry) {
          merged.points = num(pointsEntry.value)
          merged.totalPoints = num(pointsEntry.value)
          merged.rank = `#${pointsEntry.rank}`
        }

        const goldEntry = findLeaderboardEntry('gold', merged)
        if (goldEntry) {
          merged.gold = num(goldEntry.value)
          merged.goldRank = `#${goldEntry.rank}`
        }

        const watchtimeEntry = findLeaderboardEntry('watchtime', merged)
        if (watchtimeEntry) {
          const rawValue = leaderboardEntryValue(watchtimeEntry.raw)
          const minutes = num(rawValue)

          merged.watchtime = rawValue
          merged.watchMinutes = minutes
          merged.watchtimeMinutes = minutes
          merged.watchtimeText = formatWatchtimeFromMinutes(minutes)
          merged.watchtimeRank = `#${watchtimeEntry.rank}`
        }

        return merged
      }

      function mergeUser(user) {
        const profile = lookupRecord(state.index.profiles, user) || {}
        const inv = lookupRecord(state.index.inventories, user) || {}
        const mail = lookupRecord(state.index.mailboxes, user) || {}
        const merged = { ...user, ...profile }

        merged.inventory = Array.isArray(profile.inventory)
          ? profile.inventory
          : Array.isArray(inv.items)
            ? inv.items
            : Array.isArray(inv.inventory)
              ? inv.inventory
              : Array.isArray(user.inventory)
                ? user.inventory
                : []

        merged.mailbox = Array.isArray(profile.mailbox)
          ? profile.mailbox
          : Array.isArray(mail.messages)
            ? mail.messages
            : Array.isArray(mail.mailbox)
              ? mail.mailbox
              : Array.isArray(user.mailbox)
                ? user.mailbox
                : []

        return applyLeaderboardMetrics(merged)
      }

      function itemName(entry) {
        return String(get(entry, ['name', 'itemName', 'item', 'Name', 'key'], '')).trim()
      }

      function itemQty(entry) {
        return Math.max(1, num(get(entry, ['quantity', 'qty', 'amount', 'count', 'Value'], 1)))
      }

      // فهرس الكاتالوج لتجنّب البحث الخطي على كل غرض
      let catalogIndex = null
      function buildCatalogIndex() {
        catalogIndex = new Map()
        for (const item of state.items) {
          const k = key(get(item, ['name', 'itemName', 'title'], ''))
          if (k && !catalogIndex.has(k)) catalogIndex.set(k, item)
        }
      }

      function catalogItem(name) {
        if (!catalogIndex) buildCatalogIndex()
        return catalogIndex.get(key(name)) || null
      }

      const HARD_ITEMS_BY_KEY = (() => {
        const map = new Map()
        for (const [name, meta] of Object.entries(HARD_ITEMS)) map.set(key(name), meta)
        return map
      })()

      function itemMeta(name) {
        const itemKey = key(name)
        const hard = HARD_ITEMS_BY_KEY.get(itemKey)
        if (hard) return hard

        const item = catalogItem(name)
        if (!item) return { icon: '📦', rarity: 'Common', cat: 'economy' }

        return {
          icon: get(item, ['icon', 'emoji'], '📦'),
          rarity: get(item, ['rarity'], 'Common'),
          cat: get(item, ['category', 'type', 'cat'], 'economy'),
        }
      }

      function inventoryItems(user) {
        return (Array.isArray(user.inventory) ? user.inventory : [])
          .map((entry) => {
            const name = itemName(entry)
            const meta = itemMeta(name)
            const details = catalogItem(name)

            return {
              name,
              qty: itemQty(entry),
              icon: meta.icon || '📦',
              rarity: meta.rarity || 'Common',
              cat: meta.cat || 'economy',
              description: get(details, ['description', 'desc', 'how'], 'غرض من حقيبة العضو.'),
            }
          })
          .filter((item) => item.name)
      }

      function badgeName(badge) {
        return String(get(badge, ['name', 'badgeName', 'title', 'value1'], '')).trim()
      }

      function badgeImage(badge) {
        return safeUrl(get(badge, ['url', 'image', 'badgeUrl', 'value2'], ''))
      }

      function badgeRarity(badge) {
        const explicit = normalize(get(badge, ['rarity', 'tier', 'badgeRarity', 'type'], ''))
        if (explicit) {
          if (explicit.includes('mythic') || explicit.includes('اسطوري') || explicit.includes('أسطوري')) return 'Mythic'
          if (explicit.includes('legendary') || explicit.includes('legend')) return 'Legendary'
          if (explicit.includes('epic')) return 'Epic'
          if (explicit.includes('rare')) return 'Rare'
          if (explicit.includes('common')) return 'Common'
        }

        const name = normalize(badgeName(badge))

        if (
          name.includes('vip') || name.includes('king') || name.includes('ملك') ||
          name.includes('3m') || name.includes('1m') || name.includes('1000q') ||
          name.includes('100d') || name.includes('500k')
        ) return 'Legendary'

        if (
          name.includes('250k') || name.includes('600q') ||
          name.includes('60d') || name.includes('500q')
        ) return 'Epic'

        if (
          name.includes('100k') || name.includes('300q') || name.includes('30d') ||
          name.includes('law') || name.includes('محامي')
        ) return 'Rare'

        return 'Common'
      }

      function badgeXpValue(rarity) {
        return CONFIG.BADGE_XP[rarity] || CONFIG.BADGE_XP.Common
      }

      function badgeXp(badge) {
        return badgeXpValue(badgeRarity(badge))
      }

      function totalBadgeXp(badges) {
        return (Array.isArray(badges) ? badges : []).reduce((sum, badge) => sum + badgeXp(badge), 0)
      }

      function fallbackAvatar(name) {
        const letter = encodeURIComponent((name || 'U').charAt(0).toUpperCase())
        return `data:image/svg+xml;utf8,
        <svg xmlns='http://www.w3.org/2000/svg' width='300' height='300' viewBox='0 0 300 300'>
          <defs>
            <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
              <stop stop-color='%23ffdf8a'/>
              <stop offset='1' stop-color='%23613f13'/>
            </linearGradient>
          </defs>
          <rect width='300' height='300' rx='58' fill='%23090909'/>
          <circle cx='150' cy='132' r='70' fill='url(%23g)' opacity='.95'/>
          <text x='150' y='168' font-size='92' text-anchor='middle' font-family='Arial' font-weight='900' fill='%23100b04'>${letter}</text>
          <rect x='60' y='222' width='180' height='22' rx='11' fill='%23ffdf8a' opacity='.22'/>
        </svg>`
      }

      function fallbackCover() {
        return `radial-gradient(circle at 50% 20%, rgba(255,223,138,.24), transparent 35%),
                linear-gradient(135deg, #1a1208, #080808 58%, #1d160b)`
      }

      function currentPoints(user) {
        return num(deepGet(user, ['points', 'totalPoints', 'balance', 'loyaltyPoints'], 0))
      }

      function currentGold(user) {
        return num(deepGet(user, ['gold', 'Gold', 'goldBalance'], 0))
      }

      function pointsXp(user) {
        return Math.floor(currentPoints(user) / CONFIG.POINTS_PER_XP)
      }

      function watchSeconds(user) {
        const watchtimeValue = deepGet(user, [
          'watchtime', 'Watchtime', 'watchTime', 'WatchTime', 'twitchWatchtime', 'twitch_watchtime'
        ], '')

        if (watchtimeValue !== '') {
          const parsedWatchtime = parseWatchtimeText(watchtimeValue)
          if (parsedWatchtime > 0) return parsedWatchtime
        }

        const directSeconds = num(deepGet(user, [
          'watchSeconds', 'watchtimeSeconds', 'watchTimeSeconds', 'totalWatchSeconds', 'totalWatchtimeSeconds'
        ], 0))
        if (directSeconds > 0) return directSeconds

        const directMinutes = num(deepGet(user, [
          'watchMinutes', 'watchtimeMinutes', 'watchTimeMinutes', 'totalWatchMinutes', 'totalWatchtimeMinutes'
        ], 0))
        if (directMinutes > 0) return directMinutes * 60

        const directHours = num(deepGet(user, [
          'watchHours', 'watchtimeHours', 'watchTimeHours', 'totalWatchHours', 'totalWatchtimeHours'
        ], 0))
        if (directHours > 0) return directHours * 3600

        return parseWatchtimeText(deepGet(user, [
          'watchtimeText', 'watchTimeText', 'watchTime', 'totalWatchtime', 'totalWatchTime'
        ], ''))
      }

      function parseWatchtimeText(value) {
        const text = String(value || '').toLowerCase().trim()
        if (!text) return 0

        const clockMatch = text.match(/^(\d+):(\d{1,2})(?::(\d{1,2}))?$/)
        if (clockMatch) {
          const first = Number(clockMatch[1])
          const second = Number(clockMatch[2])
          const third = Number(clockMatch[3] || 0)
          if (clockMatch[3] !== undefined) return (first * 3600) + (second * 60) + third
          return (first * 60) + second
        }

        let seconds = 0
        const dayMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:d|day|days|يوم|ايام|أيام)/)
        const hourMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:h|hr|hrs|hour|hours|ساعة|ساعه)/)
        const minuteMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:m|min|mins|minute|minutes|دقيقة|دقيقه)/)
        const secondMatch = text.match(/(\d+(?:\.\d+)?)\s*(?:s|sec|secs|second|seconds|ثانية|ثانيه)/)

        if (dayMatch) seconds += Number(dayMatch[1]) * 86400
        if (hourMatch) seconds += Number(hourMatch[1]) * 3600
        if (minuteMatch) seconds += Number(minuteMatch[1]) * 60
        if (secondMatch) seconds += Number(secondMatch[1])
        if (seconds > 0) return seconds

        const plainNumber = Number(text.replace(/,/g, ''))
        if (Number.isFinite(plainNumber) && plainNumber > 0) return plainNumber * 60

        return 0
      }

      function watchMinutes(user) {
        return Math.floor(watchSeconds(user) / 60)
      }

      function watchtimeLabel(user) {
        const totalMinutes = watchMinutes(user)

        if (totalMinutes <= 0) {
          const fallback = deepGet(user, ['watchtimeText', 'watchTimeText', 'watchtime', 'Watchtime', 'WatchTime'], '')
          if (fallback !== '') {
            const parsedMinutes = Math.floor(parseWatchtimeText(fallback) / 60)
            if (parsedMinutes > 0) return formatWatchtimeFromMinutes(parsedMinutes)
          }
          return '0 يوم'
        }

        return formatWatchtimeFromMinutes(totalMinutes)
      }

      function levelScore(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const pointsScore = pointsXp(user)
        const watchScore = watchMinutes(user) * CONFIG.WATCH_MINUTE_WEIGHT
        const loginScore = dailyLoginXp(user)
        const badgesScore = totalBadgeXp(badges)

        return Math.floor(pointsScore + watchScore + loginScore + badgesScore)
      }

      function calculateLevel(user) {
        const score = levelScore(user)
        let level = 1
        let remaining = score
        let required = getRequiredXp(level)

        while (remaining >= required && level < CONFIG.MAX_LEVEL) {
          remaining -= required
          level++
          required = getRequiredXp(level)
        }

        return {
          level,
          currentXp: remaining,
          requiredXp: required,
          percent: required > 0 ? Math.min(100, Math.round((remaining / required) * 100)) : 0,
          mode: 'XP',
          score,
          pointsScore: pointsXp(user),
          watchScore: watchMinutes(user) * CONFIG.WATCH_MINUTE_WEIGHT,
          dailyLoginScore: dailyLoginXp(user),
          dailyLoginCount: dailyLoginCount(user),
          badgeScore: totalBadgeXp(Array.isArray(user.badges) ? user.badges : []),
          watchMinutes: watchMinutes(user),
        }
      }

      function getRequiredXp(level) {
        return Math.floor(
          CONFIG.LEVEL_XP_BASE * Math.pow(level, CONFIG.LEVEL_XP_EXP) + (level * CONFIG.LEVEL_XP_LINEAR)
        )
      }

      function getLevelTitle(level) {
        if (level >= 50) return 'أسطورة المجلس'
        if (level >= 35) return 'عضو نخبة'
        if (level >= 20) return 'ثقيل بالمجلس'
        if (level >= 10) return 'عضو فعّال'
        if (level >= 5) return 'عضو معروف'
        return 'عضو جديد'
      }

      /* ---------------------------------------------------------------
       * بناء فهرس الترتيب مرة واحدة بعد التحميل بدل إعادة حساب
       * كل القائمة لكل مستخدم (كان O(n²)).
       * ------------------------------------------------------------- */
      function buildRankIndex() {
        const rows = state.users
          .map((rawUser) => {
            const merged = mergeUser(rawUser)
            const levelData = calculateLevel(merged)
            return {
              merged,
              level: levelData.level,
              score: levelData.score,
              points: currentPoints(merged),
              name: userName(merged) || userLogin(merged),
              keyId: userId(merged),
              keyLogin: normalize(userLogin(merged)),
            }
          })
          .filter((row) => row.keyId || row.keyLogin || userName(row.merged))
          .sort((a, b) => {
            if (b.level !== a.level) return b.level - a.level
            if (b.score !== a.score) return b.score - a.score
            if (b.points !== a.points) return b.points - a.points
            return String(a.name).localeCompare(String(b.name))
          })

        const map = new Map()
        rows.forEach((row, index) => {
          const rank = index + 1
          if (row.keyId) map.set('id:' + row.keyId, rank)
          if (row.keyLogin) map.set('login:' + row.keyLogin, rank)
        })

        state.rankIndex = map
      }

      function rankFor(user) {
        const idx = state.rankIndex
        if (!idx) return '—'

        const id = userId(user)
        const login = normalize(userLogin(user))

        let rank = (id && idx.get('id:' + id)) || (login && idx.get('login:' + login))
        return rank ? `#${rank}` : '—'
      }

      function messagesFor(user) {
        return get(user, ['messages', 'messageCount', 'chatMessages'], 0)
      }

      function dailyLoginCount(user) {
        return num(deepGet(user, [
          'dailyLogin', 'dailyLogins', 'daily_login', 'daily_logins',
          'dailyCheckIns', 'dailyCheckins', 'checkins', 'checkIns',
          'attendance', 'loginCount', 'login_count', 'daily', 'streak'
        ], 0))
      }

      function dailyLoginXp(user) {
        return dailyLoginCount(user) * CONFIG.DAILY_LOGIN_XP
      }

      function checkinsFor(user) {
        return dailyLoginCount(user)
      }

      function chipsFor(user, level, badges, inventory) {
        const chips = []

        const job = get(user, ['jobName'], '')
        if (job) chips.push(job)

        if (level >= 20) chips.push('ثقيل بالمجلس')
        else if (level >= 10) chips.push('متفاعل')
        else if (level >= 5) chips.push('عضو معروف')

        if (badges.length >= 10) chips.push('صاحب بادجات')
        if (inventory.some((item) => normalize(item.name).includes('vip'))) chips.unshift('VIP')
        if (!chips.length) chips.push('عضو')

        return chips.slice(0, 5)
      }

      function showView(id) {
        ;['loadingView', 'searchView', 'notFoundView', 'profileView'].forEach((viewId) => {
          $(viewId)?.classList.toggle('hidden', viewId !== id)
        })
      }

      function renderProfile(rawUser) {
        const user = mergeUser(rawUser)
        state.activeUser = user

        showView('profileView')

        const login = userLogin(user)
        const name = userName(user) || login
        const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], '')) || fallbackAvatar(name)
        const coverUrl = cssUrl(get(user, ['bannerImage', 'banner', 'backgroundImage'], ''))
        const badges = Array.isArray(user.badges) ? user.badges : []
        const inventory = inventoryItems(user)
        const mail = mailItems(user)
        const level = calculateLevel(user)
        const bio = get(user, ['bio'], 'ملف العضو يعرض المستوى، الحقيبة، البادجات، والبريد في صفحة واحدة بشكل واضح.')

        document.documentElement.style.setProperty('--cover-image', coverUrl ? `url("${coverUrl}")` : fallbackCover())

        if ($('avatar')) $('avatar').src = avatar
        if ($('onlineDot')) $('onlineDot').style.display = get(user, ['online', 'isOnline'], false) ? 'block' : 'none'

        setText('displayName', name)
        setText('handle', '@' + login)
        setText('bio', bio)

        setText('levelNumber', level.level)
        setText('levelTitle', getLevelTitle(level.level))
        setText('levelDesc', `النظام يحسب من النقاط وwatchtime وتسجيل الدخول والبادجات. كل ${CONFIG.POINTS_PER_XP} نقاط = 1 XP، وكل دقيقة مشاهدة = ${CONFIG.WATCH_MINUTE_WEIGHT} XP. باقي ${formatNumber(level.requiredXp - level.currentXp)} XP للوصول إلى لفل ${level.level + 1}.`)
        setText('currentXp', `${formatNumber(level.currentXp)} XP`)
        setText('neededXp', `${formatNumber(level.requiredXp)} XP`)
        if ($('xpFill')) $('xpFill').style.width = level.percent + '%'

        setText('rank', rankFor(user))
        setText('messages', formatNumber(messagesFor(user)))
        setText('checkins', formatNumber(checkinsFor(user)))
        setText('points', formatNumber(currentPoints(user)))
        setText('gold', formatNumber(currentGold(user)))

        setText('inventoryCount', `${inventory.length} ${inventory.length === 1 ? 'غرض' : 'أغراض'}`)
        setText('badgesCount', `${badges.length} مفتوحة`)
        setText('mailCount', mail.length)

        if ($('badgesPageLink')) $('badgesPageLink').href = `/badges?user=${encodeURIComponent(login)}`

        renderChips(chipsFor(user, level.level, badges, inventory))
        renderStats(user, inventory, badges, mail)
        renderInventory(inventory)
        renderBadges(badges)
        renderMail(mail)
      }

      function renderChips(chips) {
        const box = $('chips')
        if (!box) return

        box.innerHTML = chips.map((chip, index) => `
          <span class="chip${index === 0 ? ' gold' : ''}">${esc(chip)}</span>
        `).join('')
      }

      function renderStats(user, inventory, badges, mail) {
        const box = $('statsGrid')
        if (!box) return

        const level = calculateLevel(user)

        const stats = [
          { label: 'Watchtime', value: watchtimeLabel(user) },
          { label: 'Daily Login', value: formatNumber(dailyLoginCount(user)) },
          { label: 'Gold', value: formatNumber(currentGold(user)) },
          { label: 'Badge XP', value: formatNumber(totalBadgeXp(badges)) },
          { label: 'Level XP', value: formatNumber(level.score) },
          { label: 'Items', value: formatNumber(inventory.length) },
          { label: 'Badges', value: formatNumber(badges.length) },
        ]

        box.innerHTML = stats.map((stat) => `
          <div class="stat">
            <span>${esc(stat.label)}</span>
            <strong>${esc(stat.value)}</strong>
          </div>
        `).join('')
      }

      function renderInventory(items) {
        const box = $('inventory')
        if (!box) return

        if (!items.length) {
          box.innerHTML = `<div class="empty">الحقيبة فاضية.</div>`
          return
        }

        const sorted = [...items].sort((a, b) => b.qty - a.qty || a.name.localeCompare(b.name))

        box.innerHTML = sorted.map((item, index) => {
          const color = rarityColors[item.rarity] || rarityColors[item.cat] || '#ffffff'
          return `
            <button class="item" type="button" data-item-index="${index}" style="--rarity-color:${esc(color)}">
              <div class="item-icon">${esc(item.icon)}</div>
              <div>
                <h3 class="item-name">${esc(item.name)}</h3>
                <div class="item-meta">
                  <span class="qty">x${formatNumber(item.qty)}</span>
                  <span>${esc(item.rarity || item.cat || 'Item')}</span>
                </div>
              </div>
            </button>
          `
        }).join('')

        box.querySelectorAll('[data-item-index]').forEach((button) => {
          addListener(button, 'click', () => {
            const item = sorted[Number(button.dataset.itemIndex)]
            if (item) openItemModal(item)
          })
        })
      }

      function renderBadges(badges) {
        const box = $('badges')
        if (!box) return

        if (!badges.length) {
          box.innerHTML = `<div class="empty">ما فيه بادجات ظاهرة.</div>`
          return
        }

        box.innerHTML = badges.slice(0, 15).map((badge) => {
          const name = badgeName(badge)
          const image = badgeImage(badge)
          const rarity = badgeRarity(badge)
          const xp = badgeXp(badge)

          return `
            <div class="badge" title="${esc(name)} - ${esc(rarity)} - ${formatNumber(xp)} XP">
              ${image ? `<img src="${esc(image)}" alt="${esc(name)}" loading="lazy" />` : `<div class="badge-icon">🏅</div>`}
              <div class="badge-name">${esc(name)}</div>
            </div>
          `
        }).join('')
      }

      function mailItems(user) {
        const mail = Array.isArray(user.mailbox) ? [...user.mailbox] : []
        return mail.sort((a, b) => new Date(get(b, ['date', 'createdAt'], 0)) - new Date(get(a, ['date', 'createdAt'], 0)))
      }

      function renderMail(mail) {
        const box = $('mailList')
        if (!box) return

        if (!mail.length) {
          box.innerHTML = `<div class="empty">ما عندك رسائل.</div>`
          return
        }

        box.innerHTML = mail.map((message) => {
          const from = get(message, ['from', 'fromDisplayName', 'fromLogin', 'fromUserName'], 'النظام')
          const text = get(message, ['message', 'text'], '')
          return `
            <div class="mail-message">
              <strong>${esc(from)}</strong>
              <p>${esc(text)}</p>
            </div>
          `
        }).join('')
      }

      function openMail() {
        $('mailModal')?.classList.add('show')
        $('mailModal')?.setAttribute('aria-hidden', 'false')
      }

      function closeMail() {
        $('mailModal')?.classList.remove('show')
        $('mailModal')?.setAttribute('aria-hidden', 'true')
      }

      function openItemModal(item) {
        const modal = document.createElement('div')
        modal.className = 'modal-backdrop show'
        modal.innerHTML = `
          <div class="item-modal">
            <div class="modal-head">
              <h3>${esc(item.name)}</h3>
              <button class="close-btn" type="button" data-close-item>×</button>
            </div>
            <div class="mail-list">
              <div class="mail-message">
                <strong>${esc(item.icon)} x${formatNumber(item.qty)}</strong>
                <p>${esc(item.description)}</p>
              </div>
            </div>
          </div>
        `

        document.body.appendChild(modal)

        const close = () => {
          modal.remove()
          window.removeEventListener('keydown', onKey)
        }
        const onKey = (event) => {
          if (event.key === 'Escape') close()
        }

        addListener(modal, 'click', (event) => {
          if (event.target === modal) close()
        })
        addListener(modal.querySelector('[data-close-item]'), 'click', close)
        window.addEventListener('keydown', onKey)
      }

      /* ---------------------------------------------------------------
       * البحث: debounce + تنقّل بالكيبورد (أسهم + Enter + Escape)
       * ------------------------------------------------------------- */
      let activeResultIndex = -1

      function renderSearch(query) {
        const target = $('searchResults')
        const input = $('searchInput')
        if (!target) return

        const q = normalize(query)
        target.innerHTML = ''
        activeResultIndex = -1
        if (input) input.setAttribute('aria-expanded', 'false')
        if (!q) return

        const matches = state.users.filter((user) =>
          normalize(userName(user)).includes(q) || normalize(userLogin(user)).includes(q)
        ).slice(0, CONFIG.SEARCH_MAX_RESULTS)

        target.innerHTML = matches.map((user, index) => {
          const login = userLogin(user)
          const name = userName(user) || login
          const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], '')) || fallbackAvatar(name)

          return `
            <button type="button" class="search-result" role="option" id="result-${index}"
                    data-login="${esc(login)}" data-index="${index}">
              <img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy" />
              <div>
                <strong>${esc(name)}</strong>
                <span>@${esc(login)}</span>
              </div>
            </button>
          `
        }).join('')

        if (input) input.setAttribute('aria-expanded', matches.length ? 'true' : 'false')
      }

      function setActiveResult(nextIndex) {
        const buttons = Array.from($('searchResults')?.querySelectorAll('.search-result') || [])
        if (!buttons.length) return

        const count = buttons.length
        activeResultIndex = ((nextIndex % count) + count) % count

        buttons.forEach((btn, i) => {
          const active = i === activeResultIndex
          btn.classList.toggle('is-active', active)
          if (active) {
            btn.scrollIntoView({ block: 'nearest' })
            $('searchInput')?.setAttribute('aria-activedescendant', btn.id)
          }
        })
      }

      function openSearchResult(button) {
        if (!button) return
        const user = findUser(button.dataset.login)
        if (!user) return
        history.replaceState(null, '', profileLink(user))
        renderProfile(user)
      }

      function findUser(login) {
        const target = normalize(login)
        return state.users.find((user) =>
          normalize(userLogin(user)) === target || normalize(userName(user)) === target
        ) || null
      }

      function openFromQuery() {
        const raw = new URLSearchParams(location.search).get('user')

        if (!raw) {
          showView('searchView')
          $('searchInput')?.focus()
          return
        }

        const user = findUser(raw)

        if (!user) {
          showView('notFoundView')
          return
        }

        renderProfile(user)
      }

      function profileLink(user) {
        const url = new URL(location.href)
        url.searchParams.set('user', userLogin(user))
        url.hash = ''
        return url.toString()
      }

      async function loadJson(url, fallback) {
        try {
          const res = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!res.ok) return fallback
          return await res.json()
        } catch {
          return fallback
        }
      }

      /* ---- ربط الأحداث ---- */
      let searchTimer = null
      addListener($('searchInput'), 'input', (event) => {
        const value = event.target.value
        if (searchTimer) window.clearTimeout(searchTimer)
        searchTimer = addTimer(window.setTimeout(() => renderSearch(value), CONFIG.SEARCH_DEBOUNCE_MS))
      })

      addListener($('searchInput'), 'keydown', (event) => {
        const buttons = Array.from($('searchResults')?.querySelectorAll('.search-result') || [])

        if (event.key === 'ArrowDown') {
          event.preventDefault()
          setActiveResult(activeResultIndex + 1)
        } else if (event.key === 'ArrowUp') {
          event.preventDefault()
          setActiveResult(activeResultIndex - 1)
        } else if (event.key === 'Enter') {
          if (activeResultIndex >= 0 && buttons[activeResultIndex]) {
            event.preventDefault()
            openSearchResult(buttons[activeResultIndex])
          } else if (buttons.length === 1) {
            event.preventDefault()
            openSearchResult(buttons[0])
          }
        } else if (event.key === 'Escape') {
          if ($('searchInput')) $('searchInput').value = ''
          renderSearch('')
        }
      })

      addListener($('clearSearch'), 'click', () => {
        if (!$('searchInput') || !$('searchResults')) return
        $('searchInput').value = ''
        renderSearch('')
        $('searchInput').focus()
      })

      addListener($('searchResults'), 'click', (event) => {
        const button = event.target.closest('[data-login]')
        if (!button) return
        openSearchResult(button)
      })

      addListener($('searchResults'), 'mousemove', (event) => {
        const button = event.target.closest('[data-index]')
        if (button) setActiveResult(Number(button.dataset.index))
      })

      addListener($('openMailButton'), 'click', openMail)
      addListener($('closeMailButton'), 'click', closeMail)

      addListener($('mailModal'), 'click', (event) => {
        if (event.target === $('mailModal')) closeMail()
      })

      addListener(window, 'keydown', (event) => {
        if (event.key === 'Escape' && $('mailModal')?.classList.contains('show')) closeMail()
      })

      addListener($('copyLink'), 'click', async (event) => {
        if (!state.activeUser) return

        const button = event.currentTarget
        const old = button.textContent

        try {
          await navigator.clipboard.writeText(profileLink(state.activeUser))
          button.textContent = 'تم النسخ'
          addTimer(window.setTimeout(() => { button.textContent = old }, 1200))
        } catch {
          button.textContent = profileLink(state.activeUser)
        }
      })

      addListener($('backToTop'), 'click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))

      addListener(window, 'scroll', () => {
        $('backToTop')?.classList.toggle('is-visible', window.scrollY > 420)
      }, { passive: true })

      /* ---- تحميل البيانات ثم بناء الفهارس ---- */
      const [users, inventories, mailboxes, profiles, itemPayload, leaderboardPayload] = await Promise.all([
        loadJson('/api/user_badges.json', []),
        loadJson('/api/user_inventory.json', []),
        loadJson('/api/user_mailbox.json', []),
        loadJson('/api/user_profile.json', []),
        loadJson('/api/items.json', { items: [] }),
        loadJson('/api/leaderboard_data.json', {}),
      ])

      state.users = Array.isArray(users) ? users : []
      state.items = Array.isArray(itemPayload) ? itemPayload : Array.isArray(itemPayload.items) ? itemPayload.items : []

      state.leaderboards = {
        points: normalizeLeaderboardData(leaderboardPayload, 'points'),
        gold: normalizeLeaderboardData(leaderboardPayload, 'gold'),
        watchtime: normalizeLeaderboardData(leaderboardPayload, 'watchtime'),
      }

      // فهارس O(1) للسجلات والكاتالوج، ثم فهرس الترتيب مرة واحدة
      state.index.profiles = buildIndex(Array.isArray(profiles) ? profiles : [])
      state.index.inventories = buildIndex(Array.isArray(inventories) ? inventories : [])
      state.index.mailboxes = buildIndex(Array.isArray(mailboxes) ? mailboxes : [])
      buildCatalogIndex()
      buildRankIndex()

      openFromQuery()
    })()
  </script>
</Layout>
