      }

      .profile-side .profile-panel:last-child {
        grid-column: 1 / -1;
      }
    }

    @media (max-width: 720px) {
      .profile-shell {
        padding-top: 5rem;
      }

      .profile-page-head h1 {
        font-size: 3rem;
      }

      .hero-inner {
        grid-template-columns: 1fr;
        min-height: auto;
        justify-items: center;
        padding-top: 5rem;
        text-align: center;
      }

      .identity h2 {
        white-space: normal;
        font-size: 2.35rem;
      }

      .login {
        text-align: center;
      }

      .hero-badges {
        justify-content: center;
      }

      .hero-stats,
      .display-case,
      .profile-side {
