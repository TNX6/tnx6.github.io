---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'Profile — TNX6',
  ignoreTitleTemplate: true,
  description: 'صفحة بروفايل أعضاء مجتمع TNX6.',
}
---

<Layout metadata={metadata}>
  <main class="profile-page" dir="rtl">
    <div class="page-bg"></div>
    <div class="grid-bg"></div>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="shell">
      <header class="hero">
        <div class="eyebrow"><span></span> TNX6 PROFILE</div>
        <h1>بروفايل العضو</h1>
        <p>صفحة تعرض صورة العضو، خلفيته، نقاطه، ذهبه، وظيفته، بادجاته، وأغراضه بشكل قريب من Steam Profile.</p>

        <div class="search-box">
          <span>⌕</span>
          <input id="profileSearch" type="search" autocomplete="off" placeholder="اكتب اسم المستخدم..." />
          <button id="clearProfileSearch" type="button" aria-label="مسح">×</button>
        </div>

        <div id="profileResults" class="profile-results"></div>
      </header>

      <section id="profileEmpty" class="empty">
        <strong>ابحث عن عضو</strong>
        <span>اكتب اسم Twitch أو افتح رابط مباشر مثل: /profile?user=haneen48</span>
      </section>

      <section id="profileContent" class="profile-content hidden">
        <section id="profileHeader" class="profile-header"></section>

        <section class="profile-layout">
          <div class="main-column">
            <section class="panel">
              <div class="section-head">
                <span>BADGES SHOWCASE</span>
                <h2>البادجات</h2>
                <p>البادجات المختارة والمفتوحة عند العضو.</p>
              </div>
              <div id="badgeShowcase" class="badge-showcase"></div>
            </section>

            <section class="panel">
              <div class="section-head row-head">
                <div>
                  <span>INVENTORY</span>
                  <h2>الحقيبة</h2>
                  <p>الأغراض المملوكة وعدد كل غرض.</p>
                </div>
                <div class="inventory-count"><strong id="inventoryCount">0</strong><span>غرض</span></div>
              </div>

              <div class="filter-row" id="inventoryFilters">
                <button type="button" class="is-active" data-inv-filter="all">الكل</button>
                <button type="button" data-inv-filter="featured">مميز</button>
                <button type="button" data-inv-filter="box">صناديق</button>
                <button type="button" data-inv-filter="license">رخص</button>
                <button type="button" data-inv-filter="resource">موارد</button>
                <button type="button" data-inv-filter="usable">قابل للاستخدام</button>
              </div>

              <div id="inventoryGrid" class="inventory-grid"></div>
              <div id="inventoryEmpty" class="empty empty-small hidden"><strong>ما فيه أغراض ظاهرة</strong><span>الحقيبة فاضية أو الفلتر الحالي ما طلع نتائج.</span></div>
            </section>
          </div>

          <aside class="side-column">
            <section class="panel"><div class="section-head"><span>QUICK STATS</span><h2>إحصائيات</h2></div><div id="quickStats" class="quick-stats"></div></section>
            <section class="panel"><div class="section-head"><span>RARE ITEMS</span><h2>أندر الأغراض</h2></div><div id="rareItems" class="rare-items"></div></section>
            <section class="panel"><div class="section-head"><span>LINKS</span><h2>روابط</h2></div><div class="profile-links"><a id="badgesPageLink" href="/badges">عرض بطاقة البادجات</a><button id="copyProfileLink" type="button">نسخ رابط البروفايل</button></div></section>
          </aside>
        </section>
      </section>
    </section>
  </main>

  <style is:global>
    .hidden{display:none!important}html{scrollbar-width:thin;scrollbar-color:rgba(255,218,106,.38) rgba(0,0,0,.3)}html::-webkit-scrollbar{width:10px}html::-webkit-scrollbar-track{background:rgba(0,0,0,.35)}html::-webkit-scrollbar-thumb{border:2px solid rgba(0,0,0,.35);border-radius:999px;background:linear-gradient(180deg,rgba(255,218,106,.78),rgba(194,146,0,.5))}.profile-page{position:relative;min-height:100vh;overflow:hidden;background:#07050b;color:#fff;font-family:Poppins,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}.page-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(circle at 12% 9%,rgba(255,218,106,.15),transparent 28%),radial-gradient(circle at 86% 14%,rgba(194,146,0,.13),transparent 34%),radial-gradient(circle at 48% 92%,rgba(124,58,237,.12),transparent 38%),linear-gradient(135deg,#07050b 0%,#050507 55%,#130c05 100%);animation:bgBreathe 9s ease-in-out infinite}@keyframes bgBreathe{0%,100%{filter:saturate(1) brightness(1);transform:scale(1)}50%{filter:saturate(1.12) brightness(1.06);transform:scale(1.018)}}.grid-bg{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.06;background-image:linear-gradient(rgba(255,218,106,.42) 1px,transparent 1px),linear-gradient(90deg,rgba(255,218,106,.42) 1px,transparent 1px);background-size:58px 58px;mask-image:radial-gradient(circle at center,#000 0%,transparent 74%)}.shell{position:relative;z-index:1;width:min(100%,1240px);margin:0 auto;padding:6.5rem 1rem 5rem}.back-top{position:fixed;left:1.25rem;bottom:1.25rem;z-index:90;display:grid;place-items:center;width:3.1rem;height:3.1rem;border:1px solid rgba(255,218,106,.42);border-radius:999px;background:rgba(7,5,11,.9);color:#ffda6a;font-size:1.35rem;font-weight:950;cursor:pointer;box-shadow:0 18px 40px rgba(0,0,0,.45),0 0 22px rgba(255,218,106,.12);backdrop-filter:blur(14px);opacity:0;transform:translateY(16px) scale(.92);pointer-events:none;transition:220ms cubic-bezier(.22,1,.36,1)}.back-top.is-visible{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}.hero{max-width:940px;margin:0 auto 1rem;text-align:center}.eyebrow{display:inline-flex;align-items:center;gap:.55rem;border:1px solid rgba(255,218,106,.3);border-radius:999px;background:rgba(0,0,0,.4);color:#ffda6a;padding:.55rem .95rem;font-size:.78rem;font-weight:950;letter-spacing:.16em}.eyebrow span{width:.48rem;height:.48rem;border-radius:999px;background:#ffda6a;box-shadow:0 0 14px #ffda6a}.hero h1{margin:1.1rem 0 0;background:linear-gradient(90deg,#fff1a8,#ffda6a 44%,#c29200);background-clip:text;color:transparent;font-size:clamp(3.1rem,7vw,6.6rem);font-weight:950;line-height:.95;letter-spacing:-.055em}.hero p{max-width:760px;margin:1.15rem auto 0;color:#d1d5db;font-size:1.04rem;font-weight:760;line-height:1.9}.search-box{display:grid;grid-template-columns:auto minmax(0,1fr) auto;gap:.75rem;align-items:center;max-width:680px;margin:1.2rem auto 0;border:1px solid rgba(255,218,106,.22);border-radius:1.15rem;background:rgba(0,0,0,.32);padding:.85rem;box-shadow:0 18px 46px rgba(0,0,0,.28);backdrop-filter:blur(14px)}.search-box span{color:#ffda6a;font-size:1.4rem;font-weight:950}.search-box input{width:100%;border:0;outline:0;background:transparent;color:white;font-size:.96rem;font-weight:850}.search-box button{display:grid;place-items:center;width:2.2rem;height:2.2rem;border:1px solid rgba(255,218,106,.2);border-radius:999px;background:rgba(255,218,106,.08);color:#ffda6a;font-size:1.2rem;font-weight:950;cursor:pointer}.profile-results{display:grid;gap:.55rem;max-width:680px;margin:.75rem auto 0}.profile-result{display:flex;align-items:center;gap:.8rem;border:1px solid rgba(255,218,106,.16);border-radius:1rem;background:rgba(0,0,0,.42);color:white;padding:.75rem;text-align:right;cursor:pointer;transition:180ms ease}.profile-result:hover{transform:translateY(-2px);border-color:rgba(255,218,106,.48);background:rgba(255,218,106,.08)}.profile-result img{width:42px;height:42px;border-radius:999px;object-fit:cover;border:1px solid rgba(255,218,106,.25)}.profile-result strong{display:block;color:#f7e6ac;font-size:.95rem;font-weight:950}.profile-result span{display:block;margin-top:.15rem;color:#9ca3af;font-size:.75rem;font-weight:800;direction:ltr;text-align:right}.empty{display:grid;place-items:center;gap:.35rem;max-width:720px;margin:1rem auto 0;min-height:220px;border:1px solid rgba(255,218,106,.16);border-radius:1.6rem;background:rgba(6,6,8,.76);padding:2rem;text-align:center;box-shadow:0 24px 70px rgba(0,0,0,.35);backdrop-filter:blur(16px)}.empty-small{max-width:none;min-height:180px;margin:0}.empty strong{color:#ffda6a;font-size:1.35rem;font-weight:950}.empty span{color:#9ca3af;font-size:.9rem;font-weight:800;line-height:1.7}.profile-content{display:grid;gap:1rem;margin-top:1rem}.profile-header{position:relative;overflow:hidden;min-height:380px;border:1px solid rgba(255,218,106,.22);border-radius:2rem;background:rgba(6,6,8,.78);box-shadow:0 28px 80px rgba(0,0,0,.48);backdrop-filter:blur(16px)}.profile-banner{position:absolute;inset:0 0 auto 0;height:210px;background-position:center;background-size:cover;opacity:.95}.profile-banner::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.1),rgba(7,5,11,.85)),radial-gradient(circle at top right,rgba(255,218,106,.12),transparent 42%)}.profile-header-body{position:relative;z-index:1;display:grid;grid-template-columns:auto minmax(0,1fr) auto;gap:1.25rem;align-items:end;padding:145px 1.35rem 1.35rem}.profile-avatar{width:152px;height:152px;border:6px solid var(--profile-color,#ffda6a);border-radius:1.8rem;object-fit:cover;background:#111;box-shadow:0 22px 48px rgba(0,0,0,.48)}.profile-title{min-width:0;padding-bottom:.2rem}.profile-title h2{margin:0;color:#fff;font-size:clamp(2rem,4vw,4rem);font-weight:950;line-height:1;text-shadow:0 4px 18px rgba(0,0,0,.72);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.profile-title p{margin:.5rem 0 0;color:#d1d5db;font-size:.92rem;font-weight:850;direction:ltr;text-align:right}.profile-job{display:inline-flex;align-items:center;gap:.5rem;margin-top:.75rem;border:1px solid rgba(255,218,106,.25);border-radius:999px;background:rgba(0,0,0,.45);color:#f7e6ac;padding:.55rem .75rem;font-size:.82rem;font-weight:950}.profile-job iconify-icon{color:#ffda6a;font-size:1.15rem}.profile-money{display:grid;grid-template-columns:repeat(2,minmax(110px,1fr));gap:.75rem;width:320px;max-width:100%}.money-card{border:1px solid rgba(255,218,106,.16);border-radius:1.15rem;background:rgba(0,0,0,.42);padding:1rem;text-align:center;backdrop-filter:blur(14px)}.money-card span{display:block;color:#9ca3af;font-size:.75rem;font-weight:850}.money-card strong{display:block;margin-top:.35rem;color:#ffda6a;font-size:1.35rem;font-weight:950;direction:ltr}.profile-layout{display:grid;grid-template-columns:minmax(0,1fr) 340px;gap:1rem;align-items:start}.main-column,.side-column{display:grid;gap:1rem}.panel{border:1px solid rgba(255,218,106,.18);border-radius:1.6rem;background:linear-gradient(180deg,rgba(255,255,255,.035),rgba(255,255,255,.012)),rgba(6,6,8,.78);box-shadow:0 24px 70px rgba(0,0,0,.38),inset 0 0 22px rgba(255,218,106,.025);padding:1.1rem;backdrop-filter:blur(16px)}.section-head{margin-bottom:1rem}.row-head{display:flex;justify-content:space-between;align-items:start;gap:1rem}.section-head span{color:#c29200;font-size:.75rem;font-weight:950;letter-spacing:.12em}.section-head h2{margin:.35rem 0 0;color:#f7e6ac;font-size:1.55rem;font-weight:950;line-height:1.15}.section-head p{margin:.45rem 0 0;color:#9ca3af;font-size:.86rem;font-weight:800;line-height:1.65}.inventory-count{display:grid;place-items:center;min-width:90px;border:1px solid rgba(255,218,106,.18);border-radius:1rem;background:rgba(255,218,106,.06);padding:.7rem}.inventory-count strong{color:#ffda6a;font-size:1.4rem;font-weight:950;line-height:1}.inventory-count span{margin-top:.25rem;color:#9ca3af;font-size:.72rem;font-weight:850}.badge-showcase{display:grid;grid-template-columns:repeat(auto-fit,minmax(86px,1fr));gap:.7rem}.badge-tile{display:grid;place-items:center;gap:.5rem;min-height:118px;border:1px solid rgba(255,218,106,.14);border-radius:1.1rem;background:rgba(0,0,0,.28);padding:.7rem;text-align:center}.badge-tile img{width:58px;height:58px;object-fit:contain;filter:drop-shadow(0 8px 14px rgba(0,0,0,.42))}.badge-tile span{color:#e5e7eb;font-size:.68rem;font-weight:850;line-height:1.35}.filter-row{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem}.filter-row button{border:1px solid rgba(255,218,106,.22);border-radius:.85rem;background:rgba(255,218,106,.07);color:#f7e6ac;padding:.55rem .75rem;font-size:.78rem;font-weight:950;cursor:pointer;transition:180ms ease}.filter-row button:hover,.filter-row button.is-active{transform:translateY(-1px);border-color:rgba(255,218,106,.55);background:rgba(255,218,106,.14);color:#ffda6a}.inventory-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.8rem}.item-card{position:relative;display:grid;gap:.65rem;min-height:176px;border:1px solid rgba(255,218,106,.14);border-radius:1.15rem;background:radial-gradient(circle at top right,rgba(255,218,106,.07),transparent 42%),rgba(0,0,0,.3);padding:.85rem;overflow:hidden;transition:200ms ease}.item-card:hover{transform:translateY(-3px) scale(1.012);border-color:rgba(255,218,106,.5);box-shadow:0 18px 36px rgba(0,0,0,.36),0 0 22px rgba(255,218,106,.1)}.item-card.is-rare{border-color:rgba(255,218,106,.34);box-shadow:inset 0 0 28px rgba(255,218,106,.03)}.item-icon{display:grid;place-items:center;width:3rem;height:3rem;border:1px solid rgba(255,218,106,.18);border-radius:1rem;background:rgba(255,218,106,.07);color:#ffda6a;font-size:1.45rem}.item-card h3{margin:0;color:white;font-size:1rem;font-weight:950;line-height:1.25}.item-card p{margin:0;color:#9ca3af;font-size:.75rem;font-weight:800;line-height:1.55}.item-qty{position:absolute;top:.75rem;left:.75rem;display:grid;place-items:center;min-width:2.2rem;height:2.2rem;border:1px solid rgba(255,218,106,.26);border-radius:999px;background:rgba(0,0,0,.52);color:#ffda6a;font-size:.82rem;font-weight:950;direction:ltr}.item-meta{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:auto}.item-meta span{border:1px solid rgba(255,218,106,.12);border-radius:999px;background:rgba(255,218,106,.06);color:#f7e6ac;padding:.28rem .45rem;font-size:.62rem;font-weight:900}.quick-stats,.rare-items,.profile-links{display:grid;gap:.65rem}.stat-row,.rare-item{display:flex;justify-content:space-between;gap:.8rem;border:1px solid rgba(255,218,106,.12);border-radius:1rem;background:rgba(0,0,0,.26);padding:.85rem}.stat-row span{color:#9ca3af;font-size:.78rem;font-weight:850}.stat-row strong,.rare-item span{color:#ffda6a;font-size:.92rem;font-weight:950;direction:ltr}.rare-item strong{color:#f7e6ac;font-size:.86rem;font-weight:950}.profile-links a,.profile-links button{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,218,106,.24);border-radius:.95rem;background:rgba(255,218,106,.08);color:#f7e6ac;padding:.78rem .85rem;font-size:.82rem;font-weight:950;text-decoration:none;cursor:pointer;transition:180ms ease}.profile-links a:hover,.profile-links button:hover,.profile-links button.is-copied{transform:translateY(-2px);border-color:rgba(255,218,106,.56);background:rgba(255,218,106,.14);color:#ffda6a}@media(max-width:1040px){.profile-layout{grid-template-columns:1fr}.side-column{grid-template-columns:repeat(2,minmax(0,1fr))}.side-column .panel:last-child{grid-column:1/-1}.profile-header-body{grid-template-columns:auto minmax(0,1fr)}.profile-money{grid-column:1/-1;width:100%}}@media(max-width:720px){.shell{padding-top:5.5rem}.hero h1{font-size:3rem}.profile-header-body{grid-template-columns:1fr;justify-items:center;text-align:center}.profile-title p{text-align:center}.profile-avatar{width:132px;height:132px}.side-column{grid-template-columns:1fr}.profile-money{grid-template-columns:1fr}.row-head{flex-direction:column}.inventory-count{width:100%}.inventory-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:460px){.inventory-grid{grid-template-columns:1fr}}
  </style>

  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxProfilePageCleanup'
      if (window[cleanupKey]) window[cleanupKey]()
      const listeners = [], timers = []
      function addListener(target,event,handler,options){if(!target)return;target.addEventListener(event,handler,options);listeners.push(()=>target.removeEventListener(event,handler,options))}
      function addTimer(id){timers.push(id);return id}
      window[cleanupKey]=()=>{listeners.forEach(fn=>fn());listeners.length=0;timers.forEach(id=>clearTimeout(id));timers.length=0}

      const state={users:[],inventories:[],items:[],activeUser:null,inventoryFilter:'all'}
      const profileSearch=document.getElementById('profileSearch'),clearProfileSearch=document.getElementById('clearProfileSearch'),profileResults=document.getElementById('profileResults'),profileEmpty=document.getElementById('profileEmpty'),profileContent=document.getElementById('profileContent'),profileHeader=document.getElementById('profileHeader'),badgeShowcase=document.getElementById('badgeShowcase'),inventoryGrid=document.getElementById('inventoryGrid'),inventoryEmpty=document.getElementById('inventoryEmpty'),inventoryCount=document.getElementById('inventoryCount'),inventoryFilters=Array.from(document.querySelectorAll('[data-inv-filter]')),quickStats=document.getElementById('quickStats'),rareItems=document.getElementById('rareItems'),badgesPageLink=document.getElementById('badgesPageLink'),copyProfileLink=document.getElementById('copyProfileLink'),backToTop=document.getElementById('backToTop')
      const ITEM_META={'crown':{icon:'👑',type:'featured',rarity:'legendary'},'نيوك':{icon:'💣',type:'featured',rarity:'legendary'},'vip+':{icon:'💎',type:'license',rarity:'rare'},'رخصة محامي':{icon:'⚖️',type:'license',rarity:'rare'},'البريد':{icon:'📬',type:'usable',rarity:'uncommon'},'صندوق':{icon:'🎁',type:'box',rarity:'rare'},'صندوق السمعة':{icon:'🎁',type:'box',rarity:'rare'},'خشب':{icon:'🪵',type:'resource',rarity:'common'},'حديد':{icon:'⛓️',type:'resource',rarity:'common'},'ذهب':{icon:'🟡',type:'resource',rarity:'rare'}}
      const JOB_ICONS={tier1_Citizen:'mdi:account',tier2_Farmer:'mdi:sprout',tier3_Merchant:'mdi:store',tier3_Lawyer:'mdi:gavel',tier4_Judge:'mdi:scale-balance',tier5_King:'mdi:crown'}
      function esc(v){return String(v??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;')}
      function normalize(v){return String(v||'').toLowerCase().replace(/[ًٌٍَُِّْـ]/g,'').replace(/[أإآ]/g,'ا').replace(/ة/g,'ه').replace(/ى/g,'ي').replace(/\s+/g,' ').trim()}
      function slug(v){return normalize(v).replace(/\s+/g,'')}
      function formatNumber(v){return Number(v||0).toLocaleString('en-US')}
      function safeUrl(v){const u=String(v||'').trim();if(!/^https?:\/\//i.test(u)&&!u.startsWith('/'))return'';return u.replace(/["'()\\]/g,'')}
      function cssUrl(v){const u=safeUrl(v);return u?`url('${u}')`:'none'}
      function safeColor(v,f='#423fff'){const c=String(v||'').trim();return /^#[0-9a-fA-F]{6}$/.test(c)?c:f}
      function getUserName(u){return String(u?.userLogin||u?.userName||u?.UserLogin||u?.UserName||'').trim()}
      function getDisplayName(u){return String(u?.userName||u?.UserName||u?.userLogin||u?.UserLogin||'').trim()}
      function getInvName(u){return String(u?.userLogin||u?.UserLogin||u?.userName||u?.UserName||'').trim()}
      function getBadgeImage(b){return safeUrl(b?.url||b?.image||b?.badgeUrl||b?.value2)}
      function getBadgeName(b){return String(b?.name||b?.title||b?.badgeName||b?.value1||'').trim()}
      function getItemName(i){return String(i?.name||i?.itemName||i?.Name||i?.key||'').trim()}
      function getItemQty(i){const n=Number(i?.quantity??i?.qty??i?.count??i?.amount??i?.Value??1);return Number.isFinite(n)&&n>0?n:1}
      function getItemDetails(name){const k=slug(name);return state.items.find(i=>slug(i.name||i.itemName||i.title)===k)||null}
      function getItemMeta(name,details){const k=slug(name);const hard=Object.entries(ITEM_META).find(([n])=>slug(n)===k)?.[1]||null;return{icon:hard?.icon||details?.icon||'⬟',type:hard?.type||normalize(details?.category||details?.type||'')||'usable',rarity:hard?.rarity||normalize(details?.rarity||'')||'common'}}
      function getUserInventory(user){const id=String(user?.userId||user?.UserId||'').trim();const login=normalize(getUserName(user));return state.inventories.find(e=>{const invId=String(e.userId||e.UserId||'').trim();const invLogin=normalize(getInvName(e));return(id&&invId&&id===invId)||(login&&invLogin&&login===invLogin)})||null}
      function getInventoryItems(user){const inv=getUserInventory(user);if(!inv)return[];if(Array.isArray(inv.items))return inv.items;if(Array.isArray(inv.inventory))return inv.inventory;return[]}
      function getProfileLink(user){const url=new URL(window.location.href);url.searchParams.set('user',getUserName(user));url.hash='';return url.toString()}
      async function copyText(text,button,done='تم النسخ'){if(!button)return;const old=button.textContent;try{await navigator.clipboard.writeText(text);button.textContent=done;button.classList.add('is-copied');addTimer(setTimeout(()=>{button.textContent=old;button.classList.remove('is-copied')},1000))}catch{button.textContent=text;addTimer(setTimeout(()=>button.textContent=old,1300))}}
      async function loadJson(url,fallback){try{const res=await fetch(`${url}?v=${Date.now()}`,{cache:'no-store'});if(!res.ok)throw new Error(url);return await res.json()}catch(e){console.error(e);return fallback}}
      async function loadData(){const [users,inv,itemsPayload]=await Promise.all([loadJson('/api/user_badges.json',[]),loadJson('/api/user_inventory.json',[]),loadJson('/api/items.json',{items:[]})]);state.users=Array.isArray(users)?users:[];state.inventories=Array.isArray(inv)?inv:[];state.items=Array.isArray(itemsPayload)?itemsPayload:Array.isArray(itemsPayload?.items)?itemsPayload.items:[]}
      function renderResults(query){const q=normalize(query);profileResults.innerHTML='';if(!q)return;const matches=state.users.filter(u=>normalize(getDisplayName(u)).includes(q)||normalize(getUserName(u)).includes(q)).slice(0,10);if(!matches.length){profileResults.innerHTML='<div class="empty empty-small"><strong>ما فيه نتائج</strong><span>تأكد من اسم المستخدم.</span></div>';return}profileResults.innerHTML=matches.map((u,i)=>{const name=getDisplayName(u),login=getUserName(u),avatar=safeUrl(u.profileImageUrl||u.avatar||u.ProfileImageUrl);return`<button type="button" class="profile-result" data-result-index="${i}"><img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy"><div><strong>${esc(name)}</strong><span>${esc(login)}</span></div></button>`}).join('');Array.from(profileResults.querySelectorAll('[data-result-index]')).forEach(btn=>btn.addEventListener('click',()=>{const user=matches[Number(btn.dataset.resultIndex)];if(!user)return;profileSearch.value='';profileResults.innerHTML='';const url=new URL(window.location.href);url.searchParams.set('user',getUserName(user));url.hash='';history.replaceState(null,'',`${url.pathname}${url.search}`);renderProfile(user)}))}
      function renderHeader(user){const name=getDisplayName(user),login=getUserName(user),color=safeColor(user.backgroundColor||user.profileColor||'#423fff'),avatar=safeUrl(user.profileImageUrl||user.avatar||user.ProfileImageUrl),banner=safeUrl(user.bannerImage||user.banner||user.backgroundImage),jobName=user.jobName||'Citizen',jobId=user.jobId||'tier1_Citizen',jobIcon=JOB_ICONS[jobId]||'mdi:account';profileHeader.innerHTML=`<div class="profile-banner" style="background-image:${cssUrl(banner)};background-color:${color}"></div><div class="profile-header-body" style="--profile-color:${color}"><img class="profile-avatar" src="${esc(avatar)}" alt="${esc(name)}" loading="lazy"><div class="profile-title"><h2 title="${esc(name)}">${esc(name)}</h2><p>${esc(login)}</p><div class="profile-job"><iconify-icon icon="${esc(jobIcon)}"></iconify-icon><span>${esc(jobName)}</span></div></div><div class="profile-money"><div class="money-card"><span>النقاط</span><strong>${formatNumber(user.points)}</strong></div><div class="money-card"><span>الذهب</span><strong>${formatNumber(user.gold)}</strong></div></div></div>`}
      function renderBadges(user){const badges=Array.isArray(user.badges)?user.badges:[];const equipped=badges.filter(b=>b.equipped).slice(0,8);const shown=equipped.length?equipped:badges.slice(0,8);if(!shown.length){badgeShowcase.innerHTML='<div class="empty empty-small"><strong>ما فيه بادجات</strong><span>ما تم العثور على بادجات لهذا العضو.</span></div>';return}badgeShowcase.innerHTML=shown.map(b=>`<div class="badge-tile"><img src="${esc(getBadgeImage(b))}" alt="${esc(getBadgeName(b))}" loading="lazy"><span>${esc(getBadgeName(b))}</span></div>`).join('')}
      function filteredInventory(user){const items=getInventoryItems(user).map(e=>{const name=getItemName(e),qty=getItemQty(e),details=getItemDetails(name),meta=getItemMeta(name,details),description=details?.description||details?.desc||details?.how||'غرض من حقيبة العضو.';return{name,qty,details,meta,description}}).filter(i=>i.name);if(state.inventoryFilter==='all')return items;if(state.inventoryFilter==='featured')return items.filter(i=>i.meta.rarity==='legendary'||i.meta.type==='featured');if(state.inventoryFilter==='usable')return items.filter(i=>i.meta.type==='usable'||i.details?.usable===true);return items.filter(i=>i.meta.type===state.inventoryFilter)}
      function renderInventory(user){const items=filteredInventory(user);inventoryFilters.forEach(b=>b.classList.toggle('is-active',b.dataset.invFilter===state.inventoryFilter));inventoryCount.textContent=String(getInventoryItems(user).length);inventoryEmpty.classList.toggle('hidden',items.length>0);inventoryGrid.classList.toggle('hidden',items.length===0);inventoryGrid.innerHTML=items.map(i=>{const rare=i.meta.rarity==='legendary'||i.meta.rarity==='rare',price=i.details?.price||i.details?.cost||i.details?.sellPrice||'';return`<article class="item-card${rare?' is-rare':''}"><span class="item-qty">x${formatNumber(i.qty)}</span><div class="item-icon">${esc(i.meta.icon)}</div><div><h3>${esc(i.name)}</h3><p>${esc(i.description)}</p></div><div class="item-meta"><span>${esc(i.meta.type)}</span><span>${esc(i.meta.rarity)}</span>${price?`<span>${formatNumber(price)} نقطة</span>`:''}</div></article>`}).join('')}
      function renderStats(user){const inv=getInventoryItems(user),totalQty=inv.reduce((s,i)=>s+getItemQty(i),0),badges=Array.isArray(user.badges)?user.badges:[],equipped=badges.filter(b=>b.equipped).length,rare=inv.filter(i=>{const meta=getItemMeta(getItemName(i),getItemDetails(getItemName(i)));return meta.rarity==='legendary'||meta.rarity==='rare'}).length;quickStats.innerHTML=`<div class="stat-row"><span>عدد البادجات</span><strong>${formatNumber(badges.length)}</strong></div><div class="stat-row"><span>بادجات مجهزة</span><strong>${formatNumber(equipped)}</strong></div><div class="stat-row"><span>أنواع الأغراض</span><strong>${formatNumber(inv.length)}</strong></div><div class="stat-row"><span>إجمالي الكميات</span><strong>${formatNumber(totalQty)}</strong></div><div class="stat-row"><span>أغراض نادرة</span><strong>${formatNumber(rare)}</strong></div>`}
      function renderRare(user){const items=getInventoryItems(user).map(e=>{const name=getItemName(e),qty=getItemQty(e),meta=getItemMeta(name,getItemDetails(name));return{name,qty,meta}}).filter(i=>i.meta.rarity==='legendary'||i.meta.rarity==='rare'||i.meta.type==='featured').slice(0,6);if(!items.length){rareItems.innerHTML='<div class="empty empty-small"><strong>ما فيه عرض</strong><span>ما لقينا أغراض نادرة حاليًا.</span></div>';return}rareItems.innerHTML=items.map(i=>`<div class="rare-item"><strong>${esc(i.meta.icon)} ${esc(i.name)}</strong><span>x${formatNumber(i.qty)}</span></div>`).join('')}
      function renderProfile(user){state.activeUser=user;profileEmpty.classList.add('hidden');profileContent.classList.remove('hidden');renderHeader(user);renderBadges(user);renderInventory(user);renderStats(user);renderRare(user);badgesPageLink.href=`/badges?user=${encodeURIComponent(getUserName(user))}`}
      function openFromQuery(){const raw=new URLSearchParams(window.location.search).get('user');if(!raw)return false;const key=normalize(raw);let user=state.users.find(u=>normalize(getUserName(u))===key)||state.users.find(u=>normalize(getDisplayName(u))===key)||state.users.find(u=>normalize(getUserName(u)).includes(key)||normalize(getDisplayName(u)).includes(key));if(!user){profileEmpty.innerHTML='<strong>ما لقيت العضو</strong><span>تأكد أن اسمه موجود في user_badges.json أو جرب البحث من فوق.</span>';profileEmpty.classList.remove('hidden');profileContent.classList.add('hidden');return false}renderProfile(user);return true}
      function handleBack(){backToTop.classList.toggle('is-visible',window.scrollY>520)}
      addListener(profileSearch,'input',()=>renderResults(profileSearch.value));addListener(clearProfileSearch,'click',()=>{profileSearch.value='';profileResults.innerHTML='';profileSearch.focus()});inventoryFilters.forEach(b=>addListener(b,'click',()=>{state.inventoryFilter=b.dataset.invFilter||'all';if(state.activeUser)renderInventory(state.activeUser)}));addListener(copyProfileLink,'click',()=>{if(state.activeUser)copyText(getProfileLink(state.activeUser),copyProfileLink,'تم نسخ الرابط')});addListener(backToTop,'click',()=>window.scrollTo({top:0,behavior:'smooth'}));addListener(window,'scroll',handleBack,{passive:true});(async()=>{await loadData();openFromQuery();handleBack()})()
    })()
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
