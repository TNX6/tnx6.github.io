---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'البروفايل — TNX6',
  ignoreTitleTemplate: true,
  description: 'بروفايل عضو في مجتمع TNX6 — أغراض، رصيد، بادجات، بريد، وإنجازات.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div class="tnx-bg" id="profileBg"></div>
    <div class="tnx-bg-overlay"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <section id="searchScreen" class="tnx-search-screen hidden">
        <div class="tnx-search-box">
          <div class="tnx-kicker">TNX6 PROFILE</div>
          <h1>ابحث عن عضو</h1>
          <p>اكتب اسم العضو عشان تفتح بروفايله الكامل.</p>

          <div class="tnx-search">
            <span>⌕</span>
            <input id="userSearch" type="search" autocomplete="off" placeholder="اسم العضو..." />
            <button type="button" id="clearUserSearch" aria-label="مسح البحث">×</button>
          </div>

          <div id="userResults" class="tnx-user-results"></div>
        </div>
      </section>

      <section id="profileScreen" class="tnx-profile-screen hidden">
        <header class="tnx-profile-header">
          <div class="tnx-identity">
            <div class="tnx-avatar" id="pAvatar"></div>

            <div class="tnx-identity-text">
              <h1 id="pName">—</h1>
              <div class="tnx-country hidden" id="pCountry"></div>
              <div class="tnx-bio" id="pBio"></div>
            </div>
          </div>

          <div class="tnx-header-side">
            <div class="tnx-level-row">
              <span>Level</span>
              <span class="tnx-level-badge" id="pLevel">1</span>
            </div>

            <div class="tnx-header-actions">
              <button type="button" class="tnx-mail-btn" id="mailToggle" aria-label="البريد">
                <span class="ti-mail-glyph">✉</span>
                <span class="tnx-mail-count hidden" id="mailCount">0</span>
              </button>

              <button type="button" class="tnx-copy-link" id="copyProfileLink">نسخ الرابط</button>
            </div>
          </div>
        </header>

        <section class="tnx-mailbox hidden" id="mailboxSection">
          <div class="tnx-box-head">
            <strong>صندوق البريد</strong>

            <div class="tnx-mail-filters">
              <button type="button" class="is-active" data-mail-filter="all">
                الكل <small id="mailAllCount">0</small>
              </button>

              <button type="button" data-mail-filter="unread">
                غير المقروءة <small id="mailUnreadCount">0</small>
              </button>
            </div>
          </div>

          <div id="mailList" class="tnx-mail-list"></div>

          <div class="tnx-mail-hint">
            الرسائل تُرسل من الشات عبر أمر <code>!mail @USER رسالتك</code>
          </div>
        </section>

        <div class="tnx-profile-body">
          <main class="tnx-main-col">
            <div class="tnx-box-head">
              <strong>حقيبة الأغراض</strong>
              <span id="invCount">0 غرض</span>
            </div>

            <div class="tnx-panel">
              <div id="inventoryGrid" class="tnx-inv-grid"></div>
              <div id="inventoryEmpty" class="tnx-inline-empty hidden">ما فيه أغراض في الحقيبة.</div>
            </div>

            <div class="tnx-box-head tnx-section-gap">
              <strong>آخر الإنجازات</strong>
              <span id="achCount">0 إنجاز</span>
            </div>

            <div class="tnx-panel">
              <div id="achievementsList" class="tnx-ach-list"></div>
              <div id="achievementsEmpty" class="tnx-inline-empty hidden">لا توجد إنجازات بعد.</div>
            </div>
          </main>

          <aside class="tnx-side-col">
            <div class="tnx-panel tnx-balance">
              <div class="tnx-side-title">الرصيد الحالي</div>

              <div class="tnx-balance-row">
                <span>★ النقاط</span>
                <strong id="pPoints">0</strong>
              </div>

              <div class="tnx-balance-row">
                <span>🪙 الذهب</span>
                <strong id="pGold" class="gold">0</strong>
              </div>

              <div class="tnx-balance-row">
                <span>🔥 السمعة</span>
                <strong id="pRep" class="rep">0</strong>
              </div>
            </div>

            <div class="tnx-side-block">
              <div class="tnx-side-title">البادجات <em id="badgeCount">0</em></div>
              <div id="badgeShowcase" class="tnx-badge-showcase"></div>
            </div>

            <div class="tnx-panel tnx-quicklist">
              <button type="button" data-jump="inventoryGrid">
                <span>الأغراض</span>
                <em id="qlItems">0</em>
              </button>

              <button type="button" data-jump="badgeShowcase">
                <span>البادجات</span>
                <em id="qlBadges">0</em>
              </button>

              <button type="button" data-jump="achievementsList">
                <span>الإنجازات</span>
                <em id="qlAch">0</em>
              </button>

              <a id="badgePageLink" href="/badges">
                <span>بطاقة البادجات</span>
                <em>↗</em>
              </a>
            </div>
          </aside>
        </div>
      </section>

      <section id="notFoundScreen" class="tnx-empty hidden">
        <strong>ما لقيت هذا العضو</strong>
        <span>تأكد من اسم العضو في الرابط أو من ملف user_badges.json.</span>
      </section>
    </section>
  </main>

  <style is:global>
    .hidden {
      display: none !important;
    }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.45) rgba(0, 0, 0, 0.38);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.38);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.38);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.85), rgba(194, 146, 0, 0.55));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: #c7d5e0;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-size: cover;
      background-position: center;
      background-color: #0b1015;
      filter: saturate(1.06) contrast(1.02);
      transform: scale(1.02);
    }

    .tnx-bg-overlay {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        linear-gradient(to bottom, rgba(7, 5, 11, 0.62), rgba(7, 5, 11, 0.36) 30%, rgba(7, 5, 11, 0.88)),
        linear-gradient(to right, rgba(0, 0, 0, 0.72), transparent 44%, rgba(0, 0, 0, 0.72));
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 960px);
      margin: 0 auto;
      padding: 6.5rem 1.25rem 5rem;
    }

    .tnx-search-screen {
      display: grid;
      place-items: center;
      min-height: 60vh;
    }

    .tnx-search-box {
      width: min(100%, 540px);
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.5rem;
      background: rgba(6, 6, 8, 0.8);
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.38);
      backdrop-filter: blur(16px);
    }

    .tnx-kicker {
      display: inline-flex;
      border: 1px solid rgba(255, 218, 106, 0.25);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      padding: 0.45rem 0.75rem;
      font-size: 0.68rem;
      font-weight: 950;
      letter-spacing: 0.13em;
    }

    .tnx-search-box h1 {
      margin: 0.75rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(2rem, 7vw, 3.3rem);
      font-weight: 950;
      line-height: 1;
    }

    .tnx-search-box p {
      margin: 0.65rem 0 1.25rem;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 750;
      line-height: 1.7;
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      cursor: pointer;
    }

    .tnx-user-results {
      display: grid;
      gap: 0.5rem;
      margin-top: 0.85rem;
    }

    .tnx-user-result {
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 0.9rem;
      background: rgba(0, 0, 0, 0.32);
      color: #f7e6ac;
      padding: 0.75rem 0.9rem;
      text-align: right;
      font-weight: 900;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tnx-user-result:hover {
      border-color: rgba(255, 218, 106, 0.45);
      background: rgba(255, 218, 106, 0.09);
      color: #ffda6a;
    }

    .tnx-profile-header {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
      margin-bottom: 1.25rem;
    }

    .tnx-identity {
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }

    .tnx-avatar {
      width: 84px;
      height: 84px;
      flex-shrink: 0;
      border: 2px solid var(--pColor, #6c5ce7);
      background: var(--pColor, #6c5ce7);
      background-size: cover;
      background-position: center;
      box-shadow: 0 18px 34px rgba(0, 0, 0, 0.38), 0 0 18px color-mix(in srgb, var(--pColor, #6c5ce7) 42%, transparent);
    }

    .tnx-identity-text {
      min-width: 0;
    }

    .tnx-identity-text h1 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: 1.55rem;
      font-weight: 650;
      text-overflow: ellipsis;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.8);
      white-space: nowrap;
    }

    .tnx-country {
      margin-top: 7px;
      color: #a0b3c0;
      font-size: 0.78rem;
      text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
    }

    .tnx-country::before {
      content: "🏳 ";
    }

    .tnx-bio {
      margin-top: 10px;
      color: #8fa3b0;
      font-size: 0.8rem;
      font-style: italic;
      line-height: 1.7;
      text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
    }

    .tnx-bio span {
      color: #b3a0ff;
      font-style: normal;
    }

    .tnx-header-side {
      display: grid;
      gap: 0.75rem;
      justify-items: start;
    }

    .tnx-level-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .tnx-level-row > span:first-child {
      color: #a0b3c0;
      font-size: 1rem;
    }

    .tnx-level-badge {
      display: grid;
      place-items: center;
      width: 32px;
      height: 32px;
      border: 2px solid #c0392b;
      border-radius: 50%;
      background: rgba(192, 57, 43, 0.12);
      color: #e74c3c;
      font-size: 0.82rem;
      font-weight: 650;
    }

    .tnx-header-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .tnx-mail-btn {
      position: relative;
      display: grid;
      place-items: center;
      width: 42px;
      height: 38px;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 4px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.1rem;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tnx-mail-btn:hover {
      background: rgba(255, 218, 106, 0.14);
    }

    .tnx-mail-count {
      position: absolute;
      top: -8px;
      left: -8px;
      display: grid;
      place-items: center;
      min-width: 20px;
      height: 20px;
      border: 2px solid #07050b;
      border-radius: 999px;
      background: #e74c3c;
      color: white;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0 4px;
    }

    .tnx-copy-link {
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 4px;
      background: linear-gradient(to bottom, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
      color: #c7d5e0;
      padding: 9px 16px;
      font-size: 0.78rem;
      font-weight: 650;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tnx-copy-link:hover,
    .tnx-copy-link.is-copied {
      border-color: rgba(52, 211, 153, 0.55);
      background: rgba(52, 211, 153, 0.14);
      color: rgb(167, 243, 208);
    }

    .tnx-box-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 8px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 6px;
    }

    .tnx-box-head strong {
      color: #e1e7ea;
      font-size: 0.9rem;
      font-weight: 650;
    }

    .tnx-box-head span {
      color: #6d839a;
      font-size: 0.75rem;
    }

    .tnx-section-gap {
      margin-top: 1.25rem;
    }

    .tnx-panel {
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(0, 0, 0, 0.42);
      padding: 14px;
      backdrop-filter: blur(10px);
    }

    .tnx-inline-empty {
      color: #6d839a;
      font-size: 0.82rem;
      text-align: center;
      padding: 1rem;
    }

    .tnx-mailbox {
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 0.5rem;
      background: rgba(6, 6, 8, 0.85);
      padding: 1rem;
      margin-bottom: 1.25rem;
      backdrop-filter: blur(12px);
      box-shadow: 0 22px 50px rgba(0, 0, 0, 0.32);
    }

    .tnx-mail-filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tnx-mail-filters button {
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.3);
      color: #a0b3c0;
      padding: 6px 12px;
      font-size: 0.72rem;
      font-weight: 650;
      cursor: pointer;
    }

    .tnx-mail-filters button.is-active {
      border-color: rgba(255, 218, 106, 0.45);
      background: rgba(255, 218, 106, 0.12);
      color: #ffe9a8;
    }

    .tnx-mail-filters small {
      opacity: 0.7;
      margin-inline-start: 4px;
    }

    .tnx-mail-list {
      display: grid;
      gap: 8px;
      margin-top: 12px;
    }

    .tnx-mail-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(0, 0, 0, 0.3);
      padding: 12px 14px;
    }

    .tnx-mail-item.is-unread {
      border-color: rgba(255, 218, 106, 0.32);
      border-right: 3px solid #ffda6a;
      background: rgba(255, 218, 106, 0.05);
    }

    .tnx-mail-avatar {
      display: grid;
      place-items: center;
      width: 40px;
      height: 40px;
      border-radius: 999px;
      flex-shrink: 0;
      background: linear-gradient(135deg, #6c5ce7, #423fff);
      color: white;
      font-size: 1.05rem;
      font-weight: 700;
    }

    .tnx-mail-body {
      flex: 1;
      min-width: 0;
    }

    .tnx-mail-top {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .tnx-mail-from {
      color: #ffda6a;
      font-size: 0.84rem;
      font-weight: 700;
    }

    .tnx-mail-item:not(.is-unread) .tnx-mail-from {
      color: #c7d5e0;
    }

    .tnx-mail-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #e74c3c;
    }

    .tnx-mail-date {
      color: #6d839a;
      font-size: 0.68rem;
      margin-inline-start: auto;
    }

    .tnx-mail-text {
      color: #d8e0e6;
      font-size: 0.8rem;
      line-height: 1.6;
      margin-top: 5px;
      word-break: break-word;
    }

    .tnx-mail-item:not(.is-unread) .tnx-mail-text {
      color: #a0b3c0;
    }

    .tnx-mail-hint {
      margin-top: 12px;
      padding: 10px;
      border: 1px dashed rgba(255, 255, 255, 0.14);
      background: rgba(0, 0, 0, 0.2);
      text-align: center;
      color: #6d839a;
      font-size: 0.74rem;
      line-height: 1.7;
    }

    .tnx-mail-hint code {
      color: #ffda6a;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    }

    .tnx-profile-body {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .tnx-inv-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
    }

    .tnx-inv-item {
      position: relative;
      display: grid;
      place-items: center;
      aspect-ratio: 1;
      border: 1px solid var(--cat, rgba(255, 218, 106, 0.4));
      background: linear-gradient(135deg, var(--cat-soft, rgba(255, 218, 106, 0.12)), rgba(0, 0, 0, 0.4));
      color: var(--cat, #ffda6a);
      font-size: 1.7rem;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tnx-inv-item:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
    }

    .tnx-inv-item.is-rare {
      overflow: hidden;
    }

    .tnx-inv-item.is-rare::before {
      content: "";
      position: absolute;
      inset: -40%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 218, 106, 0.25), transparent 28%);
      animation: tnxShine 5s linear infinite;
      pointer-events: none;
    }

    @keyframes tnxShine {
      to {
        transform: rotate(360deg);
      }
    }

    .tnx-inv-item > span:first-child {
      position: relative;
      z-index: 1;
    }

    .tnx-inv-amount {
      position: absolute;
      bottom: 3px;
      left: 4px;
      z-index: 1;
      color: var(--cat, #ffda6a);
      font-size: 0.62rem;
      font-weight: 700;
    }

    .tnx-inv-more {
      display: grid;
      place-items: center;
      aspect-ratio: 1;
      border: 1px dashed rgba(255, 255, 255, 0.22);
      background: rgba(255, 255, 255, 0.03);
      color: #6d839a;
      font-size: 0.82rem;
      font-weight: 700;
      cursor: pointer;
    }

    .tnx-ach-list {
      display: grid;
      gap: 8px;
    }

    .tnx-ach-item {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .tnx-ach-icon {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      border: 1px solid rgba(255, 218, 106, 0.3);
      background: rgba(255, 218, 106, 0.1);
      color: #ffda6a;
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    .tnx-ach-item strong {
      display: block;
      color: #e1e7ea;
      font-size: 0.8rem;
      font-weight: 700;
    }

    .tnx-ach-item span {
      display: block;
      color: #6d839a;
      font-size: 0.68rem;
      line-height: 1.4;
    }

    .tnx-side-col {
      display: grid;
      gap: 1rem;
    }

    .tnx-side-title {
      color: #e1e7ea;
      font-size: 0.86rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .tnx-side-title em {
      color: #ffda6a;
      font-style: normal;
      margin-inline-start: 4px;
    }

    .tnx-balance .tnx-balance-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 0;
    }

    .tnx-balance-row span {
      color: #a0b3c0;
      font-size: 0.78rem;
    }

    .tnx-balance-row strong {
      color: #ffda6a;
      font-size: 0.88rem;
      font-weight: 750;
      direction: ltr;
    }

    .tnx-balance-row strong.gold {
      color: #ffd700;
    }

    .tnx-balance-row strong.rep {
      color: #c084fc;
    }

    .tnx-side-block {
      padding: 14px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(10px);
    }

    .tnx-badge-showcase {
      display: flex;
      gap: 7px;
      flex-wrap: wrap;
    }

    .tnx-badge-showcase img,
    .tnx-badge-showcase .tnx-badge-fallback {
      display: grid;
      place-items: center;
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255, 218, 106, 0.3);
      background: radial-gradient(circle, rgba(255, 218, 106, 0.14), transparent 65%);
      color: #ffda6a;
      font-size: 1.1rem;
      object-fit: contain;
    }

    .tnx-quicklist {
      padding: 0;
      overflow: hidden;
    }

    .tnx-quicklist button,
    .tnx-quicklist a {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      border: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      background: transparent;
      color: #c7d5e0;
      padding: 12px 14px;
      font-family: inherit;
      font-size: 0.8rem;
      text-align: right;
      text-decoration: none;
      cursor: pointer;
    }

    .tnx-quicklist button:last-child,
    .tnx-quicklist a:last-child {
      border-bottom: none;
    }

    .tnx-quicklist button span,
    .tnx-quicklist a span {
      font-weight: 700;
    }

    .tnx-quicklist button em,
    .tnx-quicklist a em {
      color: #6d839a;
      font-style: normal;
    }

    .tnx-quicklist button:hover,
    .tnx-quicklist a:hover {
      background: rgba(255, 218, 106, 0.06);
    }

    .tnx-empty {
      display: grid;
      place-items: center;
      gap: 0.35rem;
      min-height: 50vh;
      text-align: center;
    }

    .tnx-empty strong {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background: rgba(7, 5, 11, 0.9);
      color: #ffda6a;
      font-size: 1.35rem;
      cursor: pointer;
      opacity: 0;
      transform: translateY(16px);
      pointer-events: none;
      transition: 220ms ease;
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.38);
      backdrop-filter: blur(12px);
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (max-width: 820px) {
      .tnx-profile-header,
      .tnx-profile-body {
        grid-template-columns: 1fr;
      }

      .tnx-inv-grid {
        grid-template-columns: repeat(4, 1fr);
      }

      .tnx-header-side {
        justify-items: stretch;
      }
    }

    @media (max-width: 560px) {
      .tnx-shell {
        padding-top: 5.25rem;
      }

      .tnx-profile-header {
        gap: 1rem;
      }

      .tnx-identity {
        align-items: center;
      }

      .tnx-avatar {
        width: 72px;
        height: 72px;
      }

      .tnx-identity-text h1 {
        font-size: 1.25rem;
      }

      .tnx-inv-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxProfilePageCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return

        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
      }

      const ITEM_META = {
        Vip: { cat: 'status', icon: '👑' },
        'Vip+': { cat: 'status', icon: '👑', rare: true },
        'محامي': { cat: 'status', icon: '⚖️' },
        'رخصة محامي': { cat: 'status', icon: '⚖️' },
        'عريف الفصل': { cat: 'status', icon: '🎖️' },
        Crown: { cat: 'rare', icon: '👑', rare: true },
        'ملك': { cat: 'rare', icon: '👑', rare: true },
        'نيوك': { cat: 'attacks', icon: '☢️', rare: true },
        'تغير العنوان': { cat: 'attacks', icon: '📝' },
        'تغيير العنوان': { cat: 'attacks', icon: '📝' },
        'تغيير العنوان مطور': { cat: 'attacks', icon: '📝', rare: true },
        'تجميد الشاشة': { cat: 'attacks', icon: '❄️' },
        'قنبلة دخانية': { cat: 'attacks', icon: '💣' },
        'يد الحرامي': { cat: 'pvp', icon: '🥷' },
        'اقول لا يكثر': { cat: 'pvp', icon: '🚫' },
        'أقول لا يكثر': { cat: 'pvp', icon: '🚫' },
        'رمي النرد': { cat: 'luck', icon: '🎲' },
        'البطاطا الحارة': { cat: 'luck', icon: '🥔' },
        'صندوق': { cat: 'boxes', icon: '📦' },
        'صندوق نادر': { cat: 'boxes', icon: '🎁', rare: true },
        'صندوق السمعة': { cat: 'boxes', icon: '🎁', rare: true },
        'رخصة مصرفي': { cat: 'permits', icon: '📜' },
        'خشب': { cat: 'resources', icon: '🪵' },
        'طماط': { cat: 'resources', icon: '🍅' },
        'سمكة': { cat: 'fishing', icon: '🐟' },
        'مرق سمك': { cat: 'cooking', icon: '🍲' },
        'مطرقة ذهبية': { cat: 'rare', icon: '🔨', rare: true },
        'البريد': { cat: 'economy', icon: '📬' },
        'سمعة': { cat: 'economy', icon: '🔥' },
        'عملة الجرأة': { cat: 'luck', icon: '🪙' },
      }

      const CAT_COLORS = {
        status: ['#c084fc', 'rgba(192,132,252,0.14)'],
        attacks: ['#f87171', 'rgba(248,113,113,0.14)'],
        pvp: ['#fb923c', 'rgba(251,146,60,0.14)'],
        luck: ['#fbbf24', 'rgba(251,191,36,0.14)'],
        boxes: ['#34d399', 'rgba(52,211,153,0.14)'],
        permits: ['#60a5fa', 'rgba(96,165,250,0.14)'],
        resources: ['#a3a3a3', 'rgba(163,163,163,0.12)'],
        fishing: ['#38bdf8', 'rgba(56,189,248,0.14)'],
        cooking: ['#fb7185', 'rgba(251,113,133,0.14)'],
        rare: ['#ffda6a', 'rgba(255,218,106,0.16)'],
        economy: ['#f7e6ac', 'rgba(247,230,172,0.12)'],
      }

      const INV_LIMIT = 14

      const $ = (id) => document.getElementById(id)

      const searchScreen = $('searchScreen')
      const profileScreen = $('profileScreen')
      const notFoundScreen = $('notFoundScreen')
      const userSearch = $('userSearch')
      const clearUserSearch = $('clearUserSearch')
      const userResults = $('userResults')
      const backToTop = $('backToTop')

      let users = []
      let inventories = []
      let mailboxes = []
      let profileExtras = []
      let itemCatalog = []
      let activeUser = null
      let mailState = { user: null, filter: 'all' }

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function key(value) {
        return normalize(value).replace(/\s+/g, '')
      }

      function fmt(value) {
        const number = Number(value || 0)
        return Number.isFinite(number) ? number.toLocaleString('en-US') : '0'
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        return /^https?:\/\//i.test(url) || url.startsWith('/') ? url : ''
      }

      function getField(source, keys, fallback) {
        for (const itemKey of keys) {
          if (source && source[itemKey] !== undefined && source[itemKey] !== null && source[itemKey] !== '') {
            return source[itemKey]
          }
        }

        return fallback
      }

      function userLogin(user) {
        return String(getField(user, ['userLogin', 'UserLogin', 'login'], '')).trim()
      }

      function userName(user) {
        return String(getField(user, ['userName', 'UserName', 'displayName', 'userLogin'], '')).trim()
      }

      function userId(user) {
        return String(getField(user, ['userId', 'UserId', 'id'], '')).trim()
      }

      function findByUser(collection, user) {
        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))

        return collection.find((entry) => {
          const entryId = String(getField(entry, ['userId', 'UserId', 'id'], '')).trim()
          const entryLogin = normalize(getField(entry, ['userLogin', 'UserLogin', 'login'], ''))
          const entryName = normalize(getField(entry, ['userName', 'UserName', 'displayName'], ''))

          return (
            (id && entryId && id === entryId) ||
            (login && entryLogin && login === entryLogin) ||
            (login && entryName && login === entryName) ||
            (name && entryLogin && name === entryLogin) ||
            (name && entryName && name === entryName)
          )
        }) || null
      }

      function mergeUserData(user) {
        const inventoryRecord = findByUser(inventories, user)
        const mailboxRecord = findByUser(mailboxes, user)
        const profileRecord = findByUser(profileExtras, user)

        const merged = {
          ...user,
          ...(profileRecord || {}),
        }

        if (inventoryRecord) {
          merged.inventory = Array.isArray(inventoryRecord.items)
            ? inventoryRecord.items
            : Array.isArray(inventoryRecord.inventory)
              ? inventoryRecord.inventory
              : []
        } else if (!Array.isArray(merged.inventory)) {
          merged.inventory = []
        }

        if (mailboxRecord) {
          merged.mailbox = Array.isArray(mailboxRecord.messages)
            ? mailboxRecord.messages
            : Array.isArray(mailboxRecord.mailbox)
              ? mailboxRecord.mailbox
              : []
        } else if (!Array.isArray(merged.mailbox)) {
          merged.mailbox = []
        }

        return merged
      }

      function getItemName(entry) {
        return String(getField(entry, ['item', 'name', 'itemName', 'Name', 'key'], '')).trim()
      }

      function getItemAmount(entry) {
        const raw = getField(entry, ['amount', 'quantity', 'qty', 'count', 'Value'], 1)
        const number = Number(raw)
        return Number.isFinite(number) && number > 0 ? number : 1
      }

      function getCatalogItem(name) {
        const itemKey = key(name)
        return itemCatalog.find((item) => key(getField(item, ['name', 'itemName', 'title'], '')) === itemKey) || null
      }

      function getMeta(name) {
        const hard = ITEM_META[name]
        if (hard) return hard

        const catalog = getCatalogItem(name)
        if (catalog) {
          return {
            cat: getField(catalog, ['category', 'type', 'cat'], 'economy'),
            icon: getField(catalog, ['icon', 'emoji'], '📦'),
            rare: Boolean(catalog.rare) || ['rare', 'legendary'].includes(normalize(catalog.rarity)),
          }
        }

        return { cat: 'economy', icon: '📦' }
      }

      function timeAgo(dateStr) {
        const date = new Date(dateStr)
        if (Number.isNaN(date.getTime())) return ''

        const seconds = Math.floor((Date.now() - date.getTime()) / 1000)

        if (seconds < 60) return 'الآن'
        if (seconds < 3600) return `قبل ${Math.floor(seconds / 60)} دقيقة`
        if (seconds < 86400) return `قبل ${Math.floor(seconds / 3600)} ساعة`
        if (seconds < 172800) return 'أمس'
        if (seconds < 604800) return `قبل ${Math.floor(seconds / 86400)} أيام`

        return `قبل ${Math.floor(seconds / 604800)} أسبوع`
      }

      async function loadJson(url, fallback) {
        try {
          const response = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!response.ok) return fallback
          const data = await response.json()
          return data
        } catch (error) {
          console.warn(`Failed to load ${url}`, error)
          return fallback
        }
      }

      function renderProfile(baseUser) {
        const user = mergeUserData(baseUser)
        activeUser = user

        searchScreen.classList.add('hidden')
        notFoundScreen.classList.add('hidden')
        profileScreen.classList.remove('hidden')

        const color = /^#[0-9a-f]{6}$/i.test(user.backgroundColor || '') ? user.backgroundColor : '#6c5ce7'
        const banner = safeUrl(user.bannerImage)
        const avatar = safeUrl(user.profileImageUrl)

        const bg = $('profileBg')

        if (banner) {
          bg.style.background = ''
          bg.style.backgroundImage = `url('${banner}')`
        } else {
          bg.style.backgroundImage = ''
          bg.style.background = `linear-gradient(160deg, ${color}, #0b1015 70%)`
        }

        const av = $('pAvatar')
        av.style.setProperty('--pColor', color)
        av.style.backgroundImage = avatar ? `url('${avatar}')` : ''

        $('pName').textContent = userName(user) || userLogin(user) || '—'

        const country = getField(user, ['country'], '')
        const countryEl = $('pCountry')

        if (country) {
          countryEl.textContent = country
          countryEl.classList.remove('hidden')
        } else {
          countryEl.classList.add('hidden')
        }

        const bio = getField(user, ['bio'], '')
        const jobName = getField(user, ['jobName'], '')
        const login = userLogin(user)
        const bioEl = $('pBio')

        bioEl.innerHTML = `${esc(bio || jobName || 'عضو في مجتمع TNX6')}${login ? `<br><span>TTV: ${esc(login)}</span>` : ''}`

        const explicitLevel = Number(getField(user, ['level'], 0))
        const points = Number(getField(user, ['points', 'totalPoints'], 0))
        const level = explicitLevel > 0 ? explicitLevel : Math.max(1, Math.floor(points / 100000) + 1)

        $('pLevel').textContent = fmt(level)
        $('pPoints').textContent = fmt(points)
        $('pGold').textContent = fmt(getField(user, ['gold'], 0))
        $('pRep').textContent = fmt(getField(user, ['reputation', 'rep', 'سمعة'], 0))

        const badgePageLink = $('badgePageLink')
        if (badgePageLink) {
          badgePageLink.href = `/badges?user=${encodeURIComponent(login)}`
        }

        renderInventory(user)
        renderBadges(user)
        renderAchievements(user)
        renderMailbox(user)
      }

      function renderInventory(user) {
        const inv = Array.isArray(user.inventory) ? user.inventory : []
        const grid = $('inventoryGrid')

        $('invCount').textContent = `${fmt(inv.length)} غرض`
        $('qlItems').textContent = fmt(inv.length)
        $('inventoryEmpty').classList.toggle('hidden', inv.length > 0)

        const shown = inv.slice(0, INV_LIMIT)
        const extra = inv.length - shown.length

        grid.innerHTML = shown.map((entry) => {
          const name = getItemName(entry)
          const amount = getItemAmount(entry)
          const meta = getMeta(name)
          const [cat, soft] = CAT_COLORS[meta.cat] || CAT_COLORS.economy
          const rare = meta.rare ? ' is-rare' : ''

          return `
            <div class="tnx-inv-item${rare}" style="--cat:${cat};--cat-soft:${soft};" title="${esc(name)} ×${amount}">
              <span>${esc(meta.icon)}</span>
              <span class="tnx-inv-amount">${fmt(amount)}</span>
            </div>
          `
        }).join('') + (extra > 0 ? `<div class="tnx-inv-more">+${fmt(extra)}</div>` : '')
      }

      function renderBadges(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const equipped = badges.filter((badge) => badge.equipped).slice(0, 6)
        const list = equipped.length ? equipped : badges.slice(0, 6)

        $('badgeCount').textContent = fmt(badges.length)
        $('qlBadges').textContent = fmt(badges.length)

        $('badgeShowcase').innerHTML = list.map((badge) => {
          const url = safeUrl(badge.url || badge.image || badge.badgeUrl)
          const name = badge.name || badge.badgeName || ''

          return url
            ? `<img src="${esc(url)}" alt="${esc(name)}" title="${esc(name)}" loading="lazy" />`
            : `<div class="tnx-badge-fallback" title="${esc(name)}">★</div>`
        }).join('') || '<div class="tnx-badge-fallback">—</div>'
      }

      function buildAutoAchievements(user) {
        const achievements = Array.isArray(user.achievements) ? [...user.achievements] : []
        const badges = Array.isArray(user.badges) ? user.badges : []
        const inv = Array.isArray(user.inventory) ? user.inventory : []
        const points = Number(getField(user, ['points', 'totalPoints'], 0))
        const gold = Number(getField(user, ['gold'], 0))

        if (badges.length >= 1) {
          achievements.push({
            icon: '🎖️',
            title: 'جامع بادجات',
            subtitle: `يمتلك ${fmt(badges.length)} بادج`,
          })
        }

        if (inv.length >= 1) {
          achievements.push({
            icon: '🎒',
            title: 'صاحب حقيبة',
            subtitle: `يمتلك ${fmt(inv.length)} نوع من الأغراض`,
          })
        }

        if (points >= 100000) {
          achievements.push({
            icon: '⭐',
            title: 'رصيد عالي',
            subtitle: `وصل إلى ${fmt(points)} نقطة`,
          })
        }

        if (gold >= 1000) {
          achievements.push({
            icon: '🪙',
            title: 'جامع ذهب',
            subtitle: `يمتلك ${fmt(gold)} ذهب`,
          })
        }

        return achievements.slice(0, 5)
      }

      function renderAchievements(user) {
        const achievements = buildAutoAchievements(user)
        const list = $('achievementsList')

        $('achCount').textContent = `${fmt(achievements.length)} إنجاز`
        $('qlAch').textContent = fmt(achievements.length)
        $('achievementsEmpty').classList.toggle('hidden', achievements.length > 0)

        list.innerHTML = achievements.map((item) => `
          <div class="tnx-ach-item">
            <div class="tnx-ach-icon">${esc(item.icon || '🏆')}</div>
            <div>
              <strong>${esc(item.title || item.name || '')}</strong>
              <span>${esc(item.subtitle || item.description || '')}</span>
            </div>
          </div>
        `).join('')
      }

      function renderMailbox(user) {
        mailState.user = user
        const mail = Array.isArray(user.mailbox) ? user.mailbox : []
        const unread = mail.filter((item) => !item.read)

        const countEl = $('mailCount')

        if (unread.length > 0) {
          countEl.textContent = fmt(unread.length)
          countEl.classList.remove('hidden')
        } else {
          countEl.classList.add('hidden')
        }

        $('mailAllCount').textContent = fmt(mail.length)
        $('mailUnreadCount').textContent = fmt(unread.length)

        drawMailList()
      }

      function drawMailList() {
        const user = mailState.user

        if (!user) return

        let mail = Array.isArray(user.mailbox) ? [...user.mailbox] : []

        if (mailState.filter === 'unread') {
          mail = mail.filter((item) => !item.read)
        }

        mail.sort((a, b) => new Date(b.date) - new Date(a.date))

        $('mailList').innerHTML = mail.length ? mail.map((item) => {
          const from = String(item.from || item.fromLogin || '؟')
          const initial = from.charAt(0).toUpperCase()
          const unread = !item.read ? ' is-unread' : ''

          return `
            <div class="tnx-mail-item${unread}">
              <div class="tnx-mail-avatar">${esc(initial)}</div>

              <div class="tnx-mail-body">
                <div class="tnx-mail-top">
                  <span class="tnx-mail-from">${esc(from)}</span>
                  ${!item.read ? '<span class="tnx-mail-dot"></span>' : ''}
                  <span class="tnx-mail-date">${esc(timeAgo(item.date))}</span>
                </div>

                <div class="tnx-mail-text">${esc(item.message || '')}</div>
              </div>
            </div>
          `
        }).join('') : '<div class="tnx-inline-empty">ما فيه رسائل.</div>'
      }

      function findUser(login) {
        const target = normalize(login)

        return users.find((item) => {
          return normalize(userLogin(item)) === target || normalize(userName(item)) === target
        }) || null
      }

      function getProfileLink(login) {
        const clean = String(login || '').replace(/[^a-zA-Z0-9_-]/g, '')
        return `${location.origin}${location.pathname}?user=${encodeURIComponent(clean)}`
      }

      function openFromQuery() {
        const param = new URLSearchParams(location.search).get('user')

        if (!param) {
          searchScreen.classList.remove('hidden')
          return
        }

        const user = findUser(param)

        if (user) {
          renderProfile(user)
        } else {
          notFoundScreen.classList.remove('hidden')
        }
      }

      function renderResults(query) {
        const normalized = normalize(query)

        userResults.innerHTML = ''

        if (!normalized) return

        const matches = users
          .filter((item) => normalize(userName(item)).includes(normalized) || normalize(userLogin(item)).includes(normalized))
          .slice(0, 10)

        userResults.innerHTML = matches.map((item) => {
          const login = userLogin(item)
          const name = userName(item) || login

          return `
            <button type="button" class="tnx-user-result" data-login="${esc(login)}">
              ${esc(name)}
            </button>
          `
        }).join('')
      }

      addListener(userSearch, 'input', () => renderResults(userSearch.value))

      addListener(clearUserSearch, 'click', () => {
        userSearch.value = ''
        userResults.innerHTML = ''
        userSearch.focus()
      })

      addListener(userResults, 'click', (event) => {
        const button = event.target.closest('[data-login]')

        if (!button) return

        const user = findUser(button.dataset.login)

        if (user) {
          history.replaceState(null, '', getProfileLink(userLogin(user)))
          renderProfile(user)
        }
      })

      addListener($('mailToggle'), 'click', () => {
        $('mailboxSection').classList.toggle('hidden')
      })

      Array.from(document.querySelectorAll('[data-mail-filter]')).forEach((button) => {
        addListener(button, 'click', () => {
          mailState.filter = button.dataset.mailFilter

          document.querySelectorAll('[data-mail-filter]').forEach((item) => {
            item.classList.toggle('is-active', item === button)
          })

          drawMailList()
        })
      })

      addListener($('copyProfileLink'), 'click', async (event) => {
        const login = activeUser ? userLogin(activeUser) : ''

        if (!login) return

        try {
          await navigator.clipboard.writeText(getProfileLink(login))
          event.currentTarget.textContent = 'تم النسخ'
          event.currentTarget.classList.add('is-copied')

          addTimer(window.setTimeout(() => {
            event.currentTarget.textContent = 'نسخ الرابط'
            event.currentTarget.classList.remove('is-copied')
          }, 1200))
        } catch {
          event.currentTarget.textContent = getProfileLink(login)
        }
      })

      Array.from(document.querySelectorAll('[data-jump]')).forEach((button) => {
        addListener(button, 'click', () => {
          $(button.dataset.jump)?.scrollIntoView({ behavior: 'smooth', block: 'center' })
        })
      })

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', () => {
        backToTop.classList.toggle('is-visible', window.scrollY > 400)
      }, { passive: true })

      users = await loadJson('/api/user_badges.json', [])
      inventories = await loadJson('/api/user_inventory.json', [])
      mailboxes = await loadJson('/api/user_mailbox.json', [])
      profileExtras = await loadJson('/api/user_profile.json', [])

      const itemsPayload = await loadJson('/api/items.json', { items: [] })
      itemCatalog = Array.isArray(itemsPayload) ? itemsPayload : Array.isArray(itemsPayload.items) ? itemsPayload.items : []

      if (!Array.isArray(users)) users = []
      if (!Array.isArray(inventories)) inventories = []
      if (!Array.isArray(mailboxes)) mailboxes = []
      if (!Array.isArray(profileExtras)) profileExtras = []

      openFromQuery()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
