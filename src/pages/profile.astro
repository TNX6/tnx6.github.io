---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'Profile — TNX6',
  ignoreTitleTemplate: true,
  description: 'Steam-style TNX6 member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-steam-page" dir="rtl">
    <div class="tnx-page-bg"></div>
    <div class="tnx-page-grid"></div>

    <section class="tnx-shell">
      <header class="tnx-page-head">
        <div class="tnx-head-copy">
          <span class="tnx-kicker">TNX6 COMMUNITY PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>صفحة تعرض حساب العضو بشكل قريب من Steam: صورة، خلفية، مستوى، بادجات، أغراض، نقاط وذهب.</p>
        </div>

        <div class="tnx-search-panel">
          <label class="tnx-search-box" for="profileSearch">
            <span>⌕</span>
            <input id="profileSearch" type="search" autocomplete="off" placeholder="ابحث باسم Twitch..." />
            <button id="clearProfileSearch" type="button" aria-label="مسح البحث">×</button>
          </label>

          <div id="profileResults" class="tnx-search-results"></div>
        </div>
      </header>

      <section id="emptyState" class="tnx-empty">
        <div class="tnx-empty-icon">☰</div>
        <strong>ابحث عن عضو</strong>
        <span>اكتب اسم المستخدم أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></span>
      </section>

      <section id="profileContent" class="tnx-profile hidden">
        <section id="profileHero" class="tnx-profile-hero"></section>

        <section class="tnx-profile-body">
          <main class="tnx-profile-main">
            <section class="tnx-module tnx-showcase-module">
              <div class="tnx-module-title">
                <span>FEATURED SHOWCASE</span>
                <h2>واجهة العضو</h2>
              </div>

              <div id="featuredShowcase" class="tnx-featured-showcase"></div>
            </section>

            <section class="tnx-module">
              <div class="tnx-module-title tnx-row-title">
                <div>
                  <span>ITEM INVENTORY</span>
                  <h2>الحقيبة</h2>
                </div>

                <div class="tnx-count-pill">
                  <strong id="inventoryCount">0</strong>
                  <small>نوع</small>
                </div>
              </div>

              <div class="tnx-filter-bar" id="inventoryFilters">
                <button type="button" class="is-active" data-filter="all">الكل</button>
                <button type="button" data-filter="rare">النادر</button>
                <button type="button" data-filter="box">الصناديق</button>
                <button type="button" data-filter="license">الرخص</button>
                <button type="button" data-filter="resource">الموارد</button>
                <button type="button" data-filter="usable">استخدام</button>
              </div>

              <div id="inventoryGrid" class="tnx-inventory-grid"></div>

              <div id="inventoryEmpty" class="tnx-mini-empty hidden">
                <strong>ما فيه أغراض ظاهرة</strong>
                <span>الحقيبة فاضية أو الفلتر الحالي ما طلع شيء.</span>
              </div>
            </section>

            <section class="tnx-module">
              <div class="tnx-module-title tnx-row-title">
                <div>
                  <span>BADGE COLLECTION</span>
                  <h2>مجموعة البادجات</h2>
                </div>

                <div class="tnx-count-pill">
                  <strong id="badgeCount">0</strong>
                  <small>بادج</small>
                </div>
              </div>

              <div id="badgeGrid" class="tnx-badge-grid"></div>
            </section>
          </main>

          <aside class="tnx-profile-side">
            <section class="tnx-module">
              <div class="tnx-module-title">
                <span>PROFILE DATA</span>
                <h2>البيانات</h2>
              </div>

              <div id="statsList" class="tnx-stats-list"></div>
            </section>

            <section class="tnx-module">
              <div class="tnx-module-title">
                <span>RARE ITEMS</span>
                <h2>أندر الأغراض</h2>
              </div>

              <div id="rareList" class="tnx-rare-list"></div>
            </section>

            <section class="tnx-module">
              <div class="tnx-module-title">
                <span>PROFILE LINKS</span>
                <h2>روابط</h2>
              </div>

              <div class="tnx-actions">
                <a id="badgesLink" href="/badges">بطاقة البادجات</a>
                <button id="copyProfileLink" type="button">نسخ رابط البروفايل</button>
              </div>
            </section>
          </aside>
        </section>
      </section>
    </section>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.38) rgba(0, 0, 0, 0.35);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.35);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.35);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.78), rgba(194, 146, 0, 0.52));
    }

    .hidden {
      display: none !important;
    }

    .tnx-steam-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #05070c;
      color: #ffffff;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .tnx-page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 16% 8%, rgba(255, 218, 106, 0.16), transparent 30%),
        radial-gradient(circle at 82% 13%, rgba(76, 120, 255, 0.13), transparent 30%),
        radial-gradient(circle at 52% 92%, rgba(194, 146, 0, 0.13), transparent 34%),
        linear-gradient(135deg, #05070c 0%, #09111d 48%, #120905 100%);
      animation: tnxBgBreath 10s ease-in-out infinite;
    }

    @keyframes tnxBgBreath {
      0%, 100% { transform: scale(1); filter: brightness(1) saturate(1); }
      50% { transform: scale(1.018); filter: brightness(1.06) saturate(1.1); }
    }

    .tnx-page-grid {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.055;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.45) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.45) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 75%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1250px);
      margin-inline: auto;
      padding: 6.4rem 1rem 5rem;
    }

    .tnx-page-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(340px, 440px);
      gap: 1rem;
      align-items: end;
      margin-bottom: 1rem;
    }

    .tnx-kicker {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      border: 1px solid rgba(255, 218, 106, 0.27);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: #ffda6a;
      padding: 0.55rem 0.9rem;
      font-size: 0.74rem;
      font-weight: 950;
      letter-spacing: 0.14em;
      backdrop-filter: blur(14px);
    }

    .tnx-head-copy h1 {
      margin: 0.9rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.05rem, 7vw, 6.2rem);
      font-weight: 950;
      line-height: 0.92;
      letter-spacing: -0.055em;
    }

    .tnx-head-copy p {
      max-width: 720px;
      margin: 1rem 0 0;
      color: rgba(226, 232, 240, 0.84);
      font-size: 1rem;
      font-weight: 760;
      line-height: 1.8;
    }

    .tnx-search-panel {
      position: relative;
      border: 1px solid rgba(255, 218, 106, 0.17);
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.08), transparent 44%),
        rgba(8, 12, 18, 0.76);
      padding: 0.8rem;
      box-shadow: 0 22px 58px rgba(0, 0, 0, 0.36);
      backdrop-filter: blur(16px);
    }

    .tnx-search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.7rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.34);
      padding: 0.75rem;
    }

    .tnx-search-box span {
      color: #ffda6a;
      font-size: 1.25rem;
      font-weight: 950;
    }

    .tnx-search-box input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: 0.96rem;
      font-weight: 850;
    }

    .tnx-search-box button {
      display: grid;
      place-items: center;
      width: 2.05rem;
      height: 2.05rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.16rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-search-results {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.65rem;
    }

    .tnx-result {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.13);
      border-radius: 0.95rem;
      background: rgba(0, 0, 0, 0.34);
      color: white;
      padding: 0.68rem;
      text-align: right;
      cursor: pointer;
      transition: 170ms ease;
    }

    .tnx-result:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 218, 106, 0.48);
      background: rgba(255, 218, 106, 0.08);
    }

    .tnx-result img {
      width: 44px;
      height: 44px;
      border-radius: 0.85rem;
      object-fit: cover;
      border: 1px solid rgba(255, 218, 106, 0.25);
    }

    .tnx-result strong {
      display: block;
      overflow: hidden;
      color: #f7e6ac;
      font-size: 0.95rem;
      font-weight: 950;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tnx-result span {
      display: block;
      margin-top: 0.12rem;
      color: rgb(148, 163, 184);
      font-size: 0.73rem;
      font-weight: 850;
      direction: ltr;
      text-align: right;
    }

    .tnx-empty,
    .tnx-mini-empty {
      display: grid;
      place-items: center;
      gap: 0.45rem;
      min-height: 230px;
      border: 1px solid rgba(255, 218, 106, 0.15);
      border-radius: 1.55rem;
      background:
        radial-gradient(circle at top, rgba(255, 218, 106, 0.08), transparent 44%),
        rgba(8, 12, 18, 0.78);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      backdrop-filter: blur(16px);
    }

    .tnx-mini-empty {
      min-height: 160px;
      margin-top: 0.75rem;
      box-shadow: none;
    }

    .tnx-empty-icon {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 4rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 1.25rem;
      background: rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1.7rem;
      font-weight: 950;
    }

    .tnx-empty strong,
    .tnx-mini-empty strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .tnx-empty span,
    .tnx-mini-empty span {
      color: rgb(148, 163, 184);
      font-size: 0.9rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-empty b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .tnx-profile {
      display: grid;
      gap: 1rem;
    }

    /* Steam-like top card */
    .tnx-profile-hero {
      position: relative;
      overflow: hidden;
      min-height: 438px;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 1.55rem;
      background: rgba(8, 12, 18, 0.8);
      box-shadow:
        0 30px 90px rgba(0, 0, 0, 0.54),
        inset 0 0 34px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(18px);
    }

    .tnx-cover {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      transform: scale(1.02);
      filter: saturate(1.05) contrast(1.05);
    }

    .tnx-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom, rgba(0,0,0,0.08), rgba(5, 8, 13, 0.5) 48%, rgba(5, 8, 13, 0.94) 100%),
        linear-gradient(to left, rgba(var(--accent-rgb), 0.24), transparent 38%),
        radial-gradient(circle at top left, rgba(255, 218, 106, 0.14), transparent 40%);
    }

    .tnx-hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 184px minmax(0, 1fr) 290px;
      gap: 1.25rem;
      align-items: end;
      min-height: 438px;
      padding: 1.35rem;
    }

    .tnx-avatar-zone {
      display: grid;
      justify-items: center;
      gap: 0.8rem;
    }

    .tnx-avatar-frame {
      position: relative;
      width: 168px;
      height: 168px;
      border-radius: 1.15rem;
      padding: 5px;
      background:
        linear-gradient(135deg, rgba(255,218,106,0.95), rgba(var(--accent-rgb),0.9), rgba(255,255,255,0.18));
      box-shadow:
        0 24px 46px rgba(0,0,0,0.5),
        0 0 26px rgba(var(--accent-rgb),0.28);
    }

    .tnx-avatar-frame img {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 0.9rem;
      object-fit: cover;
      background: #111;
    }

    .tnx-status-dot {
      position: absolute;
      right: 0.6rem;
      bottom: 0.6rem;
      width: 1rem;
      height: 1rem;
      border: 3px solid #101014;
      border-radius: 999px;
      background: #34d399;
      box-shadow: 0 0 14px rgba(52, 211, 153, 0.75);
    }

    .tnx-level {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 5.8rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.55);
      color: #ffda6a;
      padding: 0.55rem 0.75rem;
      font-size: 0.82rem;
      font-weight: 950;
      direction: ltr;
      backdrop-filter: blur(12px);
    }

    .tnx-identity {
      min-width: 0;
      padding-bottom: 0.25rem;
    }

    .tnx-identity h2 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: clamp(2.5rem, 5vw, 5rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.045em;
      text-overflow: ellipsis;
      text-shadow: 0 5px 20px rgba(0, 0, 0, 0.75);
      white-space: nowrap;
    }

    .tnx-login {
      margin: 0.65rem 0 0;
      color: rgba(226, 232, 240, 0.84);
      font-size: 0.94rem;
      font-weight: 850;
      direction: ltr;
      text-align: right;
    }

    .tnx-job {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin-top: 0.85rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.45);
      color: #f7e6ac;
      padding: 0.62rem 0.85rem;
      font-size: 0.86rem;
      font-weight: 950;
      backdrop-filter: blur(12px);
    }

    .tnx-job iconify-icon {
      color: #ffda6a;
      font-size: 1.2rem;
    }

    .tnx-mini-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1rem;
    }

    .tnx-mini-badge {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(255, 218, 106, 0.13);
      border-radius: 0.82rem;
      background: rgba(0, 0, 0, 0.42);
      backdrop-filter: blur(10px);
    }

    .tnx-mini-badge img {
      width: 36px;
      height: 36px;
      object-fit: contain;
      filter: drop-shadow(0 7px 12px rgba(0, 0, 0, 0.5));
    }

    .tnx-wallet {
      display: grid;
      gap: 0.75rem;
      align-self: end;
    }

    .tnx-wallet-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.12rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 44%),
        rgba(0, 0, 0, 0.48);
      padding: 1rem;
      backdrop-filter: blur(14px);
    }

    .tnx-wallet-card span {
      display: block;
      color: rgb(148, 163, 184);
      font-size: 0.75rem;
      font-weight: 900;
    }

    .tnx-wallet-card strong {
      display: block;
      margin-top: 0.35rem;
      color: #ffda6a;
      font-size: 1.7rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
      text-shadow: 0 0 14px rgba(255, 218, 106, 0.28);
    }

    .tnx-profile-body {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
    }

    .tnx-profile-main,
    .tnx-profile-side {
      display: grid;
      gap: 1rem;
    }

    .tnx-module {
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.4rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)),
        rgba(8, 12, 18, 0.78);
      box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.36),
        inset 0 0 22px rgba(255, 218, 106, 0.022);
      padding: 1.05rem;
      backdrop-filter: blur(16px);
    }

    .tnx-module-title {
      margin-bottom: 0.95rem;
    }

    .tnx-row-title {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
    }

    .tnx-module-title span {
      display: block;
      color: #c29200;
      font-size: 0.72rem;
      font-weight: 950;
      letter-spacing: 0.13em;
    }

    .tnx-module-title h2 {
      margin: 0.3rem 0 0;
      color: #f7e6ac;
      font-size: 1.48rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-count-pill {
      display: grid;
      place-items: center;
      min-width: 82px;
      border: 1px solid rgba(255, 218, 106, 0.17);
      border-radius: 0.95rem;
      background: rgba(255, 218, 106, 0.06);
      padding: 0.62rem;
    }

    .tnx-count-pill strong {
      color: #ffda6a;
      font-size: 1.24rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-count-pill small {
      margin-top: 0.22rem;
      color: rgb(148, 163, 184);
      font-size: 0.68rem;
      font-weight: 850;
    }

    .tnx-featured-showcase {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 0.85rem;
    }

    .tnx-big-item {
      position: relative;
      overflow: hidden;
      min-height: 235px;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.13), transparent 46%),
        rgba(0, 0, 0, 0.34);
      padding: 1rem;
    }

    .tnx-big-icon {
      display: grid;
      place-items: center;
      width: 4.8rem;
      height: 4.8rem;
      border: 1px solid rgba(255, 218, 106, 0.23);
      border-radius: 1.25rem;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 2.2rem;
      margin-bottom: 1rem;
    }

    .tnx-big-item h3 {
      margin: 0;
      color: white;
      font-size: 1.5rem;
      font-weight: 950;
      line-height: 1.18;
    }

    .tnx-big-item p {
      margin: 0.6rem 0 0;
      color: rgb(148, 163, 184);
      font-size: 0.85rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .tnx-big-item strong {
      display: inline-flex;
      margin-top: 0.9rem;
      border: 1px solid rgba(255, 218, 106, 0.19);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.36);
      color: #ffda6a;
      padding: 0.45rem 0.6rem;
      font-size: 0.8rem;
      font-weight: 950;
      direction: ltr;
    }

    .tnx-showcase-list {
      display: grid;
      gap: 0.62rem;
    }

    .tnx-showcase-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.3);
      padding: 0.72rem;
    }

    .tnx-showcase-row div {
      min-width: 0;
    }

    .tnx-showcase-row strong {
      display: block;
      overflow: hidden;
      color: #f7e6ac;
      font-size: 0.88rem;
      font-weight: 950;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tnx-showcase-row span {
      display: block;
      margin-top: 0.18rem;
      color: rgb(148, 163, 184);
