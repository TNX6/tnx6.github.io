---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'TNX6 community member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div id="profileBg" class="profile-bg"></div>
    <div class="profile-darkness"></div>

    <section class="profile-shell">
      <section id="searchView" class="search-view hidden">
        <div class="search-card">
          <span class="kicker">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>ابحث باسم Twitch أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

          <div class="search-box">
            <span>⌕</span>
            <input id="searchInput" type="search" autocomplete="off" placeholder="اكتب اسم المستخدم..." />
            <button id="clearSearch" type="button" aria-label="مسح البحث">×</button>
          </div>

          <div id="searchResults" class="search-results"></div>
        </div>
      </section>

      <section id="notFoundView" class="not-found hidden">
        <strong>ما لقيت العضو</strong>
        <span>تأكد من الاسم أو من ملف user_badges.json.</span>
      </section>

      <section id="profileView" class="profile-view hidden">
        <section class="character-card">
          <div id="coverArt" class="cover-art"></div>

          <div class="character-layout">
            <aside class="portrait-side">
              <div class="portrait-frame">
                <div id="avatar" class="portrait"></div>
              </div>

              <div class="level-medallion">
                <span>LEVEL</span>
                <strong id="levelNumber">1</strong>
              </div>
            </aside>

            <section class="identity-side">
              <div class="identity-top">
                <span id="jobChip" class="job-chip">Citizen</span>
                <span id="loginName" class="login-chip">@—</span>
              </div>

              <h1 id="displayName">—</h1>

              <p id="bioText" class="bio-text">عضو في مجتمع TNX6.</p>

              <div id="countryName" class="country-chip hidden">Saudi Arabia</div>

              <div id="featuredBadges" class="badge-ribbon"></div>

              <div class="power-meter">
                <div class="meter-head">
                  <span id="levelLabel">Level 1</span>
                  <strong id="nextLevelText">—</strong>
                </div>
                <div class="meter-track">
                  <div id="levelProgress" class="meter-fill"></div>
                </div>
              </div>
            </section>

            <aside class="stats-side">
              <div class="stat-line">
                <span>النقاط</span>
                <strong id="pointsValue">0</strong>
              </div>
              <div class="stat-line">
                <span>الذهب</span>
                <strong id="goldValue">0</strong>
              </div>
              <div class="stat-line">
                <span>السمعة</span>
                <strong id="repValue">0</strong>
              </div>
              <div class="stat-line">
                <span>البادجات</span>
                <strong id="badgesTopValue">0</strong>
              </div>
            </aside>
          </div>
        </section>

        <section class="showcase-band">
          <article class="signature-item">
            <div class="section-label">
              <span>SIGNATURE ITEM</span>
              <h2>العنصر الأبرز</h2>
            </div>

            <div id="rareFeature" class="signature-body"></div>
          </article>

          <article class="medal-wall">
            <div class="section-label">
              <div>
                <span>MEDALS</span>
                <h2>ميداليات العضو</h2>
              </div>
              <strong id="badgeCountMini">0</strong>
            </div>

            <div id="badgeWall" class="medals"></div>
          </article>
        </section>

        <section class="inventory-section">
          <div class="section-label inventory-title">
            <div>
              <span>LOADOUT</span>
              <h2>حقيبة الأغراض</h2>
            </div>

            <div class="inventory-filters">
              <button class="is-active" type="button" data-filter="all">الكل</button>
              <button type="button" data-filter="rare">النادر</button>
              <button type="button" data-filter="status">الحالات</button>
              <button type="button" data-filter="attacks">الهجمات</button>
              <button type="button" data-filter="boxes">الصناديق</button>
              <button type="button" data-filter="resources">الموارد</button>
            </div>
          </div>

          <div id="inventoryGrid" class="loadout-grid"></div>
          <div id="inventoryEmpty" class="empty-line hidden">ما فيه أغراض مطابقة.</div>
        </section>

        <section class="secondary-grid">
          <article class="secondary-card">
            <div class="section-label secondary-title">
              <div>
                <span>ACHIEVEMENTS</span>
                <h2>الإنجازات</h2>
              </div>
              <strong id="achCount">0</strong>
            </div>

            <div id="achievementsList" class="achievement-list"></div>
            <div id="achievementsEmpty" class="empty-line hidden">لا توجد إنجازات بعد.</div>
          </article>

          <article class="secondary-card">
            <div class="section-label secondary-title">
              <div>
                <span>MAILBOX</span>
                <h2>صندوق البريد</h2>
              </div>

              <div class="mail-tabs">
                <button class="is-active" type="button" data-mail-filter="all">الكل</button>
                <button type="button" data-mail-filter="unread">غير المقروء</button>
              </div>
            </div>

            <div id="mailList" class="mail-list"></div>
            <div id="mailEmpty" class="empty-line hidden">ما فيه رسائل.</div>
          </article>
        </section>

        <section class="actions-row">
          <a id="badgesPageLink" href="/badges">فتح بطاقة البادجات</a>
          <button id="copyLink" type="button">نسخ رابط البروفايل</button>
        </section>
      </section>
    </section>

    <div id="itemModal" class="item-modal hidden" aria-hidden="true">
      <button id="closeItemModal" class="modal-close" type="button" aria-label="إغلاق">×</button>
      <div id="itemModalContent" class="modal-content"></div>
    </div>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .55) rgba(0, 0, 0, .48);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.48); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.48);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.95), rgba(194,146,0,.6));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #030306;
      color: #f8fafc;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .profile-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 10%, rgba(255,218,106,.14), transparent 30%),
        radial-gradient(circle at 84% 10%, rgba(124,58,237,.12), transparent 34%),
        linear-gradient(135deg, #05050a, #0d0d14 50%, #160b04);
      background-position: center;
      background-size: cover;
      opacity: .5;
      filter: blur(2px) saturate(.9) contrast(1.08);
      transform: scale(1.06);
    }

    .profile-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.86), rgba(0,0,0,.68) 38%, rgba(0,0,0,.96)),
        linear-gradient(90deg, rgba(0,0,0,.88), rgba(0,0,0,.38) 50%, rgba(0,0,0,.88));
    }

    .profile-darkness {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 18%, rgba(255,218,106,.07), transparent 28%),
        radial-gradient(circle at center, transparent 0%, rgba(0,0,0,.32) 54%, rgba(0,0,0,.88) 100%);
    }

    .profile-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1120px);
      margin: 0 auto;
      padding: 5.5rem 1rem 5rem;
    }

    .search-view {
      min-height: 64vh;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 620px);
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 32px;
      background: rgba(8,8,12,.86);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 30px 100px rgba(0,0,0,.55);
      backdrop-filter: blur(20px);
    }

    .kicker {
      display: inline-flex;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 999px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: rgb(156,163,175);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.36);
      padding: .85rem;
    }

    .search-box span {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 999px;
      background: rgba(255,218,106,.08);
      color: #ffda6a;
      font-size: 1.12rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: #f7e6ac;
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.08);
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: rgb(156,163,175);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
    }

    .not-found strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: rgb(156,163,175);
      font-size: .9rem;
    }

    .profile-view {
      display: grid;
      gap: 1rem;
    }

    .character-card {
      position: relative;
      overflow: hidden;
      min-height: 560px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 38px;
      background:
        radial-gradient(circle at 74% 28%, rgba(255,218,106,.09), transparent 24%),
        linear-gradient(135deg, rgba(255,255,255,.04), rgba(255,255,255,.012)),
        rgba(8,8,12,.84);
      box-shadow:
        0 38px 120px rgba(0,0,0,.58),
        inset 0 0 0 1px rgba(255,255,255,.025);
      backdrop-filter: blur(22px);
    }

    .cover-art {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      opacity: .42;
      filter: saturate(.95) contrast(1.05);
    }

    .cover-art::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 79% 37%, rgba(var(--accent), .28), transparent 28%),
        linear-gradient(90deg, rgba(8,8,12,.96), rgba(8,8,12,.52) 50%, rgba(8,8,12,.92)),
        linear-gradient(180deg, rgba(8,8,12,.3), rgba(8,8,12,.94));
    }

    .character-layout {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr) 220px;
      gap: 1.25rem;
      min-height: 560px;
      align-items: center;
      padding: 2rem;
    }

    .portrait-side {
      display: grid;
      justify-items: center;
      gap: 1rem;
    }

    .portrait-frame {
      width: 250px;
      height: 330px;
      border-radius: 36px;
      padding: 5px;
      background:
        linear-gradient(135deg, rgba(255,218,106,.96), var(--profile-color, #ffda6a), rgba(255,255,255,.18));
      box-shadow:
        0 28px 64px rgba(0,0,0,.65),
        0 0 38px color-mix(in srgb, var(--profile-color, #ffda6a) 34%, transparent);
    }

    .portrait {
      width: 100%;
      height: 100%;
      border-radius: 31px;
      background: #111 center / cover no-repeat;
    }

    .level-medallion {
      display: grid;
      place-items: center;
      width: 128px;
      height: 84px;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 24px;
      background:
        radial-gradient(circle at top, rgba(255,218,106,.14), transparent 60%),
        rgba(0,0,0,.42);
      box-shadow: inset 0 0 24px rgba(255,218,106,.04);
    }

    .level-medallion span {
      color: rgb(156,163,175);
      font-size: .66rem;
      font-weight: 950;
      letter-spacing: .12em;
    }

    .level-medallion strong {
      margin-top: .2rem;
      color: #ffda6a;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1;
      direction: ltr;
    }

    .identity-side {
      min-width: 0;
      align-self: center;
      padding-inline: .4rem;
    }

    .identity-top {
      display: flex;
      flex-wrap: wrap;
      gap: .48rem;
      align-items: center;
      margin-bottom: .8rem;
    }

    .job-chip,
    .login-chip,
    .country-chip {
      border: 1px solid rgba(255,218,106,.22);
      border-radius: 999px;
      background: rgba(0,0,0,.42);
      color: #f7e6ac;
      padding: .46rem .7rem;
      font-size: .76rem;
      font-weight: 900;
      backdrop-filter: blur(12px);
    }

    .login-chip {
      color: rgb(229,231,235);
      direction: ltr;
    }

    .identity-side h1 {
      margin: 0;
      overflow: visible;
      color: #fff;
      font-size: clamp(3rem, 6vw, 5.8rem);
      font-weight: 950;
      line-height: .9;
      letter-spacing: -.06em;
      text-shadow: 0 8px 28px rgba(0,0,0,.78);
      white-space: normal;
      word-break: break-word;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .bio-text {
      max-width: 620px;
      margin: 1rem 0 0;
      color: rgb(209,213,219);
      font-size: 1rem;
      font-weight: 720;
      line-height: 1.75;
    }

    .country-chip {
      display: inline-flex;
      margin-top: .85rem;
    }

    .badge-ribbon {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: 1.1rem;
    }

    .badge-ribbon img,
    .badge-placeholder {
      display: grid;
      place-items: center;
      width: 54px;
      height: 54px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 16px;
      background: rgba(0,0,0,.38);
      object-fit: contain;
      padding: 4px;
      color: #ffda6a;
      font-weight: 950;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.42));
    }

    .power-meter {
      max-width: 560px;
      margin-top: 1.3rem;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 20px;
      background: rgba(0,0,0,.32);
      padding: .95rem;
    }

    .meter-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      color: rgb(156,163,175);
      font-size: .76rem;
      font-weight: 850;
    }

    .meter-head span {
      color: #ffda6a;
      font-weight: 950;
      direction: ltr;
    }

    .meter-track {
      height: 10px;
      margin-top: .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
    }

    .meter-fill {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #ffda6a, #c29200);
      box-shadow: 0 0 18px rgba(255,218,106,.35);
    }

    .stats-side {
      display: grid;
      gap: .72rem;
      align-self: center;
    }

    .stat-line {
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.1), transparent 45%),
        rgba(0,0,0,.38);
      padding: .9rem;
    }

    .stat-line span {
      display: block;
      color: rgb(156,163,175);
      font-size: .74rem;
      font-weight: 850;
    }

    .stat-line strong {
      display: block;
      margin-top: .22rem;
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .showcase-band {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 1rem;
    }

    .signature-item,
    .medal-wall,
    .inventory-section,
    .secondary-card {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 28px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)),
        rgba(8,8,12,.8);
      box-shadow: 0 24px 72px rgba(0,0,0,.42);
      padding: 1rem;
      backdrop-filter: blur(18px);
    }

    .section-label {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: .95rem;
    }

    .section-label span {
      display: block;
      color: #c29200;
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .section-label h2 {
      margin: .24rem 0 0;
      color: #f7e6ac;
      font-size: 1.42rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .section-label > strong,
    .secondary-title > strong {
      display: grid;
      place-items: center;
      min-width: 48px;
      height: 38px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 14px;
      background: rgba(255,218,106,.06);
      color: #ffda6a;
      font-size: .92rem;
      font-weight: 950;
      direction: ltr;
    }

    .signature-body {
      min-height: 220px;
    }

    .signature-card {
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      min-height: 220px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.14), transparent 48%),
        rgba(0,0,0,.3);
      padding: 1.1rem;
    }

    .signature-icon {
      display: grid;
      place-items: center;
      width: 132px;
      height: 132px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 30px;
      background: rgba(255,218,106,.08);
      font-size: 3.3rem;
    }

    .signature-card h3 {
      margin: 0;
      color: #fff;
      font-size: 1.8rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .signature-card p {
      margin: .55rem 0 0;
      color: rgb(156,163,175);
      font-size: .88rem;
      font-weight: 740;
      line-height: 1.65;
    }

    .signature-card strong {
      display: grid;
      place-items: center;
      min-width: 68px;
      height: 46px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      color: #ffda6a;
      padding: 0 .74rem;
      font-size: .86rem;
      font-weight: 950;
      direction: ltr;
    }

    .medals {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .65rem;
    }

    .medals img,
    .medals .badge-placeholder {
      width: 100%;
      height: 68px;
      border-radius: 18px;
    }

    .inventory-title {
      align-items: center;
    }

    .inventory-filters,
    .mail-tabs {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: .4rem;
    }

    .inventory-filters button,
    .mail-tabs button {
      border: 1px solid rgba(255,218,106,.16);
      border-radius: 999px;
      background: rgba(255,218,106,.06);
      color: #f7e6ac;
      padding: .42rem .62rem;
      font-family: inherit;
      font-size: .68rem;
      font-weight: 850;
      cursor: pointer;
    }

    .inventory-filters button.is-active,
    .inventory-filters button:hover,
    .mail-tabs button.is-active,
    .mail-tabs button:hover {
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.13);
      color: #ffda6a;
    }

    .loadout-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(86px, 1fr));
      gap: .72rem;
    }

    .loadout-item {
      position: relative;
