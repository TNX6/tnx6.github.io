---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'TNX6 member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile" dir="rtl">
    <div id="bg" class="bg"></div>
    <div class="veil"></div>

    <section class="shell">
      <section id="searchView" class="search-view hidden">
        <div class="search-card">
          <span class="label">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>ابحث باسم Twitch أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

          <div class="search">
            <span>⌕</span>
            <input id="searchInput" type="search" autocomplete="off" placeholder="اكتب اسم المستخدم..." />
            <button id="clearSearch" type="button" aria-label="مسح">×</button>
          </div>

          <div id="searchResults" class="results"></div>
        </div>
      </section>

      <section id="notFoundView" class="not-found hidden">
        <strong>ما لقيت العضو</strong>
        <span>تأكد من الاسم أو من ملف user_badges.json.</span>
      </section>

      <section id="profileView" class="profile hidden">
        <section class="profile-card">
          <div id="cover" class="cover"></div>

          <div class="profile-top">
            <div class="avatar-wrap">
              <div id="avatar" class="avatar"></div>
              <span id="level" class="level">LVL 1</span>
            </div>

            <div class="identity">
              <h1 id="displayName">—</h1>

              <div class="meta">
                <span id="loginName">@—</span>
                <span id="jobName">Citizen</span>
                <span id="countryName" class="hidden">Saudi Arabia</span>
              </div>

              <p id="bio">عضو في مجتمع TNX6.</p>

              <div id="featuredBadges" class="featured-badges"></div>
            </div>
          </div>

          <div class="wallet-row">
            <div class="wallet-card">
              <span>النقاط</span>
              <strong id="points">0</strong>
            </div>
            <div class="wallet-card gold">
              <span>الذهب</span>
              <strong id="gold">0</strong>
            </div>
            <div class="wallet-card rep">
              <span>السمعة</span>
              <strong id="rep">0</strong>
            </div>
            <div class="wallet-card">
              <span>البادجات</span>
              <strong id="badgeTotalTop">0</strong>
            </div>
          </div>
        </section>

        <section class="tabs-card">
          <nav class="tabs" aria-label="Profile sections">
            <button class="is-active" type="button" data-tab="inventory">الأغراض <b id="tabInv">0</b></button>
            <button type="button" data-tab="badges">البادجات <b id="tabBadges">0</b></button>
            <button type="button" data-tab="mail">البريد <b id="tabMail">0</b></button>
            <button type="button" data-tab="achievements">الإنجازات <b id="tabAch">0</b></button>
          </nav>

          <section id="inventoryPanel" class="tab-panel">
            <div class="section-head">
              <div>
                <span>INVENTORY</span>
                <h2>حقيبة الأغراض</h2>
              </div>
            </div>

            <div id="showcase" class="showcase"></div>
            <div id="inventoryGrid" class="inventory-grid"></div>
            <div id="inventoryEmpty" class="empty-line hidden">ما فيه أغراض في الحقيبة.</div>
          </section>

          <section id="badgesPanel" class="tab-panel hidden">
            <div class="section-head">
              <div>
                <span>BADGES</span>
                <h2>بادجات العضو</h2>
              </div>
            </div>

            <div id="badgesGrid" class="badges-grid"></div>
            <div id="badgesEmpty" class="empty-line hidden">ما فيه بادجات ظاهرة.</div>
          </section>

          <section id="mailPanel" class="tab-panel hidden">
            <div class="section-head mail-head">
              <div>
                <span>MAILBOX</span>
                <h2>صندوق البريد</h2>
              </div>

              <div class="mail-filter">
                <button class="is-active" type="button" data-mail-filter="all">الكل</button>
                <button type="button" data-mail-filter="unread">غير المقروء</button>
              </div>
            </div>

            <div id="mailList" class="mail-list"></div>
            <div id="mailEmpty" class="empty-line hidden">ما فيه رسائل.</div>
          </section>

          <section id="achievementsPanel" class="tab-panel hidden">
            <div class="section-head">
              <div>
                <span>ACHIEVEMENTS</span>
                <h2>الإنجازات</h2>
              </div>
            </div>

            <div id="achievementsList" class="achievements-list"></div>
            <div id="achievementsEmpty" class="empty-line hidden">لا توجد إنجازات بعد.</div>
          </section>
        </section>

        <section class="actions">
          <a id="badgesPageLink" href="/badges">فتح بطاقة البادجات</a>
          <button id="copyLink" type="button">نسخ رابط البروفايل</button>
        </section>
      </section>
    </section>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255,218,106,.48) rgba(0,0,0,.4);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.4); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.4);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.9), rgba(194,146,0,.58));
    }

    .tnx-profile {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #06060a;
      color: #f8fafc;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 20% 10%, rgba(255,218,106,.16), transparent 30%),
        radial-gradient(circle at 82% 18%, rgba(124,58,237,.16), transparent 32%),
        linear-gradient(135deg, #06060a, #101018 52%, #150b04);
      background-position: center;
      background-size: cover;
      filter: saturate(1.04) contrast(1.04);
      transform: scale(1.02);
      pointer-events: none;
    }

    .bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.72), rgba(0,0,0,.3) 38%, rgba(0,0,0,.9)),
        linear-gradient(90deg, rgba(0,0,0,.78), transparent 52%, rgba(0,0,0,.72));
    }

    .veil {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, transparent, rgba(0,0,0,.28) 52%, rgba(0,0,0,.82));
    }

    .shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1120px);
      margin: 0 auto;
      padding: 5.75rem 1rem 5rem;
    }

    .search-view {
      min-height: 64vh;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 620px);
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 30px;
      background: rgba(8,8,12,.84);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 28px 90px rgba(0,0,0,.48);
      backdrop-filter: blur(18px);
    }

    .label {
      display: inline-flex;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 999px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: rgb(156,163,175);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.34);
      padding: .85rem;
    }

    .search span {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 999px;
      background: rgba(255,218,106,.08);
      color: #ffda6a;
      font-size: 1.12rem;
      cursor: pointer;
    }

    .results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: #f7e6ac;
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .result:hover {
      transform: translateY(-1px);
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.08);
    }

    .result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .result span {
      display: block;
      margin-top: 2px;
      color: rgb(156,163,175);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
    }

    .not-found strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: rgb(156,163,175);
      font-size: .9rem;
    }

    .profile {
      display: grid;
      gap: 1rem;
    }

    .profile-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 34px;
      background: rgba(8,8,12,.82);
      box-shadow: 0 32px 100px rgba(0,0,0,.52);
      backdrop-filter: blur(18px);
    }

    .cover {
      height: 220px;
      background-position: center;
      background-size: cover;
    }

    .cover::after {
      content: "";
      display: block;
      width: 100%;
      height: 100%;
      background:
        linear-gradient(180deg, rgba(0,0,0,.12), rgba(8,8,12,.88)),
        radial-gradient(circle at 20% 45%, rgba(var(--accent), .32), transparent 35%);
    }

    .profile-top {
      position: relative;
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 1.25rem;
      align-items: end;
      padding: 0 1.35rem 1.35rem;
      margin-top: -78px;
    }

    .avatar-wrap {
      display: grid;
      justify-items: center;
      gap: .75rem;
    }

    .avatar {
      width: 142px;
      height: 142px;
      border: 4px solid var(--profile-color, #ffda6a);
      border-radius: 30px;
      background: #111 center / cover no-repeat;
      box-shadow:
        0 22px 46px rgba(0,0,0,.58),
        0 0 28px color-mix(in srgb, var(--profile-color, #ffda6a) 38%, transparent);
    }

    .level {
      display: inline-flex;
      justify-content: center;
      min-width: 6.2rem;
      border: 1px solid rgba(255,218,106,.32);
      border-radius: 999px;
      background: rgba(0,0,0,.5);
      color: #ffda6a;
      padding: .52rem .75rem;
      font-size: .78rem;
      font-weight: 950;
      direction: ltr;
    }

    .identity {
      min-width: 0;
      padding-bottom: .25rem;
    }

    .identity h1 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: clamp(2.45rem, 5vw, 5rem);
      font-weight: 950;
      line-height: .95;
      letter-spacing: -.05em;
      text-overflow: ellipsis;
      text-shadow: 0 5px 22px rgba(0,0,0,.72);
      white-space: nowrap;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .68rem;
      color: rgba(229,231,235,.82);
      font-size: .84rem;
      font-weight: 850;
    }

    .meta span {
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      padding: .38rem .58rem;
    }

    #loginName {
      direction: ltr;
    }

    .identity p {
      max-width: 720px;
      margin: .78rem 0 0;
      color: rgb(209,213,219);
      font-size: .92rem;
      font-weight: 720;
      line-height: 1.7;
    }

    .featured-badges {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: .9rem;
    }

    .featured-badges img,
    .badge-placeholder {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 14px;
      background: rgba(0,0,0,.38);
      object-fit: contain;
      padding: 4px;
      color: #ffda6a;
      font-weight: 950;
    }

    .wallet-row {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: .75rem;
      padding: 0 1.35rem 1.35rem;
    }

    .wallet-card {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.1), transparent 45%),
        rgba(0,0,0,.44);
      padding: .92rem;
      backdrop-filter: blur(12px);
    }

    .wallet-card span {
      display: block;
      color: rgb(156,163,175);
      font-size: .74rem;
      font-weight: 850;
    }

    .wallet-card strong {
      display: block;
      margin-top: .25rem;
      color: #ffda6a;
      font-size: 1.36rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .wallet-card.gold strong { color: #ffd166; }
    .wallet-card.rep strong { color: #c084fc; }

    .tabs-card {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 30px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)),
        rgba(8,8,12,.8);
      box-shadow: 0 26px 80px rgba(0,0,0,.42);
      overflow: hidden;
      backdrop-filter: blur(18px);
    }

    .tabs {
      display: flex;
      gap: .45rem;
      overflow-x: auto;
      padding: .8rem;
      border-bottom: 1px solid rgba(255,255,255,.08);
      background: rgba(0,0,0,.24);
    }

    .tabs button {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 999px;
      background: rgba(255,255,255,.035);
      color: #e5e7eb;
      padding: .62rem .85rem;
      font-family: inherit;
      font-size: .78rem;
      font-weight: 850;
      white-space: nowrap;
      cursor: pointer;
      transition: 160ms ease;
    }

    .tabs button:hover,
    .tabs button.is-active {
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.12);
      color: #ffda6a;
    }

    .tabs b {
      color: inherit;
      font-size: .72rem;
      direction: ltr;
    }

    .tab-panel {
      padding: 1rem;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: .95rem;
    }

    .section-head span {
      display: block;
      color: #c29200;
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .section-head h2 {
      margin: .24rem 0 0;
      color: #f7e6ac;
      font-size: 1.38rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .showcase {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: .85rem;
      margin-bottom: .85rem;
    }

    .showcase-main {
      min-height: 220px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.12), transparent 46%),
        rgba(0,0,0,.28);
      padding: 1rem;
    }

    .showcase-icon {
      display: grid;
      place-items: center;
      width: 68px;
      height: 68px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 18px;
      background: rgba(255,218,106,.08);
      font-size: 2rem;
      margin-bottom: .9rem;
    }

    .showcase-main h3 {
      margin: 0;
      color: #fff;
      font-size: 1.35rem;
      font-weight: 950;
      line-height: 1.2;
    }

    .showcase-main p {
      margin: .55rem 0 0;
      color: rgb(156,163,175);
      font-size: .82rem;
      font-weight: 740;
      line-height: 1.65;
    }

    .showcase-main strong {
      display: inline-flex;
      margin-top: .85rem;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      color: #ffda6a;
      padding: .4rem .58rem;
      font-size: .76rem;
      font-weight: 950;
      direction: ltr;
    }

    .showcase-list {
      display: grid;
      gap: .58rem;
    }

    .showcase-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .75rem;
      border: 1px solid rgba(255,218,106,.1);
      border-radius: 16px;
      background: rgba(0,0,0,.28);
      padding: .72rem;
    }

    .showcase-row strong {
      display: block;
      color: #f7e6ac;
      font-size: .82rem;
      font-weight: 950;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .showcase-row span {
      display: block;
      margin-top: .16rem;
      color: rgb(156,163,175);
      font-size: .66rem;
      font-weight: 740;
    }

    .showcase-row b {
      flex-shrink: 0;
      display: grid;
      place-items: center;
      min-width: 42px;
      height: 36px;
      border-radius: 12px;
      background: rgba(255,218,106,.08);
      color: #ffda6a;
      font-size: .74rem;
      font-weight: 950;
      direction: ltr;
    }

    .inventory-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
      gap: .75rem;
    }

    .item-card {
      position: relative;
      min-height: 168px;
      overflow: hidden;
      border: 1px solid var(--item-color, rgba(255,218,106,.18));
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.08)), transparent 48%),
        rgba(0,0,0,.32);
      padding: .82rem;
      transition: 160ms ease;
    }

    .item-card:hover {
      transform: translateY(-2px);
      border-color: var(--item-color, rgba(255,218,106,.45));
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.16)), transparent 52%),
        rgba(0,0,0,.4);
    }

    .item-card.is-rare::before {
      content: "";
      position: absolute;
      inset: -40%;
      background: conic-gradient(from 0deg, transparent, rgba(255,218,106,.18), transparent 28%);
      animation: shine 6s linear infinite;
      pointer-events: none;
    }

    @keyframes shine { to { transform: rotate(360deg); } }

    .item-icon,
    .item-card h3,
    .item-card p,
    .item-tags,
    .item-qty {
      position: relative;
      z-index: 1;
    }

    .item-icon {
      display: grid;
      place-items: center;
      width: 50px;
      height: 50px;
      border: 1px solid var(--item-color, rgba(255,218,106,.22));
      border-radius: 16px;
      background: var(--item-soft, rgba(255,218,106,.08));
      font-size: 1.55rem;
      margin-bottom: .7rem;
    }

    .item-qty {
      position: absolute;
      top: .72rem;
      left: .72rem;
      min-width: 2.12rem;
      height: 2.12rem;
      display: grid;
      place-items: center;
      border: 1px solid var(--item-color, rgba(255,218,106,.22));
      border-radius: 999px;
      background: rgba(0,0,0,.56);
      color: var(--item-color, #ffda6a);
      font-size: .72rem;
      font-weight: 950;
      direction: ltr;
    }

    .item-card h3 {
      margin: 0;
      color: #fff;
      font-size: .92rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .item-card p {
      display: -webkit-box;
      overflow: hidden;
      margin: .36rem 0 0;
      color: rgb(156,163,175);
      font-size: .69rem;
      font-weight: 730;
      line-height: 1.45;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .item-tags {
      display: flex;
      flex-wrap: wrap;
      gap: .28rem;
      margin-top: .65rem;
    }

    .item-tags span {
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 999px;
      background: rgba(255,255,255,.04);
      color: #f7e6ac;
      padding: .22rem .4rem;
      font-size: .56rem;
      font-weight: 850;
    }

    .badges-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
      gap: .7rem;
    }

    .badge-tile {
      display: grid;
      place-items: center;
      gap: .42rem;
      min-height: 116px;
      border: 1px solid rgba(255,218,106,.1);
