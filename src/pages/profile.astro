    }

    .badge-tile img {
      width: 60px;
      height: 60px;
      object-fit: contain;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.42));
    }

    .badge-tile span {
      color: rgb(229,231,235);
      font-size: .62rem;
      font-weight: 800;
      line-height: 1.25;
    }

    .mail-head {
      align-items: center;
    }

    .mail-filter {
      display: flex;
      gap: .42rem;
      flex-wrap: wrap;
    }

    .mail-filter button {
      border: 1px solid rgba(255,218,106,.16);
      border-radius: 999px;
      background: rgba(255,218,106,.06);
      color: #f7e6ac;
      padding: .42rem .62rem;
      font-size: .68rem;
      font-weight: 850;
      cursor: pointer;
    }

    .mail-filter button.is-active {
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.13);
      color: #ffda6a;
    }

    .mail-list,
    .achievements-list {
      display: grid;
      gap: .65rem;
    }

    .mail-card,
    .achievement-card {
      display: flex;
      align-items: center;
      gap: .75rem;
      border: 1px solid rgba(255,218,106,.1);
      border-radius: 16px;
      background: rgba(0,0,0,.28);
      padding: .72rem;
    }

    .mail-card {
      align-items: flex-start;
    }

    .mail-card.is-unread {
      border-color: rgba(255,218,106,.32);
      background: rgba(255,218,106,.05);
    }

    .mail-avatar,
    .achievement-icon {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      flex-shrink: 0;
      border: 1px solid rgba(255,218,106,.16);
      border-radius: 14px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
    }

    .mail-card strong,
    .achievement-card strong {
      display: block;
      color: #fff;
      font-size: .82rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .mail-card span,
    .achievement-card span {
      display: block;
      margin-top: .18rem;
      color: rgb(156,163,175);
      font-size: .68rem;
      font-weight: 730;
      line-height: 1.45;
    }

    .mail-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .5rem;
    }

    .mail-date {
      color: rgb(107,114,128) !important;
      font-size: .62rem !important;
      white-space: nowrap;
    }

    .mail-message {
      color: rgb(209,213,219) !important;
      font-size: .74rem !important;
      word-break: break-word;
    }

    .actions {
      display: flex;
      gap: .65rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .actions a,
    .actions button {
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 999px;
      background: rgba(8,8,12,.78);
      color: #f7e6ac;
      padding: .72rem 1rem;
      font-family: inherit;
      font-size: .82rem;
      font-weight: 900;
      text-decoration: none;
      cursor: pointer;
      backdrop-filter: blur(14px);
    }

    .actions a:hover,
    .actions button:hover {
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.12);
      color: #ffda6a;
    }

    .empty-line {
      color: rgb(156,163,175);
      font-size: .82rem;
      font-weight: 750;
      text-align: center;
      padding: 1.25rem .5rem;
    }

    .back-top {
      position: fixed;
      left: 1rem;
      bottom: 1rem;
      z-index: 60;
      width: 3rem;
      height: 3rem;
      border: 1px solid rgba(255,218,106,.32);
      border-radius: 999px;
      background: rgba(8,8,12,.88);
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
      cursor: pointer;
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: 160ms ease;
      backdrop-filter: blur(12px);
    }

    .back-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (max-width: 820px) {
      .profile-top {
        grid-template-columns: 1fr;
        justify-items: center;
        text-align: center;
      }

      .identity h1 {
        white-space: normal;
        font-size: 2.5rem;
      }

      .meta,
      .featured-badges {
        justify-content: center;
      }

      .wallet-row,
      .showcase {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .shell {
        padding-top: 5rem;
      }

      .cover {
        height: 180px;
      }

      .wallet-row {
        padding-inline: 1rem;
      }

      .inventory-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .item-card {
        min-height: 160px;
      }

      .tabs {
        padding: .65rem;
      }
    }

    @media (max-width: 390px) {
      .inventory-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxCinematicProfileCleanup'
      if (window[cleanupKey]) window[cleanupKey]()

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        timers.forEach((timer) => window.clearTimeout(timer))
      }

      const state = {
        users: [],
        inventories: [],
        mailboxes: [],
        profiles: [],
        items: [],
        activeUser: null,
        activeTab: 'inventory',
        mailFilter: 'all',
      }

      const CATEGORY = {
        status: ['#c084fc', 'rgba(192,132,252,.15)', 'status'],
        attacks: ['#f87171', 'rgba(248,113,113,.15)', 'attack'],
        pvp: ['#fb923c', 'rgba(251,146,60,.15)', 'pvp'],
        luck: ['#fbbf24', 'rgba(251,191,36,.15)', 'luck'],
        boxes: ['#34d399', 'rgba(52,211,153,.15)', 'box'],
        permits: ['#60a5fa', 'rgba(96,165,250,.15)', 'license'],
        resources: ['#a3a3a3', 'rgba(163,163,163,.13)', 'resource'],
        rare: ['#ffda6a', 'rgba(255,218,106,.18)', 'rare'],
        economy: ['#f7e6ac', 'rgba(247,230,172,.13)', 'item'],
      }

      const HARD_ITEMS = {
        vip: { icon: '👑', cat: 'status', rare: true },
        'vip+': { icon: '👑', cat: 'status', rare: true },
        crown: { icon: '👑', cat: 'rare', rare: true },
        'ملك': { icon: '👑', cat: 'rare', rare: true },
        'نيوك': { icon: '☢️', cat: 'attacks', rare: true },
        'محامي': { icon: '⚖️', cat: 'status' },
        'رخصة محامي': { icon: '⚖️', cat: 'status' },
        'عريف الفصل': { icon: '🎖️', cat: 'status' },
        'البريد': { icon: '📬', cat: 'economy' },
        'سمعة': { icon: '🔥', cat: 'economy' },
        'عملة الجرأة': { icon: '🪙', cat: 'luck' },
        'صندوق': { icon: '📦', cat: 'boxes' },
        'صندوق نادر': { icon: '🎁', cat: 'boxes', rare: true },
        'صندوق السمعة': { icon: '🎁', cat: 'boxes', rare: true },
        'خشب': { icon: '🪵', cat: 'resources' },
        'حديد': { icon: '⛓️', cat: 'resources' },
        'ذهب': { icon: '🪙', cat: 'rare', rare: true },
        'تغيير العنوان': { icon: '📝', cat: 'attacks' },
        'تغير العنوان': { icon: '📝', cat: 'attacks' },
        'تغيير العنوان مطور': { icon: '📝', cat: 'attacks', rare: true },
        'أقول لا يكثر': { icon: '🚫', cat: 'pvp' },
        'اقول لا يكثر': { icon: '🚫', cat: 'pvp' },
        'تجميد الشاشة': { icon: '❄️', cat: 'attacks' },
      }

      const $ = (id) => document.getElementById(id)

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function key(value) {
        return normalize(value).replace(/\s+/g, '')
      }

      function num(value) {
        const number = Number(value || 0)
        return Number.isFinite(number) ? number : 0
      }

      function fmt(value) {
        return num(value).toLocaleString('en-US')
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        return /^https?:\/\//i.test(url) || url.startsWith('/') ? url : ''
      }

      function get(source, names, fallback = '') {
        for (const name of names) {
          if (source && source[name] !== undefined && source[name] !== null && source[name] !== '') return source[name]
        }
        return fallback
      }

      function userLogin(user) {
        return String(get(user, ['userLogin', 'UserLogin', 'login', 'userName'], '')).trim()
      }

      function userName(user) {
        return String(get(user, ['userName', 'UserName', 'displayName', 'userLogin'], '')).trim()
      }

      function userId(user) {
        return String(get(user, ['userId', 'UserId', 'id'], '')).trim()
      }

      function matchUser(entry, user) {
        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))

        const entryId = String(get(entry, ['userId', 'UserId', 'id'], '')).trim()
        const entryLogin = normalize(get(entry, ['userLogin', 'UserLogin', 'login'], ''))
        const entryName = normalize(get(entry, ['userName', 'UserName', 'displayName'], ''))

        return (
          (id && entryId && id === entryId) ||
          (login && entryLogin && login === entryLogin) ||
          (login && entryName && login === entryName) ||
          (name && entryLogin && name === entryLogin) ||
          (name && entryName && name === entryName)
        )
      }

      function findRecord(collection, user) {
        return collection.find((entry) => matchUser(entry, user)) || null
      }

      function mergeUser(user) {
        const profile = findRecord(state.profiles, user) || {}
        const inv = findRecord(state.inventories, user) || {}
        const mail = findRecord(state.mailboxes, user) || {}

        const merged = { ...user, ...profile }

        merged.inventory = Array.isArray(profile.inventory)
          ? profile.inventory
          : Array.isArray(inv.items)
            ? inv.items
            : Array.isArray(inv.inventory)
              ? inv.inventory
              : Array.isArray(user.inventory)
                ? user.inventory
                : []

        merged.mailbox = Array.isArray(profile.mailbox)
          ? profile.mailbox
          : Array.isArray(mail.messages)
            ? mail.messages
            : Array.isArray(mail.mailbox)
              ? mail.mailbox
              : Array.isArray(user.mailbox)
                ? user.mailbox
                : []

        return merged
      }

      function getItemName(entry) {
        return String(get(entry, ['name', 'itemName', 'item', 'Name', 'key'], '')).trim()
      }

      function getItemQty(entry) {
        return Math.max(1, num(get(entry, ['quantity', 'qty', 'amount', 'count', 'Value'], 1)))
      }

      function catalogItem(name) {
        const itemKey = key(name)
        return state.items.find((item) => key(get(item, ['name', 'itemName', 'title'], '')) === itemKey) || null
      }

      function itemMeta(name) {
        const itemKey = key(name)
        const hard = Object.entries(HARD_ITEMS).find(([hardName]) => key(hardName) === itemKey)?.[1]
        if (hard) return hard

        const item = catalogItem(name)
        if (!item) return { icon: '📦', cat: 'economy' }

        return {
          icon: get(item, ['icon', 'emoji'], '📦'),
          cat: get(item, ['category', 'type', 'cat'], 'economy'),
          rare: Boolean(item.rare) || ['rare', 'legendary'].includes(normalize(item.rarity)),
        }
      }

      function inventoryItems(user) {
        return (Array.isArray(user.inventory) ? user.inventory : [])
          .map((entry) => {
            const name = getItemName(entry)
            const qty = getItemQty(entry)
            const meta = itemMeta(name)
            const details = catalogItem(name)

            return {
              name,
              qty,
              meta,
              description: get(details, ['description', 'desc', 'how'], 'غرض من حقيبة العضو.'),
            }
          })
          .filter((item) => item.name)
      }

      function badgeName(badge) {
        return String(get(badge, ['name', 'badgeName', 'title', 'value1'], '')).trim()
      }

      function badgeImage(badge) {
        return safeUrl(get(badge, ['url', 'image', 'badgeUrl', 'value2'], ''))
      }

      function levelFor(user) {
        const explicit = num(get(user, ['level'], 0))
        if (explicit > 0) return explicit
        return Math.max(1, Math.floor(num(get(user, ['points', 'totalPoints'], 0)) / 100000) + 1)
      }

      function hexToRgb(hex) {
        const clean = String(hex || '#ffda6a').replace('#', '')
        const number = parseInt(clean, 16)
        if (!Number.isFinite(number)) return '255, 218, 106'
        return [(number >> 16) & 255, (number >> 8) & 255, number & 255].join(', ')
      }

      function validColor(value) {
        return /^#[0-9a-fA-F]{6}$/.test(String(value || '')) ? value : '#ffda6a'
      }

      function timeAgo(value) {
        const date = new Date(value)
        if (Number.isNaN(date.getTime())) return ''
        const seconds = Math.floor((Date.now() - date.getTime()) / 1000)
        if (seconds < 60) return 'الآن'
        if (seconds < 3600) return `قبل ${Math.floor(seconds / 60)} دقيقة`
        if (seconds < 86400) return `قبل ${Math.floor(seconds / 3600)} ساعة`
        if (seconds < 604800) return `قبل ${Math.floor(seconds / 86400)} يوم`
        return `قبل ${Math.floor(seconds / 604800)} أسبوع`
      }

      async function loadJson(url, fallback) {
        try {
          const res = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!res.ok) return fallback
          return await res.json()
        } catch {
          return fallback
        }
      }

      function showSearch() {
        $('searchView').classList.remove('hidden')
        $('profileView').classList.add('hidden')
        $('notFoundView').classList.add('hidden')
      }

      function showNotFound() {
        $('searchView').classList.add('hidden')
        $('profileView').classList.add('hidden')
        $('notFoundView').classList.remove('hidden')
      }

      function findUser(login) {
        const target = normalize(login)
        return state.users.find((user) =>
          normalize(userLogin(user)) === target || normalize(userName(user)) === target
        ) || null
      }

      function profileLink(user) {
        const login = userLogin(user)
        const url = new URL(location.href)
        url.searchParams.set('user', login)
        url.hash = ''
        return url.toString()
      }

      function renderProfile(rawUser) {
        const user = mergeUser(rawUser)
        state.activeUser = user

        $('searchView').classList.add('hidden')
        $('notFoundView').classList.add('hidden')
        $('profileView').classList.remove('hidden')

        const color = validColor(get(user, ['backgroundColor', 'profileColor'], '#ffda6a'))
        const banner = safeUrl(get(user, ['bannerImage', 'banner', 'backgroundImage'], ''))
        const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], ''))
        const login = userLogin(user)
        const name = userName(user) || login
        const level = levelFor(user)
        const items = inventoryItems(user)
        const badges = Array.isArray(user.badges) ? user.badges : []
        const achievements = buildAchievements(user)
        const mails = mailItems(user)
        const unread = mails.filter((mail) => !mail.read)

        $('bg').style.backgroundImage = banner
          ? `url('${banner}')`
          : `radial-gradient(circle at 20% 12%, rgba(255, 218, 106, .16), transparent 30%), linear-gradient(135deg, ${color}, #06060a)`

        $('cover').style.setProperty('--accent', hexToRgb(color))
        $('cover').style.backgroundImage = banner ? `url('${banner}')` : `linear-gradient(135deg, ${color}, #06060a)`

        $('avatar').style.setProperty('--profile-color', color)
        $('avatar').style.backgroundImage = avatar ? `url('${avatar}')` : ''

        $('displayName').textContent = name
        $('loginName').textContent = `@${login}`
        $('jobName').textContent = get(user, ['jobName'], 'Citizen')
        $('bio').textContent = get(user, ['bio'], 'عضو في مجتمع TNX6.')
        $('level').textContent = `LVL ${fmt(level)}`
        $('points').textContent = fmt(get(user, ['points', 'totalPoints'], 0))
        $('gold').textContent = fmt(get(user, ['gold'], 0))
        $('rep').textContent = fmt(get(user, ['reputation', 'rep'], 0))
        $('badgeTotalTop').textContent = fmt(badges.length)

        const country = get(user, ['country'], '')
        $('countryName').classList.toggle('hidden', !country)
        $('countryName').textContent = country

        $('tabInv').textContent = fmt(items.length)
        $('tabBadges').textContent = fmt(badges.length)
        $('tabMail').textContent = fmt(unread.length || mails.length)
        $('tabAch').textContent = fmt(achievements.length)
        $('badgesPageLink').href = `/badges?user=${encodeURIComponent(login)}`

        renderFeaturedBadges(badges)
        renderShowcase(items)
        renderInventory(items)
        renderBadges(badges)
        renderMail(user)
        renderAchievements(achievements)
        setActiveTab('inventory')
      }

      function renderFeaturedBadges(badges) {
        const equipped = badges.filter((badge) => badge.equipped).slice(0, 7)
        const list = equipped.length ? equipped : badges.slice(0, 7)

        $('featuredBadges').innerHTML = list.length
          ? list.map((badge) => {
              const img = badgeImage(badge)
              const name = badgeName(badge)
              return img
                ? `<img src="${esc(img)}" alt="${esc(name)}" title="${esc(name)}" loading="lazy" />`
                : `<div class="badge-placeholder" title="${esc(name)}">★</div>`
            }).join('')
          : `<div class="badge-placeholder">—</div>`
      }

      function renderShowcase(items) {
        const sorted = [...items].sort((a, b) => {
          const rank = (item) => item.meta.rare ? 10 : 0
          return rank(b) - rank(a) || b.qty - a.qty
        })

        const main = sorted[0]
        const rest = sorted.slice(1, 5)

        if (!main) {
          $('showcase').innerHTML = `<div class="empty-line">ما فيه أغراض للعرض.</div>`
          return
        }

        $('showcase').innerHTML = `
          <article class="showcase-main">
            <div class="showcase-icon">${esc(main.meta.icon)}</div>
            <h3>${esc(main.name)}</h3>
            <p>${esc(main.description)}</p>
            <strong>x${fmt(main.qty)}</strong>
          </article>

          <div class="showcase-list">
            ${
              rest.length
                ? rest.map((item) => `
                  <div class="showcase-row">
                    <div>
                      <strong>${esc(item.meta.icon)} ${esc(item.name)}</strong>
                      <span>${item.meta.rare ? 'rare' : 'item'}</span>
                    </div>
                    <b>x${fmt(item.qty)}</b>
                  </div>
                `).join('')
                : `<div class="showcase-row"><div><strong>لا توجد أغراض إضافية</strong><span>بتظهر هنا إذا زادت الحقيبة.</span></div><b>—</b></div>`
            }
          </div>
        `
      }

      function renderInventory(items) {
        $('inventoryEmpty').classList.toggle('hidden', items.length > 0)

        $('inventoryGrid').innerHTML = items.map((item) => {
          const [color, soft, label] = CATEGORY[item.meta.cat] || CATEGORY.economy
          const rare = item.meta.rare ? ' is-rare' : ''

          return `
            <article class="item-card${rare}" style="--item-color:${color};--item-soft:${soft};">
              <span class="item-qty">x${fmt(item.qty)}</span>
              <div class="item-icon">${esc(item.meta.icon)}</div>
              <h3>${esc(item.name)}</h3>
              <p>${esc(item.description)}</p>
              <div class="item-tags">
                <span>${esc(label)}</span>
                ${item.meta.rare ? '<span>rare</span>' : ''}
              </div>
            </article>
          `
        }).join('')
      }

      function renderBadges(badges) {
        $('badgesEmpty').classList.toggle('hidden', badges.length > 0)

        $('badgesGrid').innerHTML = badges.slice(0, 90).map((badge) => {
          const img = badgeImage(badge)
          const name = badgeName(badge)

          return `
            <div class="badge-tile">
              ${img ? `<img src="${esc(img)}" alt="${esc(name)}" loading="lazy" />` : '<div class="badge-placeholder">★</div>'}
              <span>${esc(name)}</span>
            </div>
          `
        }).join('')
      }

      function buildAchievements(user) {
        const manual = Array.isArray(user.achievements) ? [...user.achievements] : []
        const badges = Array.isArray(user.badges) ? user.badges : []
        const items = inventoryItems(user)
        const points = num(get(user, ['points', 'totalPoints'], 0))
        const gold = num(get(user, ['gold'], 0))

        if (badges.length) manual.push({ icon: '🎖️', title: 'جامع بادجات', subtitle: `يمتلك ${fmt(badges.length)} بادج` })
        if (items.length) manual.push({ icon: '🎒', title: 'صاحب حقيبة', subtitle: `يمتلك ${fmt(items.length)} نوع من الأغراض` })
        if (points >= 100000) manual.push({ icon: '⭐', title: 'رصيد عالي', subtitle: `وصل إلى ${fmt(points)} نقطة` })
        if (gold >= 1000) manual.push({ icon: '🪙', title: 'جامع ذهب', subtitle: `يمتلك ${fmt(gold)} ذهب` })

        return manual.slice(0, 8)
      }

      function renderAchievements(achievements) {
        $('achievementsEmpty').classList.toggle('hidden', achievements.length > 0)

        $('achievementsList').innerHTML = achievements.map((item) => `
          <div class="achievement-card">
            <div class="achievement-icon">${esc(item.icon || '🏆')}</div>
            <div>
              <strong>${esc(item.title || item.name || '')}</strong>
              <span>${esc(item.subtitle || item.description || '')}</span>
            </div>
          </div>
        `).join('')
      }

      function mailItems(user) {
        const mail = Array.isArray(user.mailbox) ? [...user.mailbox] : []
        return mail.sort((a, b) => new Date(get(b, ['date', 'createdAt'], 0)) - new Date(get(a, ['date', 'createdAt'], 0)))
      }

      function renderMail(user) {
        const all = mailItems(user)
        const unread = all.filter((mail) => !mail.read)
        const list = state.mailFilter === 'unread' ? unread : all

        $('mailEmpty').classList.toggle('hidden', list.length > 0)

        $('mailList').innerHTML = list.slice(0, 12).map((mail) => {
          const from = get(mail, ['from', 'fromDisplayName', 'fromLogin', 'fromUserName'], '؟')
          const date = get(mail, ['date', 'createdAt'], '')
          const message = get(mail, ['message'], '')
          const unreadClass = !mail.read ? ' is-unread' : ''
          const initial = String(from).charAt(0).toUpperCase() || '؟'

          return `
            <div class="mail-card${unreadClass}">
              <div class="mail-avatar">${esc(initial)}</div>
              <div>
                <div class="mail-top">
                  <strong>${esc(from)}</strong>
                  <span class="mail-date">${esc(timeAgo(date))}</span>
                </div>
                <span class="mail-message">${esc(message)}</span>
              </div>
            </div>
          `
        }).join('')
      }

      function setActiveTab(tab) {
        state.activeTab = tab

        document.querySelectorAll('[data-tab]').forEach((button) => {
          button.classList.toggle('is-active', button.dataset.tab === tab)
        })

        $('inventoryPanel').classList.toggle('hidden', tab !== 'inventory')
        $('badgesPanel').classList.toggle('hidden', tab !== 'badges')
        $('mailPanel').classList.toggle('hidden', tab !== 'mail')
        $('achievementsPanel').classList.toggle('hidden', tab !== 'achievements')
      }

      function renderSearch(query) {
        const q = normalize(query)
        $('searchResults').innerHTML = ''
        if (!q) return

        const matches = state.users.filter((user) =>
          normalize(userName(user)).includes(q) || normalize(userLogin(user)).includes(q)
        ).slice(0, 10)

        $('searchResults').innerHTML = matches.map((user) => {
          const login = userLogin(user)
          const name = userName(user) || login
          const avatar = safeUrl(get(user, ['profileImageUrl', 'avatar', 'ProfileImageUrl'], ''))

          return `
            <button type="button" class="result" data-login="${esc(login)}">
              ${avatar ? `<img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy" />` : ''}
              <div>
                <strong>${esc(name)}</strong>
                <span>@${esc(login)}</span>
              </div>
            </button>
          `
        }).join('')
      }

      function openFromQuery() {
        const raw = new URLSearchParams(location.search).get('user')

        if (!raw) {
          $('searchView').classList.remove('hidden')
          $('profileView').classList.add('hidden')
          $('notFoundView').classList.add('hidden')
          return
        }

        const user = findUser(raw)

        if (!user) {
          $('searchView').classList.add('hidden')
          $('profileView').classList.add('hidden')
          $('notFoundView').classList.remove('hidden')
          return
        }

        renderProfile(user)
      }

      function findUser(login) {
        const target = normalize(login)
        return state.users.find((user) =>
          normalize(userLogin(user)) === target || normalize(userName(user)) === target
        ) || null
      }

      addListener($('searchInput'), 'input', (event) => renderSearch(event.target.value))

      addListener($('clearSearch'), 'click', () => {
        $('searchInput').value = ''
        $('searchResults').innerHTML = ''
        $('searchInput').focus()
      })

      addListener($('searchResults'), 'click', (event) => {
        const button = event.target.closest('[data-login]')
        if (!button) return
        const user = findUser(button.dataset.login)
        if (!user) return

        history.replaceState(null, '', profileLink(user))
        renderProfile(user)
      })

      document.querySelectorAll('[data-tab]').forEach((button) => {
        addListener(button, 'click', () => setActiveTab(button.dataset.tab || 'inventory'))
      })

      document.querySelectorAll('[data-mail-filter]').forEach((button) => {
        addListener(button, 'click', () => {
          state.mailFilter = button.dataset.mailFilter || 'all'
          document.querySelectorAll('[data-mail-filter]').forEach((item) => item.classList.toggle('is-active', item === button))
          if (state.activeUser) renderMail(state.activeUser)
        })
      })

      addListener($('copyLink'), 'click', async (event) => {
        if (!state.activeUser) return
        const button = event.currentTarget
        const old = button.textContent

        try {
          await navigator.clipboard.writeText(profileLink(state.activeUser))
          button.textContent = 'تم النسخ'
          addTimer(window.setTimeout(() => { button.textContent = old }, 1200))
        } catch {
          button.textContent = profileLink(state.activeUser)
        }
      })

      addListener($('backToTop'), 'click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))

      addListener(window, 'scroll', () => {
        $('backToTop').classList.toggle('is-visible', window.scrollY > 420)
      }, { passive: true })

      const [users, inventories, mailboxes, profiles, itemPayload] = await Promise.all([
        loadJson('/api/user_badges.json', []),
        loadJson('/api/user_inventory.json', []),
        loadJson('/api/user_mailbox.json', []),
        loadJson('/api/user_profile.json', []),
        loadJson('/api/items.json', { items: [] }),
      ])

      state.users = Array.isArray(users) ? users : []
      state.inventories = Array.isArray(inventories) ? inventories : []
      state.mailboxes = Array.isArray(mailboxes) ? mailboxes : []
      state.profiles = Array.isArray(profiles) ? profiles : []
      state.items = Array.isArray(itemPayload) ? itemPayload : Array.isArray(itemPayload.items) ? itemPayload.items : []

      openFromQuery()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
