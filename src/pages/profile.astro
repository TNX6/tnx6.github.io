    @media (max-width: 480px) {
      .inventory-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 380px) {
      .inventory-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxProfileCleanV1Cleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((timer) => window.clearTimeout(timer))
        timers.length = 0
      }

      const state = {
        users: [],
        inventories: [],
        items: [],
        activeUser: null,
        filter: 'all',
      }

      const profileBackdrop = document.getElementById('profileBackdrop')
      const profileSearch = document.getElementById('profileSearch')
      const clearProfileSearch = document.getElementById('clearProfileSearch')
      const profileResults = document.getElementById('profileResults')
      const emptyState = document.getElementById('emptyState')
      const profileContent = document.getElementById('profileContent')
      const profileHero = document.getElementById('profileHero')
      const displayCase = document.getElementById('displayCase')
      const inventoryGrid = document.getElementById('inventoryGrid')
      const inventoryEmpty = document.getElementById('inventoryEmpty')
      const inventoryCount = document.getElementById('inventoryCount')
      const badgeCount = document.getElementById('badgeCount')
      const badgesGrid = document.getElementById('badgesGrid')
      const statsList = document.getElementById('statsList')
      const rareList = document.getElementById('rareList')
      const badgesLink = document.getElementById('badgesLink')
      const copyProfileLink = document.getElementById('copyProfileLink')
      const backToTop = document.getElementById('backToTop')
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'))

      const JOB_ICONS = {
        tier1_Citizen: 'mdi:account',
        tier2_Farmer: 'mdi:sprout',
        tier3_Merchant: 'mdi:store',
        tier3_Lawyer: 'mdi:gavel',
        tier4_Judge: 'mdi:scale-balance',
        tier5_King: 'mdi:crown',
      }

      const ITEM_META = {
        crown: { icon: '👑', type: 'featured', rarity: 'legendary' },
        'ملك': { icon: '👑', type: 'featured', rarity: 'legendary' },
        'نيوك': { icon: '💣', type: 'featured', rarity: 'legendary' },
        'vip+': { icon: '💎', type: 'license', rarity: 'rare' },
        vip: { icon: '💎', type: 'license', rarity: 'rare' },
        'رخصة محامي': { icon: '⚖️', type: 'license', rarity: 'rare' },
        'البريد': { icon: '📬', type: 'usable', rarity: 'uncommon' },
        'صندوق': { icon: '🎁', type: 'box', rarity: 'rare' },
        'صندوق السمعة': { icon: '🎁', type: 'box', rarity: 'rare' },
        'خشب': { icon: '🪵', type: 'resource', rarity: 'common' },
        'حديد': { icon: '⛓️', type: 'resource', rarity: 'common' },
        'ذهب': { icon: '🟡', type: 'resource', rarity: 'rare' },
      }

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function key(value) {
        return normalize(value).replace(/\s+/g, '')
      }

      function formatNumber(value) {
        const number = Number(value || 0)
        return Number.isFinite(number) ? number.toLocaleString('en-US') : '0'
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        if (!/^https?:\/\//i.test(url) && !url.startsWith('/')) return ''
        return url.replace(/["'()\\]/g, '')
      }

      function cssUrl(value) {
        const url = safeUrl(value)
        return url ? `url('${url}')` : 'none'
      }

      function safeColor(value, fallback = '#423fff') {
        const color = String(value || '').trim()
        return /^#[0-9a-fA-F]{6}$/.test(color) ? color : fallback
      }

      function hexToRgb(hex) {
        const clean = safeColor(hex).replace('#', '')
        const number = parseInt(clean, 16)
        return [(number >> 16) & 255, (number >> 8) & 255, number & 255].join(', ')
      }

      function displayName(user) {
        return String(user?.userName || user?.UserName || user?.userLogin || user?.UserLogin || '').trim()
      }

      function loginName(user) {
        return String(user?.userLogin || user?.UserLogin || user?.userName || user?.UserName || '').trim()
      }

      function userId(user) {
        return String(user?.userId || user?.UserId || '').trim()
      }

      function getBadgeName(badge) {
        return String(badge?.name || badge?.badgeName || badge?.title || badge?.value1 || '').trim()
      }

      function getBadgeImage(badge) {
        return safeUrl(badge?.url || badge?.image || badge?.badgeUrl || badge?.value2)
      }

      function getItemName(item) {
        return String(item?.name || item?.itemName || item?.Name || item?.key || '').trim()
      }

      function getItemQty(item) {
        const raw = item?.quantity ?? item?.qty ?? item?.count ?? item?.amount ?? item?.Value ?? 1
        const number = Number(raw)
        return Number.isFinite(number) && number > 0 ? number : 1
      }

      function getItemDetails(name) {
        const itemKey = key(name)
        return state.items.find((item) => key(item.name || item.itemName || item.title) === itemKey) || null
      }

      function getItemMeta(name, details) {
        const itemKey = key(name)
        const hard = Object.entries(ITEM_META).find(([metaName]) => key(metaName) === itemKey)?.[1] || null
        const type = normalize(details?.category || details?.type || '')
        const rarity = normalize(details?.rarity || '')

        return {
          icon: hard?.icon || details?.icon || '⬟',
          type: hard?.type || type || 'usable',
          rarity: hard?.rarity || rarity || 'common',
        }
      }

      function getInventoryRecord(user) {
        const id = userId(user)
        const login = normalize(loginName(user))

        return state.inventories.find((entry) => {
          const entryId = String(entry.userId || entry.UserId || '').trim()
          const entryLogin = normalize(entry.userLogin || entry.UserLogin || entry.userName || entry.UserName || '')
          return (id && entryId && id === entryId) || (login && entryLogin && login === entryLogin)
        }) || null
      }

      function rawInventory(user) {
        const record = getInventoryRecord(user)
        if (!record) return []
        if (Array.isArray(record.items)) return record.items
        if (Array.isArray(record.inventory)) return record.inventory
        return []
      }

      function inventoryItems(user) {
        return rawInventory(user)
          .map((entry) => {
            const name = getItemName(entry)
            const quantity = getItemQty(entry)
            const details = getItemDetails(name)
            const meta = getItemMeta(name, details)
            const description = details?.description || details?.desc || details?.how || 'غرض موجود في حقيبة العضو.'
            const price = details?.price || details?.cost || details?.sellPrice || ''

            return { name, quantity, details, meta, description, price }
          })
          .filter((item) => item.name)
      }

      function filteredInventory(user) {
        const items = inventoryItems(user)

        if (state.filter === 'all') return items
        if (state.filter === 'rare') return items.filter((item) => ['legendary', 'rare'].includes(item.meta.rarity) || item.meta.type === 'featured')
        if (state.filter === 'featured') return items.filter((item) => item.meta.type === 'featured' || item.meta.rarity === 'legendary')
        return items.filter((item) => item.meta.type === state.filter)
      }

      async function loadJson(url, fallback) {
        try {
          const response = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!response.ok) throw new Error(`${url} failed`)
          return await response.json()
        } catch (error) {
          console.error(error)
          return fallback
        }
      }

      async function loadData() {
        const [users, inventories, itemsPayload] = await Promise.all([
          loadJson('/api/user_badges.json', []),
          loadJson('/api/user_inventory.json', []),
          loadJson('/api/items.json', { items: [] }),
        ])

        state.users = Array.isArray(users) ? users : []
        state.inventories = Array.isArray(inventories) ? inventories : []
        state.items = Array.isArray(itemsPayload) ? itemsPayload : Array.isArray(itemsPayload?.items) ? itemsPayload.items : []
      }

      function profileUrl(user) {
        const url = new URL(window.location.href)
        url.searchParams.set('user', loginName(user))
        url.hash = ''
        return url.toString()
      }

      function updateQuery(user) {
        const url = new URL(window.location.href)
        url.searchParams.set('user', loginName(user))
        url.hash = ''
        history.replaceState(null, '', `${url.pathname}${url.search}`)
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        if (!button) return

        const old = button.textContent

        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')
          addTimer(window.setTimeout(() => {
            button.textContent = old
            button.classList.remove('is-copied')
          }, 1000))
        } catch {
          button.textContent = text
          addTimer(window.setTimeout(() => {
            button.textContent = old
          }, 1300))
        }
      }

      function renderResults(value) {
        profileResults.innerHTML = ''

        const query = normalize(value)
        if (!query) return

        const matches = state.users
          .filter((user) => normalize(displayName(user)).includes(query) || normalize(loginName(user)).includes(query))
          .slice(0, 10)

        if (!matches.length) {
          profileResults.innerHTML = `
            <div class="small-empty">
              <strong>ما فيه نتائج</strong>
              <span>تأكد من اسم المستخدم.</span>
            </div>
          `
          return
        }

        profileResults.innerHTML = matches.map((user, index) => {
          const name = displayName(user)
          const login = loginName(user)
          const avatar = safeUrl(user.profileImageUrl || user.avatar || user.ProfileImageUrl)

          return `
            <button type="button" class="profile-result" data-index="${index}">
              <img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy" />
              <div>
                <strong>${esc(name)}</strong>
                <span>${esc(login)}</span>
              </div>
            </button>
          `
        }).join('')

        profileResults.querySelectorAll('[data-index]').forEach((button) => {
          button.addEventListener('click', () => {
            const user = matches[Number(button.dataset.index)]
            if (!user) return

            if (profileSearch) profileSearch.value = ''
            profileResults.innerHTML = ''
            updateQuery(user)
            renderProfile(user)
          })
        })
      }

      function shownBadges(user, limit = 7) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const equipped = badges.filter((badge) => badge.equipped).slice(0, limit)
        return equipped.length ? equipped : badges.slice(0, limit)
      }

      function renderHero(user) {
        const name = displayName(user)
        const login = loginName(user)
        const avatar = safeUrl(user.profileImageUrl || user.avatar || user.ProfileImageUrl)
        const banner = safeUrl(user.bannerImage || user.banner || user.backgroundImage)
        const color = safeColor(user.backgroundColor || user.profileColor || '#423fff')
        const points = Number(user.points || 0)
        const gold = Number(user.gold || 0)
        const level = Math.max(1, Math.floor(points / 100000) + 1)
        const jobName = user.jobName || 'Citizen'
        const jobId = user.jobId || 'tier1_Citizen'
        const jobIcon = JOB_ICONS[jobId] || 'mdi:account'
        const badges = shownBadges(user, 7)

        profileBackdrop.style.backgroundImage = banner
          ? `url("${banner}")`
          : `linear-gradient(135deg, ${color}, #07070a)`

        profileHero.innerHTML = `
          <div class="hero-cover" style="--accent-rgb: ${hexToRgb(color)}; background-image: ${cssUrl(banner)}; background-color: ${color};"></div>

          <div class="hero-inner" style="--accent-rgb: ${hexToRgb(color)};">
            <div class="avatar-frame">
              <img src="${esc(avatar)}" alt="${esc(name)}" loading="lazy" />
            </div>

            <div class="identity">
              <h2 title="${esc(name)}">${esc(name)}</h2>
              <p class="login">${esc(login)}</p>

              <div class="job-pill">
                <iconify-icon icon="${esc(jobIcon)}"></iconify-icon>
                <span>${esc(jobName)}</span>
              </div>

              <div class="hero-badges">
                ${
                  badges.length
                    ? badges.map((badge) => `
                      <div class="hero-badge" title="${esc(getBadgeName(badge))}">
                        <img src="${esc(getBadgeImage(badge))}" alt="${esc(getBadgeName(badge))}" loading="lazy" />
                      </div>
                    `).join('')
                    : '<div class="hero-badge">—</div>'
                }
              </div>
            </div>

            <div class="hero-stats">
              <div class="level-card">
                <span>Level</span>
                <strong>${formatNumber(level)}</strong>
              </div>

              <div class="wallet-card">
                <span>النقاط</span>
                <strong>${formatNumber(points)}</strong>
              </div>

              <div class="wallet-card">
                <span>الذهب</span>
                <strong>${formatNumber(gold)}</strong>
              </div>
            </div>
          </div>
        `
      }

      function renderDisplayCase(user) {
        const items = inventoryItems(user)
          .sort((a, b) => {
            const rank = { legendary: 4, rare: 3, uncommon: 2, common: 1 }
            return (rank[b.meta.rarity] || 0) - (rank[a.meta.rarity] || 0) || b.quantity - a.quantity
          })

        const main = items[0]
        const rest = items.slice(1, 5)

        if (!main) {
          displayCase.innerHTML = `
            <div class="small-empty">
              <strong>ما فيه أغراض للعرض</strong>
              <span>شغّل تصدير الحقيبة أو تأكد من user_inventory.json.</span>
            </div>
          `
          return
        }

        displayCase.innerHTML = `
          <article class="display-main">
            <div class="display-icon">${esc(main.meta.icon)}</div>
            <h3>${esc(main.name)}</h3>
            <p>${esc(main.description)}</p>
            <strong>x${formatNumber(main.quantity)}</strong>
          </article>

          <div class="display-list">
            ${
              rest.length
                ? rest.map((item) => `
                  <div class="display-row">
                    <div>
                      <strong>${esc(item.meta.icon)} ${esc(item.name)}</strong>
                      <span>${esc(item.meta.rarity)} · ${esc(item.meta.type)}</span>
                    </div>
                    <b>x${formatNumber(item.quantity)}</b>
                  </div>
                `).join('')
                : `
                  <div class="display-row">
                    <div>
                      <strong>لا توجد أغراض إضافية</strong>
                      <span>بتظهر هنا إذا صار عنده أغراض أكثر.</span>
                    </div>
                    <b>—</b>
                  </div>
                `
            }
          </div>
        `
      }

      function renderInventory(user) {
        const all = inventoryItems(user)
        const items = filteredInventory(user)

        if (inventoryCount) inventoryCount.textContent = String(all.length)

        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.filter === state.filter)
        })

        inventoryEmpty?.classList.toggle('hidden', items.length > 0)
        inventoryGrid?.classList.toggle('hidden', items.length === 0)

        inventoryGrid.innerHTML = items.map((item) => {
          const rare = ['legendary', 'rare'].includes(item.meta.rarity) || item.meta.type === 'featured'

          return `
            <article class="item-card${rare ? ' is-rare' : ''}">
              <span class="item-qty">x${formatNumber(item.quantity)}</span>
              <div class="item-icon">${esc(item.meta.icon)}</div>
              <h3>${esc(item.name)}</h3>
              <p>${esc(item.description)}</p>
              <div class="item-tags">
                <span>${esc(item.meta.type)}</span>
                <span>${esc(item.meta.rarity)}</span>
                ${item.price ? `<span>${formatNumber(item.price)} نقطة</span>` : ''}
              </div>
            </article>
          `
        }).join('')
      }

      function renderBadges(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []

        if (badgeCount) badgeCount.textContent = String(badges.length)

        if (!badges.length) {
          badgesGrid.innerHTML = `
            <div class="small-empty">
              <strong>ما فيه بادجات</strong>
              <span>ما لقينا بادجات لهذا العضو.</span>
            </div>
          `
          return
        }

        badgesGrid.innerHTML = badges.slice(0, 42).map((badge) => `
          <div class="badge-tile">
            <img src="${esc(getBadgeImage(badge))}" alt="${esc(getBadgeName(badge))}" loading="lazy" />
            <span>${esc(getBadgeName(badge))}</span>
          </div>
        `).join('')
      }

      function renderStats(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const equipped = badges.filter((badge) => badge.equipped).length
        const items = inventoryItems(user)
        const totalQuantity = items.reduce((sum, item) => sum + item.quantity, 0)
        const rareCount = items.filter((item) => ['legendary', 'rare'].includes(item.meta.rarity) || item.meta.type === 'featured').length

        statsList.innerHTML = `
          <div class="stat-row">
            <span>عدد البادجات</span>
            <strong>${formatNumber(badges.length)}</strong>
          </div>

          <div class="stat-row">
            <span>بادجات الواجهة</span>
            <strong>${formatNumber(equipped)}</strong>
          </div>

          <div class="stat-row">
            <span>أنواع الأغراض</span>
            <strong>${formatNumber(items.length)}</strong>
          </div>

          <div class="stat-row">
            <span>إجمالي الكميات</span>
            <strong>${formatNumber(totalQuantity)}</strong>
          </div>

          <div class="stat-row">
            <span>أغراض نادرة</span>
            <strong>${formatNumber(rareCount)}</strong>
          </div>
        `
      }

      function renderRare(user) {
        const items = inventoryItems(user)
          .filter((item) => ['legendary', 'rare'].includes(item.meta.rarity) || item.meta.type === 'featured')
          .slice(0, 8)

        if (!items.length) {
          rareList.innerHTML = `
            <div class="small-empty">
              <strong>ما فيه نادر</strong>
              <span>الأغراض النادرة بتظهر هنا.</span>
            </div>
          `
          return
        }

        rareList.innerHTML = items.map((item) => `
          <div class="rare-row">
            <strong>${esc(item.meta.icon)} ${esc(item.name)}</strong>
            <span>x${formatNumber(item.quantity)}</span>
          </div>
        `).join('')
      }

      function renderProfile(user) {
        state.activeUser = user
        emptyState?.classList.add('hidden')
        profileContent?.classList.remove('hidden')

        renderHero(user)
        renderDisplayCase(user)
        renderInventory(user)
        renderBadges(user)
        renderStats(user)
        renderRare(user)

        const login = loginName(user)

        if (badgesLink) {
          badgesLink.href = `/badges?user=${encodeURIComponent(login)}`
        }
      }

      function openFromQuery() {
        const params = new URLSearchParams(window.location.search)
        const raw = params.get('user')

        if (!raw) return false

        const query = normalize(raw)

        let user = state.users.find((entry) => normalize(loginName(entry)) === query)
        if (!user) user = state.users.find((entry) => normalize(displayName(entry)) === query)
        if (!user) user = state.users.find((entry) => normalize(loginName(entry)).includes(query) || normalize(displayName(entry)).includes(query))

        if (!user) {
          emptyState.innerHTML = `
            <strong>ما لقيت العضو</strong>
            <span>تأكد أنه موجود في <b>user_badges.json</b>.</span>
          `
          emptyState.classList.remove('hidden')
          profileContent.classList.add('hidden')
          return false
        }

        renderProfile(user)
        return true
      }

      function handleBackToTop() {
        backToTop?.classList.toggle('is-visible', window.scrollY > 520)
      }

      addListener(profileSearch, 'input', () => renderResults(profileSearch.value))

      addListener(clearProfileSearch, 'click', () => {
        if (!profileSearch) return
        profileSearch.value = ''
        profileResults.innerHTML = ''
        profileSearch.focus()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.filter || 'all'
          if (state.activeUser) renderInventory(state.activeUser)
        })
      })

      addListener(copyProfileLink, 'click', () => {
        if (!state.activeUser) return
        copyText(profileUrl(state.activeUser), copyProfileLink, 'تم نسخ الرابط')
      })

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTop, { passive: true })

      ;(async () => {
        await loadData()
        openFromQuery()
        handleBackToTop()
      })()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
