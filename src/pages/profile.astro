---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'البروفايل — TNX6',
  ignoreTitleTemplate: true,
  description: 'بروفايل عضو في مجتمع TNX6 — أغراض، رصيد، بادجات، بريد، وإنجازات.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div class="tnx-global-bg"></div>
    <div class="tnx-global-grid"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      
      <section id="searchScreen" class="tnx-search-screen hidden">
        <div class="tnx-search-box tnx-reveal">
          <div class="tnx-kicker">TNX6 PROFILE</div>
          <h1>ابحث عن عضو</h1>
          <p>اكتب اسم العضو عشان تفتح بروفايله الكامل وتشوف إنجازاته.</p>

          <div class="tnx-search">
            <span>⌕</span>
            <input id="userSearch" type="search" autocomplete="off" placeholder="اسم العضو (مثال: TNX6)..." />
            <button type="button" id="clearUserSearch" aria-label="مسح البحث">×</button>
          </div>

          <div id="userResults" class="tnx-user-results"></div>
        </div>
      </section>

      <section id="profileScreen" class="tnx-profile-screen hidden">
        
        <header class="tnx-profile-header tnx-reveal">
          <div class="tnx-profile-banner" id="profileBg">
            <div class="tnx-banner-overlay"></div>
          </div>

          <div class="tnx-header-content">
            <div class="tnx-identity">
              <div class="tnx-avatar-wrap">
                <div class="tnx-avatar" id="pAvatar"></div>
              </div>

              <div class="tnx-identity-text">
                <h1 id="pName">—</h1>
                <div class="tnx-identity-badges">
                  <div class="tnx-level-badge">
                    <span>Lvl</span>
                    <strong id="pLevel">1</strong>
                  </div>
                  <div class="tnx-country hidden" id="pCountry"></div>
                </div>
                <div class="tnx-bio" id="pBio"></div>
              </div>
            </div>

            <div class="tnx-header-actions">
              <button type="button" class="tnx-action-btn" id="mailToggle" aria-label="البريد">
                <span class="ti-mail-glyph">✉</span>
                <span class="tnx-mail-count hidden" id="mailCount">0</span>
              </button>

              <button type="button" class="tnx-copy-link" id="copyProfileLink">نسخ الرابط</button>
            </div>
          </div>
        </header>

        <section class="tnx-mailbox hidden" id="mailboxSection">
          <div class="tnx-box-head">
            <div class="tnx-box-title">
              <span class="icon">📬</span>
              <strong>صندوق البريد</strong>
            </div>
            <div class="tnx-mail-filters">
              <button type="button" class="is-active" data-mail-filter="all">
                الكل <small id="mailAllCount">0</small>
              </button>
              <button type="button" data-mail-filter="unread">
                غير المقروءة <small id="mailUnreadCount">0</small>
              </button>
            </div>
          </div>
          <div id="mailList" class="tnx-mail-list"></div>
          <div class="tnx-mail-hint">
            الرسائل تُرسل من الشات عبر أمر <code>!mail @USER رسالتك</code>
          </div>
        </section>

        <div class="tnx-profile-body">
          
          <aside class="tnx-side-col tnx-reveal" style="transition-delay: 100ms;">
            
            <div class="tnx-panel tnx-balance">
              <h3 class="tnx-panel-title">المحفظة</h3>
              
              <div class="tnx-balance-row">
                <div class="label">
                  <span class="icon" style="color: #60a5fa;">★</span> النقاط
                </div>
                <strong id="pPoints">0</strong>
              </div>

              <div class="tnx-balance-row">
                <div class="label">
                  <span class="icon" style="color: #ffd700;">🪙</span> الذهب
                </div>
                <strong id="pGold" class="gold">0</strong>
              </div>

              <div class="tnx-balance-row">
                <div class="label">
                  <span class="icon" style="color: #c084fc;">🔥</span> السمعة
                </div>
                <strong id="pRep" class="rep">0</strong>
              </div>
            </div>

            <div class="tnx-panel">
              <div class="tnx-box-head">
                <h3 class="tnx-panel-title m-0">البادجات</h3>
                <span class="tnx-count-badge" id="badgeCount">0</span>
              </div>
              <div id="badgeShowcase" class="tnx-badge-showcase"></div>
            </div>

            <div class="tnx-panel tnx-quicklist">
              <button type="button" data-jump="inventoryGrid">
                <span>الأغراض</span>
                <em id="qlItems">0</em>
              </button>
              <button type="button" data-jump="badgeShowcase">
                <span>البادجات</span>
                <em id="qlBadges">0</em>
              </button>
              <button type="button" data-jump="achievementsList">
                <span>الإنجازات</span>
                <em id="qlAch">0</em>
              </button>
              <a id="badgePageLink" href="/badges">
                <span>دليل البادجات الكامل</span>
                <em>↗</em>
              </a>
            </div>

          </aside>

          <main class="tnx-main-col tnx-reveal" style="transition-delay: 200ms;">
            
            <div class="tnx-panel">
              <div class="tnx-box-head">
                <h3 class="tnx-panel-title m-0">حقيبة الأغراض</h3>
                <span class="tnx-count-badge" id="invCount">0 غرض</span>
              </div>
              <div id="inventoryGrid" class="tnx-inv-grid"></div>
              <div id="inventoryEmpty" class="tnx-inline-empty hidden">لا توجد أغراض في الحقيبة حالياً.</div>
            </div>

            <div class="tnx-panel tnx-section-gap">
              <div class="tnx-box-head">
                <h3 class="tnx-panel-title m-0">الإنجازات</h3>
                <span class="tnx-count-badge" id="achCount">0 إنجاز</span>
              </div>
              <div id="achievementsList" class="tnx-ach-list"></div>
              <div id="achievementsEmpty" class="tnx-inline-empty hidden">لم يفتح أي إنجازات بعد.</div>
            </div>

          </main>
        </div>
      </section>

      <section id="notFoundScreen" class="tnx-empty hidden">
        <div class="empty-icon">👻</div>
        <strong>ما لقيت هذا العضو</strong>
        <span>تأكد من اسم العضو في الرابط أو من مربع البحث.</span>
        <button type="button" class="tnx-copy-link mt-4" onclick="document.getElementById('notFoundScreen').classList.add('hidden'); document.getElementById('searchScreen').classList.remove('hidden');">الرجوع للبحث</button>
      </section>
    </section>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.45) rgba(0, 0, 0, 0.38);
    }
    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.38); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.38); border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.85), rgba(194, 146, 0, 0.55));
    }

    .tnx-profile-page {
      position: relative; min-height: 100vh; overflow: hidden;
      background: #07050b; color: #c7d5e0;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    /* الخلفية العامة للصفحة */
    .tnx-global-bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.08), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.08), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.05), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #0a0812 55%, #130c05 100%);
    }
    .tnx-global-grid {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.04;
      background-image: linear-gradient(rgba(255, 218, 106, 0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 218, 106, 0.4) 1px, transparent 1px);
      background-size: 58px 58px; mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell { position: relative; z-index: 1; width: min(100%, 1100px); margin: 0 auto; padding: 6.5rem 1.25rem 5rem; }

    /* أنيميشن الظهور السلس */
    .tnx-reveal {
      animation: revealUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes revealUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* --- شاشة البحث --- */
    .tnx-search-screen { display: grid; place-items: center; min-height: 60vh; }
    .tnx-search-box {
      width: min(100%, 580px); border: 1px solid rgba(255, 218, 106, 0.15); border-radius: 1.5rem;
      background: rgba(10, 10, 15, 0.8); padding: 2.5rem 2rem; text-align: center;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.5); backdrop-filter: blur(20px);
    }
    .tnx-kicker {
      display: inline-flex; border: 1px solid rgba(255, 218, 106, 0.25); border-radius: 999px;
      background: rgba(255, 218, 106, 0.06); color: #ffda6a; padding: 0.45rem 0.75rem;
      font-size: 0.68rem; font-weight: 900; letter-spacing: 0.15em;
    }
    .tnx-search-box h1 {
      margin: 1rem 0 0.5rem; color: #fff; font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 900; line-height: 1.1;
    }
    .tnx-search-box p { margin: 0 0 1.5rem; color: #9ca3af; font-size: 0.95rem; line-height: 1.6; }

    .tnx-search {
      display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 0.75rem; align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2); border-radius: 1rem; background: rgba(0, 0, 0, 0.5);
      padding: 0.8rem 1rem; transition: 0.3s ease;
    }
    .tnx-search:focus-within { border-color: rgba(255, 218, 106, 0.6); box-shadow: 0 0 15px rgba(255, 218, 106, 0.1); }
    .tnx-search span { color: #ffda6a; font-size: 1.4rem; }
    .tnx-search input { width: 100%; border: 0; outline: 0; background: transparent; color: white; font-size: 1rem; }
    .tnx-search button {
      width: 2.2rem; height: 2.2rem; border: none; border-radius: 50%; background: rgba(255, 218, 106, 0.1);
      color: #ffda6a; font-size: 1.2rem; cursor: pointer; transition: 0.2s;
    }
    .tnx-search button:hover { background: rgba(255, 218, 106, 0.25); transform: scale(1.1); }

    .tnx-user-results { display: grid; gap: 0.5rem; margin-top: 0.85rem; }
    .tnx-user-result {
      border: 1px solid rgba(255, 218, 106, 0.1); border-radius: 0.8rem; background: rgba(255,255,255, 0.03);
      color: #fff; padding: 0.8rem 1rem; text-align: right; font-weight: 700; cursor: pointer; transition: 0.2s;
    }
    .tnx-user-result:hover { border-color: #ffda6a; background: rgba(255, 218, 106, 0.1); transform: translateX(-4px); }

    /* --- الهيدر (بانر Steam) --- */
    .tnx-profile-header {
      position: relative; background: #0f0f15; border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 1.5rem; overflow: hidden; margin-bottom: 2rem; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }
    .tnx-profile-banner {
      height: 240px; width: 100%; background-size: cover; background-position: center; position: relative;
    }
    .tnx-banner-overlay {
      position: absolute; inset: 0; background: linear-gradient(to top, #0f0f15 0%, transparent 70%);
    }

    .tnx-header-content {
      position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: flex-end;
      padding: 0 2.5rem 2rem; margin-top: -60px; flex-wrap: wrap; gap: 1.5rem;
    }

    .tnx-identity { display: flex; gap: 1.5rem; align-items: flex-end; }
    .tnx-avatar-wrap {
      background: #0f0f15; padding: 6px; border-radius: 50%; box-shadow: 0 10px 20px rgba(0,0,0,0.5);
    }
    .tnx-avatar {
      width: 130px; height: 130px; border-radius: 50%; background-color: var(--pColor, #6c5ce7);
      background-size: cover; background-position: center; border: 3px solid var(--pColor, #6c5ce7);
    }

    .tnx-identity-text { padding-bottom: 0.5rem; }
    .tnx-identity-text h1 { margin: 0 0 0.5rem 0; color: #fff; font-size: 2.2rem; font-weight: 900; line-height: 1; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
    
    .tnx-identity-badges { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.6rem; }
    .tnx-level-badge {
      display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(255,218,106,0.1); border: 1px solid rgba(255,218,106,0.3);
      padding: 0.2rem 0.8rem; border-radius: 1rem; color: #ffda6a; font-size: 0.8rem; font-weight: 800;
    }
    .tnx-country { color: #a0b3c0; font-size: 0.85rem; font-weight: 600; }
    .tnx-country::before { content: "🏳 "; }
    
    .tnx-bio { color: #9ca3af; font-size: 0.9rem; line-height: 1.6; max-width: 400px; }
    .tnx-bio span { color: #c084fc; font-weight: 700; background: rgba(192,132,252,0.1); padding: 0.1rem 0.5rem; border-radius: 0.4rem; }

    .tnx-header-actions { display: flex; gap: 0.8rem; align-items: center; padding-bottom: 0.5rem; }
    .tnx-action-btn {
      position: relative; display: grid; place-items: center; width: 44px; height: 44px;
      border: 1px solid rgba(255,255,255,0.1); border-radius: 0.8rem; background: rgba(255,255,255,0.05);
      color: #fff; font-size: 1.2rem; cursor: pointer; transition: 0.2s; backdrop-filter: blur(5px);
    }
    .tnx-action-btn:hover { background: rgba(255,218,106,0.15); border-color: #ffda6a; color: #ffda6a; transform: translateY(-2px); }
    .tnx-mail-count {
      position: absolute; top: -6px; right: -6px; min-width: 22px; height: 22px; display: grid; place-items: center;
      background: #e74c3c; border: 2px solid #0f0f15; border-radius: 50%; color: #fff; font-size: 0.7rem; font-weight: 800;
    }

    .tnx-copy-link {
      border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 0.8rem; background: rgba(255,255,255,0.05);
      color: #fff; padding: 0 1.2rem; height: 44px; font-size: 0.9rem; font-weight: 700; cursor: pointer; transition: 0.2s; backdrop-filter: blur(5px);
    }
    .tnx-copy-link:hover, .tnx-copy-link.is-copied { background: #10b981; border-color: #10b981; color: #fff; transform: translateY(-2px); }

    /* --- Panels العامة --- */
    .tnx-panel {
      background: rgba(15, 15, 22, 0.6); border: 1px solid rgba(255,255,255,0.05);
      border-radius: 1.2rem; padding: 1.5rem; backdrop-filter: blur(15px); box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .tnx-panel-title { margin: 0 0 1.2rem 0; color: #fff; font-size: 1.1rem; font-weight: 800; }
    .m-0 { margin-bottom: 0 !important; }
    
    .tnx-box-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.8rem; }
    .tnx-count-badge { background: rgba(255,255,255,0.05); padding: 0.2rem 0.6rem; border-radius: 1rem; color: #9ca3af; font-size: 0.75rem; font-weight: 700;}
    .tnx-section-gap { margin-top: 1.5rem; }

    /* --- تخطيط الجسم --- */
    .tnx-profile-body { display: grid; grid-template-columns: 320px 1fr; gap: 1.5rem; align-items: start; }
    .tnx-side-col { display: grid; gap: 1.5rem; }
    .tnx-main-col { display: grid; gap: 1.5rem; }

    /* --- الإحصائيات (المحفظة) --- */
    .tnx-balance-row { display: flex; justify-content: space-between; align-items: center; padding: 0.8rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
    .tnx-balance-row:last-child { border-bottom: none; padding-bottom: 0; }
    .tnx-balance-row .label { color: #d1d5db; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
    .tnx-balance-row strong { font-size: 1.1rem; font-weight: 900; }
    .tnx-balance-row strong.gold { color: #ffd700; }
    .tnx-balance-row strong.rep { color: #c084fc; }

    /* --- البادجات والإنفنتوري --- */
    .tnx-badge-showcase { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .tnx-badge-showcase img, .tnx-badge-fallback {
      width: 48px; height: 48px; border-radius: 0.5rem; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,218,106,0.15);
      object-fit: contain; padding: 4px; transition: 0.2s;
    }
    .tnx-badge-showcase img:hover { transform: scale(1.1) translateY(-2px); border-color: rgba(255,218,106,0.6); background: rgba(255,218,106,0.1); }
    .tnx-badge-fallback { display: grid; place-items: center; color: #ffda6a; font-size: 1.2rem; }

    .tnx-inv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 0.8rem; }
    .tnx-inv-item {
      aspect-ratio: 1; border-radius: 0.8rem; display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: linear-gradient(135deg, var(--cat-soft), rgba(0,0,0,0.6)); border: 1px solid var(--cat);
      position: relative; transition: 0.2s; cursor: pointer; text-align: center;
    }
    .tnx-inv-item:hover { transform: translateY(-4px); filter: brightness(1.2); box-shadow: 0 5px 15px var(--cat-soft); }
    .tnx-inv-item span:first-child { font-size: 2rem; margin-bottom: 0.2rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)); }
    .tnx-inv-amount {
      position: absolute; bottom: -5px; right: -5px; background: var(--cat); color: #000;
      font-size: 0.7rem; font-weight: 900; padding: 0.1rem 0.4rem; border-radius: 0.4rem; border: 2px solid #15151e;
    }
    .tnx-inv-more {
      aspect-ratio: 1; border-radius: 0.8rem; background: rgba(255,255,255,0.03); border: 1px dashed rgba(255,255,255,0.2);
      display: grid; place-items: center; color: #9ca3af; font-weight: 800; font-size: 1rem;
    }

    /* تأثير البادجات النادرة */
    .tnx-inv-item.is-rare::after {
      content: ""; position: absolute; inset: 0; border-radius: inherit;
      box-shadow: inset 0 0 15px var(--cat); animation: rarePulse 2s infinite alternate; pointer-events: none;
    }
    @keyframes rarePulse { from { opacity: 0.3; } to { opacity: 1; } }

    /* --- الإنجازات --- */
    .tnx-ach-list { display: grid; gap: 0.8rem; }
    .tnx-ach-item {
      display: flex; align-items: center; gap: 1rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05);
      padding: 1rem; border-radius: 1rem; transition: 0.2s;
    }
    .tnx-ach-item:hover { background: rgba(255,218,106,0.05); border-color: rgba(255,218,106,0.2); transform: translateX(-4px); }
    .tnx-ach-icon {
      width: 44px; height: 44px; border-radius: 0.6rem; background: rgba(255,218,106,0.1); border: 1px solid rgba(255,218,106,0.3);
      display: grid; place-items: center; font-size: 1.5rem;
    }
    .tnx-ach-item strong { color: #fff; font-size: 0.95rem; font-weight: 800; display: block; margin-bottom: 0.2rem; }
    .tnx-ach-item span { color: #9ca3af; font-size: 0.8rem; }

    /* --- Quick Links --- */
    .tnx-quicklist { padding: 0.5rem; }
    .tnx-quicklist button, .tnx-quicklist a {
      display: flex; justify-content: space-between; align-items: center; width: 100%;
      background: transparent; border: none; padding: 1rem; color: #d1d5db; font-size: 0.9rem; font-weight: 600;
      border-radius: 0.8rem; cursor: pointer; transition: 0.2s; text-decoration: none;
    }
    .tnx-quicklist button:hover, .tnx-quicklist a:hover { background: rgba(255,255,255,0.05); color: #fff; padding-right: 1.5rem; }
    .tnx-quicklist em { font-style: normal; background: rgba(0,0,0,0.5); padding: 0.2rem 0.6rem; border-radius: 1rem; font-size: 0.75rem;}
    .tnx-quicklist a em { background: #ffda6a; color: #000; }

    /* --- البريد --- */
    .tnx-mailbox { margin-bottom: 1.5rem; }
    .tnx-mail-filters { display: flex; gap: 0.5rem; }
    .tnx-mail-filters button {
      background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1); color: #9ca3af; padding: 0.4rem 0.8rem;
      border-radius: 0.5rem; font-size: 0.8rem; cursor: pointer; transition: 0.2s;
    }
    .tnx-mail-filters button.is-active { background: rgba(255,218,106,0.15); border-color: #ffda6a; color: #ffda6a; }
    .tnx-mail-list { display: grid; gap: 0.5rem; margin-top: 1rem; }
    .tnx-mail-item {
      display: flex; gap: 1rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05); padding: 1rem; border-radius: 1rem;
    }
    .tnx-mail-item.is-unread { border-right: 4px solid #ffda6a; background: rgba(255,218,106,0.05); border-color: rgba(255,218,106,0.2); }
    .tnx-mail-avatar { width: 44px; height: 44px; border-radius: 50%; background: #423fff; display: grid; place-items: center; font-weight: 800; font-size: 1.2rem; }
    .tnx-mail-body { flex: 1; }
    .tnx-mail-top { display: flex; justify-content: space-between; margin-bottom: 0.4rem; }
    .tnx-mail-from { font-weight: 800; color: #fff; }
    .tnx-mail-item.is-unread .tnx-mail-from { color: #ffda6a; }
    .tnx-mail-date { font-size: 0.75rem; color: #6b7280; }
    .tnx-mail-text { font-size: 0.85rem; color: #d1d5db; line-height: 1.5; }

    .tnx-mail-hint { margin-top: 1rem; padding: 1rem; background: rgba(255,255,255,0.02); border-radius: 0.8rem; text-align: center; font-size: 0.8rem; color: #9ca3af; }
    .tnx-mail-hint code { color: #ffda6a; background: rgba(0,0,0,0.5); padding: 0.2rem 0.4rem; border-radius: 0.3rem; }

    .tnx-inline-empty { text-align: center; color: #6b7280; font-size: 0.9rem; padding: 2rem; background: rgba(0,0,0,0.2); border-radius: 1rem; }

    /* الموبايل */
    @media (max-width: 900px) {
      .tnx-profile-body { grid-template-columns: 1fr; }
      .tnx-profile-header { text-align: center; }
      .tnx-header-content { flex-direction: column; align-items: center; margin-top: -70px; }
      .tnx-identity { flex-direction: column; align-items: center; }
      .tnx-identity-badges { justify-content: center; }
      .tnx-bio { margin: 0 auto; }
    }
    @media (max-width: 600px) {
      .tnx-shell { padding-top: 4rem; }
      .tnx-inv-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxProfilePageCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
      }

      const ITEM_META = {
        Vip: { cat: 'status', icon: '👑' },
        'Vip+': { cat: 'status', icon: '👑', rare: true },
        'محامي': { cat: 'status', icon: '⚖️' },
        'رخصة محامي': { cat: 'status', icon: '⚖️' },
        'عريف الفصل': { cat: 'status', icon: '🎖️' },
        Crown: { cat: 'rare', icon: '👑', rare: true },
        'ملك': { cat: 'rare', icon: '👑', rare: true },
        'نيوك': { cat: 'attacks', icon: '☢️', rare: true },
        'تغير العنوان': { cat: 'attacks', icon: '📝' },
        'تغيير العنوان': { cat: 'attacks', icon: '📝' },
        'تغيير العنوان مطور': { cat: 'attacks', icon: '📝', rare: true },
        'تجميد الشاشة': { cat: 'attacks', icon: '❄️' },
        'قنبلة دخانية': { cat: 'attacks', icon: '💣' },
        'يد الحرامي': { cat: 'pvp', icon: '🥷' },
        'اقول لا يكثر': { cat: 'pvp', icon: '🚫' },
        'أقول لا يكثر': { cat: 'pvp', icon: '🚫' },
        'رمي النرد': { cat: 'luck', icon: '🎲' },
        'البطاطا الحارة': { cat: 'luck', icon: '🥔' },
        'صندوق': { cat: 'boxes', icon: '📦' },
        'صندوق نادر': { cat: 'boxes', icon: '🎁', rare: true },
        'صندوق السمعة': { cat: 'boxes', icon: '🎁', rare: true },
        'رخصة مصرفي': { cat: 'permits', icon: '📜' },
        'خشب': { cat: 'resources', icon: '🪵' },
        'طماط': { cat: 'resources', icon: '🍅' },
        'سمكة': { cat: 'fishing', icon: '🐟' },
        'مرق سمك': { cat: 'cooking', icon: '🍲' },
        'مطرقة ذهبية': { cat: 'rare', icon: '🔨', rare: true },
        'البريد': { cat: 'economy', icon: '📬' },
        'سمعة': { cat: 'economy', icon: '🔥' },
        'عملة الجرأة': { cat: 'luck', icon: '🪙' },
      }

      const CAT_COLORS = {
        status: ['#c084fc', 'rgba(192,132,252,0.14)'],
        attacks: ['#f87171', 'rgba(248,113,113,0.14)'],
        pvp: ['#fb923c', 'rgba(251,146,60,0.14)'],
        luck: ['#fbbf24', 'rgba(251,191,36,0.14)'],
        boxes: ['#34d399', 'rgba(52,211,153,0.14)'],
        permits: ['#60a5fa', 'rgba(96,165,250,0.14)'],
        resources: ['#a3a3a3', 'rgba(163,163,163,0.12)'],
        fishing: ['#38bdf8', 'rgba(56,189,248,0.14)'],
        cooking: ['#fb7185', 'rgba(251,113,133,0.14)'],
        rare: ['#ffda6a', 'rgba(255,218,106,0.16)'],
        economy: ['#f7e6ac', 'rgba(247,230,172,0.12)'],
      }

      const INV_LIMIT = 14

      const $ = (id) => document.getElementById(id)

      const searchScreen = $('searchScreen')
      const profileScreen = $('profileScreen')
      const notFoundScreen = $('notFoundScreen')
      const userSearch = $('userSearch')
      const clearUserSearch = $('clearUserSearch')
      const userResults = $('userResults')
      const backToTop = $('backToTop')

      let users = []
      let inventories = []
      let mailboxes = []
      let profileExtras = []
      let itemCatalog = []
      let activeUser = null
      let mailState = { user: null, filter: 'all' }

      function esc(value) {
        return String(value ?? '').replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[m])
      }

      function normalize(value) {
        return String(value || '').toLowerCase().replace(/[ًٌٍَُِّْـ]/g, '').replace(/[أإآ]/g, 'ا').replace(/ة/g, 'ه').replace(/ى/g, 'ي').replace(/\s+/g, ' ').trim()
      }

      function key(value) { return normalize(value).replace(/\s+/g, '') }

      function fmt(value) {
        const number = Number(value || 0)
        return Number.isFinite(number) ? number.toLocaleString('en-US') : '0'
      }

      function safeUrl(value) {
        const url = String(value || '').trim()
        return /^https?:\/\//i.test(url) || url.startsWith('/') ? url : ''
      }

      function getField(source, keys, fallback) {
        for (const itemKey of keys) {
          if (source && source[itemKey] !== undefined && source[itemKey] !== null && source[itemKey] !== '') return source[itemKey]
        }
        return fallback
      }

      function userLogin(user) { return String(getField(user, ['userLogin', 'UserLogin', 'login'], '')).trim() }
      function userName(user) { return String(getField(user, ['userName', 'UserName', 'displayName', 'userLogin'], '')).trim() }
      function userId(user) { return String(getField(user, ['userId', 'UserId', 'id'], '')).trim() }

      function findByUser(collection, user) {
        const id = userId(user)
        const login = normalize(userLogin(user))
        const name = normalize(userName(user))

        return collection.find((entry) => {
          const entryId = String(getField(entry, ['userId', 'UserId', 'id'], '')).trim()
          const entryLogin = normalize(getField(entry, ['userLogin', 'UserLogin', 'login'], ''))
          const entryName = normalize(getField(entry, ['userName', 'UserName', 'displayName'], ''))

          return (
            (id && entryId && id === entryId) ||
            (login && entryLogin && login === entryLogin) ||
            (login && entryName && login === entryName) ||
            (name && entryLogin && name === entryLogin) ||
            (name && entryName && name === entryName)
          )
        }) || null
      }

      function mergeUserData(user) {
        const inventoryRecord = findByUser(inventories, user)
        const mailboxRecord = findByUser(mailboxes, user)
        const profileRecord = findByUser(profileExtras, user)

        const merged = { ...user, ...(profileRecord || {}) }

        if (inventoryRecord) {
          merged.inventory = Array.isArray(inventoryRecord.items) ? inventoryRecord.items : Array.isArray(inventoryRecord.inventory) ? inventoryRecord.inventory : []
        } else if (!Array.isArray(merged.inventory)) { merged.inventory = [] }

        if (mailboxRecord) {
          merged.mailbox = Array.isArray(mailboxRecord.messages) ? mailboxRecord.messages : Array.isArray(mailboxRecord.mailbox) ? mailboxRecord.mailbox : []
        } else if (!Array.isArray(merged.mailbox)) { merged.mailbox = [] }

        return merged
      }

      function getItemName(entry) { return String(getField(entry, ['item', 'name', 'itemName', 'Name', 'key'], '')).trim() }
      function getItemAmount(entry) {
        const raw = getField(entry, ['amount', 'quantity', 'qty', 'count', 'Value'], 1)
        const number = Number(raw)
        return Number.isFinite(number) && number > 0 ? number : 1
      }

      function getCatalogItem(name) {
        const itemKey = key(name)
        return itemCatalog.find((item) => key(getField(item, ['name', 'itemName', 'title'], '')) === itemKey) || null
      }

      function getMeta(name) {
        const hard = ITEM_META[name]
        if (hard) return hard

        const catalog = getCatalogItem(name)
        if (catalog) {
          return {
            cat: getField(catalog, ['category', 'type', 'cat'], 'economy'),
            icon: getField(catalog, ['icon', 'emoji'], '📦'),
            rare: Boolean(catalog.rare) || ['rare', 'legendary'].includes(normalize(catalog.rarity)),
          }
        }
        return { cat: 'economy', icon: '📦' }
      }

      function timeAgo(dateStr) {
        const date = new Date(dateStr)
        if (Number.isNaN(date.getTime())) return ''
        const seconds = Math.floor((Date.now() - date.getTime()) / 1000)
        if (seconds < 60) return 'الآن'
        if (seconds < 3600) return `قبل ${Math.floor(seconds / 60)} دقيقة`
        if (seconds < 86400) return `قبل ${Math.floor(seconds / 3600)} ساعة`
        if (seconds < 172800) return 'أمس'
        if (seconds < 604800) return `قبل ${Math.floor(seconds / 86400)} أيام`
        return `قبل ${Math.floor(seconds / 604800)} أسبوع`
      }

      async function loadJson(url, fallback) {
        try {
          const response = await fetch(`${url}?v=${Date.now()}`, { cache: 'no-store' })
          if (!response.ok) return fallback
          const data = await response.json()
          return data
        } catch (error) {
          console.warn(`Failed to load ${url}`, error)
          return fallback
        }
      }

      function renderProfile(baseUser) {
        const user = mergeUserData(baseUser)
        activeUser = user

        searchScreen.classList.add('hidden')
        notFoundScreen.classList.add('hidden')
        profileScreen.classList.remove('hidden')

        const color = /^#[0-9a-f]{6}$/i.test(user.backgroundColor || '') ? user.backgroundColor : '#6c5ce7'
        const banner = safeUrl(user.bannerImage)
        const avatar = safeUrl(user.profileImageUrl)

        const bg = $('profileBg')
        if (banner) {
          bg.style.background = ''
          bg.style.backgroundImage = `url('${banner}')`
        } else {
          bg.style.backgroundImage = ''
          bg.style.background = `linear-gradient(160deg, ${color}, #0b1015 70%)`
        }

        const av = $('pAvatar')
        av.style.setProperty('--pColor', color)
        av.style.backgroundImage = avatar ? `url('${avatar}')` : ''

        $('pName').textContent = userName(user) || userLogin(user) || '—'

        const country = getField(user, ['country'], '')
        const countryEl = $('pCountry')
        if (country) { countryEl.textContent = country; countryEl.classList.remove('hidden') } 
        else { countryEl.classList.add('hidden') }

        const bio = getField(user, ['bio'], '')
        const jobName = getField(user, ['jobName'], '')
        const login = userLogin(user)
        $('pBio').innerHTML = `${esc(bio || jobName || 'عضو في مجتمع TNX6')}${login ? `<br><span>TTV: ${esc(login)}</span>` : ''}`

        const explicitLevel = Number(getField(user, ['level'], 0))
        const points = Number(getField(user, ['points', 'totalPoints'], 0))
        const level = explicitLevel > 0 ? explicitLevel : Math.max(1, Math.floor(points / 100000) + 1)

        $('pLevel').textContent = fmt(level)
        $('pPoints').textContent = fmt(points)
        $('pGold').textContent = fmt(getField(user, ['gold'], 0))
        $('pRep').textContent = fmt(getField(user, ['reputation', 'rep', 'سمعة'], 0))

        const badgePageLink = $('badgePageLink')
        if (badgePageLink) badgePageLink.href = `/badges?user=${encodeURIComponent(login)}`

        renderInventory(user)
        renderBadges(user)
        renderAchievements(user)
        renderMailbox(user)
      }

      function renderInventory(user) {
        const inv = Array.isArray(user.inventory) ? user.inventory : []
        const grid = $('inventoryGrid')

        $('invCount').textContent = `${fmt(inv.length)} غرض`
        $('qlItems').textContent = fmt(inv.length)
        $('inventoryEmpty').classList.toggle('hidden', inv.length > 0)

        const shown = inv.slice(0, INV_LIMIT)
        const extra = inv.length - shown.length

        grid.innerHTML = shown.map((entry) => {
          const name = getItemName(entry)
          const amount = getItemAmount(entry)
          const meta = getMeta(name)
          const [cat, soft] = CAT_COLORS[meta.cat] || CAT_COLORS.economy
          const rare = meta.rare ? ' is-rare' : ''

          return `
            <div class="tnx-inv-item${rare}" style="--cat:${cat};--cat-soft:${soft};" title="${esc(name)} ×${amount}">
              <span>${esc(meta.icon)}</span>
              <span class="tnx-inv-amount">${fmt(amount)}</span>
            </div>
          `
        }).join('') + (extra > 0 ? `<div class="tnx-inv-more">+${fmt(extra)}</div>` : '')
      }

      function renderBadges(user) {
        const badges = Array.isArray(user.badges) ? user.badges : []
        const equipped = badges.filter((badge) => badge.equipped).slice(0, 6)
        const list = equipped.length ? equipped : badges.slice(0, 6)

        $('badgeCount').textContent = fmt(badges.length)
        $('qlBadges').textContent = fmt(badges.length)

        $('badgeShowcase').innerHTML = list.map((badge) => {
          const url = safeUrl(badge.url || badge.image || badge.badgeUrl)
          const name = badge.name || badge.badgeName || ''
          return url ? `<img src="${esc(url)}" alt="${esc(name)}" title="${esc(name)}" loading="lazy" />` : `<div class="tnx-badge-fallback" title="${esc(name)}">★</div>`
        }).join('') || '<div class="tnx-badge-fallback">—</div>'
      }

      function buildAutoAchievements(user) {
        const achievements = Array.isArray(user.achievements) ? [...user.achievements] : []
        const badges = Array.isArray(user.badges) ? user.badges : []
        const inv = Array.isArray(user.inventory) ? user.inventory : []
        const points = Number(getField(user, ['points', 'totalPoints'], 0))
        const gold = Number(getField(user, ['gold'], 0))

        if (badges.length >= 1) achievements.push({ icon: '🎖️', title: 'جامع بادجات', subtitle: `يمتلك ${fmt(badges.length)} بادج` })
        if (inv.length >= 1) achievements.push({ icon: '🎒', title: 'صاحب حقيبة', subtitle: `يمتلك ${fmt(inv.length)} نوع من الأغراض` })
        if (points >= 100000) achievements.push({ icon: '⭐', title: 'رصيد عالي', subtitle: `وصل إلى ${fmt(points)} نقطة` })
        if (gold >= 1000) achievements.push({ icon: '🪙', title: 'جامع ذهب', subtitle: `يمتلك ${fmt(gold)} ذهب` })

        return achievements.slice(0, 5)
      }

      function renderAchievements(user) {
        const achievements = buildAutoAchievements(user)
        const list = $('achievementsList')

        $('achCount').textContent = `${fmt(achievements.length)} إنجاز`
        $('qlAch').textContent = fmt(achievements.length)
        $('achievementsEmpty').classList.toggle('hidden', achievements.length > 0)

        list.innerHTML = achievements.map((item) => `
          <div class="tnx-ach-item">
            <div class="tnx-ach-icon">${esc(item.icon || '🏆')}</div>
            <div>
              <strong>${esc(item.title || item.name || '')}</strong>
              <span>${esc(item.subtitle || item.description || '')}</span>
            </div>
          </div>
        `).join('')
      }

      function renderMailbox(user) {
        mailState.user = user
        const mail = Array.isArray(user.mailbox) ? user.mailbox : []
        const unread = mail.filter((item) => !item.read)

        const countEl = $('mailCount')
        if (unread.length > 0) { countEl.textContent = fmt(unread.length); countEl.classList.remove('hidden') } 
        else { countEl.classList.add('hidden') }

        $('mailAllCount').textContent = fmt(mail.length)
        $('mailUnreadCount').textContent = fmt(unread.length)
        drawMailList()
      }

      function drawMailList() {
        const user = mailState.user
        if (!user) return

        let mail = Array.isArray(user.mailbox) ? [...user.mailbox] : []
        if (mailState.filter === 'unread') mail = mail.filter((item) => !item.read)

        mail.sort((a, b) => new Date(b.date) - new Date(a.date))

        $('mailList').innerHTML = mail.length ? mail.map((item) => {
          const from = String(item.from || item.fromLogin || '؟')
          const initial = from.charAt(0).toUpperCase()
          const unread = !item.read ? ' is-unread' : ''

          return `
            <div class="tnx-mail-item${unread}">
              <div class="tnx-mail-avatar">${esc(initial)}</div>
              <div class="tnx-mail-body">
                <div class="tnx-mail-top">
                  <span class="tnx-mail-from">${esc(from)}</span>
                  ${!item.read ? '<span class="tnx-mail-dot"></span>' : ''}
                  <span class="tnx-mail-date">${esc(timeAgo(item.date))}</span>
                </div>
                <div class="tnx-mail-text">${esc(item.message || '')}</div>
              </div>
            </div>
          `
        }).join('') : '<div class="tnx-inline-empty">ما فيه رسائل.</div>'
      }

      function findUser(login) {
        const target = normalize(login)
        return users.find((item) => normalize(userLogin(item)) === target || normalize(userName(item)) === target) || null
      }

      function getProfileLink(login) {
        const clean = String(login || '').replace(/[^a-zA-Z0-9_-]/g, '')
        return `${location.origin}${location.pathname}?user=${encodeURIComponent(clean)}`
      }

      function openFromQuery() {
        const param = new URLSearchParams(location.search).get('user')
        if (!param) { searchScreen.classList.remove('hidden'); return }

        const user = findUser(param)
        if (user) renderProfile(user)
        else notFoundScreen.classList.remove('hidden')
      }

      function renderResults(query) {
        const normalized = normalize(query)
        userResults.innerHTML = ''
        if (!normalized) return

        const matches = users
          .filter((item) => normalize(userName(item)).includes(normalized) || normalize(userLogin(item)).includes(normalized))
          .slice(0, 6)

        userResults.innerHTML = matches.map((item) => {
          const login = userLogin(item)
          const name = userName(item) || login
          return `<button type="button" class="tnx-user-result" data-login="${esc(login)}">${esc(name)}</button>`
        }).join('')
      }

      addListener(userSearch, 'input', () => renderResults(userSearch.value))

      addListener(clearUserSearch, 'click', () => {
        userSearch.value = ''; userResults.innerHTML = ''; userSearch.focus()
      })

      addListener(userResults, 'click', (event) => {
        const button = event.target.closest('[data-login]')
        if (!button) return
        const user = findUser(button.dataset.login)
        if (user) { history.replaceState(null, '', getProfileLink(userLogin(user))); renderProfile(user) }
      })

      addListener($('mailToggle'), 'click', () => $('mailboxSection').classList.toggle('hidden'))

      Array.from(document.querySelectorAll('[data-mail-filter]')).forEach((button) => {
        addListener(button, 'click', () => {
          mailState.filter = button.dataset.mailFilter
          document.querySelectorAll('[data-mail-filter]').forEach((item) => item.classList.toggle('is-active', item === button))
          drawMailList()
        })
      })

      addListener($('copyProfileLink'), 'click', async (event) => {
        const login = activeUser ? userLogin(activeUser) : ''
        if (!login) return
        try {
          await navigator.clipboard.writeText(getProfileLink(login))
          event.currentTarget.textContent = 'تم النسخ'
          event.currentTarget.classList.add('is-copied')
          addTimer(window.setTimeout(() => { event.currentTarget.textContent = 'نسخ الرابط'; event.currentTarget.classList.remove('is-copied') }, 1200))
        } catch { event.currentTarget.textContent = getProfileLink(login) }
      })

      Array.from(document.querySelectorAll('[data-jump]')).forEach((button) => {
        addListener(button, 'click', () => $(button.dataset.jump)?.scrollIntoView({ behavior: 'smooth', block: 'center' }))
      })

      addListener(backToTop, 'click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
      addListener(window, 'scroll', () => backToTop.classList.toggle('is-visible', window.scrollY > 400), { passive: true })

      users = await loadJson('/api/user_badges.json', [])
      inventories = await loadJson('/api/user_inventory.json', [])
      mailboxes = await loadJson('/api/user_mailbox.json', [])
      profileExtras = await loadJson('/api/user_profile.json', [])

      const itemsPayload = await loadJson('/api/items.json', { items: [] })
      itemCatalog = Array.isArray(itemsPayload) ? itemsPayload : Array.isArray(itemsPayload.items) ? itemsPayload.items : []

      if (!Array.isArray(users)) users = []
      if (!Array.isArray(inventories)) inventories = []
      if (!Array.isArray(mailboxes)) mailboxes = []
      if (!Array.isArray(profileExtras)) profileExtras = []

      openFromQuery()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
