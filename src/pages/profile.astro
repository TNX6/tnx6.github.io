---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'Profile — TNX6',
  ignoreTitleTemplate: true,
  description: 'Steam-style profile page for TNX6 community members.',
}
---

<Layout metadata={metadata}>
  <main class="steam-profile-page" dir="rtl">
    <div class="page-bg"></div>
    <div class="page-noise"></div>

    <section class="profile-shell">
      <header class="profile-top">
        <div>
          <div class="eyebrow">
            <span></span>
            TNX6 COMMUNITY PROFILE
          </div>

          <h1>بروفايل العضو</h1>

          <p>
            بطاقة شخصية للعضو تعرض الخلفية، الصورة، النقاط، الذهب، البادجات، والحقيبة.
          </p>
        </div>

        <div class="search-card">
          <div class="search-box">
            <span>⌕</span>
            <input id="profileSearch" type="search" autocomplete="off" placeholder="ابحث باسم المستخدم..." />
            <button id="clearProfileSearch" type="button" aria-label="مسح">×</button>
          </div>

          <div id="profileResults" class="profile-results"></div>
        </div>
      </header>

      <section id="emptyState" class="empty-state">
        <div class="empty-icon">⌁</div>
        <strong>ابحث عن عضو</strong>
        <span>مثال: <b>/profile?user=haneen48</b></span>
      </section>

      <section id="profileContent" class="profile-content hidden">
        <section id="steamCard" class="steam-card"></section>

        <div class="layout-grid">
          <main class="main-column">
            <section class="panel showcase-panel">
              <div class="panel-head">
                <div>
                  <span>FEATURED SHOWCASE</span>
                  <h2>واجهة العضو</h2>
                </div>
              </div>

              <div id="featuredShowcase" class="featured-showcase"></div>
            </section>

            <section class="panel">
              <div class="panel-head row">
                <div>
                  <span>INVENTORY</span>
                  <h2>الحقيبة</h2>
                </div>

                <div class="small-counter">
                  <strong id="inventoryTypeCount">0</strong>
                  <small>نوع</small>
                </div>
              </div>

              <div class="filter-strip" id="inventoryFilters">
                <button type="button" class="is-active" data-filter="all">الكل</button>
                <button type="button" data-filter="rare">نادر</button>
                <button type="button" data-filter="box">صناديق</button>
                <button type="button" data-filter="license">رخص</button>
                <button type="button" data-filter="resource">موارد</button>
                <button type="button" data-filter="usable">استخدام</button>
              </div>

              <div id="inventoryGrid" class="inventory-grid"></div>

              <div id="inventoryEmpty" class="mini-empty hidden">
                <strong>ما فيه أغراض ظاهرة</strong>
                <span>الحقيبة فاضية أو الفلتر الحالي ما طلع نتائج.</span>
              </div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <div>
                  <span>BADGE COLLECTION</span>
                  <h2>مجموعة البادجات</h2>
                </div>
              </div>

              <div id="badgeCollection" class="badge-collection"></div>
            </section>
          </main>

          <aside class="side-column">
            <section class="panel side-panel">
              <div class="panel-head">
                <div>
                  <span>PROFILE STATS</span>
                  <h2>الإحصائيات</h2>
                </div>
              </div>

              <div id="statsList" class="stats-list"></div>
            </section>

            <section class="panel side-panel">
              <div class="panel-head">
                <div>
                  <span>RAREST ITEMS</span>
                  <h2>أندر الأغراض</h2>
                </div>
              </div>

              <div id="rareList" class="rare-list"></div>
            </section>

            <section class="panel side-panel">
              <div class="panel-head">
                <div>
                  <span>ACTIONS</span>
                  <h2>روابط</h2>
                </div>
              </div>

              <div class="action-list">
                <a id="badgesLink" href="/badges">بطاقة البادجات</a>
                <button id="copyProfileLink" type="button">نسخ رابط البروفايل</button>
              </div>
            </section>
          </aside>
        </div>
      </section>
    </section>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.38) rgba(0, 0, 0, 0.3);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.35);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.35);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.78), rgba(194, 146, 0, 0.5));
    }

    .hidden {
      display: none !important;
    }

    .steam-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: #fff;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 16% 12%, rgba(255, 218, 106, 0.16), transparent 30%),
        radial-gradient(circle at 85% 10%, rgba(124, 58, 237, 0.14), transparent 30%),
        radial-gradient(circle at 52% 90%, rgba(194, 146, 0, 0.14), transparent 36%),
        linear-gradient(135deg, #07050b 0%, #0a0b10 46%, #130c05 100%);
      animation: bgBreathe 10s ease-in-out infinite;
    }

    @keyframes bgBreathe {
      0%, 100% { transform: scale(1); filter: brightness(1) saturate(1); }
      50% { transform: scale(1.018); filter: brightness(1.06) saturate(1.12); }
    }

    .page-noise {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.07;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.45) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.45) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 72%);
    }

    .profile-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1280px);
      margin: 0 auto;
      padding: 6.25rem 1rem 5rem;
    }

    .profile-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(330px, 440px);
      gap: 1rem;
      align-items: end;
      margin-bottom: 1rem;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.38);
      color: #ffda6a;
      padding: 0.55rem 0.9rem;
      font-size: 0.74rem;
      font-weight: 950;
      letter-spacing: 0.16em;
      backdrop-filter: blur(14px);
    }

    .eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
    }

    .profile-top h1 {
      margin: 0.9rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 42%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3rem, 7vw, 6.5rem);
      font-weight: 950;
      line-height: 0.92;
      letter-spacing: -0.055em;
    }

    .profile-top p {
      max-width: 680px;
      margin: 1rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 1rem;
      font-weight: 780;
      line-height: 1.8;
    }

    .search-card {
      position: relative;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1.4rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.08), transparent 42%),
        rgba(7, 5, 11, 0.76);
      padding: 0.85rem;
      box-shadow: 0 22px 58px rgba(0, 0, 0, 0.36);
      backdrop-filter: blur(16px);
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.7rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.75rem;
    }

    .search-box span {
      color: #ffda6a;
      font-size: 1.3rem;
      font-weight: 950;
    }

    .search-box input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: 0.95rem;
      font-weight: 850;
    }

    .search-box button {
      display: grid;
      place-items: center;
      width: 2rem;
      height: 2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
      cursor: pointer;
    }

    .profile-results {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.65rem;
    }

    .profile-result {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.34);
      padding: 0.68rem;
      color: white;
      text-align: right;
      cursor: pointer;
      transition: 180ms ease;
    }

    .profile-result:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 218, 106, 0.48);
      background: rgba(255, 218, 106, 0.08);
    }

    .profile-result img {
      width: 42px;
      height: 42px;
      border-radius: 0.85rem;
      object-fit: cover;
      border: 1px solid rgba(255, 218, 106, 0.28);
    }

    .profile-result strong {
      display: block;
      color: #f7e6ac;
      font-size: 0.92rem;
      font-weight: 950;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .profile-result span {
      display: block;
      margin-top: 0.14rem;
      color: rgb(156, 163, 175);
      font-size: 0.72rem;
      font-weight: 850;
      direction: ltr;
      text-align: right;
    }

    .empty-state,
    .mini-empty {
      display: grid;
      place-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.6rem;
      background:
        radial-gradient(circle at top, rgba(255, 218, 106, 0.08), transparent 44%),
        rgba(7, 5, 11, 0.76);
      padding: 2rem;
      min-height: 230px;
      text-align: center;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      backdrop-filter: blur(16px);
    }

    .mini-empty {
      min-height: 170px;
      margin-top: 0.85rem;
    }

    .empty-icon {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 4rem;
      border-radius: 1.25rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      background: rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1.8rem;
      font-weight: 950;
      margin-bottom: 0.35rem;
    }

    .empty-state strong,
    .mini-empty strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .empty-state span,
    .mini-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
      font-weight: 800;
      line-height: 1.7;
    }

    .empty-state b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .profile-content {
      display: grid;
      gap: 1rem;
    }

    .steam-card {
      position: relative;
      min-height: 430px;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 2rem;
      background: rgba(7, 5, 11, 0.76);
      box-shadow:
        0 30px 90px rgba(0, 0, 0, 0.54),
        inset 0 0 34px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(18px);
    }

    .steam-cover {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      transform: scale(1.02);
      filter: saturate(1.06) contrast(1.04);
    }

    .steam-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom, rgba(0, 0, 0, 0.18), rgba(7, 5, 11, 0.92) 72%, rgba(7, 5, 11, 0.98)),
        radial-gradient(circle at 18% 28%, rgba(var(--accent-rgb), 0.28), transparent 38%),
        radial-gradient(circle at 82% 18%, rgba(255, 218, 106, 0.12), transparent 38%);
    }

    .steam-profile-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 190px minmax(0, 1fr) 280px;
      gap: 1.2rem;
      align-items: end;
      min-height: 430px;
      padding: 1.35rem;
    }

    .avatar-block {
      display: grid;
      justify-items: center;
      gap: 0.8rem;
    }

    .avatar-frame {
      position: relative;
      width: 170px;
      height: 170px;
      border-radius: 1.55rem;
      padding: 6px;
      background:
        linear-gradient(135deg, rgba(255, 218, 106, 0.95), rgba(var(--accent-rgb), 0.98), rgba(255, 255, 255, 0.22));
      box-shadow:
        0 24px 46px rgba(0, 0, 0, 0.48),
        0 0 26px rgba(var(--accent-rgb), 0.28);
    }

    .avatar-frame img {
      width: 100%;
      height: 100%;
      border-radius: 1.22rem;
      object-fit: cover;
      display: block;
      background: #111;
    }

    .online-dot {
      position: absolute;
      right: 0.65rem;
      bottom: 0.65rem;
      width: 1rem;
      height: 1rem;
      border: 3px solid #101014;
      border-radius: 999px;
      background: #34d399;
      box-shadow: 0 0 14px rgba(52, 211, 153, 0.75);
    }

    .level-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 5.4rem;
      border: 1px solid rgba(255, 218, 106, 0.26);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.55);
      color: #ffda6a;
      padding: 0.55rem 0.75rem;
      font-size: 0.82rem;
      font-weight: 950;
      direction: ltr;
      backdrop-filter: blur(12px);
    }

    .profile-identity {
      min-width: 0;
      padding-bottom: 0.25rem;
    }

    .profile-identity h2 {
      margin: 0;
      color: #fff;
      font-size: clamp(2.4rem, 5vw, 5rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.045em;
      text-shadow: 0 5px 20px rgba(0, 0, 0, 0.75);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .profile-login {
      margin: 0.65rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 0.94rem;
      font-weight: 850;
      direction: ltr;
      text-align: right;
    }

    .job-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin-top: 0.9rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.45);
      color: #f7e6ac;
      padding: 0.62rem 0.85rem;
      font-size: 0.86rem;
      font-weight: 950;
      backdrop-filter: blur(12px);
    }

    .job-pill iconify-icon {
      color: #ffda6a;
      font-size: 1.22rem;
    }

    .mini-showcase {
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin-top: 1rem;
    }

    .mini-badge {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 0.85rem;
      background: rgba(0, 0, 0, 0.42);
      backdrop-filter: blur(10px);
    }

    .mini-badge img {
      width: 36px;
      height: 36px;
      object-fit: contain;
      filter: drop-shadow(0 7px 12px rgba(0, 0, 0, 0.5));
    }

    .profile-wallet {
      display: grid;
      gap: 0.75rem;
      align-self: end;
    }

    .wallet-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.2rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 44%),
        rgba(0, 0, 0, 0.48);
      padding: 1rem;
      backdrop-filter: blur(14px);
    }

    .wallet-card span {
      display: block;
      color: rgb(156, 163, 175);
      font-size: 0.75rem;
      font-weight: 900;
    }

    .wallet-card strong {
      display: block;
      margin-top: 0.35rem;
      color: #ffda6a;
      font-size: 1.7rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
      text-shadow: 0 0 14px rgba(255, 218, 106, 0.28);
    }

    .layout-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
    }

    .main-column,
    .side-column {
      display: grid;
      gap: 1rem;
    }

    .panel {
      border: 1px solid rgba(255, 218, 106, 0.17);
      border-radius: 1.55rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)),
        rgba(7, 5, 11, 0.78);
      box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.38),
        inset 0 0 22px rgba(255, 218, 106, 0.022);
      padding: 1.05rem;
      backdrop-filter: blur(16px);
    }

    .panel-head {
      margin-bottom: 1rem;
    }

    .panel-head.row {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
    }

    .panel-head span {
      display: block;
      color: #c29200;
      font-size: 0.72rem;
      font-weight: 950;
      letter-spacing: 0.13em;
    }

    .panel-head h2 {
      margin: 0.3rem 0 0;
      color: #f7e6ac;
      font-size: 1.5rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .small-counter {
      display: grid;
      place-items: center;
      min-width: 82px;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background: rgba(255, 218, 106, 0.06);
      padding: 0.65rem;
    }

    .small-counter strong {
      color: #ffda6a;
      font-size: 1.25rem;
      font-weight: 950;
      line-height: 1;
    }

    .small-counter small {
      color: rgb(156, 163, 175);
      font-size: 0.68rem;
      font-weight: 850;
      margin-top: 0.25rem;
    }

    .featured-showcase {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 0.85rem;
    }

    .big-feature-card,
    .showcase-stack {
      min-height: 230px;
    }

    .big-feature-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 1.25rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.13), transparent 46%),
        rgba(0, 0, 0, 0.36);
      padding: 1rem;
    }

    .big-feature-icon {
      display: grid;
      place-items: center;
      width: 4.8rem;
      height: 4.8rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 1.35rem;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 2.2rem;
      margin-bottom: 1rem;
    }

    .big-feature-card h3 {
      margin: 0;
      color: white;
      font-size: 1.55rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .big-feature-card p {
      margin: 0.6rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .big-feature-card strong {
      display: inline-flex;
      margin-top: 0.9rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.36);
      color: #ffda6a;
      padding: 0.45rem 0.6rem;
      font-size: 0.8rem;
      font-weight: 950;
      direction: ltr;
    }

    .showcase-stack {
      display: grid;
      gap: 0.65rem;
    }

    .showcase-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      border: 1px solid rgba(255, 218, 106, 0.13);
      border-radius: 1.05rem;
      background: rgba(0, 0, 0, 0.3);
      padding: 0.75rem;
    }

    .showcase-row div {
      min-width: 0;
    }

    .showcase-row strong {
      display: block;
      color: #f7e6ac;
      font-size: 0.9rem;
      font-weight: 950;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .showcase-row span {
      display: block;
      color: rgb(156, 163, 175);
      font-size: 0.72rem;
      font-weight: 800;
      margin-top: 0.2rem;
    }

    .showcase-row b {
      display: grid;
      place-items: center;
      min-width: 2.6rem;
      height: 2.4rem;
      border-radius: 0.8rem;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 0.8rem;
      font-weight: 950;
      direction: ltr;
    }

    .filter-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 0.95rem;
    }

    .filter-strip button {
      border: 1px solid rgba(255, 218, 106, 0.2);
