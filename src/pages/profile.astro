    .skeleton-head {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 0 28px 28px;
      margin-top: -52px;
    }

    .skeleton-avatar {
      width: 118px;
      height: 118px;
      border-radius: 28px;
      border: 4px solid rgba(8,8,8,.96);
      background: rgba(255,255,255,.08);
      flex: 0 0 auto;
    }

    .skeleton-lines {
      width: min(100%, 560px);
      display: grid;
      gap: 12px;
      padding-top: 54px;
    }

    .skeleton-line {
      height: 16px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
    }

    .skeleton-name {
      width: 46%;
      height: 28px;
    }

    .skeleton-handle {
      width: 26%;
    }

    .skeleton-bio {
      width: 72%;
    }

    .skeleton-grid {
      display: grid;
      grid-template-columns: 1.35fr .65fr;
      gap: 18px;
      padding: 0 28px 28px;
    }

    .skeleton-card {
      min-height: 150px;
      border-radius: 24px;
      background: rgba(255,255,255,.055);
      border: 1px solid rgba(255,255,255,.055);
    }

    .skeleton-card:first-child {
      min-height: 210px;
    }

    .skeleton-card:nth-child(3) {
      grid-column: 1 / -1;
      min-height: 110px;
    }

    .skeleton-pulse {
      position: relative;
      overflow: hidden;
    }

    .skeleton-pulse::after {
      content: "";
      position: absolute;
      inset: 0;
      transform: translateX(100%);
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.10), transparent);
      animation: skeletonPulse 1.35s infinite;
    }

    @keyframes skeletonPulse {
      100% {
        transform: translateX(-100%);
      }
    }

    @keyframes modalSoftSlideIn {
      from {
        opacity: 0;
        transform: translateY(18px) scale(.985);
        filter: blur(5px);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    }

    @keyframes modalBackdropFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    #mailModal:not(.hidden),
    .mail-modal:not(.hidden),
    .item-modal:not(.hidden),
    [data-item-modal]:not(.hidden),
    [data-modal]:not(.hidden) {
