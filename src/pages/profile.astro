      height: 3rem;
      border: 1px solid rgba(255,223,138,.32);
      border-radius: 999px;
      background: rgba(8,8,12,.88);
      color: var(--gold2);
      font-size: 1.15rem;
      font-weight: 950;
      cursor: pointer;
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: 160ms ease;
      backdrop-filter: blur(12px);
    }

    .back-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (max-width: 940px) {
      .profile-head {
        grid-template-columns: 1fr;
        align-items: center;
        text-align: center;
      }

      .avatar-wrap {
        margin: 0 auto;
      }

      .chips,
      .name-row {
        justify-content: center;
      }

      .mail-area {
        justify-content: center;
      }

      .content {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .profile-page,
      .profile-search {
        width: min(100% - 18px, 1180px);
        margin: 10px auto;
      }

      .cover {
        padding: 18px;
        min-height: 380px;
      }

      .content {
        padding: 14px;
      }

      .inventory {
        grid-template-columns: 1fr;
      }

      .badges {
        grid-template-columns: repeat(3, 1fr);
      }

      .level-main {
        flex-direction: row;
        align-items: flex-start;
        text-align: right;
        direction: rtl;
      }

      .level-info h2 {
        text-align: right;
      }

      .level-badge {
        flex-basis: 108px;
        width: 108px;
        height: 108px;
        margin: 0;
      }

      .xp-breakdown,
      .item-actions {
        grid-template-columns: 1fr;
      }
    }

    .twitch-login-btn {
      width: min(100%, 360px);
      margin: 26px auto 0;
      min-height: 58px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border-radius: 18px;
      border: 1px solid rgba(145, 70, 255, .55);
      background:
        radial-gradient(circle at 30% 0%, rgba(255,255,255,.20), transparent 34%),
        linear-gradient(135deg, #9146ff, #5f22c8);
      color: #fff;
      font-weight: 950;
      letter-spacing: -.02em;
      box-shadow: 0 18px 50px rgba(145, 70, 255, .22);
      transition: transform .18s ease, filter .18s ease, border-color .18s ease;
    }

    .twitch-login-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
      border-color: rgba(255,255,255,.42);
    }

    .twitch-icon {
      width: 30px;
      height: 30px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: rgba(255,255,255,.16);
      border: 1px solid rgba(255,255,255,.14);
      font-size: 17px;
    }

    .login-note {
      margin: 14px auto 0 !important;
      max-width: 520px;
      color: rgba(255,255,255,.48) !important;
      font-size: .92rem;
      line-height: 1.8;
    }


    /* Login prompt design */
    .profile-search {
      position: relative;
      isolation: isolate;
      min-height: 72vh;
      overflow: hidden;
    }

    .profile-search .profile-login-card {
      width: min(100%, 620px);
      margin-inline: auto;
      padding: 48px 32px;
      border-radius: 28px;
      text-align: center;
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)),
        rgba(20, 20, 25, .72);
      border: 1px solid rgba(255, 255, 255, .085);
      box-shadow:
        0 26px 60px rgba(0, 0, 0, .48),
        inset 0 1px 0 rgba(255,255,255,.06);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      overflow: hidden;
    }

    .profile-search .profile-login-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.28), transparent);
      pointer-events: none;
    }

    .profile-search .eyebrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
      padding: 7px 17px;
      border-radius: 999px;
      border: 1px solid rgba(215, 168, 79, .32);
      background: rgba(215, 168, 79, .07);
      color: #d7a84f;
      font-size: .74rem;
      font-weight: 950;
      letter-spacing: .12em;
      text-transform: uppercase;
      box-shadow: 0 0 22px rgba(215, 168, 79, .10);
    }

    .profile-search .profile-login-card h1 {
      margin: 0 0 14px;
      font-size: clamp(2.15rem, 6vw, 4.2rem);
      line-height: 1.05;
      font-weight: 950;
      letter-spacing: -.06em;
      color: #fff;
      background: linear-gradient(180deg, #fff 0%, #d7d7d7 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 18px 42px rgba(0,0,0,.34);
    }

    .login-description {
      max-width: 520px;
      margin: 0 auto 30px !important;
      color: rgba(255,255,255,.60) !important;
      font-size: 1.02rem;
      line-height: 1.9;
      font-weight: 750;
    }

    .twitch-login-btn {
      width: min(100%, 380px);
      min-height: 58px;
      margin: 0 auto;
      padding: 15px 24px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      border-radius: 17px;
      border: 0;
      background: linear-gradient(135deg, #a970ff 0%, #9146ff 52%, #772ce8 100%);
      color: #fff;
      font-size: 1.06rem;
      font-weight: 950;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      box-shadow:
        0 14px 34px rgba(145, 70, 255, .34),
        inset 0 0 0 1px rgba(255,255,255,.12);
      transition: transform .2s ease, filter .2s ease, box-shadow .2s ease;
    }

    .twitch-login-btn::after {
      content: "";
      position: absolute;
      top: 0;
      right: -120%;
      width: 90%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
      transform: skewX(-18deg);
      transition: right .55s ease;
    }

    .twitch-login-btn:hover {
      transform: translateY(-3px);
      filter: brightness(1.08);
      box-shadow:
        0 22px 44px rgba(145, 70, 255, .44),
        inset 0 0 0 1px rgba(255,255,255,.18);
    }

    .twitch-login-btn:hover::after {
      right: 130%;
    }

    .twitch-login-btn:active {
      transform: translateY(-1px);
    }

    .twitch-icon {
      width: 31px;
      height: 31px;
      display: grid;
      place-items: center;
      border-radius: 11px;
      background: rgba(255,255,255,.16);
      border: 1px solid rgba(255,255,255,.14);
      flex: 0 0 auto;
    }

    .twitch-icon svg {
      width: 19px;
      height: 19px;
      fill: #fff;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,.22));
    }

    .login-note {
      max-width: 500px;
      margin: 22px auto 0 !important;
      color: rgba(255,255,255,.46) !important;
      font-size: .9rem;
      line-height: 1.8;
      font-weight: 650;
    }

    .login-glow-orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(72px);
      opacity: .34;
      z-index: -1;
      pointer-events: none;
      animation: loginFloat 10s infinite ease-in-out;
    }

    .login-orb-1 {
      width: 280px;
      height: 280px;
      background: #9146ff;
      top: 40px;
      left: calc(50% - 430px);
    }

    .login-orb-2 {
      width: 240px;
      height: 240px;
      background: #d7a84f;
      bottom: 60px;
      right: calc(50% - 420px);
      animation-delay: 2s;
    }

    @keyframes loginFloat {
      0%, 100% { transform: translate3d(0, 0, 0); }
      50% { transform: translate3d(18px, 26px, 0); }
    }

    @media (max-width: 560px) {
      .profile-search .profile-login-card {
        padding: 36px 20px;
        border-radius: 24px;
      }

      .login-description {
        font-size: .95rem;
      }

      .twitch-login-btn {
        min-height: 56px;
        font-size: 1rem;
      }
    }


    /* Fix Arabic title clipping */
    .profile-search .profile-login-card h1 {
      line-height: 1.22 !important;
      padding-bottom: .14em;
      margin-bottom: 8px;
      overflow: visible;
    }


    /* Smooth login background glow without clipped orbs */
    .profile-search {
      overflow: visible !important;
    }

    .login-glow-orb,
    .login-orb-1,
    .login-orb-2 {
      display: none !important;
    }

    .profile-search::before {
      content: "";
      position: fixed;
      inset: -20%;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 22%, rgba(145, 70, 255, .16), transparent 34%),
        radial-gradient(circle at 78% 82%, rgba(215, 168, 79, .13), transparent 36%);
      filter: blur(18px);
      opacity: .9;
    }

    .profile-search::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 38px 38px;
      mask-image: radial-gradient(circle at center, black, transparent 75%);
      opacity: .45;
    }


    /* Profile polish: skeleton, smooth modals, legendary glow */
    .profile-skeleton {
      width: min(100% - 32px, 1180px);
      margin: 26px auto;
      position: relative;
      z-index: 1;
    }

    .profile-skeleton.is-hidden {
      display: none !important;
    }

    .skeleton-shell {
      overflow: hidden;
      border-radius: 32px;
      border: 1px solid rgba(255,255,255,.08);
      background:
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018)),
        rgba(12,12,15,.72);
      box-shadow: 0 24px 70px rgba(0,0,0,.38);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .skeleton-cover {
      height: 190px;
      background:
        radial-gradient(circle at 18% 20%, rgba(255,223,138,.16), transparent 38%),
        radial-gradient(circle at 82% 80%, rgba(145,70,255,.14), transparent 42%),
        linear-gradient(135deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
      border-bottom: 1px solid rgba(255,255,255,.06);
