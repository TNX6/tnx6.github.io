---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'TNX6 community member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <section id="loadingView" class="profile-loading">
      <div class="loading-card">
        <div class="spinner" aria-hidden="true"></div>
        <span>جاري تحميل البيانات...</span>
      </div>
    </section>

    <section id="searchView" class="profile-search hidden">
      <div class="search-card">
        <span class="eyebrow">TNX6 PROFILE</span>
        <h1>بروفايل العضو</h1>
        <p>ابحث باسم Twitch أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

        <div class="search-box">
          <span>⌕</span>
          <input id="searchInput" type="search" autocomplete="off" role="combobox"
                 aria-expanded="false" aria-controls="searchResults" aria-autocomplete="list"
                 placeholder="اكتب اسم المستخدم..." />
          <button id="clearSearch" type="button" aria-label="مسح البحث">×</button>
        </div>

        <div id="searchResults" class="search-results" role="listbox"></div>
      </div>
    </section>

    <section id="notFoundView" class="not-found hidden">
      <strong>ما لقيت العضو</strong>
      <span>تأكد من الاسم أو من ملفات الـ API.</span>
    </section>

    <section id="profileView" class="profile-page hidden">
      <section class="profile-shell">
        <div class="cover" id="cover">
          <div class="profile-head">
            <div class="avatar-wrap">
              <div class="avatar-ring"></div>
              <img class="avatar" id="avatar" alt="Profile Avatar" />
              <span class="online-dot" id="onlineDot"></span>
            </div>

            <div class="identity">
              <div class="name-row">
                <h1 class="display-name" id="displayName">---</h1>
                <span class="handle" id="handle">---</span>
              </div>

              <p class="bio" id="bio">---</p>

              <div class="chips" id="chips"></div>
            </div>

            <div class="mail-area">
              <button class="mail-btn" type="button" id="openMailButton">
                البريد
                <span class="mail-count" id="mailCount">0</span>
              </button>
            </div>
          </div>
        </div>

        <div class="content">
          <div class="main-stack">
            <section class="card level-card">
              <div class="level-main">
                <div class="level-badge">
                  <div>
                    <span>LEVEL</span>
                    <strong id="levelNumber">1</strong>
                  </div>
                </div>

                <div class="level-info">
                  <h2 id="levelTitle">عضو جديد</h2>
                  <p id="levelDesc">كل تفاعل يرفع مستواك داخل المجتمع.</p>

                  <div class="xp-bar">
                    <div class="xp-fill" id="xpFill"></div>
                  </div>

                  <div class="xp-text">
                    <span id="currentXp">0</span>
                    <span id="neededXp">0</span>
                  </div>
                </div>
              </div>

              <div class="stats-grid" id="statsGrid"></div>
            </section>

            <section class="card">
              <div class="card-header">
                <h2 class="card-title">الحقيبة</h2>
                <span class="card-subtitle" id="inventoryCount">0 غرض</span>
              </div>

              <div class="inventory" id="inventory"></div>
            </section>
          </div>

          <aside class="side-stack">
            <section class="card">
              <div class="card-header">
                <h2 class="card-title">البادجات</h2>
                <span class="card-subtitle" id="badgesCount">0 مفتوحة</span>
              </div>

              <div class="badges" id="badges"></div>
            </section>

            <section class="card rank-card">
              <div class="card-header rank-header">
                <h2 class="card-title">ملخص العضو</h2>
                <span class="card-subtitle">Profile Summary</span>
              </div>

              <div class="rank-row">
                <span class="rank-label">رتبة الليفل</span>
                <span class="rank-value" id="rank">---</span>
              </div>

              <div class="rank-row">
                <span class="rank-label">عدد الرسائل</span>
                <span class="rank-value" id="messages">---</span>
              </div>

              <div class="rank-row">
                <span class="rank-label">تسجيل الدخول اليومي</span>
                <span class="rank-value" id="checkins">---</span>
              </div>

              <div class="rank-row">
                <span class="rank-label">النقاط</span>
                <span class="rank-value" id="points">---</span>
              </div>

              <div class="rank-row">
                <span class="rank-label">الذهب</span>
                <span class="rank-value" id="gold">---</span>
              </div>
            </section>
          </aside>
        </div>
      </section>

      <section class="actions-row">
        <a id="badgesPageLink" href="/badges">فتح بطاقة البادجات</a>
        <button id="copyLink" type="button">نسخ رابط البروفايل</button>
      </section>
    </section>

    <div class="modal-backdrop" id="mailModal" aria-hidden="true">
      <div class="mail-modal">
        <div class="modal-head">
          <h3>البريد</h3>
          <button class="close-btn" type="button" id="closeMailButton">×</button>
        </div>

        <div class="mail-list" id="mailList"></div>
      </div>
    </div>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    :root {
      --bg: #070707;
      --panel: rgba(18, 18, 20, 0.78);
      --panel2: rgba(255, 255, 255, 0.055);
      --line: rgba(255, 215, 130, 0.18);
      --gold: #d7a84f;
      --gold2: #ffdf8a;
      --text: #f4f0e8;
      --muted: rgba(244, 240, 232, 0.62);
      --danger: #ff5d5d;
      --green: #7CFFB2;
      --shadow: 0 28px 90px rgba(0, 0, 0, 0.62);
      --radius: 28px;
      --cover-image: radial-gradient(circle at 50% 20%, rgba(255,223,138,.24), transparent 35%),
                     linear-gradient(135deg, #1a1208, #080808 58%, #1d160b);
    }

    .hidden {
      display: none !important;
    }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .55) rgba(0, 0, 0, .48);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.48); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.48);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.95), rgba(194,146,0,.6));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 70% 10%, rgba(215, 168, 79, 0.15), transparent 34%),
        radial-gradient(circle at 20% 80%, rgba(255, 223, 138, 0.09), transparent 40%),
        linear-gradient(145deg, #030303, #0b0b0e 60%, #030303);
      color: var(--text);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Tahoma, Arial, sans-serif;
    }

    .tnx-profile-page::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size: 46px 46px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,.9), transparent 90%);
      pointer-events: none;
      z-index: 0;
    }

    /* ---- Loading state ---- */
    .profile-loading {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      min-height: 60vh;
      margin: 34px auto;
      display: grid;
      place-items: center;
    }

    .loading-card {
      display: grid;
      gap: 1.1rem;
      place-items: center;
      color: var(--muted);
      font-weight: 850;
      font-size: .95rem;
    }

    .spinner {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: 4px solid rgba(255, 223, 138, .14);
      border-top-color: var(--gold2);
      animation: tnx-spin .9s linear infinite;
    }

    @keyframes tnx-spin {
      to { transform: rotate(360deg); }
    }

    @media (prefers-reduced-motion: reduce) {
      .spinner { animation-duration: 2.2s; }
    }

    .profile-search {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      min-height: 78vh;
      margin: 34px auto;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 620px);
      border: 1px solid var(--line);
      border-radius: calc(var(--radius) + 8px);
      background:
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025)),
        rgba(10, 10, 12, 0.78);
      box-shadow: var(--shadow);
      padding: 2rem;
      text-align: center;
      backdrop-filter: blur(18px);
    }

    .eyebrow {
      display: inline-flex;
      border: 1px solid rgba(255,223,138,.28);
      border-radius: 999px;
      background: rgba(215,168,79,.1);
      color: var(--gold2);
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: var(--muted);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: var(--gold2);
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,223,138,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.34);
      padding: .85rem;
    }

    .search-box span {
      color: var(--gold2);
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,223,138,.2);
      border-radius: 999px;
      background: rgba(215,168,79,.1);
      color: var(--gold2);
      font-size: 1.12rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,223,138,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: var(--gold2);
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover,
    .search-result.is-active {
      transform: translateY(-1px);
      border-color: rgba(255,223,138,.45);
      background: rgba(215,168,79,.1);
    }

    .search-result.is-active {
      outline: 2px solid rgba(255,223,138,.3);
      outline-offset: 1px;
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      position: relative;
      z-index: 1;
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
      margin: 34px auto;
    }

    .not-found strong {
      color: var(--gold2);
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: var(--muted);
      font-size: .9rem;
    }

    .profile-page {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100% - 32px));
      margin: 34px auto;
    }

    .profile-shell {
      border: 1px solid var(--line);
      border-radius: calc(var(--radius) + 8px);
      background:
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.025)),
        rgba(10, 10, 12, 0.72);
      box-shadow: var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(18px);
    }

    .cover {
      min-height: 330px;
      position: relative;
      background:
        linear-gradient(to top, rgba(7,7,7,1), rgba(7,7,7,.15) 55%, rgba(7,7,7,.35)),
        var(--cover-image),
        radial-gradient(circle at center, #292014, #070707 65%);
      background-size: cover;
      background-position: center;
      padding: 28px;
      display: flex;
      align-items: flex-end;
    }

    .cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(0,0,0,.72), transparent 50%, rgba(0,0,0,.32)),
        radial-gradient(circle at 50% 100%, rgba(215,168,79,.16), transparent 35%);
      pointer-events: none;
    }

    .profile-head {
      position: relative;
      z-index: 2;
      width: 100%;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 22px;
      align-items: end;
    }

    .avatar-wrap {
      width: 148px;
      height: 148px;
      position: relative;
      flex: none;
    }

    .avatar-ring {
      position: absolute;
      inset: -5px;
      border-radius: 34px;
      background: conic-gradient(from 160deg, #5d4219, #ffdf8a, #9c6b20, #ffdf8a, #5d4219);
      box-shadow: 0 0 38px rgba(215,168,79,.28);
    }

    .avatar {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 30px;
      object-fit: cover;
      border: 4px solid #090909;
      background: #111;
      display: block;
    }

    .online-dot {
      position: absolute;
      bottom: 7px;
      left: 7px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--green);
      border: 4px solid #080808;
      box-shadow: 0 0 18px rgba(124, 255, 178, .75);
    }

    .identity {
      min-width: 0;
    }

    .name-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .display-name {
      margin: 0;
      font-size: clamp(32px, 5vw, 56px);
      line-height: 1;
      letter-spacing: -1.5px;
      font-weight: 900;
      text-shadow: 0 18px 40px rgba(0,0,0,.75);
      word-break: break-word;
    }

    .handle {
      color: var(--gold2);
      font-size: 15px;
      font-weight: 800;
      padding: 7px 12px;
      border: 1px solid rgba(255,223,138,.25);
      border-radius: 999px;
      background: rgba(0,0,0,.36);
      direction: ltr;
    }

    .bio {
      margin: 0;
      max-width: 680px;
      color: rgba(244,240,232,.76);
      font-size: 16px;
      line-height: 1.8;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
      margin-top: 16px;
    }

    .chip {
      padding: 9px 13px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.065);
      color: rgba(255,255,255,.82);
      font-weight: 750;
      font-size: 13px;
    }

    .chip.gold {
      border-color: rgba(255, 223, 138, .34);
      background: rgba(215,168,79,.12);
      color: var(--gold2);
    }

    .mail-area {
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
    }

    .mail-btn {
      appearance: none;
      border: 0;
      cursor: pointer;
      border-radius: 18px;
      padding: 15px 18px;
      min-width: 150px;
      color: #15100a;
      background: linear-gradient(135deg, var(--gold2), var(--gold));
      font-size: 16px;
      font-weight: 950;
      box-shadow: 0 18px 38px rgba(215,168,79,.2);
      transition: transform .18s ease, filter .18s ease;
      position: relative;
    }

    .mail-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.06);
    }

    .mail-count {
      position: absolute;
      top: -9px;
      right: -9px;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--danger);
      color: white;
      display: grid;
      place-items: center;
      border: 3px solid #080808;
      font-size: 13px;
      font-weight: 950;
    }

    .content {
      padding: 26px;
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 20px;
    }

    .main-stack,
    .side-stack {
      display: grid;
      gap: 20px;
      align-content: start;
    }

    .card {
      border: 1px solid rgba(255,255,255,.09);
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.065), rgba(255,255,255,.028)),
        rgba(12,12,14,.76);
      box-shadow: 0 20px 55px rgba(0,0,0,.28);
      overflow: hidden;
    }

    .card-header {
      padding: 20px 20px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .rank-header {
      padding: 0 0 10px;
    }

    .card-title {
      margin: 0;
      font-size: 20px;
      font-weight: 950;
      letter-spacing: -.4px;
    }

    .card-subtitle {
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .level-card {
      padding: 20px;
    }

    .level-main {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 18px;
      align-items: center;
    }

    .level-badge {
      width: 116px;
      height: 116px;
      border-radius: 28px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 20%, rgba(255,223,138,.45), transparent 34%),
        linear-gradient(145deg, #251908, #0f0d0a);
      border: 1px solid rgba(255,223,138,.28);
      box-shadow: inset 0 0 30px rgba(255,223,138,.08), 0 20px 55px rgba(0,0,0,.35);
    }

    .level-badge span {
      display: block;
      font-size: 12px;
      color: var(--muted);
      font-weight: 800;
      text-align: center;
      margin-bottom: 4px;
    }

    .level-badge strong {
      display: block;
      font-size: 48px;
      line-height: .9;
      color: var(--gold2);
      font-weight: 1000;
      text-align: center;
    }

    .level-info h2 {
      margin: 0 0 8px;
      font-size: 25px;
      font-weight: 950;
    }

    .level-info p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }

    .xp-bar {
      height: 18px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.08);
      position: relative;
    }

    .xp-fill {
      height: 100%;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(90deg, #8d5e1f, #ffdf8a);
      box-shadow: 0 0 26px rgba(255,223,138,.35);
      transition: width .8s ease;
    }

    .xp-text {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      color: rgba(244,240,232,.72);
      font-size: 13px;
      font-weight: 800;
    }

    .stats-grid {
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 10px;
    }

    .stat {
      padding: 15px;
      border-radius: 20px;
      background: rgba(255,255,255,.052);
      border: 1px solid rgba(255,255,255,.075);
    }

    .stat span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 7px;
    }

    .stat strong {
      display: block;
      font-size: 21px;
      font-weight: 1000;
      color: #fff;
      direction: ltr;
      text-align: right;
    }

    .inventory {
      padding: 18px 20px 20px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .item {
      min-height: 92px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 13px;
      align-items: center;
      padding: 14px;
      border-radius: 22px;
      background: rgba(255,255,255,.045);
      border: 1px solid rgba(255,255,255,.075);
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }

    .item:hover {
      transform: translateY(-2px);
      border-color: rgba(255,223,138,.22);
      background: rgba(255,255,255,.065);
    }

    .item::before {
      content: "";
      position: absolute;
      inset-inline-start: 0;
      top: 0;
      width: 4px;
      height: 100%;
      background: var(--rarity-color);
      opacity: .9;
    }

    .item-icon {
      width: 52px;
      height: 52px;
      border-radius: 17px;
      display: grid;
      place-items: center;
      background: rgba(0,0,0,.22);
      border: 1px solid rgba(255,255,255,.08);
      font-size: 27px;
    }

    .item-name {
      margin: 0;
      font-size: 15px;
      font-weight: 950;
      color: #fff;
    }

    .item-meta {
      margin-top: 5px;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
