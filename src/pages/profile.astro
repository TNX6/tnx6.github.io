      border: 1px solid rgba(255, 218, 106, .32);
      border-radius: 999px;
      background: rgba(7,7,11,.88);
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
      cursor: pointer;
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: 160ms ease;
      backdrop-filter: blur(12px);
    }

    .back-top.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
