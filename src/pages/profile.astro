---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'TNX6 community member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div id="profileBg" class="profile-bg"></div>
    <div class="profile-noise"></div>
    <div class="profile-glow"></div>

    <section class="profile-shell">
      <section id="searchView" class="search-view hidden">
        <div class="search-card">
          <span class="kicker">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>ابحث باسم Twitch أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

          <div class="search-box">
            <span>⌕</span>
            <input id="searchInput" type="search" autocomplete="off" placeholder="اكتب اسم المستخدم..." />
            <button id="clearSearch" type="button" aria-label="مسح البحث">×</button>
          </div>

          <div id="searchResults" class="search-results"></div>
        </div>
      </section>

      <section id="notFoundView" class="not-found hidden">
        <strong>ما لقيت العضو</strong>
        <span>تأكد من الاسم أو من ملف user_badges.json.</span>
      </section>

      <section id="profileView" class="profile-view hidden">
        <header class="player-card">
          <div id="coverArt" class="cover-art"></div>

          <div class="player-core">
            <div class="avatar-stack">
              <div class="avatar-frame">
                <div id="avatar" class="avatar"></div>
              </div>
              <div id="levelChip" class="level-chip">LVL 1</div>
            </div>

            <div class="player-info">
              <div class="name-row">
                <h1 id="displayName">—</h1>
                <span id="jobChip" class="job-chip">Citizen</span>
              </div>

              <div class="meta-row">
                <span id="loginName">@—</span>
                <span id="countryName" class="hidden">Saudi Arabia</span>
              </div>

              <p id="bioText" class="bio-text">عضو في مجتمع TNX6.</p>

              <div id="featuredBadges" class="featured-badges"></div>
            </div>

            <div class="progress-card">
              <div class="progress-top">
                <span>Progress</span>
                <strong id="levelLabel">Level 1</strong>
              </div>

              <div class="progress-track">
                <div id="levelProgress" class="progress-fill"></div>
              </div>

              <p id="nextLevelText">—</p>
            </div>
          </div>

          <div class="wallet-strip">
            <div class="wallet-cell">
              <span>النقاط</span>
              <strong id="pointsValue">0</strong>
            </div>

            <div class="wallet-cell">
              <span>الذهب</span>
              <strong id="goldValue">0</strong>
            </div>

            <div class="wallet-cell">
              <span>السمعة</span>
              <strong id="repValue">0</strong>
            </div>

            <div class="wallet-cell">
              <span>البادجات</span>
              <strong id="badgesTopValue">0</strong>
            </div>
          </div>
        </header>

        <section class="feature-row">
          <article class="feature-card rare-feature">
            <div class="section-head">
              <div>
                <span>RAREST ITEM</span>
                <h2>أندر غرض</h2>
              </div>
            </div>

            <div id="rareFeature" class="rare-feature-body"></div>
          </article>

          <article class="feature-card badge-feature">
            <div class="section-head">
              <div>
                <span>BADGE WALL</span>
                <h2>واجهة البادجات</h2>
              </div>
              <strong id="badgeCountMini">0</strong>
            </div>

            <div id="badgeWall" class="badge-wall"></div>
          </article>

          <article class="feature-card mail-feature">
            <div class="section-head">
              <div>
                <span>MAILBOX</span>
                <h2>آخر البريد</h2>
              </div>
              <strong id="mailCountMini">0</strong>
            </div>

            <div id="mailPreview" class="mail-preview"></div>
          </article>
        </section>

        <section class="content-panel">
          <div class="section-head inventory-head">
            <div>
              <span>INVENTORY</span>
              <h2>حقيبة الأغراض</h2>
            </div>

            <div class="inventory-tools">
              <button class="is-active" type="button" data-filter="all">الكل</button>
              <button type="button" data-filter="rare">النادر</button>
              <button type="button" data-filter="status">الحالات</button>
              <button type="button" data-filter="attacks">الهجمات</button>
              <button type="button" data-filter="boxes">الصناديق</button>
              <button type="button" data-filter="resources">الموارد</button>
            </div>
          </div>

          <div id="inventoryGrid" class="inventory-grid"></div>
          <div id="inventoryEmpty" class="empty-line hidden">ما فيه أغراض مطابقة.</div>
        </section>

        <section class="lower-grid">
          <article class="content-panel">
            <div class="section-head">
              <div>
                <span>ACHIEVEMENTS</span>
                <h2>الإنجازات</h2>
              </div>
              <strong id="achCount">0</strong>
            </div>

            <div id="achievementsList" class="achievements-list"></div>
            <div id="achievementsEmpty" class="empty-line hidden">لا توجد إنجازات بعد.</div>
          </article>

          <article class="content-panel">
            <div class="section-head">
              <div>
                <span>MESSAGES</span>
                <h2>صندوق البريد</h2>
              </div>

              <div class="mail-tabs">
                <button class="is-active" type="button" data-mail-filter="all">الكل</button>
                <button type="button" data-mail-filter="unread">غير المقروء</button>
              </div>
            </div>

            <div id="mailList" class="mail-list"></div>
            <div id="mailEmpty" class="empty-line hidden">ما فيه رسائل.</div>
          </article>
        </section>

        <section class="actions-row">
          <a id="badgesPageLink" href="/badges">فتح بطاقة البادجات</a>
          <button id="copyLink" type="button">نسخ رابط البروفايل</button>
        </section>
      </section>
    </section>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .55) rgba(0, 0, 0, .45);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0, 0, 0, .45); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, .45);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, .9), rgba(194, 146, 0, .55));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #05050a;
      color: #f8fafc;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .profile-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 10%, rgba(255, 218, 106, .18), transparent 30%),
        radial-gradient(circle at 84% 12%, rgba(124, 58, 237, .18), transparent 32%),
        linear-gradient(135deg, #05050a 0%, #0e0e17 52%, #180c04 100%);
      background-position: center;
      background-size: cover;
      opacity: .42;
      filter: blur(2px) saturate(.92) contrast(1.08);
      transform: scale(1.06);
    }

    .profile-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.88), rgba(0,0,0,.68) 38%, rgba(0,0,0,.96)),
        linear-gradient(90deg, rgba(0,0,0,.88), rgba(0,0,0,.42) 50%, rgba(0,0,0,.88));
    }

    .profile-noise {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: .06;
      background-image:
        linear-gradient(rgba(255, 218, 106, .3) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, .3) 1px, transparent 1px);
      background-size: 72px 72px;
      mask-image: radial-gradient(circle at center, black, transparent 68%);
    }

    .profile-glow {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, transparent 0%, rgba(0,0,0,.26) 52%, rgba(0,0,0,.84) 100%);
    }

    .profile-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1180px);
      margin: 0 auto;
      padding: 5.75rem 1rem 5rem;
    }

    .search-view {
      min-height: 64vh;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 640px);
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 32px;
      background: rgba(8,8,12,.84);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 30px 100px rgba(0,0,0,.5);
      backdrop-filter: blur(20px);
    }

    .kicker {
      display: inline-flex;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 999px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: rgb(156,163,175);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.36);
      padding: .85rem;
    }

    .search-box span {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 999px;
      background: rgba(255,218,106,.08);
      color: #ffda6a;
      font-size: 1.12rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: #f7e6ac;
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.08);
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: rgb(156,163,175);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
    }

    .not-found strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: rgb(156,163,175);
      font-size: .9rem;
    }

    .profile-view {
      display: grid;
      gap: 1rem;
    }

    .player-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 34px;
      background: rgba(8,8,12,.82);
      box-shadow: 0 34px 110px rgba(0,0,0,.58), inset 0 0 0 1px rgba(255,255,255,.025);
      backdrop-filter: blur(20px);
    }

    .cover-art {
      height: 215px;
      background-position: center;
      background-size: cover;
    }

    .cover-art::after {
      content: "";
      display: block;
      width: 100%;
      height: 100%;
      background:
        linear-gradient(180deg, rgba(0,0,0,.12), rgba(8,8,12,.88)),
        radial-gradient(circle at 22% 48%, rgba(var(--accent), .34), transparent 35%);
    }

    .player-core {
      position: relative;
      display: grid;
      grid-template-columns: 162px minmax(0, 1fr) 270px;
      gap: 1.2rem;
      align-items: end;
      padding: 0 1.35rem 1.1rem;
      margin-top: -74px;
    }

    .avatar-stack {
      display: grid;
      justify-items: center;
      gap: .7rem;
    }

    .avatar-frame {
      width: 152px;
      height: 152px;
      border-radius: 34px;
      padding: 4px;
      background:
        linear-gradient(135deg, rgba(255,218,106,.95), var(--profile-color, #ffda6a), rgba(255,255,255,.18));
      box-shadow:
        0 24px 48px rgba(0,0,0,.6),
        0 0 30px color-mix(in srgb, var(--profile-color, #ffda6a) 36%, transparent);
    }

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 29px;
      background: #111 center / cover no-repeat;
    }

    .level-chip {
      display: inline-flex;
      justify-content: center;
      min-width: 6.4rem;
      border: 1px solid rgba(255,218,106,.32);
      border-radius: 999px;
      background: rgba(0,0,0,.52);
      color: #ffda6a;
      padding: .54rem .8rem;
      font-size: .78rem;
      font-weight: 950;
      direction: ltr;
    }

    .player-info {
      min-width: 0;
      padding-bottom: .18rem;
    }

    .name-row {
      display: flex;
      align-items: center;
      gap: .75rem;
      flex-wrap: wrap;
      min-width: 0;
    }

    .name-row h1 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: clamp(2.55rem, 5vw, 5.15rem);
      font-weight: 950;
      line-height: .95;
      letter-spacing: -.05em;
      text-overflow: ellipsis;
      text-shadow: 0 5px 22px rgba(0,0,0,.72);
      white-space: nowrap;
    }

    .job-chip {
      flex-shrink: 0;
      border: 1px solid rgba(255,218,106,.24);
      border-radius: 999px;
      background: rgba(0,0,0,.44);
      color: #f7e6ac;
      padding: .48rem .7rem;
      font-size: .78rem;
      font-weight: 900;
      backdrop-filter: blur(12px);
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .68rem;
      color: rgba(229,231,235,.82);
      font-size: .84rem;
      font-weight: 850;
    }

    .meta-row span {
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      padding: .38rem .58rem;
    }

    #loginName {
      direction: ltr;
    }

    .bio-text {
      max-width: 720px;
      margin: .78rem 0 0;
      color: rgb(209,213,219);
      font-size: .92rem;
      font-weight: 720;
      line-height: 1.7;
    }

    .featured-badges {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: .9rem;
    }

    .featured-badges img,
    .badge-placeholder {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 14px;
      background: rgba(0,0,0,.38);
      object-fit: contain;
      padding: 4px;
      color: #ffda6a;
      font-weight: 950;
    }

    .progress-card {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 22px;
      background: rgba(0,0,0,.44);
      padding: 1rem;
      backdrop-filter: blur(14px);
    }

    .progress-top {
      display: flex;
      justify-content: space-between;
      gap: .8rem;
      align-items: center;
    }

    .progress-top span {
      color: rgb(156,163,175);
      font-size: .74rem;
      font-weight: 850;
    }

    .progress-top strong {
      color: #ffda6a;
      font-size: .86rem;
      font-weight: 950;
      direction: ltr;
    }

    .progress-track {
      height: 9px;
      margin-top: .7rem;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
    }

    .progress-fill {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #ffda6a, #c29200);
      box-shadow: 0 0 18px rgba(255,218,106,.35);
    }

    .progress-card p {
      margin: .55rem 0 0;
      color: rgb(156,163,175);
      font-size: .7rem;
      font-weight: 720;
    }

    .wallet-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: .75rem;
      padding: 0 1.35rem 1.35rem;
    }

    .wallet-cell {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.1), transparent 45%),
        rgba(0,0,0,.44);
      padding: .92rem;
      backdrop-filter: blur(12px);
    }

    .wallet-cell span {
      display: block;
      color: rgb(156,163,175);
      font-size: .74rem;
      font-weight: 850;
    }

    .wallet-cell strong {
      display: block;
      margin-top: .25rem;
      color: #ffda6a;
      font-size: 1.36rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .feature-row {
      display: grid;
      grid-template-columns: 1.25fr .95fr .95fr;
      gap: 1rem;
    }

    .feature-card,
    .content-panel {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 26px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)),
        rgba(8,8,12,.8);
      box-shadow: 0 24px 72px rgba(0,0,0,.4);
      padding: 1rem;
      backdrop-filter: blur(18px);
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: .92rem;
    }

    .section-head span {
      display: block;
      color: #c29200;
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .section-head h2 {
      margin: .24rem 0 0;
      color: #f7e6ac;
      font-size: 1.36rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .section-head > strong {
      display: grid;
      place-items: center;
      min-width: 48px;
      height: 38px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 14px;
      background: rgba(255,218,106,.06);
      color: #ffda6a;
      font-size: .92rem;
      font-weight: 950;
      direction: ltr;
    }

    .rare-feature-body {
      min-height: 188px;
    }

    .big-item {
      height: 100%;
      min-height: 188px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 22px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.13), transparent 48%),
        rgba(0,0,0,.3);
      padding: 1rem;
    }

    .big-item-icon {
      display: grid;
      place-items: center;
      width: 70px;
      height: 70px;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 20px;
      background: rgba(255,218,106,.08);
      font-size: 2.1rem;
      margin-bottom: .85rem;
    }

    .big-item h3 {
      margin: 0;
      color: #fff;
      font-size: 1.35rem;
      font-weight: 950;
      line-height: 1.2;
    }

    .big-item p {
      margin: .55rem 0 0;
      color: rgb(156,163,175);
      font-size: .82rem;
      font-weight: 740;
      line-height: 1.6;
    }

    .big-item strong {
      display: inline-flex;
      margin-top: .78rem;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      color: #ffda6a;
      padding: .4rem .58rem;
      font-size: .76rem;
      font-weight: 950;
      direction: ltr;
    }

    .badge-wall {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: .55rem;
    }

    .badge-wall img,
    .badge-wall .badge-placeholder {
      width: 100%;
      height: 58px;
      border-radius: 16px;
    }

    .mail-preview,
    .mail-list,
    .achievements-list {
      display: grid;
      gap: .65rem;
    }

    .mail-card,
    .achievement-card {
      display: flex;
      align-items: flex-start;
      gap: .75rem;
      border: 1px solid rgba(255,218,106,.1);
      border-radius: 16px;
      background: rgba(0,0,0,.28);
      padding: .72rem;
    }

    .mail-card.is-unread {
      border-color: rgba(255,218,106,.32);
      background: rgba(255,218,106,.05);
    }

    .mail-avatar,
    .achievement-icon {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      flex-shrink: 0;
      border: 1px solid rgba(255,218,106,.16);
      border-radius: 14px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
    }

