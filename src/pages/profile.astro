---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'بروفايل أعضاء مجتمع TNX6.',
}
---

<Layout metadata={metadata}>
  <main class="profile-page" dir="rtl">
    <div id="pageBg" class="page-bg"></div>
    <div class="page-overlay"></div>

    <section class="page-shell">
      <section id="searchView" class="search-view hidden">
        <div class="search-card">
          <span class="eyebrow">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>ابحث باسم العضو أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

          <div class="search-box">
            <span>⌕</span>
            <input id="userSearch" type="search" autocomplete="off" placeholder="اكتب اسم Twitch..." />
            <button id="clearSearch" type="button" aria-label="مسح">×</button>
          </div>

          <div id="searchResults" class="search-results"></div>
        </div>
      </section>

      <section id="notFoundView" class="empty-view hidden">
        <strong>ما لقيت العضو</strong>
        <span>تأكد من الاسم أو من ملف <b>user_badges.json</b>.</span>
      </section>

      <section id="profileView" class="profile-view hidden">
        <header class="hero-card">
          <div id="heroCover" class="hero-cover"></div>

          <div class="hero-content">
            <div id="avatar" class="avatar"></div>

            <div class="identity">
              <div class="title-line">
                <h1 id="displayName">—</h1>
                <span id="levelPill" class="level-pill">LVL 1</span>
              </div>

              <div class="sub-line">
                <span id="loginName">@—</span>
                <span id="jobName">Citizen</span>
                <span id="countryName" class="hidden">Saudi Arabia</span>
              </div>

              <p id="bioText" class="bio-text">عضو في مجتمع TNX6.</p>

              <div id="equippedBadges" class="equipped-badges"></div>
            </div>

            <div class="wallet">
              <div class="wallet-card">
                <span>النقاط</span>
                <strong id="pointsValue">0</strong>
              </div>

              <div class="wallet-card gold">
                <span>الذهب</span>
                <strong id="goldValue">0</strong>
              </div>

              <div class="wallet-card rep">
                <span>السمعة</span>
                <strong id="repValue">0</strong>
              </div>
            </div>
          </div>
        </header>

        <section class="dashboard">
          <main class="main-column">
            <section class="panel inventory-panel">
              <div class="panel-head">
                <div>
                  <span>INVENTORY</span>
                  <h2>حقيبة الأغراض</h2>
                </div>
                <strong id="inventoryTotal">0</strong>
              </div>

              <div id="inventoryGrid" class="inventory-grid"></div>
              <div id="inventoryEmpty" class="inline-empty hidden">ما فيه أغراض في الحقيبة.</div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <div>
                  <span>BADGES</span>
                  <h2>البادجات</h2>
                </div>
                <strong id="badgesTotal">0</strong>
              </div>

              <div id="badgesGrid" class="badges-grid"></div>
              <div id="badgesEmpty" class="inline-empty hidden">ما فيه بادجات ظاهرة.</div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <div>
                  <span>ACHIEVEMENTS</span>
                  <h2>آخر الإنجازات</h2>
                </div>
                <strong id="achievementsTotal">0</strong>
              </div>

              <div id="achievementsList" class="achievements-list"></div>
              <div id="achievementsEmpty" class="inline-empty hidden">لا توجد إنجازات بعد.</div>
            </section>
          </main>

          <aside class="side-column">
            <section class="panel mailbox-panel">
              <div class="panel-head">
                <div>
                  <span>MAILBOX</span>
                  <h2>صندوق البريد</h2>
                </div>
                <strong id="mailTotal">0</strong>
              </div>

              <div class="mail-tabs">
                <button class="is-active" type="button" data-mail-filter="all">الكل</button>
                <button type="button" data-mail-filter="unread">غير المقروء</button>
              </div>

              <div id="mailList" class="mail-list"></div>
              <div id="mailEmpty" class="inline-empty hidden">ما فيه رسائل.</div>
            </section>

            <section class="panel">
              <div class="panel-head">
                <div>
                  <span>RARE ITEMS</span>
                  <h2>الأندر</h2>
                </div>
              </div>

              <div id="rareItems" class="rare-list"></div>
              <div id="rareEmpty" class="inline-empty hidden">ما فيه أغراض نادرة.</div>
            </section>

            <section class="panel quick-panel">
              <a id="badgePageLink" href="/badges">بطاقة البادجات <span>↗</span></a>
              <button id="copyLink" type="button">نسخ رابط البروفايل <span>⌁</span></button>
              <button type="button" data-jump="inventoryGrid">الأغراض <span id="quickItems">0</span></button>
              <button type="button" data-jump="badgesGrid">البادجات <span id="quickBadges">0</span></button>
            </section>
          </aside>
        </section>
      </section>
    </section>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .45) rgba(0, 0, 0, .35);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.35); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.35);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.85), rgba(194,146,0,.55));
    }

    .profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07070b;
      color: #f8fafc;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(circle at 20% 12%, rgba(255, 218, 106, .16), transparent 28%),
        radial-gradient(circle at 80% 20%, rgba(124, 58, 237, .14), transparent 30%),
        linear-gradient(135deg, #07070b 0%, #0b0b12 48%, #140b05 100%);
      background-size: cover;
      background-position: center;
      filter: saturate(1.05) contrast(1.03);
      transform: scale(1.02);
      pointer-events: none;
    }

    .page-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.68), rgba(0,0,0,.32) 42%, rgba(0,0,0,.82)),
        linear-gradient(90deg, rgba(0,0,0,.72), transparent 48%, rgba(0,0,0,.68));
    }

    .page-overlay {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, transparent 0%, rgba(0,0,0,.24) 48%, rgba(0,0,0,.72) 100%);
    }

    .page-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1180px);
      margin: 0 auto;
      padding: 5.8rem 1rem 5rem;
    }

    .search-view {
      display: grid;
      place-items: center;
      min-height: 62vh;
    }

    .search-card,
    .empty-view {
      width: min(100%, 620px);
      border: 1px solid rgba(255, 218, 106, .18);
      border-radius: 24px;
      background: rgba(7, 7, 11, .82);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 28px 80px rgba(0,0,0,.42);
      backdrop-filter: blur(18px);
    }

    .eyebrow {
      display: inline-flex;
      border: 1px solid rgba(255, 218, 106, .28);
      border-radius: 999px;
      background: rgba(255, 218, 106, .07);
      color: #ffda6a;
      padding: .45rem .8rem;
      font-size: .7rem;
      font-weight: 900;
      letter-spacing: .12em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
    }

    .search-card p {
      color: rgb(156, 163, 175);
      font-size: .95rem;
      font-weight: 700;
      line-height: 1.7;
    }

    .search-card b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, .2);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      padding: .85rem;
    }

    .search-box span {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 800;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, .2);
      border-radius: 999px;
      background: rgba(255, 218, 106, .08);
      color: #ffda6a;
      font-size: 1.1rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      border: 1px solid rgba(255, 218, 106, .12);
      border-radius: 14px;
      background: rgba(0,0,0,.34);
      color: #f7e6ac;
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, .42);
      background: rgba(255, 218, 106, .08);
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: rgb(156, 163, 175);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .empty-view {
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
    }

    .empty-view strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .empty-view span {
      color: rgb(156, 163, 175);
      font-size: .9rem;
    }

    .profile-view {
      display: grid;
      gap: 1rem;
    }

    .hero-card {
      position: relative;
      overflow: hidden;
      min-height: 320px;
      border: 1px solid rgba(255, 218, 106, .18);
      border-radius: 28px;
      background: rgba(7, 7, 11, .78);
      box-shadow: 0 28px 90px rgba(0,0,0,.48);
      backdrop-filter: blur(18px);
    }

    .hero-cover {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      opacity: .95;
    }

    .hero-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.12), rgba(7,7,11,.7) 56%, rgba(7,7,11,.96)),
        radial-gradient(circle at 20% 36%, rgba(var(--accent), .28), transparent 36%),
        linear-gradient(90deg, rgba(0,0,0,.65), transparent 52%);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 128px minmax(0, 1fr) 310px;
      gap: 1.1rem;
      align-items: end;
      min-height: 320px;
      padding: 1.25rem;
    }

    .avatar {
      width: 120px;
      height: 120px;
      border: 4px solid var(--profile-color, #ffda6a);
      border-radius: 22px;
      background-color: #111;
      background-size: cover;
      background-position: center;
      box-shadow:
        0 20px 42px rgba(0,0,0,.55),
        0 0 26px color-mix(in srgb, var(--profile-color, #ffda6a) 38%, transparent);
    }

    .identity {
      min-width: 0;
    }

    .title-line {
      display: flex;
      align-items: center;
      gap: .75rem;
      min-width: 0;
    }

    .title-line h1 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: clamp(2rem, 5vw, 4.4rem);
      font-weight: 950;
      line-height: .95;
      letter-spacing: -.04em;
      text-overflow: ellipsis;
      text-shadow: 0 5px 22px rgba(0,0,0,.72);
      white-space: nowrap;
    }

    .level-pill {
      flex-shrink: 0;
      border: 1px solid rgba(255, 218, 106, .36);
      border-radius: 999px;
      background: rgba(0,0,0,.48);
      color: #ffda6a;
      padding: .45rem .65rem;
      font-size: .76rem;
      font-weight: 950;
      direction: ltr;
    }

    .sub-line {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .65rem;
      color: rgba(229, 231, 235, .82);
      font-size: .84rem;
      font-weight: 850;
    }

    .sub-line span {
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      padding: .38rem .58rem;
    }

    #loginName {
      direction: ltr;
    }

    .bio-text {
      max-width: 620px;
      margin: .75rem 0 0;
      color: rgb(209, 213, 219);
      font-size: .9rem;
      font-weight: 700;
      line-height: 1.7;
    }

    .equipped-badges {
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      margin-top: .85rem;
    }

    .equipped-badges img,
    .badge-placeholder {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      border: 1px solid rgba(255, 218, 106, .2);
      border-radius: 12px;
      background: rgba(0,0,0,.38);
      object-fit: contain;
      padding: 4px;
    }

    .badge-placeholder {
      color: #ffda6a;
      font-weight: 950;
    }

    .wallet {
      display: grid;
      gap: .65rem;
    }

    .wallet-card {
      border: 1px solid rgba(255, 218, 106, .14);
      border-radius: 18px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.1), transparent 45%),
        rgba(0,0,0,.44);
      padding: .9rem;
      backdrop-filter: blur(12px);
    }

    .wallet-card span {
      display: block;
      color: rgb(156, 163, 175);
      font-size: .74rem;
      font-weight: 850;
    }

    .wallet-card strong {
      display: block;
      margin-top: .25rem;
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .wallet-card.gold strong { color: #ffd166; }
    .wallet-card.rep strong { color: #c084fc; }

    .dashboard {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
    }

    .main-column,
    .side-column {
      display: grid;
      gap: 1rem;
    }

    .panel {
      border: 1px solid rgba(255, 218, 106, .14);
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)),
        rgba(7,7,11,.78);
      box-shadow:
        0 22px 64px rgba(0,0,0,.38),
        inset 0 0 20px rgba(255,218,106,.018);
      padding: 1rem;
      backdrop-filter: blur(16px);
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: .9rem;
    }

    .panel-head span {
      display: block;
      color: #c29200;
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .panel-head h2 {
      margin: .24rem 0 0;
      color: #f7e6ac;
      font-size: 1.35rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .panel-head > strong {
      display: grid;
      place-items: center;
      min-width: 54px;
      height: 42px;
      border: 1px solid rgba(255, 218, 106, .18);
      border-radius: 14px;
      background: rgba(255, 218, 106, .06);
      color: #ffda6a;
      font-size: 1rem;
      font-weight: 950;
      direction: ltr;
    }

    .inventory-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(132px, 1fr));
      gap: .7rem;
    }

    .item-card {
      position: relative;
      min-height: 156px;
      overflow: hidden;
      border: 1px solid var(--item-color, rgba(255,218,106,.18));
      border-radius: 16px;
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.08)), transparent 48%),
        rgba(0,0,0,.32);
      padding: .78rem;
      transition: 160ms ease;
    }

    .item-card:hover {
      transform: translateY(-2px);
      border-color: var(--item-color, rgba(255,218,106,.45));
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.14)), transparent 52%),
        rgba(0,0,0,.38);
    }

    .item-card.is-rare::before {
      content: "";
      position: absolute;
      inset: -40%;
      background: conic-gradient(from 0deg, transparent, rgba(255,218,106,.18), transparent 28%);
      animation: shine 6s linear infinite;
      pointer-events: none;
    }

    @keyframes shine { to { transform: rotate(360deg); } }

    .item-icon,
    .item-card h3,
    .item-card p,
    .item-tags,
    .item-qty {
      position: relative;
      z-index: 1;
    }

    .item-icon {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      border: 1px solid var(--item-color, rgba(255,218,106,.22));
      border-radius: 14px;
      background: var(--item-soft, rgba(255,218,106,.08));
      font-size: 1.45rem;
      margin-bottom: .65rem;
    }

    .item-qty {
      position: absolute;
      top: .65rem;
      left: .65rem;
      min-width: 2rem;
      height: 2rem;
      display: grid;
      place-items: center;
      border: 1px solid var(--item-color, rgba(255,218,106,.22));
      border-radius: 999px;
      background: rgba(0,0,0,.55);
      color: var(--item-color, #ffda6a);
      font-size: .72rem;
      font-weight: 950;
      direction: ltr;
    }

    .item-card h3 {
      margin: 0;
      color: #fff;
      font-size: .9rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .item-card p {
      display: -webkit-box;
      overflow: hidden;
      margin: .35rem 0 0;
      color: rgb(156, 163, 175);
      font-size: .68rem;
      font-weight: 750;
      line-height: 1.45;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .item-tags {
      display: flex;
      flex-wrap: wrap;
      gap: .28rem;
      margin-top: .62rem;
    }

    .item-tags span {
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 999px;
      background: rgba(255,255,255,.04);
      color: #f7e6ac;
      padding: .21rem .38rem;
      font-size: .56rem;
      font-weight: 850;
    }

    .badges-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(82px, 1fr));
      gap: .65rem;
    }

    .badge-tile {
      display: grid;
      place-items: center;
      gap: .4rem;
      min-height: 108px;
      border: 1px solid rgba(255, 218, 106, .1);
      border-radius: 16px;
      background: rgba(0,0,0,.26);
      padding: .6rem;
      text-align: center;
    }

    .badge-tile img {
      width: 56px;
      height: 56px;
      object-fit: contain;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.42));
    }

    .badge-tile span {
      color: rgb(229, 231, 235);
      font-size: .62rem;
      font-weight: 800;
      line-height: 1.25;
    }

    .achievements-list,
    .mail-list,
    .rare-list {
      display: grid;
      gap: .65rem;
    }

    .achievement-card,
    .mail-card,
    .rare-card {
      display: flex;
      align-items: center;
      gap: .75rem;
      border: 1px solid rgba(255, 218, 106, .1);
      border-radius: 16px;
      background: rgba(0,0,0,.28);
      padding: .72rem;
    }

    .achievement-icon,
    .mail-avatar,
    .rare-icon {
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      flex-shrink: 0;
      border: 1px solid rgba(255, 218, 106, .16);
      border-radius: 14px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
    }

    .achievement-card strong,
    .mail-card strong,
    .rare-card strong {
      display: block;
      color: #fff;
      font-size: .82rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .achievement-card span,
    .mail-card span,
    .rare-card span {
      display: block;
      margin-top: .18rem;
      color: rgb(156, 163, 175);
      font-size: .68rem;
      font-weight: 750;
      line-height: 1.45;
    }

    .mail-card {
      align-items: flex-start;
    }

    .mail-card.is-unread {
      border-color: rgba(255, 218, 106, .32);
      background: rgba(255, 218, 106, .05);
    }

    .mail-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .5rem;
    }

    .mail-date {
      color: rgb(107, 114, 128) !important;
