---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX6 Profile',
  ignoreTitleTemplate: true,
  description: 'TNX6 community member profile.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div id="pageBg" class="page-bg"></div>
    <div class="page-vignette"></div>

    <section class="profile-shell">
      <section id="searchView" class="search-view hidden">
        <div class="search-card">
          <span class="eyebrow">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>ابحث باسم Twitch أو افتح رابط مباشر مثل <b>/profile?user=haneen48</b></p>

          <div class="search-box">
            <span>⌕</span>
            <input id="searchInput" type="search" autocomplete="off" placeholder="اكتب اسم المستخدم..." />
            <button id="clearSearch" type="button" aria-label="مسح البحث">×</button>
          </div>

          <div id="searchResults" class="search-results"></div>
        </div>
      </section>

      <section id="notFoundView" class="not-found hidden">
        <strong>ما لقيت العضو</strong>
        <span>تأكد من الاسم أو من ملف user_badges.json.</span>
      </section>

      <section id="profileView" class="profile-view hidden">
        <section class="profile-hero">
          <div id="heroCover" class="hero-cover"></div>

          <div class="hero-inner">
            <aside class="hero-avatar">
              <div class="avatar-ring">
                <div id="avatar" class="avatar"></div>
              </div>

              <div class="level-box">
                <span>LEVEL</span>
                <strong id="levelNumber">1</strong>
              </div>
            </aside>

            <section class="hero-identity">
              <div class="identity-pills">
                <span id="loginName">@—</span>
                <span id="jobName">Citizen</span>
                <span id="countryName" class="hidden">Saudi Arabia</span>
              </div>

              <h1 id="displayName">—</h1>

              <p id="bioText">عضو في مجتمع TNX6.</p>

              <div id="featuredBadges" class="featured-badges"></div>
            </section>

            <aside class="hero-status">
              <div class="status-head">
                <span>STATUS</span>
                <strong id="levelLabel">Level 1</strong>
              </div>

              <div class="progress-track">
                <div id="levelProgress" class="progress-fill"></div>
              </div>

              <p id="nextLevelText">—</p>

              <div class="stat-grid">
                <div>
                  <span>النقاط</span>
                  <strong id="pointsValue">0</strong>
                </div>
                <div>
                  <span>الذهب</span>
                  <strong id="goldValue">0</strong>
                </div>
                <div>
                  <span>السمعة</span>
                  <strong id="repValue">0</strong>
                </div>
                <div>
                  <span>البادجات</span>
                  <strong id="badgesCountValue">0</strong>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section class="top-showcase">
          <article class="panel featured-items-panel">
            <div class="panel-head">
              <div>
                <span>SHOWCASE</span>
                <h2>أبرز الأغراض</h2>
              </div>
            </div>

            <div id="featuredItems" class="featured-items"></div>
            <div id="featuredItemsEmpty" class="empty-line hidden">ما فيه أغراض للعرض.</div>
          </article>

          <article class="panel badge-panel">
            <div class="panel-head">
              <div>
                <span>BADGES</span>
                <h2>واجهة البادجات</h2>
              </div>
              <strong id="badgeWallCount">0</strong>
            </div>

            <div id="badgeWall" class="badge-wall"></div>
            <div id="badgeWallEmpty" class="empty-line hidden">ما فيه بادجات ظاهرة.</div>
          </article>
        </section>

        <section class="panel inventory-panel">
          <div class="panel-head inventory-head">
            <div>
              <span>INVENTORY</span>
              <h2>حقيبة الأغراض</h2>
            </div>

            <div class="filters">
              <button class="is-active" type="button" data-filter="all">الكل</button>
              <button type="button" data-filter="rare">النادر</button>
              <button type="button" data-filter="status">الحالات</button>
              <button type="button" data-filter="attacks">الهجمات</button>
              <button type="button" data-filter="boxes">الصناديق</button>
              <button type="button" data-filter="resources">الموارد</button>
            </div>
          </div>

          <div id="inventoryGrid" class="inventory-grid"></div>
          <div id="inventoryEmpty" class="empty-line hidden">ما فيه أغراض مطابقة.</div>
        </section>

        <section class="bottom-grid">
          <article class="panel">
            <div class="panel-head">
              <div>
                <span>ACHIEVEMENTS</span>
                <h2>الإنجازات</h2>
              </div>
              <strong id="achievementsCount">0</strong>
            </div>

            <div id="achievementsList" class="stack-list"></div>
            <div id="achievementsEmpty" class="empty-line hidden">لا توجد إنجازات بعد.</div>
          </article>

          <article class="panel">
            <div class="panel-head">
              <div>
                <span>MAILBOX</span>
                <h2>صندوق البريد</h2>
              </div>

              <div class="mail-tabs">
                <button class="is-active" type="button" data-mail-filter="all">الكل</button>
                <button type="button" data-mail-filter="unread">غير المقروء</button>
              </div>
            </div>

            <div id="mailList" class="stack-list"></div>
            <div id="mailEmpty" class="empty-line hidden">ما فيه رسائل.</div>
          </article>
        </section>

        <section class="actions-row">
          <a id="badgesPageLink" href="/badges">فتح بطاقة البادجات</a>
          <button id="copyLink" type="button">نسخ رابط البروفايل</button>
        </section>
      </section>
    </section>

    <div id="itemModal" class="modal hidden" aria-hidden="true">
      <button id="closeItemModal" class="modal-close" type="button" aria-label="إغلاق">×</button>
      <div id="itemModalContent" class="modal-card"></div>
    </div>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    .hidden { display: none !important; }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, .55) rgba(0, 0, 0, .48);
    }

    html::-webkit-scrollbar { width: 10px; }
    html::-webkit-scrollbar-track { background: rgba(0,0,0,.48); }
    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0,0,0,.48);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,218,106,.95), rgba(194,146,0,.6));
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #030306;
      color: #f8fafc;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .page-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 16% 12%, rgba(255,218,106,.16), transparent 28%),
        radial-gradient(circle at 84% 16%, rgba(124,58,237,.12), transparent 32%),
        linear-gradient(135deg, #05050a, #0d0d14 50%, #150b04);
      background-position: center;
      background-size: cover;
      opacity: .42;
      filter: blur(2px) saturate(.9) contrast(1.1);
      transform: scale(1.06);
    }

    .page-bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.9), rgba(0,0,0,.72) 36%, rgba(0,0,0,.96)),
        linear-gradient(90deg, rgba(0,0,0,.9), rgba(0,0,0,.45) 50%, rgba(0,0,0,.9));
    }

    .page-vignette {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, transparent 0%, rgba(0,0,0,.3) 54%, rgba(0,0,0,.9) 100%);
    }

    .profile-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1120px);
      margin: 0 auto;
      padding: 5.5rem 1rem 5rem;
    }

    .search-view {
      min-height: 64vh;
      display: grid;
      place-items: center;
    }

    .search-card,
    .not-found {
      width: min(100%, 620px);
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 30px;
      background: rgba(8,8,12,.86);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 30px 100px rgba(0,0,0,.55);
      backdrop-filter: blur(20px);
    }

    .eyebrow {
      display: inline-flex;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 999px;
      background: rgba(255,218,106,.07);
      color: #ffda6a;
      padding: .45rem .82rem;
      font-size: .7rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .search-card h1 {
      margin: .9rem 0 0;
      color: #fff;
      font-size: clamp(2.2rem, 6vw, 4rem);
      font-weight: 950;
      line-height: 1;
      letter-spacing: -.04em;
    }

    .search-card p {
      color: rgb(156,163,175);
      font-size: .95rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .search-card b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .search-box {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 18px;
      background: rgba(0,0,0,.36);
      padding: .85rem;
    }

    .search-box span {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .search-box input {
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: .96rem;
      font-weight: 850;
    }

    .search-box button {
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 999px;
      background: rgba(255,218,106,.08);
      color: #ffda6a;
      font-size: 1.12rem;
      cursor: pointer;
    }

    .search-results {
      display: grid;
      gap: .55rem;
      margin-top: .85rem;
    }

    .search-result {
      display: flex;
      align-items: center;
      gap: .75rem;
      width: 100%;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.34);
      color: #f7e6ac;
      padding: .75rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .search-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255,218,106,.42);
      background: rgba(255,218,106,.08);
    }

    .search-result img {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      object-fit: cover;
      background: #111;
    }

    .search-result strong {
      display: block;
      color: #fff;
      font-size: .92rem;
      font-weight: 900;
    }

    .search-result span {
      display: block;
      margin-top: 2px;
      color: rgb(156,163,175);
      font-size: .74rem;
      direction: ltr;
      text-align: right;
    }

    .not-found {
      display: grid;
      place-items: center;
      gap: .5rem;
      min-height: 280px;
    }

    .not-found strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .not-found span {
      color: rgb(156,163,175);
      font-size: .9rem;
    }

    .profile-view {
      display: grid;
      gap: 1rem;
    }

    .profile-hero {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 34px;
      background:
        linear-gradient(135deg, rgba(255,255,255,.04), rgba(255,255,255,.012)),
        rgba(8,8,12,.86);
      box-shadow:
        0 34px 110px rgba(0,0,0,.58),
        inset 0 0 0 1px rgba(255,255,255,.025);
      backdrop-filter: blur(22px);
    }

    .hero-cover {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      opacity: .38;
      filter: saturate(.95) contrast(1.05);
    }

    .hero-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 84% 32%, rgba(var(--accent), .28), transparent 28%),
        linear-gradient(90deg, rgba(8,8,12,.94), rgba(8,8,12,.55) 52%, rgba(8,8,12,.92)),
        linear-gradient(180deg, rgba(8,8,12,.32), rgba(8,8,12,.95));
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-areas: "status identity avatar";
      grid-template-columns: 270px minmax(0, 1fr) 210px;
      gap: 1.2rem;
      min-height: 420px;
      align-items: center;
      padding: 1.6rem;
    }

    .hero-avatar {
      grid-area: avatar;
      display: grid;
      place-items: center;
      gap: .85rem;
    }

    .avatar-ring {
      width: 188px;
      height: 188px;
      border-radius: 34px;
      padding: 5px;
      background:
        linear-gradient(135deg, rgba(255,218,106,.96), var(--profile-color, #ffda6a), rgba(255,255,255,.18));
      box-shadow:
        0 26px 56px rgba(0,0,0,.64),
        0 0 32px color-mix(in srgb, var(--profile-color, #ffda6a) 34%, transparent);
    }

    .avatar {
      width: 100%;
      height: 100%;
      border-radius: 29px;
      background: #111 center / cover no-repeat;
    }

    .level-box {
      display: grid;
      place-items: center;
      min-width: 116px;
      border: 1px solid rgba(255,218,106,.26);
      border-radius: 20px;
      background: rgba(0,0,0,.42);
      padding: .72rem .95rem;
    }

    .level-box span {
      color: rgb(156,163,175);
      font-size: .66rem;
      font-weight: 950;
      letter-spacing: .12em;
    }

    .level-box strong {
      margin-top: .18rem;
      color: #ffda6a;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1;
      direction: ltr;
    }

    .hero-identity {
      grid-area: identity;
      min-width: 0;
      text-align: right;
    }

    .identity-pills {
      display: flex;
      flex-wrap: wrap;
      gap: .48rem;
      align-items: center;
      margin-bottom: .8rem;
    }

    .identity-pills span {
      border: 1px solid rgba(255,218,106,.22);
      border-radius: 999px;
      background: rgba(0,0,0,.42);
      color: #f7e6ac;
      padding: .46rem .7rem;
      font-size: .76rem;
      font-weight: 900;
      backdrop-filter: blur(12px);
    }

    #loginName {
      color: rgb(229,231,235);
      direction: ltr;
    }

    .hero-identity h1 {
      margin: 0;
      color: #fff;
      font-size: clamp(3rem, 6vw, 5.8rem);
      font-weight: 950;
      line-height: .9;
      letter-spacing: -.06em;
      text-shadow: 0 8px 28px rgba(0,0,0,.78);
      word-break: break-word;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .hero-identity p {
      max-width: 620px;
      margin: .95rem 0 0;
      color: rgb(209,213,219);
      font-size: .98rem;
      font-weight: 720;
      line-height: 1.75;
    }

    .featured-badges {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: 1.05rem;
    }

    .featured-badges img,
    .badge-placeholder {
      display: grid;
      place-items: center;
      width: 50px;
      height: 50px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 15px;
      background: rgba(0,0,0,.38);
      object-fit: contain;
      padding: 4px;
      color: #ffda6a;
      font-weight: 950;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,.42));
    }

    .hero-status {
      grid-area: status;
      border: 1px solid rgba(255,218,106,.13);
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, rgba(255,218,106,.1), transparent 45%),
        rgba(0,0,0,.38);
      padding: 1rem;
      box-shadow: inset 0 0 24px rgba(255,218,106,.035);
    }

    .status-head {
      display: flex;
      justify-content: space-between;
      gap: .8rem;
      align-items: center;
    }

    .status-head span {
      color: rgb(156,163,175);
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .1em;
    }

    .status-head strong {
      color: #ffda6a;
      font-size: .86rem;
      font-weight: 950;
      direction: ltr;
    }

    .progress-track {
      height: 10px;
      margin-top: .75rem;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
    }

    .progress-fill {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #ffda6a, #c29200);
      box-shadow: 0 0 18px rgba(255,218,106,.35);
    }

    .hero-status p {
      margin: .55rem 0 .85rem;
      color: rgb(156,163,175);
      font-size: .68rem;
      font-weight: 720;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: .58rem;
    }

    .stat-grid div {
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 16px;
      background: rgba(0,0,0,.26);
      padding: .75rem;
    }

    .stat-grid span {
      display: block;
      color: rgb(156,163,175);
      font-size: .68rem;
      font-weight: 850;
    }

    .stat-grid strong {
      display: block;
      margin-top: .18rem;
      color: #ffda6a;
      font-size: 1.04rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .top-showcase,
    .bottom-grid {
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 1rem;
    }

    .panel {
      border: 1px solid rgba(255,218,106,.14);
      border-radius: 28px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)),
        rgba(8,8,12,.82);
      box-shadow: 0 24px 72px rgba(0,0,0,.42);
      padding: 1rem;
      backdrop-filter: blur(18px);
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      margin-bottom: .95rem;
    }

    .panel-head span {
      display: block;
      color: #c29200;
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .13em;
    }

    .panel-head h2 {
      margin: .24rem 0 0;
      color: #f7e6ac;
      font-size: 1.42rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .panel-head > strong {
      display: grid;
      place-items: center;
      min-width: 48px;
      height: 38px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 14px;
      background: rgba(255,218,106,.06);
      color: #ffda6a;
      font-size: .92rem;
      font-weight: 950;
      direction: ltr;
    }

    .featured-items {
      display: grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: .75rem;
      min-height: 220px;
    }

    .featured-item {
      position: relative;
      overflow: hidden;
      border: 1px solid var(--item-color, rgba(255,218,106,.18));
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.12)), transparent 48%),
        rgba(0,0,0,.32);
      padding: 1rem;
      min-height: 220px;
      cursor: pointer;
      transition: 160ms ease;
    }

    .featured-item:hover {
      transform: translateY(-2px);
      border-color: var(--item-color, rgba(255,218,106,.42));
      background:
        radial-gradient(circle at top right, var(--item-soft, rgba(255,218,106,.18)), transparent 48%),
        rgba(0,0,0,.4);
    }

    .featured-item:first-child {
      min-height: 220px;
    }

    .featured-icon {
      display: grid;
      place-items: center;
      width: 74px;
      height: 74px;
      border: 1px solid var(--item-color, rgba(255,218,106,.18));
      border-radius: 22px;
      background: var(--item-soft, rgba(255,218,106,.1));
      font-size: 2.2rem;
      margin-bottom: .8rem;
    }

    .featured-item h3 {
      margin: 0;
      color: #fff;
      font-size: 1.1rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .featured-item p {
      display: -webkit-box;
      overflow: hidden;
      margin: .45rem 0 0;
      color: rgb(156,163,175);
      font-size: .75rem;
      font-weight: 730;
      line-height: 1.5;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .featured-qty {
      position: absolute;
      top: .8rem;
      left: .8rem;
      display: grid;
      place-items: center;
      min-width: 2.2rem;
      height: 2.2rem;
      border: 1px solid var(--item-color, rgba(255,218,106,.18));
      border-radius: 999px;
      background: rgba(0,0,0,.58);
      color: var(--item-color, #ffda6a);
      padding: 0 .35rem;
      font-size: .72rem;
      font-weight: 950;
      direction: ltr;
    }

    .badge-wall {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: .65rem;
    }

    .badge-wall img,
    .badge-wall .badge-placeholder {
      width: 100%;
      height: 68px;
      border-radius: 18px;
    }

    .inventory-head {
      align-items: center;
    }

    .filters,
    .mail-tabs {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: .4rem;
    }

    .filters button,
    .mail-tabs button {
