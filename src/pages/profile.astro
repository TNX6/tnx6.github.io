---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'TNX Profile',
  ignoreTitleTemplate: true,
  description: 'صفحة بروفايل أعضاء TNX6.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-profile-page" dir="rtl">
    <div id="profileBackdrop" class="profile-backdrop"></div>
    <div class="profile-vignette"></div>

    <section class="profile-shell">
      <header class="profile-page-head">
        <div>
          <span class="page-kicker">TNX6 PROFILE</span>
          <h1>بروفايل العضو</h1>
          <p>صفحة تعرض حساب العضو بشكل واضح: الخلفية، الصورة، الوظيفة، النقاط، الذهب، البادجات، والأغراض.</p>
        </div>

        <section class="profile-search-panel">
          <div class="profile-search">
            <span>⌕</span>
            <input id="profileSearch" type="search" autocomplete="off" placeholder="ابحث باسم Twitch..." />
            <button id="clearProfileSearch" type="button" aria-label="مسح البحث">×</button>
          </div>

          <div id="profileResults" class="profile-results"></div>
        </section>
      </header>

      <section id="emptyState" class="empty-state">
        <strong>ابحث عن عضو</strong>
        <span>اكتب اسم المستخدم أو افتح رابط مباشر مثل: <b>/profile?user=haneen48</b></span>
      </section>

      <section id="profileContent" class="profile-content hidden">
        <section id="profileHero" class="profile-hero"></section>

        <section class="profile-layout">
          <main class="profile-main">
            <section class="profile-panel">
              <div class="panel-head">
                <div>
                  <span>DISPLAY CASE</span>
                  <h2>واجهة العضو</h2>
                </div>
              </div>

              <div id="displayCase" class="display-case"></div>
            </section>

            <section class="profile-panel">
              <div class="panel-head panel-head-row">
                <div>
                  <span>INVENTORY</span>
                  <h2>الأغراض</h2>
                </div>

                <div class="panel-counter">
                  <strong id="inventoryCount">0</strong>
                  <small>نوع</small>
                </div>
              </div>

              <div id="inventoryFilters" class="filter-row">
                <button type="button" class="is-active" data-filter="all">الكل</button>
                <button type="button" data-filter="rare">النادر</button>
                <button type="button" data-filter="featured">المميز</button>
                <button type="button" data-filter="box">الصناديق</button>
                <button type="button" data-filter="license">الرخص</button>
                <button type="button" data-filter="resource">الموارد</button>
                <button type="button" data-filter="usable">استخدام</button>
              </div>

              <div id="inventoryGrid" class="inventory-grid"></div>

              <div id="inventoryEmpty" class="small-empty hidden">
                <strong>ما فيه أغراض ظاهرة</strong>
                <span>الحقيبة فاضية أو الفلتر الحالي ما طلع نتائج.</span>
              </div>
            </section>

            <section class="profile-panel">
              <div class="panel-head panel-head-row">
                <div>
                  <span>BADGES</span>
                  <h2>البادجات</h2>
                </div>

                <div class="panel-counter">
                  <strong id="badgeCount">0</strong>
                  <small>بادج</small>
                </div>
              </div>

              <div id="badgesGrid" class="badges-grid"></div>
            </section>
          </main>

          <aside class="profile-side">
            <section class="profile-panel">
              <div class="panel-head">
                <div>
                  <span>OVERVIEW</span>
                  <h2>ملخص</h2>
                </div>
              </div>

              <div id="statsList" class="stats-list"></div>
            </section>

            <section class="profile-panel">
              <div class="panel-head">
                <div>
                  <span>RARE ITEMS</span>
                  <h2>أندر الأغراض</h2>
                </div>
              </div>

              <div id="rareList" class="rare-list"></div>
            </section>

            <section class="profile-panel">
              <div class="panel-head">
                <div>
                  <span>LINKS</span>
                  <h2>روابط</h2>
                </div>
              </div>

              <div class="profile-links">
                <a id="badgesLink" href="/badges">عرض بطاقة البادجات</a>
                <button id="copyProfileLink" type="button">نسخ رابط البروفايل</button>
              </div>
            </section>
          </aside>
        </section>
      </section>
    </section>

    <button id="backToTop" class="back-top" type="button" aria-label="الرجوع للأعلى">↑</button>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.42) rgba(0, 0, 0, 0.42);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.42);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.42);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.78), rgba(194, 146, 0, 0.52));
    }

    .hidden {
      display: none !important;
    }

    .tnx-profile-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07070a;
      color: #fff;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .profile-backdrop {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 20% 10%, rgba(255, 218, 106, 0.16), transparent 28%),
        radial-gradient(circle at 86% 15%, rgba(124, 58, 237, 0.14), transparent 30%),
        linear-gradient(135deg, #07070a 0%, #0c0c12 46%, #160d04 100%);
      background-size: cover;
      background-position: center;
      filter: saturate(1.05) contrast(1.04);
      transform: scale(1.02);
    }

    .profile-backdrop::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.34) 46%, rgba(0,0,0,0.78) 100%),
        linear-gradient(180deg, rgba(0,0,0,0.28) 0%, rgba(0,0,0,0.18) 42%, rgba(0,0,0,0.88) 100%);
    }

    .profile-vignette {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.22) 48%, rgba(0, 0, 0, 0.82) 100%);
    }

    .profile-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1160px);
      margin: 0 auto;
      padding: 6rem 1rem 5rem;
    }

    .profile-page-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 430px);
      gap: 1rem;
      align-items: end;
      margin-bottom: 1rem;
    }

    .page-kicker {
      display: inline-flex;
      width: fit-content;
      border: 1px solid rgba(255, 218, 106, 0.26);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.36);
      color: #ffda6a;
      padding: 0.5rem 0.82rem;
      font-size: 0.72rem;
      font-weight: 950;
      letter-spacing: 0.14em;
      backdrop-filter: blur(12px);
    }

    .profile-page-head h1 {
      margin: 0.85rem 0 0;
      color: #fff;
      font-size: clamp(2.8rem, 6vw, 5.6rem);
      font-weight: 950;
      line-height: 0.94;
      letter-spacing: -0.055em;
      text-shadow: 0 0 24px rgba(255, 218, 106, 0.12), 0 6px 22px rgba(0, 0, 0, 0.72);
    }

    .profile-page-head p {
      max-width: 680px;
      margin: 0.95rem 0 0;
      color: rgba(229, 231, 235, 0.78);
      font-size: 0.98rem;
      font-weight: 750;
      line-height: 1.75;
    }

    .profile-search-panel {
      position: relative;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1.2rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.08), transparent 42%),
        rgba(8, 8, 12, 0.74);
      padding: 0.8rem;
      box-shadow: 0 22px 58px rgba(0, 0, 0, 0.36);
      backdrop-filter: blur(16px);
    }

    .profile-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.7rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 0.92rem;
      background: rgba(0, 0, 0, 0.34);
      padding: 0.72rem;
    }

    .profile-search span {
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
    }

    .profile-search input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font-size: 0.94rem;
      font-weight: 850;
    }

    .profile-search button {
      display: grid;
      place-items: center;
      width: 2rem;
      height: 2rem;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.08rem;
      font-weight: 950;
      cursor: pointer;
    }

    .profile-results {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.62rem;
    }

    .profile-result {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.72rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 0.85rem;
      background: rgba(0, 0, 0, 0.34);
      color: white;
      padding: 0.64rem;
      text-align: right;
      cursor: pointer;
      transition: 160ms ease;
    }

    .profile-result:hover {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.42);
      background: rgba(255, 218, 106, 0.08);
    }

    .profile-result img {
      width: 42px;
      height: 42px;
      border-radius: 0.75rem;
      object-fit: cover;
      border: 1px solid rgba(255, 218, 106, 0.22);
    }

    .profile-result strong {
      display: block;
      overflow: hidden;
      color: #f7e6ac;
      font-size: 0.92rem;
      font-weight: 950;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .profile-result span {
      display: block;
      margin-top: 0.12rem;
      color: rgb(156, 163, 175);
      font-size: 0.72rem;
      font-weight: 800;
      direction: ltr;
      text-align: right;
    }

    .empty-state,
    .small-empty {
      display: grid;
      place-items: center;
      gap: 0.4rem;
      min-height: 220px;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at top, rgba(255, 218, 106, 0.08), transparent 45%),
        rgba(8, 8, 12, 0.76);
      padding: 2rem;
      text-align: center;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      backdrop-filter: blur(16px);
    }

    .small-empty {
      min-height: 150px;
      box-shadow: none;
    }

    .empty-state strong,
    .small-empty strong {
      color: #ffda6a;
      font-size: 1.3rem;
      font-weight: 950;
    }

    .empty-state span,
    .small-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.88rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .empty-state b {
      color: #f7e6ac;
      direction: ltr;
      unicode-bidi: embed;
    }

    .profile-content {
      display: grid;
      gap: 1rem;
    }

    .profile-hero {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.45rem;
      background: rgba(8, 8, 12, 0.76);
      box-shadow: 0 28px 80px rgba(0, 0, 0, 0.48);
      backdrop-filter: blur(18px);
    }

    .hero-cover {
      position: absolute;
      inset: 0;
      background-position: center;
      background-size: cover;
      opacity: 0.98;
      filter: saturate(1.04) contrast(1.04);
    }

    .hero-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom, rgba(0,0,0,0.12), rgba(8,8,12,0.58) 46%, rgba(8,8,12,0.96) 100%),
        radial-gradient(circle at 18% 35%, rgba(var(--accent-rgb), 0.28), transparent 34%),
        linear-gradient(to left, rgba(0,0,0,0.58), transparent 45%);
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr) 250px;
      gap: 1.15rem;
      align-items: end;
      min-height: 330px;
      padding: 1.25rem;
    }

    .avatar-frame {
      width: 142px;
      height: 142px;
      border-radius: 1.15rem;
      padding: 5px;
      background:
        linear-gradient(135deg, rgba(255,218,106,0.95), rgba(var(--accent-rgb),0.92), rgba(255,255,255,0.18));
      box-shadow:
        0 22px 44px rgba(0, 0, 0, 0.52),
        0 0 24px rgba(var(--accent-rgb), 0.24);
    }

    .avatar-frame img {
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 0.86rem;
      object-fit: cover;
      background: #111;
    }

    .identity {
      min-width: 0;
    }

    .identity h2 {
      margin: 0;
      overflow: hidden;
      color: #fff;
      font-size: clamp(2.2rem, 5vw, 4.8rem);
      font-weight: 950;
      line-height: 0.96;
      letter-spacing: -0.045em;
      text-overflow: ellipsis;
      text-shadow: 0 5px 20px rgba(0, 0, 0, 0.72);
      white-space: nowrap;
    }

    .login {
      margin: 0.55rem 0 0;
      color: rgba(229, 231, 235, 0.82);
      font-size: 0.9rem;
      font-weight: 850;
      direction: ltr;
      text-align: right;
    }

    .job-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.75rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.42);
      color: #f7e6ac;
      padding: 0.56rem 0.78rem;
      font-size: 0.82rem;
      font-weight: 950;
      backdrop-filter: blur(12px);
    }

    .job-pill iconify-icon {
      color: #ffda6a;
      font-size: 1.12rem;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.9rem;
    }

    .hero-badge {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 0.82rem;
      background: rgba(0, 0, 0, 0.38);
      backdrop-filter: blur(10px);
    }

    .hero-badge img {
      width: 34px;
      height: 34px;
      object-fit: contain;
      filter: drop-shadow(0 7px 10px rgba(0,0,0,0.48));
    }

    .hero-stats {
      display: grid;
      gap: 0.7rem;
    }

    .level-card,
    .wallet-card {
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.45);
      padding: 0.86rem;
      backdrop-filter: blur(14px);
    }

    .level-card span,
    .wallet-card span {
      display: block;
      color: rgb(156, 163, 175);
      font-size: 0.72rem;
      font-weight: 850;
    }

    .level-card strong,
    .wallet-card strong {
      display: block;
      margin-top: 0.25rem;
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      direction: ltr;
      text-align: right;
    }

    .profile-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 320px;
      gap: 1rem;
      align-items: start;
    }

    .profile-main,
    .profile-side {
      display: grid;
      gap: 1rem;
    }

    .profile-panel {
      border: 1px solid rgba(255, 218, 106, 0.15);
      border-radius: 1.25rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.012)),
        rgba(8, 8, 12, 0.78);
      box-shadow:
        0 22px 58px rgba(0, 0, 0, 0.34),
        inset 0 0 20px rgba(255, 218, 106, 0.018);
      padding: 1rem;
      backdrop-filter: blur(16px);
    }

    .panel-head {
      margin-bottom: 0.9rem;
    }

    .panel-head-row {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
    }

    .panel-head span {
      display: block;
      color: #c29200;
      font-size: 0.7rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .panel-head h2 {
      margin: 0.28rem 0 0;
      color: #f7e6ac;
      font-size: 1.38rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .panel-counter {
      display: grid;
      place-items: center;
      min-width: 78px;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.055);
      padding: 0.58rem;
    }

    .panel-counter strong {
      color: #ffda6a;
      font-size: 1.15rem;
      font-weight: 950;
      line-height: 1;
    }

    .panel-counter small {
      margin-top: 0.2rem;
      color: rgb(156, 163, 175);
      font-size: 0.64rem;
      font-weight: 850;
    }

    .display-case {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 0.78rem;
    }

    .display-main {
      min-height: 220px;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 46%),
        rgba(0, 0, 0, 0.28);
      padding: 0.95rem;
      overflow: hidden;
    }

    .display-icon {
      display: grid;
      place-items: center;
      width: 4.4rem;
      height: 4.4rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1rem;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 2rem;
      margin-bottom: 0.85rem;
    }

    .display-main h3 {
      margin: 0;
      color: #fff;
      font-size: 1.35rem;
      font-weight: 950;
      line-height: 1.18;
    }

    .display-main p {
      margin: 0.55rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.82rem;
      font-weight: 800;
      line-height: 1.6;
    }

    .display-main strong {
      display: inline-flex;
      margin-top: 0.8rem;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: #ffda6a;
      padding: 0.4rem 0.55rem;
      font-size: 0.76rem;
      font-weight: 950;
      direction: ltr;
    }

    .display-list {
      display: grid;
      gap: 0.55rem;
    }

    .display-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.7rem;
      border: 1px solid rgba(255, 218, 106, 0.1);
      border-radius: 0.9rem;
      background: rgba(0, 0, 0, 0.27);
      padding: 0.68rem;
    }

    .display-row div {
      min-width: 0;
    }

    .display-row strong {
      display: block;
      overflow: hidden;
      color: #f7e6ac;
      font-size: 0.84rem;
      font-weight: 950;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .display-row span {
      display: block;
      margin-top: 0.16rem;
      color: rgb(156, 163, 175);
      font-size: 0.68rem;
      font-weight: 800;
    }

    .display-row b {
      display: grid;
      place-items: center;
      min-width: 2.4rem;
      height: 2.2rem;
      border-radius: 0.72rem;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 0.74rem;
      font-weight: 950;
      direction: ltr;
    }

    .filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-bottom: 0.85rem;
    }

    .filter-row button {
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 0.78rem;
      background: rgba(255, 218, 106, 0.06);
      color: #f7e6ac;
      padding: 0.5rem 0.68rem;
      font-size: 0.74rem;
      font-weight: 950;
      cursor: pointer;
      transition: 160ms ease;
    }

    .filter-row button:hover,
    .filter-row button.is-active {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.46);
      background: rgba(255, 218, 106, 0.13);
      color: #ffda6a;
    }

    .inventory-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(128px, 1fr));
      gap: 0.68rem;
    }

    .item-card {
      position: relative;
      overflow: hidden;
      min-height: 150px;
      border: 1px solid rgba(255, 218, 106, 0.1);
      border-radius: 0.92rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.01)),
        rgba(0, 0, 0, 0.3);
      padding: 0.72rem;
      transition: 170ms ease;
    }

    .item-card:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 218, 106, 0.4);
      background: rgba(255, 218, 106, 0.07);
    }

    .item-card.is-rare {
      box-shadow: inset 0 0 0 1px rgba(255, 218, 106, 0.18);
    }

    .item-icon {
      display: grid;
      place-items: center;
      width: 2.8rem;
      height: 2.8rem;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 0.8rem;
      background: rgba(255, 218, 106, 0.075);
