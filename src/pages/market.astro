---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'السوق — TNX6',
  ignoreTitleTemplate: true,
  description: 'سوق أغراض مجتمع TNX6 — اشترِ وبيع أغراض الأعضاء.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-market-page" dir="rtl">
    <section class="mkp-shell">
      <div class="mkp-panel">
        <header class="mkp-head">
          <div class="mkp-head-main">
            <h1>السوق</h1>
            <p>اشترِ وبيع أغراض المجتمع</p>
          </div>

          <div class="mkp-head-side">
            <span class="mkp-count">العروض النشطة: <b id="mkpCountMarket">0</b></span>
            <button class="mkp-refresh" type="button" id="mkpRefresh" title="تحديث">
              <span class="mkp-refresh-ico" aria-hidden="true">⟳</span> تحديث
            </button>
          </div>
        </header>

        <nav class="mkp-tabs">
          <button class="mkp-tab active" type="button" data-mkp-tab="market">السوق</button>
          <button class="mkp-tab" type="button" data-mkp-tab="mine" id="mkpMineTab" hidden>
            عروضي <span class="mkp-badge" id="mkpCountMine">0</span>
          </button>
        </nav>

        <div class="mkp-notice" id="mkpNotice" hidden></div>

        <div class="mkp-grid" id="mkpGrid">
          <div class="mkp-empty"><strong>جاري تحميل السوق...</strong></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .tnx-market-page {
    min-height: 82vh;
    padding: 40px 16px 76px;
    color: #f4f4f5;
  }

  .mkp-shell {
    max-width: 1080px;
    margin: 0 auto;
  }

  /* ---------- main panel ---------- */
  .mkp-panel {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      #0d0d10;
    border: 1px solid rgba(255, 223, 138, 0.14);
    border-radius: 26px;
    padding: 26px 26px 28px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    min-height: 540px;
    display: flex;
    flex-direction: column;
  }

  /* ---------- header ---------- */
  .mkp-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .mkp-head-main h1 {
    margin: 0;
    font-size: 24px;
    font-weight: 1000;
    color: #ffda6a;
    letter-spacing: -0.01em;
  }

  .mkp-head-main p {
    margin: 5px 0 0;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.52);
    font-weight: 700;
  }

  .mkp-head-side {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .mkp-count {
    font-size: 12.5px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.55);
    white-space: nowrap;
  }

  .mkp-count b {
    color: #ffda6a;
    font-weight: 1000;
    font-variant-numeric: tabular-nums;
  }

  .mkp-refresh {
    height: 36px;
    padding: 0 15px;
    border-radius: 12px;
    border: 1px solid rgba(255, 223, 138, 0.18);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.72);
    font-size: 12.5px;
    font-weight: 900;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .mkp-refresh:hover {
    color: #ffe1a8;
    border-color: rgba(255, 223, 138, 0.4);
    background: rgba(255, 218, 106, 0.08);
  }

  .mkp-refresh-ico {
    font-size: 15px;
    line-height: 1;
  }

  .mkp-refresh.is-loading .mkp-refresh-ico {
    animation: mkpspin 0.8s linear infinite;
    display: inline-block;
  }

  /* ---------- tabs ---------- */
  .mkp-tabs {
    display: inline-flex;
    gap: 5px;
    margin: 18px 0 4px;
    padding: 5px;
    border-radius: 14px;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.06);
    width: fit-content;
  }

  .mkp-tab {
    height: 38px;
    padding: 0 20px;
    border: 1px solid transparent;
    border-radius: 10px;
    background: transparent;
    color: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    font-size: 13.5px;
    font-weight: 1000;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }

  .mkp-tab:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .mkp-tab.active {
    background: rgba(255, 218, 106, 0.12);
    border-color: rgba(255, 223, 138, 0.32);
    color: #ffda6a;
  }

  .mkp-badge {
    min-width: 19px;
    height: 19px;
    padding: 0 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    display: inline-grid;
    place-items: center;
    font-size: 10.5px;
    font-weight: 1000;
  }

  .mkp-tab.active .mkp-badge {
    background: rgba(255, 218, 106, 0.2);
    color: #ffe9ad;
  }

  /* ---------- notice ---------- */
  .mkp-notice {
    margin: 16px 0 0;
    padding: 11px 15px;
    border-radius: 13px;
    font-size: 12.5px;
    font-weight: 900;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.75);
  }

  .mkp-notice.is-ok {
    border-color: rgba(255, 223, 138, 0.3);
    background: rgba(255, 218, 106, 0.08);
    color: #ffe1a1;
  }

  .mkp-notice.is-error {
    border-color: rgba(239, 68, 68, 0.34);
    background: rgba(239, 68, 68, 0.08);
    color: #ffb0b0;
  }

  /* ---------- grid ---------- */
  .mkp-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 18px;
    flex: 1;
    align-content: start;
  }

  /* ---------- offer card ---------- */
  .mkp-card {
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    padding: 17px 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color 0.15s, background 0.15s;
  }

  .mkp-card:hover {
    border-color: rgba(255, 223, 138, 0.26);
    background: rgba(255, 218, 106, 0.045);
  }

  .mkp-card-head {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .mkp-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 13px;
    display: grid;
    place-items: center;
    background: rgba(255, 218, 106, 0.09);
    border: 1px solid rgba(255, 223, 138, 0.22);
    font-size: 21px;
    flex: 0 0 auto;
  }

  .mkp-card-title {
    min-width: 0;
    display: flex;
    align-items: baseline;
    gap: 7px;
    flex-wrap: wrap;
  }

  .mkp-card-title strong {
    font-size: 15.5px;
    font-weight: 1000;
    color: #fff;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mkp-card-title span {
    font-size: 12px;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.5);
  }

  /* meta rows */
  .mkp-card-meta {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding-top: 13px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .mkp-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    min-width: 0;
  }

  .mkp-meta-label {
    font-size: 12px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.45);
    flex: 0 0 auto;
  }

  .mkp-meta-price {
    font-size: 15px;
    font-weight: 1000;
    color: #ffda6a;
    font-variant-numeric: tabular-nums;
  }

  .mkp-meta-seller {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    font-size: 12.5px;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.72);
    overflow: hidden;
  }

  .mkp-meta-seller img,
  .mkp-seller-fallback {
    width: 22px;
    height: 22px;
    border-radius: 999px;
    flex: 0 0 auto;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .mkp-seller-fallback {
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.6);
    font-size: 10.5px;
    font-weight: 1000;
    border-style: solid;
  }

  .mkp-meta-seller span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .mkp-meta-value {
    font-size: 12.5px;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.68);
  }

  /* status pill */
  .mkp-status {
    display: inline-flex;
    align-items: center;
    padding: 4px 11px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 1000;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mkp-status.is-live {
    background: rgba(255, 218, 106, 0.1);
    color: #ffda6a;
    border-color: rgba(255, 223, 138, 0.3);
  }

  .mkp-status.is-wait {
    background: rgba(250, 204, 21, 0.08);
    color: #f5d97a;
    border-color: rgba(250, 204, 21, 0.22);
  }

  .mkp-status.is-done {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.72);
    border-color: rgba(255, 255, 255, 0.13);
  }

  .mkp-status.is-err {
    background: rgba(239, 68, 68, 0.08);
    color: #ffb0b0;
    border-color: rgba(239, 68, 68, 0.25);
  }

  /* action */
  .mkp-card-action {
    margin-top: auto;
  }

  .mkp-buy {
    height: 42px;
    border: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, #ffda6a, #c29200);
    color: #241404;
    font-size: 13.5px;
    font-weight: 1000;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    width: 100%;
    transition: filter 0.15s;
  }

  .mkp-buy:hover {
    filter: brightness(1.06);
  }

  .mkp-buy:disabled {
    cursor: wait;
    opacity: 0.8;
  }

  .mkp-buy.is-done {
    background: rgba(255, 218, 106, 0.14);
    color: #ffe1a1;
    border: 1px solid rgba(255, 223, 138, 0.32);
  }

  .mkp-own {
    height: 42px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.5);
    font-size: 12.5px;
    font-weight: 900;
    display: grid;
    place-items: center;
  }

  .mkp-login {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 42px;
    border-radius: 12px;
    border: 1px solid rgba(255, 223, 138, 0.36);
    background: rgba(255, 218, 106, 0.08);
    color: #ffe1a8;
    font-size: 12.5px;
    font-weight: 1000;
    text-decoration: none;
    width: 100%;
  }

  .mkp-cancel {
    height: 40px;
    border-radius: 12px;
    border: 1px solid rgba(239, 68, 68, 0.28);
    background: rgba(239, 68, 68, 0.06);
    color: #ffb0b0;
    font-size: 12.5px;
    font-weight: 1000;
    cursor: pointer;
    width: 100%;
    transition: background 0.15s;
  }

  .mkp-cancel:hover {
    background: rgba(239, 68, 68, 0.1);
  }

  .mkp-cancel:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  /* ---------- empty ---------- */
  .mkp-empty {
    grid-column: 1 / -1;
    min-height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 8px;
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.012);
  }

  .mkp-empty strong {
    color: rgba(255, 255, 255, 0.75);
    font-size: 15px;
    font-weight: 1000;
  }

  .mkp-empty span {
    color: rgba(255, 255, 255, 0.42);
    font-size: 12.5px;
    font-weight: 700;
  }

  /* ---------- spinner ---------- */
  .mkp-spin {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    border: 2px solid rgba(36, 20, 4, 0.25);
    border-top-color: #241404;
    animation: mkpspin 0.7s linear infinite;
    display: inline-block;
    flex: 0 0 auto;
  }

  @keyframes mkpspin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ---------- responsive ---------- */
  @media (max-width: 720px) {
    .mkp-panel {
      padding: 20px 16px 24px;
      border-radius: 20px;
    }

    .mkp-head {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .mkp-head-side {
      justify-content: space-between;
    }

    .mkp-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function () {
    var API = 'https://api.tnx6.xyz'

    var mkp = {
      me: null,
      listings: [],
      mine: [],
      tab: 'market',
      busy: false,
    }

    function el(id) { return document.getElementById(id) }

    function escText(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
    }

    function fmt(value) {
      try { return new Intl.NumberFormat('en-US').format(Number(value || 0)) } catch { return String(value || 0) }
    }

    function remainingText(seconds) {
      var total = Math.max(0, Math.floor(Number(seconds || 0)))
      if (total <= 0) return 'ينتهي الآن'
      var h = Math.floor(total / 3600)
      var m = Math.floor((total % 3600) / 60)
      if (h > 0) return 'بعد ' + h + 'س ' + (m > 0 ? m + 'د' : '')
      if (m > 0) return 'بعد ' + m + 'د'
      return 'أقل من دقيقة'
    }

    function statusInfo(status) {
      if (status === 'active') return { cls: 'is-live', text: 'نشط' }
      if (status === 'pending_list') return { cls: 'is-wait', text: 'قيد النشر' }
      if (status === 'pending_buy') return { cls: 'is-wait', text: 'قيد الشراء' }
      if (status === 'pending_refund') return { cls: 'is-wait', text: 'قيد الاسترجاع' }
      if (status === 'sold') return { cls: 'is-done', text: 'مباع ✓' }
      if (status === 'refunded') return { cls: 'is-done', text: 'رجع لك' }
      if (status === 'cancelled') return { cls: 'is-done', text: 'ملغي' }
      return { cls: 'is-err', text: 'خطأ' }
    }

    function buyErrorText(error) {
      var value = String(error || '').toLowerCase()
      if (value.indexOf('not_enough_points') >= 0) return 'نقاطك ما تكفي لهذا الشراء.'
      if (value.indexOf('item_limit_reached') >= 0) return 'وصلت الحد الأعلى من هذا الغرض.'
      if (value.indexOf('listing_unavailable') >= 0) return 'العرض ما عاد متاحًا.'
      if (value.indexOf('own_listing') >= 0) return 'هذا عرضك أنت.'
      if (value.indexOf('parse_failed') >= 0) return 'صار خطأ في البيانات، تواصل مع الإدارة.'
      if (value.indexOf('timeout') >= 0) return 'تأخر التنفيذ، جرّب بعد قليل.'
      return 'حدث خطأ، جرّب بعد قليل.'
    }

    function setNotice(kind, text) {
      var box = el('mkpNotice')
      if (!box) return

      if (!text) {
        box.hidden = true
        return
      }

      box.hidden = false
      box.className = 'mkp-notice' + (kind ? ' is-' + kind : '')
      box.textContent = text
    }

    function setRefreshLoading(on) {
      var btn = el('mkpRefresh')
      if (btn) btn.classList.toggle('is-loading', !!on)
    }

    async function fetchMe() {
      if (mkp.me !== null) return mkp.me

      try {
        var res = await fetch(API + '/api/me', { credentials: 'include', cache: 'no-store' })
        var data = await res.json().catch(function () { return null })
        mkp.me = res.ok && data ? (data.user || data) : false
      } catch { mkp.me = false }

      return mkp.me
    }

    function meId() {
      var me = mkp.me
      if (!me) return ''
      return String(me.twitchId || me.twitch_id || me.userId || me.id || '')
    }

    async function loadAll() {
      if (mkp.busy) return
      mkp.busy = true
      setRefreshLoading(true)

      try {
        await fetchMe()

        var jobs = [fetch(API + '/api/market/listings?v=' + Date.now(), { cache: 'no-store' })]

        if (mkp.me) {
          jobs.push(fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' }))
        }

        var responses = await Promise.all(jobs)
        var marketData = await responses[0].json().catch(function () { return null })

        if (marketData && marketData.ok) {
          mkp.listings = marketData.listings || []
        }

        if (responses[1]) {
          var mineData = await responses[1].json().catch(function () { return null })
          if (mineData && mineData.ok) mkp.mine = mineData.listings || []
        }

        render()
      } catch (error) {
        console.warn('[Market] load failed', error)
      } finally {
        mkp.busy = false
        setRefreshLoading(false)
      }
    }

    function sellerAvatar(listing) {
      return listing.sellerImage
        ? '<img src="' + escText(listing.sellerImage) + '" alt="" loading="lazy" referrerpolicy="no-referrer">'
        : '<span class="mkp-seller-fallback">' + escText(String(listing.sellerName || '؟').charAt(0).toUpperCase()) + '</span>'
    }

    function cardHead(listing) {
      return (
        '<div class="mkp-card-head">' +
          '<div class="mkp-card-icon">📦</div>' +
          '<div class="mkp-card-title">' +
            '<strong>' + escText(listing.itemName) + '</strong>' +
            '<span>×' + fmt(listing.quantity) + '</span>' +
          '</div>' +
        '</div>'
      )
    }

    function metaRow(label, valueHtml) {
      return (
        '<div class="mkp-meta-row">' +
          '<span class="mkp-meta-label">' + label + '</span>' +
          valueHtml +
        '</div>'
      )
    }

    function marketCard(listing) {
      var isOwn = mkp.me && listing.sellerId === meId()

      var action = ''
      if (!mkp.me) {
        action = '<a class="mkp-login" href="' + API + '/auth/twitch/login">سجل دخول للشراء</a>'
      } else if (isOwn) {
        action = '<div class="mkp-own">هذا عرضك</div>'
      } else {
        action = '<button class="mkp-buy" type="button" data-mkp-buy="' + escText(listing.listingId) + '">شراء</button>'
      }

      var seller =
        '<span class="mkp-meta-seller">' +
          sellerAvatar(listing) +
          '<span>' + escText(listing.sellerName || listing.sellerLogin || '') + '</span>' +
        '</span>'

      return (
        '<article class="mkp-card">' +
          cardHead(listing) +
          '<div class="mkp-card-meta">' +
            metaRow('السعر', '<span class="mkp-meta-price">' + fmt(listing.price) + ' نقطة</span>') +
            metaRow('البائع', seller) +
            metaRow('ينتهي', '<span class="mkp-meta-value">' + remainingText(listing.remainingSeconds) + '</span>') +
          '</div>' +
          '<div class="mkp-card-action">' + action + '</div>' +
        '</article>'
      )
    }

    function mineCard(listing) {
      var info = statusInfo(listing.status)
      var isActive = listing.status === 'active'

      var rows =
        metaRow('السعر', '<span class="mkp-meta-price">' + fmt(listing.price) + ' نقطة</span>') +
        metaRow('الحالة', '<span class="mkp-status ' + info.cls + '">' + info.text + '</span>')

      if (listing.status === 'sold' && listing.buyerName) {
        rows += metaRow('المشتري', '<span class="mkp-meta-value">' + escText(listing.buyerName) + '</span>')
      }

      if (isActive) {
        rows += metaRow('ينتهي', '<span class="mkp-meta-value">' + remainingText(listing.remainingSeconds) + '</span>')
      }

      var action = isActive
        ? '<button class="mkp-cancel" type="button" data-mkp-cancel="' + escText(listing.listingId) + '">إلغاء العرض</button>'
        : ''

      return (
        '<article class="mkp-card">' +
          cardHead(listing) +
          '<div class="mkp-card-meta">' + rows + '</div>' +
          (action ? '<div class="mkp-card-action">' + action + '</div>' : '') +
        '</article>'
      )
    }

    function render() {
      var grid = el('mkpGrid')
      if (!grid) return

      var mineTab = el('mkpMineTab')
      if (mineTab) mineTab.hidden = !mkp.me

      if (!mkp.me && mkp.tab === 'mine') mkp.tab = 'market'

      var countMarket = el('mkpCountMarket')
      if (countMarket) countMarket.textContent = fmt(mkp.listings.length)

      var countMine = el('mkpCountMine')
      if (countMine) countMine.textContent = fmt(mkp.mine.length)

      document.querySelectorAll('[data-mkp-tab]').forEach(function (btn) {
        btn.classList.toggle('active', btn.getAttribute('data-mkp-tab') === mkp.tab)
      })

      if (mkp.tab === 'mine') {
        grid.innerHTML = mkp.mine.length
          ? mkp.mine.map(mineCard).join('')
          : '<div class="mkp-empty"><strong>لا توجد عروض حاليًا</strong><span>اعرض غرضًا من حقيبتك ليظهر هنا</span></div>'
        return
      }

      grid.innerHTML = mkp.listings.length
        ? mkp.listings.map(marketCard).join('')
        : '<div class="mkp-empty"><strong>لا توجد عروض حاليًا</strong><span>اعرض غرضًا من حقيبتك ليظهر هنا</span></div>'
    }

    async function pollRequest(requestId, timeoutMs) {
      var startedAt = Date.now()
      var limit = timeoutMs || 9000
      var wait = 700

      while (Date.now() - startedAt < limit) {
        await new Promise(function (resolve) { setTimeout(resolve, wait) })
        wait = 1500

        try {
          var res = await fetch(API + '/api/me/market/request-status?id=' + encodeURIComponent(requestId) + '&v=' + Date.now(), {
            credentials: 'include',
            cache: 'no-store',
          })

          var data = await res.json().catch(function () { return null })

          if (!res.ok || !data || data.ok !== true) continue
          if (data.status === 'completed') return { ok: true }
          if (data.status === 'error') return { error: data.errorMessage || 'failed' }
        } catch {}
      }

      return { timeout: true }
    }

    // متابعة خلفية لطلب الشراء بعد انتهاء المهلة السريعة — تحدّث الحالة عند التأكيد الفعلي
    async function watchBuyRequest(requestId) {
      var result = await pollRequest(requestId, 60000)

      if (result.ok) {
        setNotice('ok', 'تم الشراء ✓ الغرض وصل حقيبتك.')
      } else if (result.error) {
        setNotice('error', buyErrorText(result.error))
      } else {
        setNotice('', 'ما زال طلبك قيد المعالجة، حدّث الصفحة بعد قليل.')
      }

      await loadAll()
    }

    // متابعة خلفية لطلب الإلغاء — تحدّث الحالة عند رجوع الغرض فعليًا
    async function watchCancelRequest(listingId) {
      var startedAt = Date.now()

      while (Date.now() - startedAt < 60000) {
        await new Promise(function (resolve) { setTimeout(resolve, 2000) })

        try {
          var check = await fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })
          var checkData = await check.json().catch(function () { return null })

          if (checkData && checkData.ok) {
            var found = (checkData.listings || []).find(function (entry) { return entry.listingId === listingId })

            if (found && (found.status === 'cancelled' || found.status === 'refunded')) {
              setNotice('ok', 'رجع الغرض لحقيبتك ✓')
              await loadAll()
              return
            }

            if (found && found.status === 'error') {
              setNotice('error', 'صار خطأ أثناء الإلغاء، تواصل مع الإدارة.')
              await loadAll()
              return
            }
          }
        } catch {}
      }

      await loadAll()
    }

    async function buyListing(listingId, button) {
      setNotice('', '')
      button.disabled = true
      button.innerHTML = '<span class="mkp-spin"></span>جاري الشراء...'

      try {
        var res = await fetch(API + '/api/me/market/buy', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: listingId }),
        })

        var data = await res.json().catch(function () { return null })

        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', buyErrorText((data && data.error) || 'buy_failed'))
          button.disabled = false
          button.textContent = 'شراء'
          await loadAll()
          return
        }

        var result = await pollRequest(data.requestId, 9000)

        if (result.ok) {
          button.classList.add('is-done')
          button.textContent = 'تم الشراء ✓'
          setNotice('ok', 'تم الشراء ✓ الغرض وصل حقيبتك.')
          setTimeout(function () { loadAll() }, 1200)
          return
        }

        if (result.error) {
          setNotice('error', buyErrorText(result.error))
          button.disabled = false
          button.textContent = 'شراء'
          await loadAll()
          return
        }

        // لا نعرض نجاحًا وهميًا — الطلب قيد المعالجة ونتابعه في الخلفية حتى يتأكد
        button.textContent = 'قيد المعالجة...'
        setNotice('', 'طلبك قيد المعالجة، سيتم تحديث الحالة خلال لحظات.')
        watchBuyRequest(data.requestId)
        await loadAll()
        return
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
        button.disabled = false
        button.textContent = 'شراء'
        await loadAll()
      }
    }

    async function cancelListing(listingId, button) {
      setNotice('', '')
      button.disabled = true
      button.innerHTML = '<span class="mkp-spin" style="border-color:rgba(255,176,176,.3);border-top-color:#ffb0b0"></span>جاري الإلغاء...'

      try {
        var res = await fetch(API + '/api/me/market/cancel', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: listingId }),
        })

        var data = await res.json().catch(function () { return null })

        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', 'تعذر إلغاء العرض، جرّب بعد قليل.')
          button.disabled = false
          button.textContent = 'إلغاء العرض'
          await loadAll()
          return
        }

        var startedAt = Date.now()
        var done = false

        while (Date.now() - startedAt < 8000) {
          await new Promise(function (resolve) { setTimeout(resolve, 1000) })

          try {
            var check = await fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })
            var checkData = await check.json().catch(function () { return null })

            if (checkData && checkData.ok) {
              var found = (checkData.listings || []).find(function (entry) { return entry.listingId === listingId })

              if (found && (found.status === 'cancelled' || found.status === 'refunded')) {
                setNotice('ok', 'رجع الغرض لحقيبتك ✓')
                done = true
                break
              }

              if (found && found.status === 'error') {
                setNotice('error', 'صار خطأ أثناء الإلغاء، تواصل مع الإدارة.')
                done = true
                break
              }
            }
          } catch {}
        }

        if (!done) {
          // لا نعرض نجاحًا وهميًا — الإلغاء قيد المعالجة ونتابعه في الخلفية
          setNotice('', 'طلب الإلغاء قيد المعالجة، سيتم تحديث الحالة خلال لحظات.')
          watchCancelRequest(listingId)
        }

        await loadAll()
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
        await loadAll()
      }
    }

    document.addEventListener('click', function (event) {
      var target = event.target
      if (!(target instanceof Element)) return

      var tabButton = target.closest('[data-mkp-tab]')
      if (tabButton) {
        mkp.tab = tabButton.getAttribute('data-mkp-tab') || 'market'
        render()
        return
      }

      var buyButton = target.closest('[data-mkp-buy]')
      if (buyButton) {
        buyListing(buyButton.getAttribute('data-mkp-buy') || '', buyButton)
        return
      }

      var cancelButton = target.closest('[data-mkp-cancel]')
      if (cancelButton) {
        cancelListing(cancelButton.getAttribute('data-mkp-cancel') || '', cancelButton)
      }
    })

    var refreshButton = el('mkpRefresh')
    if (refreshButton) refreshButton.addEventListener('click', function () { loadAll() })

    // تحديث دوري خفيف — فقط والصفحة ظاهرة
    setInterval(function () {
      if (!document.hidden) loadAll()
    }, 60000)

    loadAll()
  })()
</script>
