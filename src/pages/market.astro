    function el(id) { return document.getElementById(id) }

    function escText(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
    }

    function fmt(value) {
      try { return new Intl.NumberFormat('en-US').format(Number(value || 0)) } catch { return String(value || 0) }
    }

    function mktPrefersReducedMotion() {
      try {
        return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches
      } catch {
        return false
      }
    }

    function mktEaseOutCubic(t) {
      return 1 - Math.pow(1 - t, 3)
    }

    function mktCountUp(elm, from, to, duration) {
      if (!elm) return
      if (mktActiveCountFrame) cancelAnimationFrame(mktActiveCountFrame)

      if (mktPrefersReducedMotion() || from === to) {
        elm.textContent = fmt(to)
        return
      }

      var startedAt = performance.now()
      var diff = to - from
      var limit = duration || 600

      function frame(now) {
        var p = Math.min((now - startedAt) / limit, 1)
        var eased = mktEaseOutCubic(p)
        elm.textContent = fmt(Math.round(from + diff * eased))
        if (p < 1) {
          mktActiveCountFrame = requestAnimationFrame(frame)
        } else {
          mktActiveCountFrame = 0
        }
      }

      mktActiveCountFrame = requestAnimationFrame(frame)
    }

    function updateActiveCount(next) {
      var activeCount = el('mktActiveCount')
      var value = Math.max(0, Math.floor(Number(next || 0)))
      mktCountUp(activeCount, mktActiveCountValue, value, 620)
      mktActiveCountValue = value
    }

    function addMarketRipple(event) {
      if (mktPrefersReducedMotion()) return
      var target = event.target
      if (!(target instanceof Element)) return
      var trigger = target.closest('.mkt-ripple')
      if (!trigger || trigger.disabled) return

      var rect = trigger.getBoundingClientRect()
      var size = Math.max(rect.width, rect.height)
      var wave = document.createElement('span')
      wave.className = 'mkt-ripple-wave'
      wave.style.width = size + 'px'
      wave.style.height = size + 'px'
      wave.style.left = (event.clientX - rect.left - size / 2) + 'px'
      wave.style.top = (event.clientY - rect.top - size / 2) + 'px'
      trigger.appendChild(wave)
      window.setTimeout(function () { wave.remove() }, 620)
    }

    function waitForCardExit(card) {
      if (!card || mktPrefersReducedMotion()) return Promise.resolve()
      card.classList.add('is-removing')
      return new Promise(function (resolve) {
        var done = false
        function finish() {
          if (done) return
          done = true
          resolve()
        }
        card.addEventListener('animationend', finish, { once: true })
        window.setTimeout(finish, 280)
      })
    }

    function closeMarketModal(selector, afterClose, immediate) {
      var modal = document.querySelector(selector)
      if (!modal) {
        if (afterClose) afterClose()
        return
      }

      function removeNow() {
        modal.remove()
        if (afterClose) afterClose()
      }

      if (immediate || modal.classList.contains('is-closing') || mktPrefersReducedMotion()) {
        removeNow()
        return
      }

      modal.classList.add('is-closing')
      var done = false
      function finish(event) {
        if (event && event.target !== modal) return
        if (done) return
        done = true
        modal.removeEventListener('animationend', finish)
        removeNow()
      }

      modal.addEventListener('animationend', finish)
      window.setTimeout(function () { finish() }, 240)
    }

    function errorHtml() {
      return (
        '<div class="mkt-empty">' +
          '<div class="mkt-empty-icon">' + ICON_STORE + '</div>' +
          '<div class="mkt-empty-title">تعذر تحميل السوق</div>' +
          '<div class="mkt-empty-desc">جرّب التحديث بعد لحظات.</div>' +
        '</div>'
      )
    }

    function normalizeMarketText(value) {
      return String(value == null ? '' : value)
        .toLowerCase()
        .replace(/[إأآ]/g, 'ا')
        .replace(/ى/g, 'ي')
        .replace(/ة/g, 'ه')
        .trim()
    }

    function listingSearchText(listing) {
      return normalizeMarketText([
        listing.itemName,
        listing.item_name,
        listing.name,
        listing.sellerName,
        listing.sellerDisplayName,
        listing.userDisplayName,
        listing.sellerLogin,
        listing.seller_login,
      ].join(' '))
    }

    function listingCreatedTime(listing) {
      var values = [
        listing.createdAt,
        listing.created_at,
        listing.listedAt,
        listing.listed_at,
        listing.created,
        listing.timestamp,
      ]

      for (var i = 0; i < values.length; i++) {
        var t = Date.parse(values[i])
        if (Number.isFinite(t)) return t
      }

      return 0
    }

    function listingEndingValue(listing) {
      var remaining = Number(listing.remainingSeconds)
      if (Number.isFinite(remaining) && remaining >= 0) return remaining

      var expires = Date.parse(listing.expiresAt || listing.expires_at || listing.expires)
      if (Number.isFinite(expires)) return Math.max(0, Math.ceil((expires - Date.now()) / 1000))

      return Number.MAX_SAFE_INTEGER
    }

    function getVisibleMarketListings(listings) {
      var visible = (listings || []).slice()
      var query = normalizeMarketText(mkp.marketSearchQuery)

      if (query) {
        visible = visible.filter(function (listing) {
          return listingSearchText(listing).indexOf(query) >= 0
        })
      }

      var mode = mkp.marketSortMode || 'newest'
      return visible
        .map(function (listing, index) { return { listing: listing, index: index } })
        .sort(function (a, b) {
          if (mode === 'price-asc') {
            return (Number(a.listing.price || 0) - Number(b.listing.price || 0)) || (a.index - b.index)
          }

          if (mode === 'price-desc') {
            return (Number(b.listing.price || 0) - Number(a.listing.price || 0)) || (a.index - b.index)
          }

          if (mode === 'ending-soon') {
            return (listingEndingValue(a.listing) - listingEndingValue(b.listing)) || (a.index - b.index)
          }

          return (listingCreatedTime(b.listing) - listingCreatedTime(a.listing)) || (a.index - b.index)
        })
        .map(function (entry) { return entry.listing })
    }

    function remainingText(seconds) {
      var total = Math.max(0, Math.floor(Number(seconds || 0)))
      if (total <= 0) return 'ينتهي الآن'
      var h = Math.floor(total / 3600)
      var m = Math.floor((total % 3600) / 60)
      if (h > 0) return 'بعد ' + h + 'س ' + (m > 0 ? m + 'د' : '')
      if (m > 0) return 'بعد ' + m + 'د'
      return 'أقل من دقيقة'
    }

    function statusInfo(status) {
      if (status === 'active') return { cls: 'is-green', text: 'نشط' }
      if (status === 'pending_list') return { cls: 'is-amber is-pending', text: 'قيد النشر' }
      if (status === 'pending_buy') return { cls: 'is-amber is-pending', text: 'قيد الشراء' }
      if (status === 'pending_refund') return { cls: 'is-amber is-pending', text: 'قيد الاسترجاع' }
      if (status === 'sold') return { cls: 'is-green', text: 'مباع' }
      if (status === 'refunded') return { cls: 'is-blue', text: 'رجع لك' }
      if (status === 'cancelled') return { cls: 'is-red', text: 'ملغي' }
      return { cls: 'is-red', text: 'خطأ' }
    }

    function isTerminal(status) {
      return status === 'sold' || status === 'refunded' || status === 'cancelled' || status === 'error'
    }

    function buyErrorText(error) {
      var value = String(error || '').toLowerCase()
      if (value.indexOf('not_enough_points') >= 0) return 'نقاطك ما تكفي لهذا الشراء.'
      if (value.indexOf('item_limit_reached') >= 0) return 'وصلت الحد الأعلى من هذا الغرض.'
      if (value.indexOf('listing_unavailable') >= 0) return 'العرض ما عاد متاحًا.'
      if (value.indexOf('own_listing') >= 0) return 'هذا عرضك أنت.'
      if (value.indexOf('parse_failed') >= 0) return 'صار خطأ في البيانات، تواصل مع الإدارة.'
      if (value.indexOf('timeout') >= 0) return 'تأخر التنفيذ، جرّب بعد قليل.'
      return 'حدث خطأ، جرّب بعد قليل.'
    }

    function listErrorText(error, data) {
      var v = String(error || '').toLowerCase()
      if (v.indexOf('missing_item') >= 0) return 'الكمية المطلوبة غير متوفرة في حقيبتك.'
      if (v.indexOf('listing_limit_reached') >= 0) return 'وصلت الحد الأعلى للعروض المتزامنة (' + ((data && data.limit) || 3) + ').'
      if (v.indexOf('invalid_price') >= 0) return 'السعر لازم يكون ' + fmt((data && data.minPrice) || 500) + ' نقطة أو أكثر.'
      if (v.indexOf('not_enough_points_fee') >= 0) return 'نقاطك ما تكفي لرسوم المدة المختارة.'
      if (v.indexOf('inventory_parse_failed') >= 0) return 'صار خطأ في بيانات الحقيبة، تواصل مع الإدارة.'
      if (v.indexOf('invalid_duration') >= 0) return 'اختر مدة عرض صحيحة.'
      if (v.indexOf('timeout') >= 0) return 'تأخر النشر، جرّب بعد قليل.'
      return 'حدث خطأ، جرّب بعد قليل.'
    }

    function archiveErrorText(error) {
      var v = String(error || '').toLowerCase()
      if (v.indexOf('not_archivable') >= 0) return 'ما نقدر نحذف عرضًا نشطًا أو قيد المعالجة.'
      if (v.indexOf('not_found') >= 0) return 'العرض غير موجود.'
      if (v.indexOf('unauthorized') >= 0) return 'سجّل دخولك أولًا.'
      return 'تعذر حذف العرض، جرّب بعد قليل.'
    }

    function offerErrorText(error) {
      var v = String(error || '').toLowerCase()
      if (v.indexOf('insufficient_available_points') >= 0) return 'عندك عروض معلقة تتجاوز رصيدك الحالي.'
      if (v.indexOf('buyer_insufficient_points') >= 0) return 'تعذر قبول العرض لأن المشتري لا يملك نقاطًا كافية الآن.'
      if (v.indexOf('insufficient_points') >= 0) return 'نقاطك غير كافية لإرسال هذا العرض.'
      if (v.indexOf('pending_offer_exists') >= 0) return 'عندك عرض معلق على هذا الغرض.'
      if (v.indexOf('empty_offer') >= 0) return 'أضف نقاطًا أو غرضًا واحدًا على الأقل.'
      if (v.indexOf('offers_disabled') >= 0) return 'البائع لا يستقبل عروضًا على هذا الغرض.'
      if (v.indexOf('not_enough_offer_items') >= 0 || v.indexOf('insufficient_offer_items') >= 0) return 'بعض الأغراض المعروضة غير متوفرة الآن في حقيبتك.'
      if (v.indexOf('too_many_offer_items') >= 0) return 'قلّل عدد أنواع الأغراض في العرض.'
      if (v.indexOf('invalid_offer_item_quantity') >= 0) return 'كمية أحد الأغراض غير صحيحة.'
      if (v.indexOf('offer_item_not_tradeable') >= 0) return 'أحد الأغراض لا يمكن تداوله في السوق.'
      if (v.indexOf('offer_item_not_found') >= 0 || v.indexOf('inventory_lookup_failed') >= 0) return 'تعذر التحقق من أحد الأغراض في العرض.'
      if (v.indexOf('not_archivable') >= 0) return 'لا يمكن إخفاء عرض ما زال قيد المعالجة.'
      if (v.indexOf('listing_unavailable') >= 0) return 'العرض ما عاد متاحًا.'
      if (v.indexOf('own_listing') >= 0) return 'هذا عرضك أنت.'
      if (v.indexOf('invalid') >= 0) return 'أدخل سعرًا صحيحًا.'
      return 'حدث خطأ، جرّب بعد قليل.'
    }

    // أرشفة على الخادم (إخفاء من قائمتك فقط، بدون حذف نهائي)
    async function archiveListing(listingId, btn) {
      if (btn) { btn.disabled = true; btn.textContent = '…' }

      try {
        var res = await fetch(API + '/api/me/market/archive-listing', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: listingId }),
        })

        var data = await res.json().catch(function () { return null })

        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', archiveErrorText(data && data.error))
          if (btn) { btn.disabled = false; btn.textContent = '×' }
          return false
        }

        return true
      } catch {
        setNotice('error', 'تعذر حذف العرض، جرّب بعد قليل.')
        if (btn) { btn.disabled = false; btn.textContent = '×' }
        return false
      }
    }

    function setNotice(kind, text) {
      var box = el('mktNotice')
      if (!box) return
      if (mktNoticeTimer) {
        clearTimeout(mktNoticeTimer)
        mktNoticeTimer = 0
      }

      if (!text) {
        box.hidden = true
        box.innerHTML = ''
        return
      }

      box.hidden = false
      box.className = 'mkt-notice' + (kind ? ' is-' + kind : '')
      box.innerHTML =
        '<span class="mkt-notice-text">' + escText(text) + '</span>' +
        '<button type="button" class="mkt-notice-close" data-mkt-notice-close aria-label="إغلاق التنبيه">×</button>'
    }

    function setRefreshLoading(on) {
      var btn = el('mktRefresh')
      if (btn) btn.classList.toggle('is-loading', !!on)
    }

    function clearHeaderOfferBadges() {
      ;['tnx-market-alert-badge', 'tnx-market-alert-menu-badge'].forEach(function (id) {
        var badge = document.getElementById(id)
        if (!badge) return
        badge.textContent = ''
        badge.classList.remove('is-visible')
        badge.setAttribute('aria-hidden', 'true')
      })
    }

    function rememberUnreadOffers(offers) {
      ;(offers || []).forEach(function (offer) {
        if (!offer || !offer.offerId || !offer.isUnreadForCurrentUser) return
        mkp.unreadOfferSession[offer.offerId] = offer.unreadEventType || 'offer_update'
      })
    }

    function currentUnreadOfferSignature() {
      var seen = {}
      ;((mkp.offers && mkp.offers.offers) || []).forEach(function (offer) {
        if (!offer || !offer.offerId || !offer.isUnreadForCurrentUser) return
        seen[offer.offerId] = true
      })
      return Object.keys(seen).sort().join('|')
    }

    function markIncomingOffersSeenFromMarket() {
      if (!mkp.me) return
      var signature = currentUnreadOfferSignature()
      clearHeaderOfferBadges()
      if (!signature || signature === marketOffersSeenSignature) return
      marketOffersSeenSignature = signature

      try {
        fetch(API + '/api/me/market/offers/mark-seen', {
          method: 'POST',
          credentials: 'include',
          cache: 'no-store',
          keepalive: true,
        }).catch(function () {
          marketOffersSeenSignature = ''
        })
      } catch {
        marketOffersSeenSignature = ''
      }
    }

    async function fetchMe() {
      if (mkp.me !== null) return mkp.me

      try {
        var res = await fetch(API + '/api/me', { credentials: 'include', cache: 'no-store' })
        var data = await res.json().catch(function () { return null })
        mkp.me = res.ok && data ? (data.user || data) : false
      } catch { mkp.me = false }

      return mkp.me
    }

    function meId() {
      var me = mkp.me
      if (!me) return ''
      return String(me.twitchId || me.twitch_id || me.userId || me.id || '')
    }

    async function loadAll() {
      if (mkp.busy) return
      mkp.busy = true
      setRefreshLoading(true)

      try {
        await fetchMe()
        if (!mkp.me) mkp.offers = { incoming: [], outgoing: [], offers: [] }

        var jobs = [fetch(API + '/api/market/listings?v=' + Date.now(), { cache: 'no-store' })]
        var mineIndex = -1
        var offersIndex = -1

        if (mkp.me) {
          mineIndex = jobs.push(fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })) - 1
          offersIndex = jobs.push(fetch(API + '/api/me/market/offers?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })) - 1
        }

        var responses = await Promise.all(jobs)
        var marketData = await responses[0].json().catch(function () { return null })

        if (marketData && marketData.ok) {
          mkp.listings = marketData.listings || []
        }

        if (mineIndex >= 0 && responses[mineIndex]) {
          var mineData = await responses[mineIndex].json().catch(function () { return null })
          if (mineData && mineData.ok) mkp.mine = mineData.listings || []
        }

        if (offersIndex >= 0 && responses[offersIndex]) {
          var offersData = await responses[offersIndex].json().catch(function () { return null })
          if (offersData && offersData.ok) {
            rememberUnreadOffers(offersData.offers || [])
            mkp.offers = {
              incoming: offersData.incoming || [],
              outgoing: offersData.outgoing || [],
              offers: offersData.offers || [],
            }
          }
        }

        render()
        mkp.loadedOnce = true
      } catch (error) {
        console.warn('[Market] load failed', error)
        if (!mkp.loadedOnce) {
          var grid = el('mktGrid')
          if (grid) grid.innerHTML = errorHtml()
        }
      } finally {
        mkp.busy = false
        setRefreshLoading(false)
      }
    }

    function findListingCard(listingId) {
      var cards = document.querySelectorAll('[data-listing-id]')
      for (var i = 0; i < cards.length; i++) {
        if (cards[i].getAttribute('data-listing-id') === listingId) return cards[i]
      }
      return null
    }

    function focusLinkedListing() {
      var listingId = String(mkp.linkedListingId || '').trim()
      if (!listingId || mkp.linkedListingFocused || mkp.tab !== 'market') return

      window.setTimeout(function () {
        var card = findListingCard(listingId)
        if (!card) return

        mkp.linkedListingFocused = true
        card.classList.add('is-linked-listing')

        try {
          card.scrollIntoView({ behavior: 'smooth', block: 'center' })
        } catch {
          card.scrollIntoView()
        }

        window.setTimeout(function () {
          card.classList.remove('is-linked-listing')
        }, 4500)
      }, 80)
    }

    function findOfferCard(offerId) {
      var cards = document.querySelectorAll('[data-offer-id]')
      for (var i = 0; i < cards.length; i++) {
        if (cards[i].getAttribute('data-offer-id') === offerId) return cards[i]
      }
      return null
    }

    function focusLinkedOffer() {
      var offerId = String(mkp.linkedOfferId || '').trim()
      if (!offerId || mkp.linkedOfferFocused || mkp.tab !== 'offers') return

      window.setTimeout(function () {
        var card = findOfferCard(offerId)
        if (!card) return

        mkp.linkedOfferFocused = true
        card.classList.add('is-linked-offer')

        try {
          card.scrollIntoView({ behavior: 'smooth', block: 'center' })
        } catch {
          card.scrollIntoView()
        }

        window.setTimeout(function () {
          card.classList.remove('is-linked-offer')
        }, 4500)
      }, 100)
    }

    function sellerAvatar(listing) {
      return listing.sellerImage
        ? '<img src="' + escText(listing.sellerImage) + '" alt="" loading="lazy" referrerpolicy="no-referrer">'
        : '<span class="mkt-seller-fallback">' + escText(String(listing.sellerName || '؟').charAt(0).toUpperCase()) + '</span>'
    }

    function cardTop(listing) {
      return (
        '<div class="mkt-card-top">' +
          '<div class="mkt-icon">' + ICON_ITEM + '</div>' +
          '<div class="mkt-info">' +
            '<div class="mkt-name">' + escText(listing.itemName) + '</div>' +
            '<div class="mkt-qty">×' + fmt(listing.quantity) + '</div>' +
          '</div>' +
        '</div>'
      )
    }

    function priceBlock(listing) {
      return (
        '<div class="mkt-price">' +
          '<span class="mkt-price-val">' + fmt(listing.price) + '</span>' +
          '<span class="mkt-price-unit">نقطة</span>' +
        '</div>'
      )
    }

    function marketCard(listing) {
      var isOwn = mkp.me && listing.sellerId === meId()

      var action = ''
      if (!mkp.me) {
        action = '<a class="mkt-btn mkt-btn-guest guest-login-buy-btn" href="' + API + '/auth/twitch/login">سجل دخول للشراء</a>'
      } else if (isOwn) {
        action = '<div class="mkt-btn mkt-btn-own">هذا عرضك</div>'
      } else {
        var offerBtn = listing.canOffer === false || listing.allowOffers === false
          ? ''
          : '<button class="mkt-btn mkt-btn-offer mkt-ripple" type="button" data-mkp-offer-open="' + escText(listing.listingId) + '">إرسال عرض</button>'
        action =
          '<div class="mkt-actions">' +
            '<button class="mkt-btn mkt-btn-buy mkt-ripple" type="button" data-mkp-buy="' + escText(listing.listingId) + '">شراء</button>' +
            offerBtn +
          '</div>'
      }

      var secs = Math.max(0, Math.floor(Number(listing.remainingSeconds || 0)))
      var urgent = secs > 0 && secs < 3600 ? ' is-urgent' : ''

      return (
        '<article class="mkt-card" data-listing-id="' + escText(listing.listingId) + '">' +
          cardTop(listing) +
          priceBlock(listing) +
          '<div class="mkt-divider"></div>' +
          '<div class="mkt-meta">' +
            '<div class="mkt-seller">' +
              sellerAvatar(listing) +
              '<span class="mkt-seller-name">' + escText(listing.sellerName || listing.sellerLogin || '') + '</span>' +
            '</div>' +
            '<div class="mkt-time' + urgent + '">' + ICON_CLOCK + '<span>' + remainingText(listing.remainingSeconds) + '</span></div>' +
          '</div>' +
          action +
        '</article>'
      )
    }

    function mineFooter(listing) {
      var status = listing.status

      if (status === 'active') {
        return '<button class="mkt-btn mkt-btn-cancel mkt-ripple" type="button" data-mkp-cancel="' + escText(listing.listingId) + '">إلغاء العرض</button>'
      }

      if (status === 'sold') {
        var buyer = listing.buyerName
          ? '<div class="mkt-sub">المشتري: <strong>' + escText(listing.buyerName) + '</strong></div>'
          : ''
        return buyer + '<div class="mkt-btn mkt-btn-disabled">تم البيع</div>'
      }

      if (status === 'refunded') {
        return '<div class="mkt-sub">رجع الغرض لحقيبتك.</div><div class="mkt-btn mkt-btn-disabled">في حقيبتك</div>'
      }

      if (status === 'pending_list') {
        return '<div class="mkt-sub">جاري نشر العرض.</div><div class="mkt-btn mkt-btn-processing">' + SPIN + ' يُنشر الآن</div>'
      }

      if (status === 'pending_refund') {
        return '<div class="mkt-sub">جاري إرجاع الغرض.</div><div class="mkt-btn mkt-btn-processing">' + SPIN + ' قيد الاسترجاع</div>'
      }

      if (status === 'pending_buy') {
        return '<div class="mkt-btn mkt-btn-processing">' + SPIN + ' قيد الشراء</div>'
      }

      if (status === 'cancelled') {
        return '<div class="mkt-sub">تم إلغاء العرض ولم يُبَع.</div><div class="mkt-btn mkt-btn-disabled">ملغي</div>'
      }

      return '<div class="mkt-sub">حدث خطأ في هذا العرض.</div><div class="mkt-btn mkt-btn-disabled">خطأ</div>'
    }

    function mineCard(listing) {
      var info = statusInfo(listing.status)

      var dismissBtn = isTerminal(listing.status)
        ? '<button class="mkt-dismiss" type="button" data-mkp-dismiss="' + escText(listing.listingId) + '" title="حذف من القائمة" aria-label="حذف">×</button>'
        : ''

      return (
        '<article class="mkt-card">' +
          dismissBtn +
          cardTop(listing) +
          priceBlock(listing) +
          '<div class="mkt-divider"></div>' +
          '<span class="mkt-badge ' + info.cls + '"><span class="dot"></span>' + info.text + '</span>' +
          mineFooter(listing) +
        '</article>'
      )
    }

    function emptyHtml(title, desc) {
      return (
        '<div class="mkt-empty">' +
          '<div class="mkt-empty-icon">' + ICON_STORE + '</div>' +
          '<div class="mkt-empty-title">' + escText(title || 'لا توجد عروض حاليًا') + '</div>' +
          '<div class="mkt-empty-desc">' + escText(desc || 'اعرض غرضًا من حقيبتك ليظهر هنا') + '</div>' +
        '</div>'
      )
    }

    function getOfferStatusMeta(status, direction, viewerRole) {
      if (status === 'pending_seller') {
        return { label: viewerRole === 'seller' ? 'بانتظار ردك' : 'بانتظار البائع', className: 'status-pending', tone: 'amber' }
      }
      if (status === 'pending_buyer') {
        return { label: viewerRole === 'buyer' ? 'بانتظار ردك' : 'بانتظار المشتري', className: 'status-counter', tone: 'blue' }
      }
      if (status === 'rejected') return { label: 'مرفوض', className: 'status-rejected', tone: 'red' }
      if (status === 'countered') return { label: 'تم الرد بعرض مضاد', className: 'status-counter', tone: 'blue' }
      if (status === 'processing') return { label: 'قيد التنفيذ', className: 'status-processing', tone: 'orange' }
      if (status === 'completed') return { label: 'تم البيع', className: 'status-sold', tone: 'green' }
      if (status === 'failed') return { label: 'فشل', className: 'status-failed', tone: 'red' }
      if (status === 'expired_insufficient_points') return { label: 'نقاط غير كافية', className: 'status-insufficient', tone: 'orange' }
      if (status === 'cancelled') return { label: 'ملغي', className: 'status-cancelled', tone: 'gray' }
      return { label: status || 'غير معروف', className: 'status-cancelled', tone: 'gray' }
    }

    function offerDetail(label, value, extraClass) {
      return (
        '<div class="detail-row ' + (extraClass || '') + '">' +
          '<span class="offer-detail-label">' + escText(label) + '</span>' +
          '<strong class="offer-detail-value">' + escText(value) + '</strong>' +
        '</div>'
      )
    }

    function offeredItemsForDisplay(offer) {
      var items = Array.isArray(offer && offer.offeredItems) ? offer.offeredItems : []
      return items.map(function (item) {
        return {
          key: String(item.itemKey || item.item_key || item.name || item.itemName || '').trim(),
          name: String(item.itemName || item.item_name || item.name || item.itemKey || item.item_key || '').trim(),
          qty: Math.max(1, Math.floor(Number(item.quantity || item.qty || 1))),
        }
      }).filter(function (item) { return item.name && item.qty > 0 })
    }

    function offerItemsListHtml(items) {
      return (
        '<div class="offer-items-list">' +
          items.map(function (item) {
            return (
              '<span class="offer-item-chip">' +
                '<span class="offer-item-chip-name">' + escText(item.name) + '</span>' +
                '<span class="offer-item-chip-qty">×' + fmt(item.qty) + '</span>' +
              '</span>'
            )
          }).join('') +
        '</div>'
      )
    }

    function offerItemsDetail(label, items, extraClass) {
      return (
        '<div class="detail-row is-items ' + (extraClass || '') + '">' +
          '<span class="offer-detail-label">' + escText(label) + '</span>' +
          offerItemsListHtml(items) +
        '</div>'
      )
    }

    function offerItemsPayload(offer) {
      return offeredItemsForDisplay(offer).map(function (item) {
        return { itemKey: item.key || item.name, itemName: item.name, quantity: item.qty }
      })
    }

    function inferOfferType(price, items) {
      var hasItems = Array.isArray(items) && items.length > 0
      var points = Math.max(0, Math.floor(Number(price || 0)))
      if (hasItems && points > 0) return 'mixed'
      if (hasItems) return 'items'
      return 'points'
    }

    function counterItemsHtml(items) {
      if (!items.length) return ''
      return (
        '<div class="mkt-counter-items">' +
          '<div class="mkt-counter-items-title">الأغراض الموجودة في العرض</div>' +
          offerItemsListHtml(items) +
          '<div class="mkt-counter-note">سيتم الاحتفاظ بالأغراض الموجودة وتعديل عدد النقاط فقط.</div>' +
        '</div>'
      )
    }

    function offerTypeLabel(offer) {
      var items = offeredItemsForDisplay(offer)
      var price = Math.max(0, Math.floor(Number(offer && offer.offerPrice || 0)))
      var type = String(offer && (offer.offerType || offer.offer_type) || '').toLowerCase()
      if (!type) type = items.length && price > 0 ? 'mixed' : items.length ? 'items' : 'points'
      if (type === 'mixed') return 'نقاط + أغراض'
      if (type === 'items') return 'أغراض'
      return 'نقاط'
    }

    function isLiveOfferStatus(status) {
      return status === 'pending_seller' || status === 'pending_buyer' || status === 'processing'
    }

    function offerUnreadText(offer) {
      var eventType = mkp.unreadOfferSession[offer.offerId] || offer.unreadEventType || ''
      if (eventType === 'new_offer') return 'عرض شراء جديد'
      if (eventType === 'counter_offer') return 'وصلك سعر مضاد'
      if (eventType === 'offer_rejected') return 'تم رفض عرضك'
      if (eventType === 'counter_rejected') return 'رفض المشتري السعر المضاد'
      if (eventType === 'offer_completed') {
        return offer.viewerRole === 'seller' ? 'تم بيع الغرض' : 'اكتملت عملية الشراء'
      }
      if (eventType === 'offer_failed') return 'تعذرت العملية'
      return 'تحديث جديد'
    }

    function offerCard(offer, bucket) {
      var actionButtons = []
      var meta = getOfferStatusMeta(offer.status, offer.direction, offer.viewerRole)
      var liveBadge = isLiveOfferStatus(offer.status)
      var isUnread = !!(offer.isUnreadForCurrentUser || mkp.unreadOfferSession[offer.offerId])
      var otherName = offer.viewerRole === 'seller'
        ? (offer.buyerName || offer.buyerLogin || '')
        : (offer.sellerName || offer.sellerLogin || '')
      var partyLabel = bucket === 'incoming' ? 'من' : 'إلى'
      var offerPrice = Math.max(0, Math.floor(Number(offer.offerPrice || 0)))
      var offerItems = offeredItemsForDisplay(offer)
      var hasOfferItems = offerItems.length > 0

      if (!otherName) {
        otherName = bucket === 'incoming'
          ? (offer.buyerName || offer.buyerLogin || offer.sellerName || offer.sellerLogin || '')
          : (offer.sellerName || offer.sellerLogin || offer.buyerName || offer.buyerLogin || '')
      }

      if (offer.canAccept) actionButtons.push('<button class="mkt-btn mkt-btn-buy mkt-ripple" type="button" data-mkp-offer-accept="' + escText(offer.offerId) + '">قبول</button>')
      if (offer.canCounter) actionButtons.push('<button class="mkt-btn mkt-btn-offer mkt-ripple" type="button" data-mkp-offer-counter="' + escText(offer.offerId) + '">رد بسعر مختلف</button>')
      if (offer.canReject) actionButtons.push('<button class="mkt-btn mkt-btn-cancel mkt-ripple" type="button" data-mkp-offer-reject="' + escText(offer.offerId) + '">رفض</button>')
      if (offer.canArchive) actionButtons.push('<button class="mkt-btn offer-hide mkt-ripple" type="button" data-mkp-offer-archive="' + escText(offer.offerId) + '">إخفاء</button>')

      var archiveOnly = actionButtons.length === 1 && offer.canArchive
      var actions = actionButtons.length
        ? '<div class="card-sep"></div><div class="offer-actions ' + (archiveOnly ? 'is-archive-only' : '') + '">' + actionButtons.join('') + '</div>'
        : ''
      var unreadBadge = isUnread ? '<span class="offer-new-badge">جديد</span>' : ''
      var typeBadge = '<span class="offer-type-badge">' + escText(offerTypeLabel(offer)) + '</span>'
      var unreadNote = isUnread ? '<div class="offer-unread-note">' + escText(offerUnreadText(offer)) + '</div>' : ''
      var offerRows = ''

      if (offerPrice > 0) {
        offerRows += offerDetail('عرض الشراء', fmt(offerPrice), 'is-offer')
      }

      if (hasOfferItems) {
        offerRows += offerItemsDetail(offerPrice > 0 ? 'أغراض مضافة' : 'العرض', offerItems, offerPrice > 0 ? '' : 'is-offer')
      }

      return (
        '<article class="offer-card' + (isUnread ? ' is-unread-offer' : '') + '" data-offer-id="' + escText(offer.offerId) + '" data-mkp-offer-id="' + escText(offer.offerId) + '">' +
          '<div class="offer-card-head">' +
            '<div class="offer-item-main">' +
              '<div class="item-icon">' + ICON_ITEM + '</div>' +
              '<div class="offer-item-text">' +
                '<div class="offer-item-name">' + escText(offer.itemName) + '</div>' +
                '<div class="offer-item-qty">' + fmt(offer.quantity) + '×</div>' +
              '</div>' +
            '</div>' +
            '<div class="offer-card-badges">' +
              unreadBadge +
              typeBadge +
              '<span class="status-badge ' + meta.className + (liveBadge ? ' is-processing' : '') + '">' + (liveBadge ? '<span class="dot"></span>' : '') + escText(meta.label) + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="card-sep"></div>' +
          '<div class="offer-card-body">' +
            offerDetail('السعر الأصلي', fmt(offer.listingPrice), '') +
            offerRows +
            offerDetail(partyLabel, otherName || 'غير معروف', 'is-party') +
          '</div>' +
          unreadNote +
          actions +
        '</article>'
      )
    }

    function offerSection(title, count, emptyText, items, bucket) {
      var body = count
        ? '<div class="mkt-offer-list">' + items.map(function (offer) { return offerCard(offer, bucket) }).join('') + '</div>'
        : '<div class="mkt-offer-empty">' + escText(emptyText) + '</div>'

      return (
        '<section class="mkt-offer-section">' +
          '<div class="mkt-offer-head">' +
            '<h2 class="mkt-offer-title">' + escText(title) + '</h2>' +
            '<span class="section-count">' + fmt(count) + '</span>' +
          '</div>' +
          body +
        '</section>'
      )
    }

    function offersHtml() {
      var incoming = mkp.offers.incoming || []
      var outgoing = mkp.offers.outgoing || []

      return (
        '<div class="mkt-offers-board">' +
          offerSection('العروض الواردة', incoming.length, 'لا توجد عروض واردة', incoming, 'incoming') +
          offerSection('العروض المرسلة', outgoing.length, 'لا توجد عروض مرسلة', outgoing, 'outgoing') +
        '</div>'
      )
    }

    function render() {
      var grid = el('mktGrid')
      if (!grid) return

      var mineTab = el('mktMineTab')
      if (mineTab) mineTab.hidden = !mkp.me

      var offersTab = el('mktOffersTab')
      if (offersTab) offersTab.hidden = !mkp.me

      var sellBtn = el('mktSellBtn')
      if (sellBtn) sellBtn.hidden = !mkp.me

      if (!mkp.me && mkp.tab === 'mine') mkp.tab = 'market'
      if (!mkp.me && mkp.tab === 'offers') mkp.tab = 'market'

      var tools = el('mktTools')
      if (tools) tools.hidden = mkp.tab !== 'market'

      var mineList = mkp.mine
      var terminals = mineList.filter(function (l) { return isTerminal(l.status) })
      var offerCount = ((mkp.offers.incoming || []).length + (mkp.offers.outgoing || []).length)

      updateActiveCount(mkp.listings.length)

      var mineCount = el('mktMineCount')
      if (mineCount) mineCount.textContent = fmt(mineList.length)

      var offersCount = el('mktOffersCount')
      if (offersCount) offersCount.textContent = fmt(offerCount)

      document.querySelectorAll('[data-mkp-tab]').forEach(function (btn) {
        btn.classList.toggle('active', btn.getAttribute('data-mkp-tab') === mkp.tab)
      })

      var listbar = el('mktListbar')
      if (listbar) {
        if (mkp.tab === 'mine' && terminals.length) {
          listbar.hidden = false
          var t = el('mktListbarText')
          if (t) t.textContent = 'عندك ' + fmt(terminals.length) + ' عرض منتهٍ في القائمة'
        } else {
          listbar.hidden = true
        }
      }

      if (mkp.tab === 'mine') {
        grid.innerHTML = mineList.length ? mineList.map(mineCard).join('') : emptyHtml()
        return
      }

      if (mkp.tab === 'offers') {
        grid.innerHTML = offersHtml()
        markIncomingOffersSeenFromMarket()
        focusLinkedOffer()
        return
      }

      var visibleListings = getVisibleMarketListings(mkp.listings)
      var hasMarketFilter = !!normalizeMarketText(mkp.marketSearchQuery)
      grid.innerHTML = visibleListings.length
        ? visibleListings.map(marketCard).join('')
        : (hasMarketFilter
          ? emptyHtml('لا توجد نتائج مطابقة', 'جرّب كلمة بحث مختلفة أو امسح البحث.')
          : emptyHtml())
      focusLinkedListing()
    }

    async function clearFinished() {
      var terminals = mkp.mine.filter(function (l) { return isTerminal(l.status) })
      if (!terminals.length) return

      var btn = el('mktClearFinished')
      if (btn) { btn.disabled = true; btn.textContent = 'جاري المسح...' }

      var failed = 0
      for (var i = 0; i < terminals.length; i++) {
        var ok = await archiveListing(terminals[i].listingId, null)
        if (!ok) failed++
      }

      if (btn) { btn.disabled = false; btn.textContent = 'مسح المنتهية' }
      if (!failed) setNotice('ok', 'تم مسح العروض المنتهية من قائمتك.')

      await loadAll()
    }

    async function pollRequest(requestId, timeoutMs) {
      var startedAt = Date.now()
      var limit = timeoutMs || 9000
      var wait = 400

      while (Date.now() - startedAt < limit) {
        await new Promise(function (resolve) { setTimeout(resolve, wait) })
        wait = 1000

        try {
          var res = await fetch(API + '/api/me/market/request-status?id=' + encodeURIComponent(requestId) + '&v=' + Date.now(), {
            credentials: 'include',
            cache: 'no-store',
          })

          var data = await res.json().catch(function () { return null })

          if (!res.ok || !data || data.ok !== true) continue
          if (data.status === 'completed') return { ok: true }
          if (data.status === 'error') return { error: data.errorMessage || 'failed' }
        } catch {}
      }

      return { timeout: true }
    }

    async function pollOffer(offerId, timeoutMs) {
      var startedAt = Date.now()
      var limit = timeoutMs || 60000
      var wait = 600

      while (Date.now() - startedAt < limit) {
        await new Promise(function (resolve) { setTimeout(resolve, wait) })
        wait = 1200

        try {
          var res = await fetch(API + '/api/me/market/offers/status?id=' + encodeURIComponent(offerId) + '&v=' + Date.now(), {
            credentials: 'include',
            cache: 'no-store',
          })
          var data = await res.json().catch(function () { return null })
          var offer = data && data.offer
          if (!res.ok || !data || data.ok !== true || !offer) continue
          if (offer.status === 'completed') return { ok: true }
          if (offer.status === 'failed' || offer.status === 'expired_insufficient_points') {
            return { error: offer.errorMessage || offer.status }
          }
        } catch {}
      }

      return { timeout: true }
    }

    // متابعة خلفية لطلب الشراء بعد المهلة السريعة — تحدّث الحالة عند التأكيد الفعلي
    async function watchBuyRequest(requestId) {
      var result = await pollRequest(requestId, 60000)

      if (result.ok) {
        setNotice('ok', 'تم الشراء ✓ الغرض وصل حقيبتك.')
      } else if (result.error) {
        setNotice('error', buyErrorText(result.error))
      } else {
        setNotice('', 'ما زال طلبك قيد المعالجة، حدّث الصفحة بعد قليل.')
      }

      await loadAll()
    }

    // متابعة خلفية لطلب الإلغاء — تحدّث الحالة عند رجوع الغرض فعليًا
    async function watchCancelRequest(listingId) {
      var startedAt = Date.now()

      while (Date.now() - startedAt < 60000) {
        await new Promise(function (resolve) { setTimeout(resolve, 2000) })

        try {
          var check = await fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })
          var checkData = await check.json().catch(function () { return null })

          if (checkData && checkData.ok) {
            var found = (checkData.listings || []).find(function (entry) { return entry.listingId === listingId })

            if (found && (found.status === 'cancelled' || found.status === 'refunded')) {
              setNotice('ok', 'رجع الغرض لحقيبتك ✓')
              await loadAll()
              return
            }

            if (found && found.status === 'error') {
              setNotice('error', 'صار خطأ أثناء الإلغاء، تواصل مع الإدارة.')
              await loadAll()
              return
            }
          }
        } catch {}
      }

      await loadAll()
    }

    async function buyListing(listingId, button) {
      setNotice('', '')
      button.disabled = true
      button.className = 'mkt-btn mkt-btn-loading'
      button.innerHTML = SPIN + ' جاري الشراء...'

      try {
        var res = await fetch(API + '/api/me/market/buy', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: listingId }),
        })

        var data = await res.json().catch(function () { return null })

        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', buyErrorText((data && data.error) || 'buy_failed'))
          await loadAll()
          return
        }

        var result = await pollRequest(data.requestId, 9000)

        if (result.ok) {
          button.className = 'mkt-btn mkt-btn-done'
          button.innerHTML = 'تم الشراء ✓'
          setNotice('ok', 'تم الشراء ✓ الغرض وصل حقيبتك.')
          setTimeout(function () { loadAll() }, 1200)
          return
        }

        if (result.error) {
          setNotice('error', buyErrorText(result.error))
          await loadAll()
          return
        }

        // لا نعرض نجاحًا وهميًا — الطلب قيد المعالجة ونتابعه في الخلفية حتى يتأكد
        button.className = 'mkt-btn mkt-btn-processing'
        button.innerHTML = SPIN + ' طلبك قيد المعالجة'
        setNotice('', 'طلبك قيد المعالجة، سيتم تحديث الحالة خلال لحظات.')
        watchBuyRequest(data.requestId)
        await loadAll()
        return
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
        await loadAll()
      }
    }

    function closeOfferModal(immediate) {
      closeMarketModal('[data-offer-modal]', null, immediate)
    }

    function openOfferModal(listingId) {
      if (!mkp.me) return
      var listing = (mkp.listings || []).find(function (entry) { return entry.listingId === listingId })
      if (!listing) return
      if (listing.canOffer === false || listing.allowOffers === false) {
        setNotice('error', 'البائع لا يستقبل عروضًا على هذا الغرض.')
        return
      }
      closeOfferModal(true)

      var modal = document.createElement('div')
      modal.className = 'mkt-modal'
      modal.setAttribute('data-offer-modal', '')
      modal.innerHTML =
        '<div class="mkt-dialog">' +
          '<button class="mkt-dialog-close" type="button" data-offer-close aria-label="إغلاق">×</button>' +
          '<div class="mkt-dialog-head"><h3>إرسال عرض شراء</h3><p>' + escText(listing.itemName) + ' · السعر الحالي ' + fmt(listing.price) + ' نقطة</p></div>' +
          '<label class="mkt-flabel" for="mktOfferPrice">النقاط المعروضة</label>' +
          '<input class="mkt-input" id="mktOfferPrice" data-offer-price type="number" min="0" step="1" inputmode="numeric" value="' + Math.max(0, Math.floor(Number(listing.price || 0))) + '">' +
          '<div class="mkt-offer-help">يمكنك تقديم نقاط فقط، أغراض فقط، أو نقاط مع أغراض.</div>' +
          '<div class="mkt-offer-summary">' +
            '<div class="mkt-offer-selected is-empty" data-offer-selected>لم تضف أغراضًا للعرض.</div>' +
            '<button class="mkt-offer-add" type="button" data-offer-add-items>إضافة أغراض من الحقيبة</button>' +
          '</div>' +
          '<div class="mkt-offer-items-panel" data-offer-items-panel></div>' +
          '<div class="mkt-sell-state" data-offer-state></div>' +
          '<button class="mkt-btn mkt-btn-buy mkt-ripple" type="button" data-offer-submit>إرسال العرض</button>' +
        '</div>'
      document.body.appendChild(modal)

      var input = modal.querySelector('[data-offer-price]')
      var state = modal.querySelector('[data-offer-state]')
      var submit = modal.querySelector('[data-offer-submit]')
      var selectedBox = modal.querySelector('[data-offer-selected]')
      var itemsPanel = modal.querySelector('[data-offer-items-panel]')
      var st = { items: [], selected: [], inventoryLoaded: false, inventoryLoading: false, panelOpen: false }
      if (input) input.focus()

      function setState(kind, text) {
        if (!state) return
        state.className = 'mkt-sell-state' + (kind ? ' is-' + kind : '')
        state.innerHTML = text || ''
      }

      function selectedKey(item) {
        return String(item.key || item.name || '').toLowerCase()
      }

      function selectedQuantity(it) {
        var key = selectedKey(it)
        var found = st.selected.find(function (entry) { return selectedKey(entry) === key })
        return found ? found.qty : 0
      }

      function renderSelectedItems() {
        if (!selectedBox) return
        if (!st.selected.length) {
          selectedBox.className = 'mkt-offer-selected is-empty'
          selectedBox.innerHTML = 'لم تضف أغراضًا للعرض.'
          return
        }

        selectedBox.className = 'mkt-offer-selected'
        selectedBox.innerHTML = st.selected.map(function (it, i) {
          return (
            '<span class="mkt-offer-chip">' +
              escText(it.name) + ' ×' + fmt(it.qty) +
              '<button type="button" data-offer-item-remove="' + i + '" aria-label="إزالة">×</button>' +
            '</span>'
          )
        }).join('')
      }

      function renderInventoryPanel() {
        if (!itemsPanel) return
        itemsPanel.className = 'mkt-offer-items-panel' + (st.panelOpen ? ' is-open' : '')

        if (!st.panelOpen) {
          itemsPanel.innerHTML = ''
          return
        }

        if (st.inventoryLoading) {
          itemsPanel.innerHTML = '<div class="mkt-inv-loading">' + SPIN + ' جاري تحميل الحقيبة...</div>'
          return
        }

        if (!st.items.length) {
          itemsPanel.innerHTML = '<div class="mkt-inv-empty">لا توجد أغراض متاحة لتقديمها في العرض.</div>'
          return
        }

        itemsPanel.innerHTML = st.items.map(function (it, i) {
          var picked = selectedQuantity(it)
          var left = Math.max(0, it.qty - picked)
          return (
            '<div class="mkt-offer-inv-row">' +
              '<div class="mkt-inv-icon sm">' + ICON_ITEM + '</div>' +
              '<div>' +
                '<div class="mkt-offer-inv-name">' + escText(it.name) + '</div>' +
                '<div class="mkt-offer-inv-qty">متاح ×' + fmt(it.qty) + (picked ? ' · مضاف ×' + fmt(picked) : '') + '</div>' +
              '</div>' +
              '<div class="mkt-offer-qty-actions">' +
                '<button type="button" data-offer-item-minus="' + i + '"' + (picked <= 0 ? ' disabled' : '') + '>−</button>' +
                '<button type="button" data-offer-item-add="' + i + '"' + (left <= 0 ? ' disabled' : '') + '>+</button>' +
              '</div>' +
            '</div>'
          )
        }).join('')
      }

      function addSelectedItem(index, delta) {
        var it = st.items[index]
        if (!it) return
        var key = selectedKey(it)
        var existingIndex = st.selected.findIndex(function (entry) { return selectedKey(entry) === key })
        var current = existingIndex >= 0 ? st.selected[existingIndex].qty : 0
        var next = Math.max(0, Math.min(it.qty, current + delta))

        if (next <= 0) {
          if (existingIndex >= 0) st.selected.splice(existingIndex, 1)
        } else if (existingIndex >= 0) {
          st.selected[existingIndex].qty = next
        } else {
          st.selected.push({ key: it.key, name: it.name, qty: next })
        }

        renderSelectedItems()
        renderInventoryPanel()
      }

      async function toggleInventoryPanel() {
        st.panelOpen = !st.panelOpen
        renderInventoryPanel()

        if (!st.panelOpen || st.inventoryLoaded || st.inventoryLoading) return

        st.inventoryLoading = true
        renderInventoryPanel()
        st.items = await fetchInventory()
        st.inventoryLoaded = true
        st.inventoryLoading = false
        renderInventoryPanel()
      }

      modal.addEventListener('click', function (e) {
        var t = e.target
        if (t === modal || t.closest('[data-offer-close]')) closeOfferModal()
        var addItems = t.closest('[data-offer-add-items]')
        if (addItems) {
          toggleInventoryPanel()
          return
        }

        var addBtn = t.closest('[data-offer-item-add]')
        if (addBtn) {
          addSelectedItem(Math.floor(Number(addBtn.getAttribute('data-offer-item-add') || -1)), 1)
          return
        }

        var minusBtn = t.closest('[data-offer-item-minus]')
        if (minusBtn) {
          addSelectedItem(Math.floor(Number(minusBtn.getAttribute('data-offer-item-minus') || -1)), -1)
          return
        }

        var removeBtn = t.closest('[data-offer-item-remove]')
        if (removeBtn) {
          var removeIndex = Math.floor(Number(removeBtn.getAttribute('data-offer-item-remove') || -1))
          if (removeIndex >= 0) st.selected.splice(removeIndex, 1)
          renderSelectedItems()
          renderInventoryPanel()
        }
      })

      if (submit) submit.addEventListener('click', async function () {
        var price = Math.max(0, Math.floor(Number(input && input.value || 0)))
        var itemsPayload = st.selected.map(function (it) {
          return { itemKey: it.key, itemName: it.name, quantity: it.qty }
        }).filter(function (it) { return it.itemName && it.quantity > 0 })

        if (!Number.isFinite(price) || price < 0) {
          setState('error', 'أدخل عدد نقاط صحيحًا.')
          return
        }

        if (price < 1 && !itemsPayload.length) {
          setState('error', 'أضف نقاطًا أو غرضًا واحدًا على الأقل.')
          return
        }

        submit.disabled = true
        submit.innerHTML = SPIN + ' جاري الإرسال...'
        setState('loading', 'نرسل العرض...')

        try {
          var res = await fetch(API + '/api/me/market/offers/create', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ listingId: listingId, offerPrice: price, items: itemsPayload }),
          })
          var data = await res.json().catch(function () { return null })
          if (!res.ok || !data || data.ok !== true) {
            setState('error', offerErrorText(data && data.error))
            submit.disabled = false
            submit.textContent = 'إرسال العرض'
            return
          }

          closeOfferModal()
          setNotice('ok', 'تم إرسال العرض للبائع.')
          mkp.tab = 'offers'
          await loadAll()
        } catch {
          setState('error', 'حدث خطأ، جرّب بعد قليل.')
          submit.disabled = false
          submit.textContent = 'إرسال العرض'
        }
      })
    }

    function openCounterModal(offerId) {
      var offer = ((mkp.offers.incoming || []).concat(mkp.offers.outgoing || [])).find(function (entry) { return entry.offerId === offerId })
      if (!offer) return
      closeOfferModal(true)
      var offeredItems = offerItemsPayload(offer)
      var hasOfferItems = offeredItems.length > 0
      var currentPrice = Math.max(0, Math.floor(Number(offer.offerPrice || 0)))
      var initialPrice = Math.max(hasOfferItems ? 0 : 1, Math.floor(Number(offer.listingPrice || offer.offerPrice || (hasOfferItems ? 0 : 1))))

      var modal = document.createElement('div')
      modal.className = 'mkt-modal'
      modal.setAttribute('data-offer-modal', '')
      modal.innerHTML =
        '<div class="mkt-dialog">' +
          '<button class="mkt-dialog-close" type="button" data-offer-close aria-label="إغلاق">×</button>' +
          '<div class="mkt-dialog-head"><h3>رد بسعر مختلف</h3><p>' + escText(offer.itemName) + ' · السعر الحالي في العرض ' + fmt(currentPrice) + ' نقطة</p></div>' +
          counterItemsHtml(offeredItems) +
          '<label class="mkt-flabel" for="mktCounterPrice">السعر الجديد</label>' +
          '<input class="mkt-input" id="mktCounterPrice" data-offer-price type="number" min="' + (hasOfferItems ? '0' : '1') + '" step="1" inputmode="numeric" value="' + initialPrice + '">' +
          '<div class="mkt-sell-state" data-offer-state></div>' +
          '<button class="mkt-btn mkt-btn-buy mkt-ripple" type="button" data-offer-submit>إرسال العرض المضاد</button>' +
        '</div>'
      document.body.appendChild(modal)

      var input = modal.querySelector('[data-offer-price]')
      var state = modal.querySelector('[data-offer-state]')
      var submit = modal.querySelector('[data-offer-submit]')
      if (input) input.focus()

      function setState(kind, text) {
        if (!state) return
        state.className = 'mkt-sell-state' + (kind ? ' is-' + kind : '')
        state.innerHTML = text || ''
      }

      modal.addEventListener('click', function (e) {
        var t = e.target
        if (t === modal || t.closest('[data-offer-close]')) closeOfferModal()
      })

      if (submit) submit.addEventListener('click', async function () {
        var price = Math.max(0, Math.floor(Number(input && input.value || 0)))
        var nextOfferType = inferOfferType(price, offeredItems)
        var offeredItemsJson = JSON.stringify(offeredItems)

        if (!Number.isFinite(price) || price < 0 || (!hasOfferItems && price < 1)) {
          setState('error', hasOfferItems ? 'أدخل عدد نقاط صحيحًا.' : 'أدخل سعرًا صحيحًا.')
          return
        }

        submit.disabled = true
        submit.innerHTML = SPIN + ' جاري الإرسال...'
        setState('loading', 'نرسل العرض المضاد...')

        try {
          var res = await fetch(API + '/api/me/market/offers/counter', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              offerId: offerId,
              counterPrice: price,
              offerType: nextOfferType,
              offer_type: nextOfferType,
              offeredItems: offeredItems,
              offered_items: offeredItems,
              offeredItemsJson: offeredItemsJson,
              offered_items_json: offeredItemsJson,
            }),
          })
          var data = await res.json().catch(function () { return null })
          if (!res.ok || !data || data.ok !== true) {
            setState('error', offerErrorText(data && data.error))
            submit.disabled = false
            submit.textContent = 'إرسال العرض المضاد'
            return
          }

          closeOfferModal()
          setNotice('ok', 'تم إرسال العرض المضاد.')
          await loadAll()
        } catch {
          setState('error', 'حدث خطأ، جرّب بعد قليل.')
          submit.disabled = false
          submit.textContent = 'إرسال العرض المضاد'
        }
      })
    }

    async function rejectOffer(offerId, button) {
      if (button) { button.disabled = true; button.innerHTML = SPIN + ' جاري الرفض...' }

      try {
        var res = await fetch(API + '/api/me/market/offers/reject', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ offerId: offerId }),
        })
        var data = await res.json().catch(function () { return null })
        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', offerErrorText(data && data.error))
        } else {
          setNotice('ok', 'تم رفض العرض.')
        }
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
      }

      await loadAll()
    }

    async function archiveOffer(offerId, button) {
      if (button) { button.disabled = true; button.textContent = '…' }

      try {
        var res = await fetch(API + '/api/me/market/offers/archive', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ offerId: offerId }),
        })
        var data = await res.json().catch(function () { return null })
        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', offerErrorText(data && data.error))
          if (button) { button.disabled = false; button.textContent = '×' }
          return
        }

        var card = button && button.closest ? button.closest('.offer-card') : null
        await waitForCardExit(card)

        ;['incoming', 'outgoing', 'offers'].forEach(function (key) {
          mkp.offers[key] = (mkp.offers[key] || []).filter(function (offer) { return offer.offerId !== offerId })
        })
        render()
        setNotice('ok', 'تم إخفاء العرض.')
        loadAll()
      } catch {
        setNotice('error', 'تعذر إخفاء العرض، جرّب بعد قليل.')
        if (button) { button.disabled = false; button.textContent = '×' }
      }
    }

    async function acceptOffer(offerId, button) {
      if (button) { button.disabled = true; button.innerHTML = SPIN + ' جاري القبول...' }
      setNotice('', '')

      try {
        var res = await fetch(API + '/api/me/market/offers/accept', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ offerId: offerId }),
        })
        var data = await res.json().catch(function () { return null })
        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', offerErrorText(data && data.error))
          await loadAll()
          return
        }

        setNotice('', 'العرض قيد التنفيذ، سيتم تحديث الحالة خلال لحظات.')
        var result = await pollOffer(offerId, 60000)
        if (result.ok) setNotice('ok', 'تم تنفيذ العرض ✓')
        else if (result.error) setNotice('error', offerErrorText(result.error))
        else setNotice('', 'ما زال العرض قيد التنفيذ، حدّث الصفحة بعد قليل.')
        await loadAll()
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
        await loadAll()
      }
    }

    async function cancelListing(listingId, button) {
      setNotice('', '')
      button.disabled = true
      button.className = 'mkt-btn mkt-btn-loading'
      button.innerHTML = SPIN + ' جاري الإلغاء...'

      try {
        var res = await fetch(API + '/api/me/market/cancel', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ listingId: listingId }),
        })

        var data = await res.json().catch(function () { return null })

        if (!res.ok || !data || data.ok !== true) {
          setNotice('error', 'تعذر إلغاء العرض، جرّب بعد قليل.')
          await loadAll()
          return
        }

        var startedAt = Date.now()
        var done = false

        while (Date.now() - startedAt < 8000) {
          await new Promise(function (resolve) { setTimeout(resolve, 1000) })

          try {
            var check = await fetch(API + '/api/me/market/my-listings?v=' + Date.now(), { credentials: 'include', cache: 'no-store' })
            var checkData = await check.json().catch(function () { return null })

            if (checkData && checkData.ok) {
              var found = (checkData.listings || []).find(function (entry) { return entry.listingId === listingId })

              if (found && (found.status === 'cancelled' || found.status === 'refunded')) {
                setNotice('ok', 'رجع الغرض لحقيبتك ✓')
                done = true
                break
              }

              if (found && found.status === 'error') {
                setNotice('error', 'صار خطأ أثناء الإلغاء، تواصل مع الإدارة.')
                done = true
                break
              }
            }
          } catch {}
        }

        if (!done) {
          // لا نعرض نجاحًا وهميًا — الإلغاء قيد المعالجة ونتابعه في الخلفية
          setNotice('', 'طلب الإلغاء قيد المعالجة، سيتم تحديث الحالة خلال لحظات.')
          watchCancelRequest(listingId)
        }

        await loadAll()
      } catch {
        setNotice('error', 'حدث خطأ، جرّب بعد قليل.')
        await loadAll()
      }
    }

    /* ---------- sell (list an item) modal ---------- */
    async function fetchInventory() {
      var id = meId()
      var params = 'marketAvailable=1'
      if (id) params += '&twitchId=' + encodeURIComponent(id)
      else if (mkp.me && mkp.me.login) params += '&login=' + encodeURIComponent(String(mkp.me.login).toLowerCase())
      else return []

      try {
        var res = await fetch(API + '/api/profile/inventory?' + params + '&v=' + Date.now(), { credentials: 'include', cache: 'no-store' })
        var data = await res.json().catch(function () { return null })
        if (!data || !data.ok || !Array.isArray(data.items)) return []
        return data.items.map(function (it) {
          var qty = Math.max(0, Math.floor(Number(it.availableQuantity ?? it.quantity ?? it.qty ?? 0)))
          return {
            key: String(it.itemKey || it.key || it.name || it.itemName || '').trim(),
            name: String(it.name || it.itemName || it.itemKey || '').trim(),
            qty: qty,
            totalQty: Math.max(0, Math.floor(Number(it.totalQuantity ?? it.quantity ?? it.qty ?? qty))),
            reservedQty: Math.max(0, Math.floor(Number(it.reservedQuantity || 0))),
          }
        }).filter(function (it) { return it.name && it.qty > 0 })
      } catch { return [] }
    }

    function closeSellModal(immediate) {
      closeMarketModal('[data-sell-modal]', function () {
        document.body.style.overflow = ''
      }, immediate)
    }

    function openSellModal() {
      if (!mkp.me) return
      closeSellModal(true)

      var modal = document.createElement('div')
      modal.className = 'mkt-modal'
      modal.setAttribute('data-sell-modal', '')
      modal.innerHTML =
        '<div class="mkt-dialog">' +
          '<button class="mkt-dialog-close" type="button" data-sell-close aria-label="إغلاق">×</button>' +
          '<div class="mkt-dialog-head"><h3>اعرض غرضًا في السوق</h3><p data-sell-sub>اختر غرضًا من حقيبتك</p></div>' +
          '<div class="mkt-dialog-body" data-sell-body><div class="mkt-inv-loading">' + SPIN + ' جاري تحميل حقيبتك...</div></div>' +
        '</div>'

      document.body.appendChild(modal)
      document.body.style.overflow = 'hidden'

      var body = modal.querySelector('[data-sell-body]')
      var sub = modal.querySelector('[data-sell-sub]')
      var st = { items: [], picked: null, dur: DURATIONS[0].s }

      function renderPicker() {
        if (sub) sub.textContent = 'اختر غرضًا من حقيبتك'
        if (!st.items.length) {
          body.innerHTML = '<div class="mkt-inv-empty">حقيبتك فاضية — ما فيه أغراض تقدر تعرضها.</div>'
          return
        }
        var html = '<div class="mkt-inv-grid">'
        st.items.forEach(function (it, i) {
          html +=
            '<button class="mkt-inv-item" type="button" data-pick="' + i + '">' +
              '<div class="mkt-inv-icon">' + ICON_ITEM + '</div>' +
              '<div class="mkt-inv-name">' + escText(it.name) + '</div>' +
              '<div class="mkt-inv-qty">تملك ×' + fmt(it.qty) + '</div>' +
            '</button>'
        })
        html += '</div>'
        body.innerHTML = html
      }

      function renderForm() {
        var it = st.picked
        if (sub) sub.textContent = 'حدّد الكمية والسعر والمدة'
        var durs = DURATIONS.map(function (d) {
          return (
            '<button type="button" class="mkt-dur' + (d.s === st.dur ? ' sel' : '') + '" data-dur="' + d.s + '">' +
              '<b>' + d.label + '</b><span>' + (d.fee ? fmt(d.fee) + ' نقطة' : 'مجانًا') + '</span>' +
            '</button>'
          )
        }).join('')

        body.innerHTML =
          '<button class="mkt-back" type="button" data-sell-back>‹ رجوع للأغراض</button>' +
          '<div class="mkt-sell-pick"><div class="mkt-inv-icon sm">' + ICON_ITEM + '</div>' +
            '<div><strong>' + escText(it.name) + '</strong><span>تملك ×' + fmt(it.qty) + '</span></div></div>' +
          '<label class="mkt-flabel">الكمية</label>' +
          '<input class="mkt-input" type="number" data-qty min="1" max="' + it.qty + '" value="1" inputmode="numeric">' +
          '<label class="mkt-flabel">السعر المطلوب (نقاط)</label>' +
          '<input class="mkt-input" type="number" data-price min="500" step="100" placeholder="500 نقطة أو أكثر" inputmode="numeric">' +
          '<label class="mkt-flabel">مدة العرض</label>' +
          '<div class="mkt-durs">' + durs + '</div>' +
          '<label class="mkt-offer-toggle">' +
            '<input type="checkbox" data-allow-offers checked>' +
            '<span>السماح باستقبال العروض على هذا الغرض</span>' +
          '</label>' +
          '<div class="mkt-sell-state" data-state></div>' +
          '<button class="mkt-btn mkt-btn-buy mkt-ripple" type="button" data-submit>نشر العرض</button>'
      }

      function setSellState(kind, text) {
        var s = body.querySelector('[data-state]')
        if (!s) return
        s.className = 'mkt-sell-state' + (kind ? ' is-' + kind : '')
        s.textContent = text || ''
      }

      async function submit(btn) {
        var it = st.picked
        var qtyEl = body.querySelector('[data-qty]')
        var priceEl = body.querySelector('[data-price]')
        var allowOffersEl = body.querySelector('[data-allow-offers]')
        var qty = Math.floor(Number((qtyEl && qtyEl.value) || 0))
        var price = Math.floor(Number((priceEl && priceEl.value) || 0))
        var allowOffers = !allowOffersEl || !!allowOffersEl.checked

        if (!(qty >= 1 && qty <= it.qty)) {
          setSellState('error', 'الكمية لازم تكون بين 1 و' + fmt(it.qty) + '.')
          return
        }
        if (!(price >= 500)) {
          setSellState('error', 'السعر لازم يكون 500 نقطة أو أكثر.')
          return
        }

        btn.disabled = true
        btn.innerHTML = SPIN + ' جاري النشر...'
        setSellState('loading', 'جاري إرسال العرض...')

        try {
          var res = await fetch(API + '/api/me/market/list', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ itemName: it.name, itemKey: it.key, quantity: qty, price: price, durationSeconds: st.dur, allowOffers: allowOffers }),
          })

          var data = await res.json().catch(function () { return null })

          if (!res.ok || !data || data.ok !== true) {
            setSellState('error', listErrorText((data && data.error) || 'list_failed', data))
            btn.disabled = false
            btn.textContent = 'نشر العرض'
            return
          }

          setSellState('loading', 'يُنشر الآن...')

          if (data.requestId) {
            var result = await pollRequest(data.requestId, 60000)

            if (result.ok) {
              closeSellModal()
              mkp.tab = 'mine'
              setNotice('ok', 'تم نشر العرض في السوق ✓')
              await loadAll()
              return
            }

            if (result.error) {
              setSellState('error', listErrorText(result.error, data))
              btn.disabled = false
              btn.textContent = 'نشر العرض'
              await loadAll()
              return
            }

            setSellState('', 'النشر تأخر، جرّب تحديث السوق.')
            btn.disabled = false
            btn.textContent = 'نشر العرض'
            await loadAll()
            return
          }

          closeSellModal()
          mkp.tab = 'mine'
          await loadAll()
        } catch {
          setSellState('error', 'حدث خطأ، جرّب بعد قليل.')
          btn.disabled = false
          btn.textContent = 'نشر العرض'
        }
      }

      modal.addEventListener('click', function (e) {
        var t = e.target
        if (!(t instanceof Element)) return

        if (t === modal || t.closest('[data-sell-close]')) {
          closeSellModal()
          return
        }

        if (t.closest('[data-sell-back]')) {
          renderPicker()
          return
        }

        var pick = t.closest('[data-pick]')
        if (pick) {
          st.picked = st.items[Number(pick.getAttribute('data-pick'))]
          st.dur = DURATIONS[0].s
          if (st.picked) renderForm()
          return
        }

        var dur = t.closest('[data-dur]')
        if (dur) {
          st.dur = Number(dur.getAttribute('data-dur'))
          body.querySelectorAll('[data-dur]').forEach(function (d) {
            d.classList.toggle('sel', Number(d.getAttribute('data-dur')) === st.dur)
          })
          return
        }

        var submitBtn = t.closest('[data-submit]')
        if (submitBtn) {
          submit(submitBtn)
        }
      })

      fetchInventory().then(function (items) {
        st.items = items
        renderPicker()
      })
    }

    document.addEventListener('click', function (event) {
      var target = event.target
      if (!(target instanceof Element)) return

      if (target.closest('[data-mkt-notice-close]')) {
        setNotice('', '')
        return
      }

      addMarketRipple(event)

      if (target.closest('#mktSellBtn')) {
        openSellModal()
        return
      }

      if (target.closest('#mktClearFinished')) {
        clearFinished()
        return
      }

      var dismissBtn = target.closest('[data-mkp-dismiss]')
      if (dismissBtn) {
        var dismissCard = dismissBtn.closest('.mkt-card')
        archiveListing(dismissBtn.getAttribute('data-mkp-dismiss') || '', dismissBtn).then(function (ok) {
          if (ok) waitForCardExit(dismissCard).then(function () { loadAll() })
        })
        return
      }


      var tabButton = target.closest('[data-mkp-tab]')
      if (tabButton) {
        mkp.tab = tabButton.getAttribute('data-mkp-tab') || 'market'
        if (mkp.tab !== 'offers') marketOffersSeenSignature = ''
        render()
        return
      }

      var buyButton = target.closest('[data-mkp-buy]')
      if (buyButton) {
        buyListing(buyButton.getAttribute('data-mkp-buy') || '', buyButton)
        return
      }

      var offerOpen = target.closest('[data-mkp-offer-open]')
      if (offerOpen) {
        openOfferModal(offerOpen.getAttribute('data-mkp-offer-open') || '')
        return
      }

      var offerAccept = target.closest('[data-mkp-offer-accept]')
      if (offerAccept) {
        acceptOffer(offerAccept.getAttribute('data-mkp-offer-accept') || '', offerAccept)
        return
      }

      var offerReject = target.closest('[data-mkp-offer-reject]')
      if (offerReject) {
        rejectOffer(offerReject.getAttribute('data-mkp-offer-reject') || '', offerReject)
        return
      }

      var offerArchive = target.closest('[data-mkp-offer-archive]')
      if (offerArchive) {
        archiveOffer(offerArchive.getAttribute('data-mkp-offer-archive') || '', offerArchive)
        return
      }

      var offerCounter = target.closest('[data-mkp-offer-counter]')
      if (offerCounter) {
        openCounterModal(offerCounter.getAttribute('data-mkp-offer-counter') || '')
        return
      }

      var cancelButton = target.closest('[data-mkp-cancel]')
      if (cancelButton) {
        cancelListing(cancelButton.getAttribute('data-mkp-cancel') || '', cancelButton)
      }
    })

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeSellModal()
    })

    var refreshButton = el('mktRefresh')
    if (refreshButton) refreshButton.addEventListener('click', function () { loadAll() })

    var searchInput = el('mktSearch')
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        mkp.marketSearchQuery = searchInput.value || ''
        render()
      })
    }

    var sortSelect = el('mktSort')
    if (sortSelect) {
      sortSelect.addEventListener('change', function () {
        mkp.marketSortMode = sortSelect.value || 'newest'
        render()
      })
    }

    // تحديث دوري خفيف — فقط والصفحة ظاهرة
    setInterval(function () {
      if (!document.hidden) loadAll()
    }, 60000)

    loadAll()
  })()
</script>
