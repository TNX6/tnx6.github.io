  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxCommandsCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0

        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
      }

      const searchInput = document.getElementById('commandSearch')
      const clearSearchButton = document.getElementById('clearCommandSearch')
      const groupBlocks = Array.from(document.querySelectorAll('.tnx-command-group'))
      const filterButtons = Array.from(document.querySelectorAll('.tnx-filter-btn'))
      const copyButtons = Array.from(document.querySelectorAll('.tnx-copy-command'))
      const emptyState = document.getElementById('emptyState')

      let activeGroup = 'all'

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function applyFilters() {
        const term = normalize(searchInput?.value || '')
        let visibleTotal = 0

        groupBlocks.forEach((block) => {
          const group = block.dataset.group || ''
          const cards = Array.from(block.querySelectorAll('.tnx-command-card'))
          const groupMatches = activeGroup === 'all' || group === activeGroup
          let visibleInGroup = 0

          cards.forEach((card) => {
            const searchText = normalize(card.dataset.search || card.textContent || '')
            const searchMatches = !term || searchText.includes(term)
            const shouldShow = groupMatches && searchMatches

            card.classList.toggle('is-hidden', !shouldShow)

            if (shouldShow) {
              visibleInGroup++
              visibleTotal++
            }
          })

          block.classList.toggle('is-hidden', visibleInGroup === 0)
        })

        emptyState?.classList.toggle('hidden', visibleTotal > 0)
      }

      addListener(searchInput, 'input', applyFilters)

      addListener(clearSearchButton, 'click', () => {
        if (!searchInput) return

        searchInput.value = ''
        searchInput.focus()
        applyFilters()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          activeGroup = button.dataset.filterGroup || 'all'

          filterButtons.forEach((item) => item.classList.remove('is-active'))
          button.classList.add('is-active')

          applyFilters()
        })
      })

      copyButtons.forEach((button) => {
        addListener(button, 'click', async () => {
          const copyText = button.dataset.copy || button.textContent || ''
          const originalText = button.textContent

          try {
            await navigator.clipboard.writeText(copyText)

            button.textContent = 'تم النسخ'
            button.classList.add('is-copied')

            addTimer(
              window.setTimeout(() => {
                button.textContent = originalText
                button.classList.remove('is-copied')
              }, 900)
            )
          } catch {
            button.textContent = copyText

            addTimer(
              window.setTimeout(() => {
                button.textContent = originalText
              }, 900)
            )
          }
        })
      })

      applyFilters()
    })()
  </script>
</Layout>
