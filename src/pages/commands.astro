/*
  اختياري مستقبلًا:
  تقدر تسوي ملف public/api/commands-page-config.json
  وتحط فيه hiddenGroups / hiddenAliases / forceVisibleAliases بدون تعديل الصفحة.
*/

const externalConfig = readJsonFile('public/api/commands-page-config.json', {})

function asArray(value) {
  return Array.isArray(value) ? value : []
}

const siteConfig = {
  ...DEFAULT_CONFIG,
  ...externalConfig,
  hiddenGroups: [...DEFAULT_CONFIG.hiddenGroups, ...asArray(externalConfig.hiddenGroups)],
  hiddenGroupKeywords: [...DEFAULT_CONFIG.hiddenGroupKeywords, ...asArray(externalConfig.hiddenGroupKeywords)],
  hiddenNames: [...DEFAULT_CONFIG.hiddenNames, ...asArray(externalConfig.hiddenNames)],
  hiddenNameKeywords: [...DEFAULT_CONFIG.hiddenNameKeywords, ...asArray(externalConfig.hiddenNameKeywords)],
  hiddenAliases: [...DEFAULT_CONFIG.hiddenAliases, ...asArray(externalConfig.hiddenAliases)],
  hiddenAliasKeywords: [...DEFAULT_CONFIG.hiddenAliasKeywords, ...asArray(externalConfig.hiddenAliasKeywords)],
  forceVisibleAliases: [...DEFAULT_CONFIG.forceVisibleAliases, ...asArray(externalConfig.forceVisibleAliases)],
  groupLabels: {
    ...DEFAULT_CONFIG.groupLabels,
    ...(externalConfig.groupLabels || {}),
  },
  groupOrder: [...DEFAULT_CONFIG.groupOrder, ...asArray(externalConfig.groupOrder)],
}

function cleanText(value) {
  return String(value ?? '').trim().replace(/\s+/g, ' ')
}

function normalizeText(value) {
  return cleanText(value)
    .toLowerCase()
    .replace(/[ًٌٍَُِّْـ]/g, '')
    .replace(/[أإآ]/g, 'ا')
    .replace(/ة/g, 'ه')
    .replace(/ى/g, 'ي')
    .replace(/\s+/g, ' ')
    .trim()
}

function makeNormalizedSet(items) {
  return new Set(items.map((item) => normalizeText(item)).filter(Boolean))
}

const hiddenGroups = makeNormalizedSet(siteConfig.hiddenGroups)
const hiddenGroupKeywords = siteConfig.hiddenGroupKeywords.map((item) => normalizeText(item)).filter(Boolean)
const hiddenNames = makeNormalizedSet(siteConfig.hiddenNames)
const hiddenNameKeywords = siteConfig.hiddenNameKeywords.map((item) => normalizeText(item)).filter(Boolean)
const hiddenAliases = makeNormalizedSet(siteConfig.hiddenAliases)
const hiddenAliasKeywords = siteConfig.hiddenAliasKeywords.map((item) => normalizeText(item)).filter(Boolean)
const forceVisibleAliases = makeNormalizedSet(siteConfig.forceVisibleAliases)

function isEnabled(command) {
  if (!siteConfig.hideDisabled) return true

  return (
    command?.Enabled === true ||
    command?.Enabled === 'true' ||
    command?.enabled === true ||
    command?.enabled === 'true'
  )
}

function isWebsiteHidden(command) {
  return (
    command?.WebsiteHidden === true ||
    command?.HiddenOnWebsite === true ||
    command?.ShowOnWebsite === false ||
    command?.Public === false ||
    command?.public === false
  )
}

function getRawGroup(command) {
  return cleanText(command?.Group || command?.group || 'أوامر عامة')
}

function getDisplayGroup(command) {
  const rawGroup = getRawGroup(command)
  return siteConfig.groupLabels[rawGroup] || rawGroup || 'أوامر عامة'
}

function getRawName(command) {
  return cleanText(command?.Name || command?.name || 'أمر بدون اسم')
}

function getDisplayName(command) {
  return getRawName(command)
    .replace(/^\[[^\]]+\]\s*-\s*/g, '')
    .replace(/^\[[^\]]+\]\s*/g, '')
    .replace(/^Game\s*-\s*/i, '')
    .replace(/^Scoreboard\s*-\s*/i, '')
    .trim()
}

function isGroupHidden(group) {
  const normalizedGroup = normalizeText(group)

  if (hiddenGroups.has(normalizedGroup)) return true

  return hiddenGroupKeywords.some((keyword) => normalizedGroup.includes(keyword))
}

function isNameHidden(name) {
  const normalizedName = normalizeText(name)

  if (hiddenNames.has(normalizedName)) return true

  return hiddenNameKeywords.some((keyword) => normalizedName.includes(keyword))
}

function getRawAliases(command) {
  const aliases = Array.isArray(command?.Commands) ? command.Commands : []
  const seen = new Set()
  const result = []

  for (const alias of aliases) {
    const cleanAlias = cleanText(alias)
    const normalizedAlias = normalizeText(cleanAlias)

    if (!cleanAlias || seen.has(normalizedAlias)) continue

    seen.add(normalizedAlias)
    result.push(cleanAlias)
  }

  return result
}

function startsWithCommandPrefix(alias) {
  return cleanText(alias).startsWith('!')
}

function isAliasHidden(alias) {
  const normalizedAlias = normalizeText(alias)

  if (!normalizedAlias) return true
  if (forceVisibleAliases.has(normalizedAlias)) return false
  if (hiddenAliases.has(normalizedAlias)) return true

  if (siteConfig.onlyBangCommands && !startsWithCommandPrefix(alias)) {
    return true
  }

  return hiddenAliasKeywords.some((keyword) => normalizedAlias.includes(keyword))
}

function getVisibleAliases(command) {
  return getRawAliases(command).filter((alias) => !isAliasHidden(alias))
}

function classifyCommand(command) {
  if (!command || typeof command !== 'object') {
    return {
      show: false,
      reason: 'invalid',
      visibleAliases: [],
    }
  }

  if (!isEnabled(command)) {
    return {
      show: false,
      reason: 'disabled',
      visibleAliases: [],
    }
  }

  if (isWebsiteHidden(command)) {
    return {
      show: false,
      reason: 'website-hidden',
      visibleAliases: [],
    }
  }

  const rawGroup = getRawGroup(command)
  const rawName = getRawName(command)

  if (isGroupHidden(rawGroup)) {
    return {
      show: false,
      reason: 'hidden-group',
      visibleAliases: [],
    }
  }

  if (isNameHidden(rawName)) {
    return {
      show: false,
      reason: 'hidden-name',
      visibleAliases: [],
    }
  }

  const visibleAliases = getVisibleAliases(command)

  if (visibleAliases.length === 0) {
    return {
      show: false,
      reason: 'no-visible-aliases',
      visibleAliases: [],
    }
  }

  return {
    show: true,
    reason: 'visible',
    visibleAliases,
  }
}

const preparedCommands = rawCommands.map((command) => ({
  command,
  ...classifyCommand(command),
}))

const commands = preparedCommands
  .filter((item) => item.show)
  .map((item) => {
    const command = item.command
    const displayGroup = getDisplayGroup(command)
    const displayName = getDisplayName(command)
    const visibleAliases = item.visibleAliases
    const primaryAlias = visibleAliases[0] || ''

    return {
      Id: cleanText(command.Id || command.id || `${displayGroup}-${displayName}-${primaryAlias}`),
      RawName: getRawName(command),
      DisplayName: displayName,
      RawGroup: getRawGroup(command),
      DisplayGroup: displayGroup,
      VisibleAliases: visibleAliases,
      PrimaryAlias: primaryAlias,
      SearchText: normalizeText(`${displayName} ${getRawName(command)} ${displayGroup} ${getRawGroup(command)} ${visibleAliases.join(' ')}`),
    }
  })

const groups = {}

for (const command of commands) {
  if (!groups[command.DisplayGroup]) {
    groups[command.DisplayGroup] = []
  }

  groups[command.DisplayGroup].push(command)
}

for (const groupName of Object.keys(groups)) {
  groups[groupName].sort((a, b) => {
    return a.DisplayName.localeCompare(b.DisplayName, 'ar')
  })
}

function getGroupSortIndex(group) {
  const index = siteConfig.groupOrder.indexOf(group)
  return index === -1 ? 999 : index
}

const groupNames = Object.keys(groups).sort((a, b) => {
  const indexA = getGroupSortIndex(a)
  const indexB = getGroupSortIndex(b)

  if (indexA !== indexB) return indexA - indexB

  return a.localeCompare(b, 'ar')
})

const importantAliases = [
  '!نقاط',
  '!نقاطي',
  '!points',
  '!ليدربورد',
  '!بريد',
  '!mail',
  '!هدية',
  '!gift',
  '!قبول الهدية',
  '!رفض الهدية',
  '!clip',
  '!مزاد',
  '!بطاطا',
  '!فاميلي فيود',
  '!تحدي',
]

const importantAliasSet = makeNormalizedSet(importantAliases)
const featuredCommands = []
const featuredSeen = new Set()

for (const command of commands) {
  const hasImportantAlias = command.VisibleAliases.some((alias) => importantAliasSet.has(normalizeText(alias)))

  if (!hasImportantAlias) continue

  const key = normalizeText(command.PrimaryAlias || command.DisplayName)
  if (featuredSeen.has(key)) continue

  featuredSeen.add(key)
  featuredCommands.push(command)

  if (featuredCommands.length >= 8) break
}

const totalRawCommands = rawCommands.length
const totalVisibleCommands = commands.length
const totalAliases = commands.reduce((sum, command) => sum + command.VisibleAliases.length, 0)
const totalGroups = groupNames.length
const totalDisabled = preparedCommands.filter((item) => item.reason === 'disabled').length
const totalHidden = preparedCommands.filter((item) => item.reason !== 'visible' && item.reason !== 'disabled').length
---

<Layout metadata={metadata}>
  <main class="tnx-commands-page" dir="rtl">
    <div class="tnx-commands-bg"></div>
    <div class="tnx-commands-grid"></div>

    <section class="tnx-commands-wrap">
      <header class="tnx-commands-hero">
        <div class="tnx-commands-hero-copy">
          <div class="tnx-commands-kicker">
            <span></span>
            TNX6 COMMANDS
          </div>

          <h1>أوامر البث</h1>

          <p>
            الأوامر الظاهرة هنا مخصصة للمشاهدين. أوامر المودز، الردود التلقائية، والأوامر المطفيّة داخل Streamer.bot مخفية من الموقع.
          </p>
        </div>

        <div class="tnx-commands-stats" aria-label="إحصائيات الأوامر">
          <div>
            <strong>{totalVisibleCommands}</strong>
            <span>أمر ظاهر</span>
          </div>

          <div>
            <strong>{totalGroups}</strong>
            <span>قسم</span>
          </div>

          <div>
            <strong>{totalAliases}</strong>
            <span>اختصار</span>
          </div>

          <div>
            <strong>{totalDisabled + totalHidden}</strong>
            <span>مخفي</span>
          </div>
        </div>
      </header>

      {featuredCommands.length > 0 && (
        <section class="tnx-commands-featured" aria-label="أهم الأوامر">
          <div class="tnx-commands-section-head">
            <div>
              <span>QUICK START</span>
              <h2>أهم الأوامر</h2>
            </div>
          </div>

          <div class="tnx-commands-featured-grid">
            {featuredCommands.map((command) => (
              <article class="tnx-command-featured-card" data-search={command.SearchText}>
                <div>
                  <strong>{command.DisplayName}</strong>
                  <small>{command.DisplayGroup}</small>
                </div>

                <button type="button" class="tnx-copy-command" data-copy={command.PrimaryAlias}>
                  {command.PrimaryAlias}
                </button>
              </article>
            ))}
