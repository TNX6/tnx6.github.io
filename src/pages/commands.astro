      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.24);
    }

    .tnx-command-card-header {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 0.85rem;
    }

    .tnx-command-card-header span {
      display: block;
      color: #c29200;
      font-size: 0.72rem;
      font-weight: 950;
    }

    .tnx-command-card-header h3 {
      margin: 0.25rem 0 0;
      color: #fff;
      font-size: 1.22rem;
      font-weight: 950;
      line-height: 1.3;
    }

    .tnx-mini-icon {
      width: 2.8rem;
      height: 2.8rem;
      flex: 0 0 2.8rem;
      border-radius: 0.95rem;
    }

    .tnx-command-description {
      margin: 0;
      color: rgb(209, 213, 219);
      font-size: 0.92rem;
      font-weight: 790;
      line-height: 1.8;
    }

    .tnx-command-box {
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.8rem;
    }

    .tnx-command-box > span,
    .tnx-example-box > span {
      display: block;
      margin-bottom: 0.35rem;
      color: rgb(148, 163, 184);
      font-size: 0.74rem;
      font-weight: 900;
    }

    .tnx-command-box > div {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.7rem;
    }

    .tnx-command-box code,
    .tnx-example-box code {
      display: block;
      overflow: hidden;
      color: #ffda6a;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.98rem;
      font-weight: 950;
      direction: ltr;
      text-align: left;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tnx-command-box button,
    .tnx-more-aliases button {
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.78rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.55rem 0.8rem;
      font-size: 0.78rem;
      font-weight: 950;
      cursor: pointer;
      transition: 0.16s ease;
    }

    .tnx-command-box button:hover,
    .tnx-more-aliases button:hover {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-command-box button.is-copied,
    .tnx-more-aliases button.is-copied,
    .tnx-copy-primary.is-copied {
      border-color: rgba(52, 211, 153, 0.65) !important;
      background: rgba(52, 211, 153, 0.14) !important;
      color: rgb(167, 243, 208) !important;
    }

    .tnx-copy-primary.is-copied span {
      background: rgba(52, 211, 153, 0.16) !important;
      color: rgb(167, 243, 208) !important;
    }

    .tnx-example-box {
      border: 1px dashed rgba(255, 218, 106, 0.15);
      border-radius: 1rem;
      background: rgba(255, 218, 106, 0.035);
      padding: 0.75rem;
    }

    .tnx-more-aliases {
      border-top: 1px solid rgba(255, 218, 106, 0.12);
      padding-top: 0.72rem;
    }

    .tnx-more-aliases summary {
      color: rgb(156, 163, 175);
      font-size: 0.82rem;
      font-weight: 900;
      cursor: pointer;
    }

    .tnx-more-aliases div {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-top: 0.7rem;
    }

    .tnx-more-aliases button {
      max-width: 100%;
      overflow: hidden;
      direction: ltr;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tnx-empty {
      display: grid;
      place-items: center;
      gap: 0.35rem;
      border-radius: 1.5rem;
      padding: 2rem;
      text-align: center;
    }

    .tnx-empty strong {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .tnx-command-card.is-hidden,
    .tnx-command-group.is-hidden,
    .tnx-feature-card.is-hidden {
      display: none !important;
    }

    @media (max-width: 1100px) {
      .tnx-hero {
        grid-template-columns: 1fr;
      }

      .tnx-hero-panel {
        grid-template-columns: 220px minmax(0, 1fr);
        align-items: center;
      }

      .tnx-panel-ring {
        width: 220px;
      }

      .tnx-panel-stats {
        align-self: stretch;
      }

      .tnx-main-layout {
        grid-template-columns: 1fr;
      }

      .tnx-side-nav {
        position: relative;
        top: auto;
        display: flex;
        overflow-x: auto;
        border-radius: 1.4rem;
      }

      .tnx-side-title {
        display: none;
      }

      .tnx-nav-item {
        min-width: 180px;
      }
    }

    @media (max-width: 820px) {
      .tnx-shell {
        padding-top: 5.5rem;
      }

      .tnx-hero-main,
      .tnx-hero-panel,
      .tnx-featured,
      .tnx-side-nav,
      .tnx-command-group {
        border-radius: 1.45rem;
      }

      .tnx-hero-main {
        padding: 1.25rem;
      }

      .tnx-hero h1 {
        font-size: 3.1rem;
      }

      .tnx-hero-panel {
        grid-template-columns: 1fr;
      }

      .tnx-panel-ring {
        width: 100%;
        max-width: 260px;
        margin: 0 auto;
      }

      .tnx-featured-grid,
      .tnx-command-grid {
        grid-template-columns: 1fr;
      }

      .tnx-command-group-head {
        align-items: start;
        flex-direction: column;
      }

      .tnx-group-count {
        min-width: 100%;
        min-height: auto;
        display: flex;
        justify-content: center;
        gap: 0.4rem;
        padding: 0.8rem;
      }
    }

    @media (max-width: 520px) {
      .tnx-hero h1 {
        font-size: 2.55rem;
      }

      .tnx-launcher {
        grid-template-columns: auto minmax(0, 1fr);
      }

      .tnx-launcher button {
        display: none;
      }

      .tnx-command-box > div {
        grid-template-columns: 1fr;
      }

      .tnx-command-box button {
        width: 100%;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxCommandCenterCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0

        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
      }

      const searchInput = document.getElementById('commandSearch')
      const clearSearchButton = document.getElementById('clearCommandSearch')
      const categoryButtons = Array.from(document.querySelectorAll('[data-category-filter]'))
      const searchChips = Array.from(document.querySelectorAll('[data-search-chip]'))
      const commandCards = Array.from(document.querySelectorAll('[data-command-card]'))
      const commandGroups = Array.from(document.querySelectorAll('[data-command-group]'))
      const emptyState = document.getElementById('emptyState')
      const copyButtons = Array.from(document.querySelectorAll('[data-copy]'))

      let activeCategory = 'all'

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function applyFilters() {
        const term = normalize(searchInput?.value || '')
        let visibleTotal = 0

        commandCards.forEach((card) => {
          const cardCategory = card.dataset.category || ''
          const cardSearch = normalize(card.dataset.search || card.textContent || '')

          const categoryMatches = activeCategory === 'all' || cardCategory === activeCategory
          const searchMatches = !term || cardSearch.includes(term)
          const shouldShow = categoryMatches && searchMatches

          card.classList.toggle('is-hidden', !shouldShow)

          if (shouldShow) {
            visibleTotal++
          }
        })

        commandGroups.forEach((group) => {
          const groupCategory = group.dataset.commandGroup || ''
          const visibleCards = group.querySelectorAll('[data-command-card]:not(.is-hidden)').length
          const categoryMatches = activeCategory === 'all' || groupCategory === activeCategory

          group.classList.toggle('is-hidden', !categoryMatches || visibleCards === 0)
        })

        emptyState?.classList.toggle('hidden', visibleTotal > 0)
      }

      addListener(searchInput, 'input', applyFilters)

      addListener(clearSearchButton, 'click', () => {
        if (!searchInput) return

        searchInput.value = ''
        searchInput.focus()
        applyFilters()
      })

      searchChips.forEach((chip) => {
        addListener(chip, 'click', () => {
          if (!searchInput) return

          searchInput.value = chip.dataset.searchChip || ''
          searchInput.focus()
          applyFilters()
        })
      })

      categoryButtons.forEach((button) => {
        addListener(button, 'click', () => {
          activeCategory = button.dataset.categoryFilter || 'all'

          categoryButtons.forEach((item) => item.classList.remove('is-active'))
          button.classList.add('is-active')

          applyFilters()

          const layout = document.querySelector('.tnx-main-layout')
          if (layout && window.innerWidth < 1100) {
            layout.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        })
      })

      copyButtons.forEach((button) => {
        addListener(button, 'click', async () => {
          const copyText = button.dataset.copy || button.textContent || ''
          const oldText = button.textContent

          try {
            await navigator.clipboard.writeText(copyText)

            button.textContent = 'تم النسخ'
            button.classList.add('is-copied')

            addTimer(
              window.setTimeout(() => {
                button.textContent = oldText
                button.classList.remove('is-copied')
              }, 900)
            )
          } catch {
            button.textContent = copyText

            addTimer(
              window.setTimeout(() => {
                button.textContent = oldText
              }, 900)
            )
          }
        })
      })

      applyFilters()
    })()
  </script>
</Layout>
