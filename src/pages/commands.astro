  <script is:inline data-reinit>
    ;(() => {
      const cleanupKey = '__tnxCommandJourneyCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0

        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
      }

      const entryChoice = document.getElementById('entryChoice')
      const newUserFlow = document.getElementById('newUserFlow')
      const allCommandsView = document.getElementById('allCommandsView')
      const progressCurrent = document.getElementById('progressCurrent')
      const progressTotal = document.getElementById('progressTotal')
      const progressBar = document.getElementById('progressBar')
      const completionBox = document.getElementById('completionBox')
      const systemPanels = Array.from(document.querySelectorAll('[data-system-panel]'))
      const systemCards = Array.from(document.querySelectorAll('[data-system-card]'))
      const systemStatuses = Array.from(document.querySelectorAll('[data-system-status]'))
      const resetButtons = Array.from(document.querySelectorAll('[data-reset-choice]'))
      const openAllButtons = Array.from(document.querySelectorAll('[data-open-all]'))
      const startModeButtons = Array.from(document.querySelectorAll('[data-start-mode]'))
      const copyButtons = Array.from(document.querySelectorAll('[data-copy]'))

      const commandSearch = document.getElementById('commandSearch')
      const clearCommandSearch = document.getElementById('clearCommandSearch')
      const filterButtons = Array.from(document.querySelectorAll('[data-category-filter]'))
      const allCommandCards = Array.from(document.querySelectorAll('#allCommandsView [data-command-card]'))
      const commandGroups = Array.from(document.querySelectorAll('#allCommandsView [data-command-group]'))
      const emptyState = document.getElementById('emptyState')

      const seenSystems = new Set()
      const totalSystems = Number(progressTotal?.textContent || systemCards.length || 0)
      let activeFilter = 'all'

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function showEntry() {
        entryChoice?.classList.remove('hidden')
        newUserFlow?.classList.add('hidden')
        allCommandsView?.classList.add('hidden')
      }

      function showNewFlow() {
        entryChoice?.classList.add('hidden')
        newUserFlow?.classList.remove('hidden')
        allCommandsView?.classList.add('hidden')
        newUserFlow?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }

      function showAllCommands() {
        entryChoice?.classList.add('hidden')
        newUserFlow?.classList.add('hidden')
        allCommandsView?.classList.remove('hidden')
        allCommandsView?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        applyAllCommandsFilters()
      }

      function updateProgress() {
        const current = seenSystems.size
        const percent = totalSystems > 0 ? Math.round((current / totalSystems) * 100) : 0

        if (progressCurrent) {
          progressCurrent.textContent = String(current)
        }

        if (progressBar) {
          progressBar.style.width = `${percent}%`
        }

        if (completionBox) {
          completionBox.classList.toggle('hidden', current < totalSystems || totalSystems === 0)
        }

        systemCards.forEach((card) => {
          const category = card.dataset.systemCard || ''
          card.classList.toggle('is-done', seenSystems.has(category))
        })

        systemStatuses.forEach((status) => {
          const category = status.dataset.systemStatus || ''
          status.textContent = seenSystems.has(category) ? 'تم' : 'جديد'
        })
      }

      function openSystem(category) {
        systemCards.forEach((card) => {
          card.classList.toggle('is-active', card.dataset.systemCard === category)
        })

        systemPanels.forEach((panel) => {
          const isActive = panel.dataset.systemPanel === category
          panel.classList.toggle('hidden', !isActive)

          if (isActive) {
            addTimer(
              window.setTimeout(() => {
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' })
              }, 80)
            )
          }
        })

        seenSystems.add(category)
        updateProgress()
      }

      function syncFilterButtons() {
        filterButtons.forEach((button) => {
          const value = button.dataset.categoryFilter || 'all'
          button.classList.toggle('is-active', value === activeFilter)
        })
      }

      function applyAllCommandsFilters() {
        const term = normalize(commandSearch?.value || '')
        let visibleTotal = 0

        allCommandCards.forEach((card) => {
          const category = card.dataset.category || ''
          const searchText = normalize(card.dataset.search || card.textContent || '')
          const categoryMatch = activeFilter === 'all' || activeFilter === category
          const searchMatch = !term || searchText.includes(term)
          const shouldShow = categoryMatch && searchMatch

          card.classList.toggle('is-hidden', !shouldShow)

          if (shouldShow) {
            visibleTotal++
          }
        })

        commandGroups.forEach((group) => {
          const category = group.dataset.commandGroup || ''
          const categoryMatch = activeFilter === 'all' || activeFilter === category
          const visibleCards = group.querySelectorAll('[data-command-card]:not(.is-hidden)').length

          group.classList.toggle('is-hidden', !categoryMatch || visibleCards === 0)
        })

        emptyState?.classList.toggle('hidden', visibleTotal > 0)
      }

      startModeButtons.forEach((button) => {
        addListener(button, 'click', () => {
          const mode = button.dataset.startMode

          if (mode === 'new') {
            showNewFlow()
          } else {
            showAllCommands()
          }
        })
      })

      resetButtons.forEach((button) => {
        addListener(button, 'click', showEntry)
      })

      openAllButtons.forEach((button) => {
        addListener(button, 'click', showAllCommands)
      })

      systemCards.forEach((card) => {
        addListener(card, 'click', () => {
          const category = card.dataset.systemCard

          if (category) {
            openSystem(category)
          }
        })
      })

      addListener(commandSearch, 'input', applyAllCommandsFilters)

      addListener(clearCommandSearch, 'click', () => {
        if (!commandSearch) return

        commandSearch.value = ''
        commandSearch.focus()
        applyAllCommandsFilters()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          activeFilter = button.dataset.categoryFilter || 'all'
          syncFilterButtons()
          applyAllCommandsFilters()
        })
      })

      copyButtons.forEach((button) => {
        addListener(button, 'click', async () => {
          const copyText = button.dataset.copy || button.textContent || ''
          const oldText = button.textContent

          try {
            await navigator.clipboard.writeText(copyText)

            button.textContent = 'تم النسخ'
            button.classList.add('is-copied')

            addTimer(
              window.setTimeout(() => {
                button.textContent = oldText
                button.classList.remove('is-copied')
              }, 900)
            )
          } catch {
            button.textContent = copyText

            addTimer(
              window.setTimeout(() => {
                button.textContent = oldText
              }, 900)
            )
          }
        })
      })

      updateProgress()
      syncFilterButtons()
      applyAllCommandsFilters()
    })()
  </script>
</Layout>
