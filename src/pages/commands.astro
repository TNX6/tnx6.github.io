---
import Layout from '~/layouts/PageLayout.astro'
import fs from 'fs'
import path from 'path'

const metadata = {
  title: 'Commands — TNX6',
  ignoreTitleTemplate: true,
  description: 'مركز أوامر مجتمع TNX6.',
}

function readJsonFile(relativePath, fallback) {
  try {
    const filePath = path.resolve(relativePath)

    if (!fs.existsSync(filePath)) {
      return fallback
    }

    const data = fs.readFileSync(filePath, 'utf-8')
    return JSON.parse(data)
  } catch (error) {
    console.error(`Failed to load ${relativePath}:`, error)
    return fallback
  }
}

const loadedCommands = readJsonFile('public/api/commands.json', [])
const rawCommands = Array.isArray(loadedCommands) ? loadedCommands : []

function cleanText(value) {
  return String(value ?? '').trim().replace(/\s+/g, ' ')
}

function normalizeText(value) {
  return cleanText(value)
    .toLowerCase()
    .replace(/[ًٌٍَُِّْـ]/g, '')
    .replace(/[أإآ]/g, 'ا')
    .replace(/ة/g, 'ه')
    .replace(/ى/g, 'ي')
    .replace(/\s+/g, ' ')
    .trim()
}

function normalizeAlias(value) {
  return normalizeText(value)
}

/*
  فلترة المصدر:
  الصفحة ما تثق في commands.json كامل.
  أي أمر مطفي، أو مودز، أو إداري، أو داخلي، ما يدخل أصلًا في الخريطة.
*/

const HIDDEN_GROUP_KEYWORDS = [
  'mod tools',
  'مودز',
  'admin',
  'admins',
  'moderator',
  'moderators',
  'old',
  'setup',
  'bot responses',
  'ردود البوت',
]

const HIDDEN_NAME_KEYWORDS = [
  'setup',
  'backup',
  'exclude user',

  'add points',
  'remove points',
  'multiply',
  'collect taxes',
  'happy hour',

  'blacklist',
  'whitelist',
  'custom command',
  'add custom',
  'edit custom',
  'remove custom',

  'reward',
  'prediction',
  'poll',
  'scene',
  'obs',
  'browser source',
  'audio source',

  'run ads',
  'snooze',
  'pre-roll',
  'preroll',

  'botted',
  'follow attack',
  'hate raid',

  'ban user',
  'timeout',
  'permit user',

  'هدية للكل',
  'ارسل للكل',
  'أرسل للكل',
  'مستخدمين البريد',
  'اصحاب البريد',
  'أصحاب البريد',
  'مسح البريد',
  'حذف هدية النظام',
]

function commandIsEnabled(command) {
  return command?.Enabled === true || command?.Enabled === 'true'
}

function commandIsHiddenBySource(command) {
  const group = normalizeText(command?.Group)
  const name = normalizeText(command?.Name)

  if (!commandIsEnabled(command)) return true

  if (HIDDEN_GROUP_KEYWORDS.some((keyword) => group.includes(normalizeText(keyword)))) {
    return true
  }

  if (HIDDEN_NAME_KEYWORDS.some((keyword) => name.includes(normalizeText(keyword)))) {
    return true
  }

  return false
}

function getCommandAliases(command) {
  if (!Array.isArray(command?.Commands)) return []

  const seen = new Set()
  const aliases = []

  for (const alias of command.Commands) {
    const cleanAlias = cleanText(alias)
    const normalized = normalizeAlias(cleanAlias)

    if (!cleanAlias) continue
    if (!cleanAlias.startsWith('!')) continue
    if (seen.has(normalized)) continue

    seen.add(normalized)
    aliases.push(cleanAlias)
  }

  return aliases
}

const availableAliasMap = new Map()

for (const command of rawCommands) {
  if (commandIsHiddenBySource(command)) continue

  for (const alias of getCommandAliases(command)) {
    const key = normalizeAlias(alias)

    if (!availableAliasMap.has(key)) {
      availableAliasMap.set(key, {
        alias,
        sourceName: cleanText(command.Name),
        sourceGroup: cleanText(command.Group),
      })
    }
  }
}

