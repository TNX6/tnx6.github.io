---
import Layout from '~/layouts/PageLayout.astro'
import fs from 'fs'
import path from 'path'

const metadata = {
  title: 'Commands — TNX6',
  ignoreTitleTemplate: true,
  description: 'دليل أوامر مجتمع TNX6 للمشاهدين.',
}

function readJsonFile(relativePath, fallback) {
  try {
    const filePath = path.resolve(relativePath)

    if (!fs.existsSync(filePath)) {
      return fallback
    }

    const data = fs.readFileSync(filePath, 'utf-8')
    return JSON.parse(data)
  } catch (error) {
    console.error(`Failed to load ${relativePath}:`, error)
    return fallback
  }
}

const loadedCommands = readJsonFile('public/api/commands.json', [])
const rawCommands = Array.isArray(loadedCommands) ? loadedCommands : []

function cleanText(value) {
  return String(value ?? '').trim().replace(/\s+/g, ' ')
}

function normalizeText(value) {
  return cleanText(value)
    .toLowerCase()
    .replace(/[ًٌٍَُِّْـ]/g, '')
    .replace(/[أإآ]/g, 'ا')
    .replace(/ة/g, 'ه')
    .replace(/ى/g, 'ي')
    .replace(/\s+/g, ' ')
    .trim()
}

function normalizeAlias(value) {
  return normalizeText(value)
}

const HIDDEN_GROUP_KEYWORDS = [
  'mod tools',
  'مودز',
  'admin',
  'moderator',
  'old',
  'setup',
  'bot responses',
  'ردود البوت',
]

const HIDDEN_NAME_KEYWORDS = [
  'setup',
  'add points',
  'remove points',
  'multiply',
  'collect taxes',
  'happy hour',
  'blacklist',
  'whitelist',
  'custom command',
  'reward',
  'prediction',
  'poll',
  'scene',
  'obs',
  'browser source',
  'audio source',
  'run ads',
  'snooze',
  'botted',
  'follow attack',
  'hate raid',
  'ban user',
  'timeout',
  'exclude user',
  'backup',
  'هدية للكل',
  'ارسل للكل',
  'مستخدمين البريد',
  'مسح البريد',
  'حذف هدية النظام',
]

function commandIsEnabled(command) {
  return command?.Enabled === true || command?.Enabled === 'true'
}

function commandIsHiddenBySource(command) {
  const group = normalizeText(command?.Group)
  const name = normalizeText(command?.Name)

  if (!commandIsEnabled(command)) {
    return true
  }

  if (HIDDEN_GROUP_KEYWORDS.some((keyword) => group.includes(normalizeText(keyword)))) {
    return true
  }

  if (HIDDEN_NAME_KEYWORDS.some((keyword) => name.includes(normalizeText(keyword)))) {
    return true
  }

  return false
}

function getCommandAliases(command) {
  if (!Array.isArray(command?.Commands)) {
    return []
  }

  return command.Commands
    .map((alias) => cleanText(alias))
    .filter(Boolean)
    .filter((alias) => alias.startsWith('!'))
}

const availableAliasMap = new Map()

for (const command of rawCommands) {
  if (commandIsHiddenBySource(command)) {
    continue
  }

  for (const alias of getCommandAliases(command)) {
    const key = normalizeAlias(alias)

    if (!availableAliasMap.has(key)) {
      availableAliasMap.set(key, {
        alias,
        sourceName: cleanText(command.Name),
        sourceGroup: cleanText(command.Group),
      })
    }
  }
}

