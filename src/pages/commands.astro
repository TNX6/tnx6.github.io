const CATEGORY_ORDER = ['points', 'inventory', 'badges', 'mail', 'tools', 'games']
const BEGINNER_CATEGORY_ORDER = ['points', 'inventory', 'badges']

function getAvailableAliases(definition) {
  const result = []
  const seen = new Set()

  for (const alias of definition.aliases) {
    const key = normalizeAlias(alias)
    const available = availableAliasMap.get(key)

    if (!available) continue

    const cleanAlias = cleanText(available.alias)
    const normalized = normalizeAlias(cleanAlias)

    if (seen.has(normalized)) continue

    seen.add(normalized)
    result.push(cleanAlias)
  }

  return result
}

const visibleCommands = COMMAND_CATALOG
  .map((definition) => {
    const aliases = getAvailableAliases(definition)
    if (aliases.length === 0) return null

    const category = definition.category
    const meta = CATEGORY_META[category] || CATEGORY_META.points
    const primaryAlias = aliases[0]

    return {
      ...definition,
      aliases,
      primaryAlias,
      categoryTitle: meta.title,
      categoryShort: meta.short,
      categoryIcon: meta.icon,
      searchText: normalizeText(
        [
          definition.title,
          definition.description,
          definition.example,
          definition.badge,
          definition.requirement,
          definition.usage,
          ...(definition.keywords || []),
          ...aliases,
          meta.title,
          meta.short,
        ].join(' ')
      ),
    }
  })
  .filter(Boolean)

const commandsByCategory = {}

for (const category of CATEGORY_ORDER) {
  commandsByCategory[category] = []
}

for (const command of visibleCommands) {
  if (!commandsByCategory[command.category]) {
    commandsByCategory[command.category] = []
  }

  commandsByCategory[command.category].push(command)
}

const visibleCategories = CATEGORY_ORDER.filter((category) => commandsByCategory[category]?.length > 0)

function findCommandById(id) {
  return visibleCommands.find((command) => command.id === id)
}

const beginnerCategories = BEGINNER_CATEGORY_ORDER.filter((category) => {
  return commandsByCategory[category]?.some((command) => command.beginner)
})

const totalBeginnerCategories = beginnerCategories.length
