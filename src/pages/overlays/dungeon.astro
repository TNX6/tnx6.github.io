---
import '~/assets/styles/dungeon-overlay.css';

const slots = Array.from({ length: 6 }, (_, index) => index + 1);
const battleBursts = [
  { name: 'one', sparks: ['one', 'two', 'three', 'four', 'five'] },
  { name: 'two', sparks: ['six', 'seven', 'eight', 'nine'] },
  { name: 'three', sparks: ['ten', 'eleven', 'twelve'] },
];
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>TNX6 Dungeon Overlay</title>
  </head>
  <body>
    <main id="dungeonOverlay" class="dov-overlay" hidden>
      <section id="dungeonOverlayScene" class="dov-scene" aria-label="مشهد دنجن TNX6 التجريبي">
        <div id="dovJoinNotice" class="dov-notice" role="status" aria-live="polite" aria-atomic="true" hidden>
          <span class="dov-notice__spark" aria-hidden="true"></span>
          <strong id="dovJoinNoticeText"></strong>
        </div>

        <div
          id="dovEventFeed"
          class="dov-event-feed"
          role="log"
          aria-live="polite"
          aria-relevant="additions"
          aria-atomic="false"
          hidden
        >
        </div>

        <div id="dovEvent" class="dov-battle-status" role="status" aria-live="polite" aria-atomic="true" hidden>
          <span id="dovEventIcon" class="dov-event-feed__icon" aria-hidden="true"></span>
          <p id="dovEventText"></p>
        </div>

        <div class="dov-cave-layer" aria-hidden="true">
          <img
            class="dov-cave-art"
            src="/assets/dungeon-overlay/cave.webp"
            alt=""
            width="1448"
            height="1086"
            loading="eager"
            decoding="sync"
            draggable="false"
          />
          <span class="dov-torch-flame dov-torch-flame--right"></span>
          <span class="dov-torch-flame dov-torch-flame--left"></span>
        </div>

        <div id="dovEntryFx" class="dov-entry-fx" aria-hidden="true" hidden>
          {
            battleBursts.map((burst) => (
              <span class={`dov-entry-fx__burst dov-entry-fx__burst--${burst.name}`}>
                <span class="dov-entry-fx__flash" />
                {burst.sparks.map((spark) => (
                  <span class={`dov-entry-fx__spark dov-entry-fx__spark--${spark}`} />
                ))}
              </span>
            ))
          }
          <span class="dov-entry-fx__dust dov-entry-fx__dust--one"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--two"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--three"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--four"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--five"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--six"></span>
          <span class="dov-entry-fx__dust dov-entry-fx__dust--seven"></span>
        </div>

        <div id="dovBattleAmbient" class="dov-battle-ambient" aria-hidden="true" hidden>
          <span class="dov-battle-ambient__gate"></span>
          <span class="dov-battle-ambient__flash"></span>
          <span class="dov-battle-ambient__spark dov-battle-ambient__spark--one"></span>
          <span class="dov-battle-ambient__spark dov-battle-ambient__spark--two"></span>
          <span class="dov-battle-ambient__spark dov-battle-ambient__spark--three"></span>
          <span class="dov-battle-ambient__dust dov-battle-ambient__dust--one"></span>
          <span class="dov-battle-ambient__dust dov-battle-ambient__dust--two"></span>
        </div>

        <div class="dov-brand" aria-label="TNX6 Dungeon">
          <span aria-hidden="true"></span>
          <strong>TNX6 DUNGEON</strong>
          <span aria-hidden="true"></span>
        </div>

        <div id="dovStatus" class="dov-status" hidden>
          <span id="dovStatusLabel" class="dov-status__label">تبدأ الرحلة خلال</span>
          <strong id="dovCountdown" class="dov-status__count">43</strong>
          <span class="dov-status__players"><b id="dovPlayerCount">4 / 6</b> لاعبين</span>
        </div>

        <div id="dovResult" class="dov-result" role="status" aria-live="polite" hidden>
          <span id="dovResultMark" class="dov-result__mark" aria-hidden="true"></span>
          <strong id="dovResultTitle"></strong>
          <span id="dovResultText"></span>
          <div id="dovResultRewards" class="dov-result__rewards"></div>
        </div>

        <div id="dovParty" class="dov-party" aria-label="مقاعد فريق الدنجن">
          {
            slots.map((slot) => (
              <article class="dov-slot dov-slot--empty" data-dov-slot={slot} aria-label={`المقعد ${slot} فارغ`}>
                <span class="dov-empty-seat" aria-hidden="true">
                  <span />
                </span>

                <span
                  class="dov-player-actor"
                  data-animation-state="inside"
                  data-character-style={['red', 'purple', 'green', 'orange', 'blue', 'black-gold'][slot - 1]}
                >
                  <span class="dov-player-shadow" aria-hidden="true" />
                  <span class="dov-player-figure">
                    <span class="dov-slot__identity-anchor">
                      <span class="dov-slot__identity">
                        <span class="dov-slot__name-row">
                          <strong class="dov-slot__name" />
                          <span class="dov-slot__key" aria-label="صاحب فتح الدنجن" title="صاحب الفتح" />
                        </span>
                        <span class="dov-slot__level" />
                        <span class="dov-slot__state" />
                      </span>
                    </span>

                    <span class="dov-avatar" aria-hidden="true">
                      <span class="dov-character-motion">
                        <span class="dov-character-sprite" />
                        <span class="dov-character-accent" />
                      </span>
                    </span>
                  </span>
                </span>
                <span class="dov-slot__reward" aria-live="polite" />
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <script>
      import '~/scripts/dungeon-overlay-client';
    </script>
  </body>
</html>
