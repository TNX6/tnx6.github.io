  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxItemsPageCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []
      let revealObserver = null

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
        if (revealObserver) revealObserver.disconnect()
      }

      // ============ Item Catalog Metadata ============
      // Maps item names to: category, icon, special flag
      const ITEM_META = {
        // Status / Royalty (purple)
        'Vip':                 { cat: 'status', icon: '👑' },
        'Vip+':                { cat: 'status', icon: '👑', rare: true },
        'محامي':               { cat: 'status', icon: '⚖️' },
        'عريف الفصل':          { cat: 'status', icon: '🎖️' },
        'Crown':               { cat: 'rare',   icon: '👑', rare: true },

        // Attacks on stream (red)
        'نيوك':                { cat: 'attacks', icon: '☢️', rare: true },
        'تغير العنوان':        { cat: 'attacks', icon: '📝' },
        'تغير العنوان مطور':   { cat: 'attacks', icon: '✍️' },
        'تجميد الشاشة':        { cat: 'attacks', icon: '❄️' },
        'قنبلة دخانية':        { cat: 'attacks', icon: '💣' },

        // PvP (orange)
        'يد الحرامي':          { cat: 'pvp', icon: '🥷' },
        'اقول لا يكثر':        { cat: 'pvp', icon: '🚫' },

        // Luck / gambling (yellow)
        'عملة الجرأة':         { cat: 'luck', icon: '🎯' },
        'رمي النرد':           { cat: 'luck', icon: '🎲' },
        'البطاطا الحارة':      { cat: 'luck', icon: '🥔' },

        // Boxes (green)
        'صندوق':               { cat: 'boxes', icon: '📦' },
        'صندوق نادر':          { cat: 'boxes', icon: '🎁', rare: true },
        'صندوق النقاط':        { cat: 'boxes', icon: '💰' },
        'صندوق السمعة':        { cat: 'boxes', icon: '💎' },

        // Permits / licenses (blue)
        'رخصة الطبخ':          { cat: 'permits', icon: '📜' },
        "Lawyer's Exam":       { cat: 'permits', icon: '📜' },
        'رخصة مصرفي':          { cat: 'permits', icon: '📜' },
        'رخصة التجارة':        { cat: 'permits', icon: '📜' },

        // Resources (gray/neutral)
        'علف':                 { cat: 'resources', icon: '🌾' },
        'خشب':                 { cat: 'resources', icon: '🪵' },
        'طماط':                { cat: 'resources', icon: '🍅' },
        'يقطين':               { cat: 'resources', icon: '🎃' },
        'بصل':                 { cat: 'resources', icon: '🧅' },
        'حليب':                { cat: 'resources', icon: '🥛' },
        'بقرة':                { cat: 'resources', icon: '🐄' },
        'فأس':                 { cat: 'resources', icon: '🪓' },

        // Fishing (cyan)
        'صنارة صيد':           { cat: 'fishing', icon: '🎣' },
        'طعم صيد':             { cat: 'fishing', icon: '🪱' },
        'سمكة':                { cat: 'fishing', icon: '🐟' },

        // Cooking (pink)
        'مرق خضار':            { cat: 'cooking', icon: '🥣' },
        'مرق سمك':             { cat: 'cooking', icon: '🍲' },

        // Rare / legendary (gold with shine)
        'مطرقة ذهبية':         { cat: 'rare', icon: '🔨', rare: true },

        // Economy (cream)
        'سمعة':                { cat: 'economy', icon: '💎' },
        'البريد':              { cat: 'economy', icon: '📬' },
      }

      const CATEGORY_LABELS = {
        all: 'الكل',
        status: '👑 مكانة',
        attacks: '💥 هجمات',
        pvp: '⚔️ PvP',
        luck: '🎲 حظ',
        boxes: '🎁 صناديق',
        permits: '📜 رخص',
        resources: '🌾 موارد',
        fishing: '🎣 صيد',
        cooking: '🍳 طبخ',
        rare: '✨ نادر',
        economy: '💎 اقتصاد',
      }

      const state = {
        data: { items: [], crafting: [], lootTables: [] },
        items: [],
        filter: 'all',
        search: '',
        selectedItemName: '',
      }

      const itemsGrid = document.getElementById('itemsGrid')
      const itemsEmpty = document.getElementById('itemsEmpty')
      const itemFocusPanel = document.getElementById('itemFocusPanel')
      const itemSearch = document.getElementById('itemSearch')
      const clearItemSearch = document.getElementById('clearItemSearch')
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'))
      const howtoButtons = Array.from(document.querySelectorAll('[data-filter-mode]'))
      const backToTop = document.getElementById('backToTop')
      const craftingGrid = document.getElementById('craftingGrid')
      const craftingEmpty = document.getElementById('craftingEmpty')

      const statItems = document.getElementById('statItems')
      const statCategories = document.getElementById('statCategories')
      const statCrafting = document.getElementById('statCrafting')
      const statRare = document.getElementById('statRare')

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function itemSlug(name) {
        return `item-${String(name || '')
          .trim()
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')}`
      }

      function formatNumber(n) {
        return Number(n || 0).toLocaleString('de-DE')
      }

      function isRealCommand(option) {
        const text = String(option || '').trim()
        if (!text) return false
        if (normalize(text) === normalize('Type to filter options...')) return false
        return true
      }

      function getItemMeta(name) {
        return ITEM_META[name] || { cat: 'economy', icon: '📦' }
      }

      function getCraftableNames() {
        const set = new Set()
        const crafting = state.data.crafting || []
        crafting.forEach((recipe) => {
          if (recipe && recipe.result) {
            set.add(String(recipe.result).trim())
          }
        })
        return set
      }

      function getSource(item, craftableSet) {
        if (craftableSet.has(item.name)) return { type: 'craft', label: 'تركيب', icon: '⚒️' }
        if (item.excludePurchase && item.excludeSale && item.excludeUsage === true) {
          return { type: 'locked', label: 'حصري', icon: '🔒' }
        }
        if (item.excludePurchase) return { type: 'locked', label: 'غير متاح', icon: '🔒' }
        return { type: 'shop', label: 'متاح للشراء', icon: '🪙' }
      }

      function enrichItem(item, index, craftableSet) {
        const name = String(item?.text || '').trim()
        const meta = getItemMeta(name)
        const option = String(item?.option || '').trim()
        const description = String(item?.description || '').trim() || 'بدون وصف.'
        const hashId = itemSlug(name)
        const source = getSource(item, craftableSet)

        const searchText = normalize([
          name,
          option,
          description,
          meta.cat,
          CATEGORY_LABELS[meta.cat] || '',
          item.excludePurchase ? 'لا يشترى' : 'يشترى',
          item.itemLimitEnabled ? 'محدود' : '',
          meta.rare ? 'نادر' : '',
        ].join(' '))

        return {
          ...item,
          index,
          name,
          option,
          description,
          category: meta.cat,
          icon: meta.icon,
          isRare: !!meta.rare || meta.cat === 'rare',
          hashId,
          value: Number(item?.value || 0),
          source,
          searchText,
        }
      }

      function matchesFilter(item, filter) {
        if (filter === 'all') return true
        if (filter === 'rare') return item.isRare
        return item.category === filter
      }

      function updateStats() {
        const items = state.items
        const categories = new Set(items.map((i) => i.category))
        const rare = items.filter((i) => i.isRare).length

        if (statItems) statItems.textContent = String(items.length)
        if (statCategories) statCategories.textContent = String(categories.size)
        if (statCrafting) statCrafting.textContent = String(state.data.crafting.length)
        if (statRare) statRare.textContent = String(rare)

        const counts = { all: items.length, rare }

        Object.keys(CATEGORY_LABELS).forEach((cat) => {
          if (cat !== 'all') counts[cat] = items.filter((i) => i.category === cat).length
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.filter === state.filter)
        })
      }

      function getFilteredItems() {
        return state.items.filter((item) => {
          const filterMatch = matchesFilter(item, state.filter)
          const searchMatch = !state.search || item.searchText.includes(normalize(state.search))
          return filterMatch && searchMatch
        })
      }

      function renderItems() {
        const items = getFilteredItems()
        if (!itemsGrid) return

        itemsEmpty?.classList.toggle('hidden', items.length > 0)

        itemsGrid.innerHTML = items.map((item) => {
          const selected = item.name === state.selectedItemName ? ' is-selected' : ''
          const flags = []
          if (item.itemLimitEnabled) flags.push(`<span class="tnx-item-flag" title="حد ${item.itemLimitAmount || 1}">📦</span>`)
          if (item.isRare) flags.push(`<span class="tnx-item-flag" title="نادر">✨</span>`)

          const priceHtml = item.value > 0
            ? `<span class="tnx-item-price">🪙 ${formatNumber(item.value)}</span>`
            : `<span class="tnx-item-price" style="color: rgb(156, 163, 175);">—</span>`

          return `
            <button
              type="button"
              id="${esc(item.hashId)}"
              class="tnx-item-card cat-${esc(item.category)}${selected}"
              data-item-name="${esc(item.name)}"
            >
              ${flags.length ? `<div class="tnx-item-flags">${flags.join('')}</div>` : ''}

              <div class="tnx-item-icon">${item.icon}</div>

              <strong class="tnx-item-name">${esc(item.name)}</strong>

              <p class="tnx-item-desc">${esc(item.description)}</p>

              <div class="tnx-item-foot">
                ${priceHtml}
                <span class="tnx-item-source ${item.source.type === 'locked' ? 'locked' : ''}">${item.source.icon} ${esc(item.source.label)}</span>
              </div>
            </button>
          `
        }).join('')
      }

      function getItemLink(hashId) {
        return `${window.location.origin}${window.location.pathname}#${hashId}`
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent
        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
            button.classList.remove('is-copied')
          }, 1100))
        } catch {
          button.textContent = text
          addTimer(window.setTimeout(() => {
            button.textContent = oldText
          }, 1300))
        }
      }

      function renderFocus(item) {
        if (!itemFocusPanel || !item) return

        const command = isRealCommand(item.option) ? item.option : null
        const recipe = (state.data.crafting || []).find((r) => String(r.result).trim() === item.name)

        const recipeHtml = recipe
          ? `
            <div style="border: 1px solid rgba(52, 211, 153, 0.32); border-radius: 1rem; background: rgba(52, 211, 153, 0.06); padding: 0.8rem;">
              <div style="color: rgb(167, 243, 208); font-size: 0.7rem; font-weight: 950; letter-spacing: 0.08em; margin-bottom: 0.5rem;">⚒️ طريقة التركيب</div>
              <div style="color: white; font-size: 0.85rem; line-height: 1.8;">
                ${recipe.ingredients.map((ing) => `${esc(ing.item)} <b style="color: #ffda6a;">×${esc(ing.amount)}</b>`).join(' + ')}
              </div>
            </div>
          `
          : ''

        const cmdBtn = command
          ? `<button type="button" class="tnx-focus-btn" data-copy-command="${esc(command)}">📋 نسخ الأمر</button>`
          : ''

        itemFocusPanel.innerHTML = `
          <div class="tnx-focus-card cat-${esc(item.category)}" style="--tnx-cat: var(--tnx-cat); --tnx-cat-soft: var(--tnx-cat-soft); --tnx-cat-border: var(--tnx-cat-border);">
            <div class="tnx-focus-icon cat-${esc(item.category)}" style="background: radial-gradient(circle, var(--tnx-cat-glow, rgba(255,218,106,0.18)), transparent 65%);">${item.icon}</div>

            <div>
              <span class="tnx-focus-tag" style="border-color: var(--tnx-cat-border); background: var(--tnx-cat-soft); color: var(--tnx-cat);">${esc(CATEGORY_LABELS[item.category] || 'عام')}</span>
              <h3>${esc(item.name)}</h3>
            </div>

            <p class="tnx-focus-desc">${esc(item.description)}</p>

            <div class="tnx-focus-meta">
              <div>
                <span>السعر</span>
                <strong>${item.value > 0 ? `🪙 ${formatNumber(item.value)}` : '—'}</strong>
              </div>

              <div>
                <span>الحد الأقصى</span>
                <strong>${item.itemLimitEnabled ? `${esc(item.itemLimitAmount || 1)} فقط` : 'بدون'}</strong>
              </div>

              <div>
                <span>الشراء</span>
                <strong class="${item.excludePurchase ? 'bad' : 'good'}">${item.excludePurchase ? '🔒 غير متاح' : '✓ متاح'}</strong>
              </div>

              <div>
                <span>التركيب</span>
                <strong class="${recipe ? 'good' : 'bad'}">${recipe ? '⚒️ متاح' : '— غير متاح'}</strong>
              </div>

              ${command ? `
                <div style="grid-column: 1 / -1;">
                  <span>الأمر البرمجي</span>
                  <code style="direction: ltr; text-align: left; display: block;">${esc(command)}</code>
                </div>
              ` : ''}
            </div>

            ${recipeHtml}

            <div class="tnx-focus-actions">
              <button type="button" class="tnx-focus-btn" data-copy-link="${esc(item.hashId)}">🔗 نسخ رابط الغرض</button>
              ${cmdBtn}
            </div>
          </div>
        `

        // Apply category vars to focus card root (since it inherits from .tnx-focus-panel parent)
        const focusCard = itemFocusPanel.querySelector('.tnx-focus-card')
        if (focusCard) {
          focusCard.style.setProperty('--tnx-cat', `var(--tnx-cat, #ffda6a)`)
        }
      }

      function selectItem(name, options = {}) {
        const item = state.items.find((entry) => entry.name === name)
        if (!item) return

        state.selectedItemName = item.name

        if (options.updateHash !== false) {
          history.replaceState(null, '', `#${item.hashId}`)
        }

        renderItems()
        renderFocus(item)

        // Apply category color tokens to focus panel by adding category class
        const focusPanel = itemFocusPanel
        if (focusPanel) {
          // Strip existing cat-* classes
          focusPanel.className = focusPanel.className.replace(/\bcat-\S+/g, '').trim()
          focusPanel.classList.add(`cat-${item.category}`)
        }

        if (options.scrollToItem) {
          addTimer(window.setTimeout(() => {
            document.getElementById(item.hashId)?.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }, 80))
        }
      }

      function openItemFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('item-')) return false

        const item = state.items.find((entry) => entry.hashId === hash)
        if (!item) return false

        state.filter = 'all'
        state.search = ''
        if (itemSearch) itemSearch.value = ''

        renderFilterButtons()
        selectItem(item.name, { updateHash: false, scrollToItem: options.scrollToItem !== false })
        return true
      }

      function getItemIconByName(name) {
        const meta = getItemMeta(name)
        return meta.icon || '📦'
      }

      function renderCrafting() {
        const crafting = (state.data.crafting || []).filter((r) => r && Array.isArray(r.ingredients) && r.result)
        if (!craftingGrid) return

        craftingEmpty?.classList.toggle('hidden', crafting.length > 0)

        craftingGrid.innerHTML = crafting.map((recipe) => {
          const ingredientsHtml = recipe.ingredients.map((ing, idx) => {
            const ingName = String(ing.item || '').trim()
            const ingIcon = getItemIconByName(ingName)
            const ingItem = state.items.find((i) => i.name === ingName)
            const ingHash = ingItem ? ingItem.hashId : ''
            const sep = idx > 0 ? `<span class="tnx-craft-plus">+</span>` : ''

            return `
              ${sep}
              <button type="button" class="tnx-craft-chip" data-jump-item="${esc(ingHash)}">
                <span class="tnx-craft-icon">${ingIcon}</span>
                <span class="tnx-craft-chip-name">${esc(ingName)}</span>
                <span class="tnx-craft-amount">×${esc(ing.amount)}</span>
              </button>
            `
          }).join('')

          const resultName = String(recipe.result).trim()
          const resultIcon = getItemIconByName(resultName)
          const resultItem = state.items.find((i) => i.name === resultName)
          const resultHash = resultItem ? resultItem.hashId : ''

          return `
            <div class="tnx-craft-card">
              <div class="tnx-craft-flow">
                ${ingredientsHtml}
                <span class="tnx-craft-arrow">←</span>
                <button type="button" class="tnx-craft-chip tnx-craft-result" data-jump-item="${esc(resultHash)}">
                  <span class="tnx-craft-icon">${resultIcon}</span>
                  <span class="tnx-craft-chip-name">${esc(resultName)}</span>
                </button>
              </div>
            </div>
          `
        }).join('')
      }

      function handleBackToTop() {
        if (!backToTop) return
        backToTop.classList.toggle('is-visible', window.scrollY > 520)
      }

      async function loadData() {
        try {
          const res = await fetch('/api/items.json')
          if (!res.ok) throw new Error(`items.json request failed: ${res.status}`)

          const data = await res.json()
          state.data = {
            items: Array.isArray(data.items) ? data.items : [],
            crafting: Array.isArray(data.crafting) ? data.crafting : [],
            lootTables: Array.isArray(data.lootTables) ? data.lootTables : [],
          }

          const craftableSet = getCraftableNames()
          state.items = state.data.items
            .map((item, idx) => enrichItem(item, idx, craftableSet))
            .filter((item) => item.name)

          updateStats()
          renderFilterButtons()
          renderItems()
          renderCrafting()

          const opened = openItemFromHash({ scrollToItem: true })
          if (!opened && state.items.length > 0) {
            selectItem(state.items[0].name, { updateHash: false })
          }
        } catch (error) {
          console.error('Failed to load /api/items.json', error)
          if (itemsGrid) {
            itemsGrid.innerHTML = `
              <div class="tnx-empty">
                <strong>تعذر تحميل الأغراض</strong>
                <span>تأكد من وجود الملف public/api/items.json</span>
              </div>
            `
          }
        }
      }

      function setupReveal() {
        const elements = Array.from(document.querySelectorAll('.tnx-reveal'))
        if (!elements.length) return

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              revealObserver.unobserve(entry.target)
            }
          })
        }, { threshold: 0.12 })

        elements.forEach((element) => revealObserver.observe(element))
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTop, { passive: true })

      addListener(itemsGrid, 'click', (event) => {
        const card = event.target.closest('[data-item-name]')
        if (!card) return
        selectItem(card.dataset.itemName)
      })

      addListener(document, 'click', (event) => {
        const linkBtn = event.target.closest('[data-copy-link]')
        if (linkBtn) {
          copyText(getItemLink(linkBtn.dataset.copyLink || ''), linkBtn, '✓ تم نسخ الرابط')
          return
        }

        const cmdBtn = event.target.closest('[data-copy-command]')
        if (cmdBtn) {
          copyText(cmdBtn.dataset.copyCommand || '', cmdBtn, '✓ تم نسخ الأمر')
          return
        }

        const jumpBtn = event.target.closest('[data-jump-item]')
        if (jumpBtn) {
          const hash = jumpBtn.dataset.jumpItem || ''
          const item = state.items.find((i) => i.hashId === hash)
          if (item) {
            selectItem(item.name, { updateHash: true, scrollToItem: true })
            document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        }
      })

      addListener(window, 'hashchange', () => {
        openItemFromHash({ scrollToItem: true })
      })

      addListener(itemSearch, 'input', () => {
        state.search = itemSearch.value
        renderItems()
      })

      addListener(clearItemSearch, 'click', () => {
        if (!itemSearch) return
        itemSearch.value = ''
        state.search = ''
        itemSearch.focus()
        renderItems()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.filter || 'all'
          renderFilterButtons()
          renderItems()
        })
      })

      howtoButtons.forEach((button) => {
        addListener(button, 'click', () => {
          const mode = button.dataset.filterMode
          if (mode === 'box') state.filter = 'boxes'
          else if (mode === 'craft') {
            state.filter = 'all'
            document.querySelector('.tnx-crafting')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
            return
          }
          else state.filter = 'all'

          state.search = ''
          if (itemSearch) itemSearch.value = ''

          renderFilterButtons()
          renderItems()

          document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      })

      await loadData()
      setupReveal()
      handleBackToTop()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
