---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Items — TNX6',
  ignoreTitleTemplate: true,
  description: 'قائمة الأغراض والصياغة في مجتمع TNX6.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-items-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX ITEMS VAULT
        </div>

        <h1>خزنة الأغراض</h1>

        <p>
          استكشف جميع الأغراض المتاحة في النظام، أسعارها، استخداماتها، وكيفية دمجها وصناعتها للحصول على أدوات أندر.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statItems">0</strong>
            <span>غرض</span>
          </div>
          <div>
            <strong id="statCrafting">0</strong>
            <span>وصفة دمج</span>
          </div>
          <div>
            <strong id="statLimited">0</strong>
            <span>غرض محدود</span>
          </div>
        </div>
      </header>

      <section class="tnx-toolbar tnx-reveal">
        <div class="tnx-search">
          <span>⌕</span>
          <input id="itemSearch" type="search" autocomplete="off" placeholder="ابحث: Vip، صندوق، محامي، رخصة، سمعة..." />
          <button type="button" id="clearItemSearch">×</button>
        </div>

        <div class="tnx-filter-row" id="itemFilters">
          <button type="button" class="is-active" data-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-filter="purchase"><span>قابل للشراء</span><small id="count-purchase">0</small></button>
          <button type="button" data-filter="use"><span>قابل للاستخدام</span><small id="count-use">0</small></button>
          <button type="button" data-filter="sale"><span>قابل للبيع</span><small id="count-sale">0</small></button>
          <button type="button" data-filter="limited"><span>محدود</span><small id="count-limited">0</small></button>
          <button type="button" data-filter="boxes"><span>صناديق</span><small id="count-boxes">0</small></button>
          <button type="button" data-filter="effects"><span>تأثيرات</span><small id="count-effects">0</small></button>
          <button type="button" data-filter="materials"><span>مواد</span><small id="count-materials">0</small></button>
          <button type="button" data-filter="permits"><span>رخص / رتب</span><small id="count-permits">0</small></button>
        </div>
      </section>

      <section class="tnx-items-layout tnx-reveal">
        <div>
          <div class="tnx-section-head">
            <span>AVAILABLE ITEMS</span>
            <h2>قائمة الأغراض المتاحة</h2>
            <p>اضغط على أي غرض عشان تشوف تفاصيله ورابطه المباشر.</p>
          </div>

          <div id="itemsGrid" class="tnx-items-grid"></div>

          <div id="itemsEmpty" class="tnx-empty hidden">
            <strong>ما لقيت غرض مطابق</strong>
            <span>جرّب تبحث باسم أبسط مثل: صندوق، Vip، رخصة، سمعة.</span>
          </div>
        </div>

        <aside id="itemFocusPanel" class="tnx-focus-panel">
          <div class="tnx-focus-placeholder">
            <div>⬟</div>
            <h3>اختر غرض</h3>
            <p>اضغط على أي غرض من القائمة عشان تظهر تفاصيله هنا.</p>
          </div>
        </aside>
      </section>

      <section class="tnx-crafting-section tnx-reveal">
        <div class="tnx-section-line-head">
          <div></div>
          <h2>وصفات الدمج</h2>
          <div></div>
        </div>

        <div id="craftingGrid" class="tnx-crafting-grid"></div>

        <div id="craftingEmpty" class="tnx-empty hidden">
          <strong>ما فيه وصفات دمج حاليًا</strong>
          <span>إذا أضفت crafting في items.json بتظهر هنا تلقائيًا.</span>
        </div>
      </section>

      <section class="tnx-loot-section tnx-reveal">
        <div class="tnx-section-line-head">
          <div></div>
          <h2>Loot Tables</h2>
          <div></div>
        </div>

        <div id="lootGrid" class="tnx-loot-grid"></div>

        <div id="lootEmpty" class="tnx-empty hidden">
          <strong>ما فيه Loot Tables واضحة</strong>
          <span>إذا أضفت جداول احتمالات في items.json بتظهر هنا.</span>
        </div>
      </section>
    </section>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.55) rgba(7, 5, 11, 0.95);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(7, 5, 11, 0.96);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(7, 5, 11, 0.96);
      border-radius: 999px;
      background: linear-gradient(180deg, #ffda6a, #c29200);
    }

    .hidden {
      display: none !important;
    }

    .tnx-items-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.13), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.12), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.09), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
      animation: tnxBgBreathe 12s ease-in-out infinite;
    }

    @keyframes tnxBgBreathe {
      0%, 100% { filter: brightness(1); transform: scale(1); }
      50% { filter: brightness(1.09); transform: scale(1.015); }
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.055;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.42) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.42) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background: rgba(7, 5, 11, 0.9);
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 22px rgba(255, 218, 106, 0.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.78);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 650ms ease, transform 650ms ease;
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 940px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.4);
      color: #ffda6a;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.16em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
      animation: tnxPulse 1.8s ease-in-out infinite;
    }

    @keyframes tnxPulse {
      0%, 100% { opacity: 0.75; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.25); }
    }

    .tnx-hero h1 {
      margin: 1.1rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.1rem, 7vw, 6.6rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.055em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.04rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 760px;
      margin: 1.35rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-toolbar,
    .tnx-focus-panel,
    .tnx-crafting-section,
    .tnx-loot-section {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)), rgba(6, 6, 8, 0.78);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.44), inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 1rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.85rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.8rem;
      font-weight: 850;
    }

    .tnx-toolbar,
    .tnx-crafting-section,
    .tnx-loot-section {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
      max-width: 700px;
      margin: 0 auto;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
      transition: 180ms ease;
    }

    .tnx-search button:hover {
      transform: translateY(-2px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.55);
    }

    .tnx-filter-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.55rem;
      margin: 1rem auto 0;
      max-width: 1040px;
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.62rem 0.8rem;
      font-size: 0.82rem;
      font-weight: 950;
      cursor: pointer;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-2px) scale(1.025);
      border-color: rgba(255, 218, 106, 0.58);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.68rem;
    }

    .tnx-items-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 1rem;
      align-items: start;
      margin-top: 1rem;
    }

    .tnx-section-head {
      margin: 0 0 1rem;
      text-align: center;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.35rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.45rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-items-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .tnx-item-card {
      position: relative;
      min-height: 238px;
      display: flex;
      flex-direction: column;
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 1.35rem;
      background: linear-gradient(145deg, rgba(13, 10, 20, 0.86), rgba(26, 20, 8, 0.55));
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      overflow: hidden;
      backdrop-filter: blur(16px);
      opacity: 0;
      transform: translateY(14px) scale(0.985);
      animation: tnxCardIn 520ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: calc(var(--stagger, 0) * 55ms);
      transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), border-color 220ms ease, box-shadow 220ms ease, background 220ms ease;
    }

    @keyframes tnxCardIn {
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .tnx-item-card::before {
      content: '';
      position: absolute;
      inset: -45%;
      background: conic-gradient(from 180deg, transparent, rgba(255, 218, 106, 0.08), transparent 32%);
      opacity: 0;
      transition: opacity 220ms ease;
      pointer-events: none;
    }

    .tnx-item-card:hover,
    .tnx-item-card.is-selected {
      transform: translateY(-5px) scale(1.012);
      border-color: rgba(255, 218, 106, 0.45);
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.38), 0 0 22px rgba(255, 218, 106, 0.08);
      background: linear-gradient(145deg, rgba(18, 14, 28, 0.92), rgba(35, 26, 10, 0.66));
    }

    .tnx-item-card:hover::before,
    .tnx-item-card.is-selected::before {
      opacity: 1;
      animation: tnxItemShine 5s linear infinite;
    }

    @keyframes tnxItemShine {
      to { transform: rotate(360deg); }
    }

    .tnx-item-top,
    .tnx-item-desc,
    .tnx-item-command,
    .tnx-item-flags {
      position: relative;
      z-index: 1;
    }

    .tnx-item-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.85rem;
      margin-bottom: 0.8rem;
    }

    .tnx-item-name {
      color: white;
      font-size: 1.08rem;
      font-weight: 950;
      line-height: 1.45;
    }

    .tnx-item-card:hover .tnx-item-name,
    .tnx-item-card.is-selected .tnx-item-name {
      color: #ffda6a;
    }

    .tnx-item-price {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      border: 1px solid rgba(194, 146, 0, 0.32);
      border-radius: 0.8rem;
      background: rgba(194, 146, 0, 0.11);
      color: #ffda6a;
      padding: 0.44rem 0.6rem;
      font-size: 0.83rem;
      font-weight: 950;
      box-shadow: inset 0 0 12px rgba(255, 218, 106, 0.04);
    }

    .tnx-item-desc {
      color: rgb(156, 163, 175);
      font-size: 0.84rem;
      font-weight: 760;
      line-height: 1.72;
      margin: 0 0 1rem;
      flex: 1;
    }

    .tnx-item-command {
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 0.85rem;
      background: rgba(0, 0, 0, 0.36);
      padding: 0.7rem;
      margin-top: auto;
    }

    .tnx-item-command span {
      display: block;
      color: rgb(107, 114, 128);
      font-size: 0.67rem;
      font-weight: 950;
      margin-bottom: 0.25rem;
    }

    .tnx-item-command code {
      display: block;
      color: #ffda6a;
      font-size: 0.77rem;
      font-weight: 850;
      direction: ltr;
      text-align: left;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tnx-item-flags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.75rem;
    }

    .tnx-flag {
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 0.55rem;
      background: rgba(255, 255, 255, 0.035);
      color: rgb(209, 213, 219);
      padding: 0.28rem 0.48rem;
      font-size: 0.65rem;
      font-weight: 950;
      white-space: nowrap;
    }

    .tnx-flag.good { color: rgb(167, 243, 208); border-color: rgba(52, 211, 153, 0.22); background: rgba(52, 211, 153, 0.08); }
    .tnx-flag.bad { color: rgb(252, 165, 165); border-color: rgba(239, 68, 68, 0.22); background: rgba(239, 68, 68, 0.08); }
    .tnx-flag.warn { color: #ffda6a; border-color: rgba(255, 218, 106, 0.22); background: rgba(255, 218, 106, 0.08); }

    .tnx-focus-panel {
      position: sticky;
      top: 6rem;
      min-height: 520px;
      border-radius: 1.5rem;
      padding: 1rem;
    }

    .tnx-focus-placeholder {
      display: grid;
      place-items: center;
      align-content: center;
      min-height: 460px;
      text-align: center;
    }

    .tnx-focus-placeholder div {
      display: grid;
      place-items: center;
      width: 4rem;
      height: 4rem;
      border-radius: 1.25rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      background: rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1.6rem;
      margin-bottom: 0.85rem;
    }

    .tnx-focus-placeholder h3 {
      margin: 0;
      color: #f7e6ac;
      font-size: 1.45rem;
      font-weight: 950;
    }

    .tnx-focus-placeholder p {
      max-width: 260px;
      margin: 0.55rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-focus-card {
      display: grid;
      gap: 0.9rem;
    }

    .tnx-focus-icon {
      display: grid;
      place-items: center;
      min-height: 130px;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1.25rem;
      background: radial-gradient(circle at center, rgba(255, 218, 106, 0.14), transparent 56%), rgba(0, 0, 0, 0.28);
      color: #ffda6a;
      font-size: 3rem;
    }

    .tnx-focus-card h3 {
      margin: 0;
      color: white;
      font-size: 1.7rem;
      font-weight: 950;
      line-height: 1.25;
    }

    .tnx-focus-card p {
      margin: 0;
      color: rgb(209, 213, 219);
      font-size: 0.9rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-focus-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.6rem;
    }

    .tnx-focus-meta div {
      border: 1px solid rgba(255, 218, 106, 0.12);
      border-radius: 1rem;
      background: rgba(0, 0, 0, 0.26);
      padding: 0.75rem;
    }

    .tnx-focus-meta span {
      display: block;
      color: rgb(148, 163, 184);
      font-size: 0.72rem;
      font-weight: 900;
      margin-bottom: 0.25rem;
    }

    .tnx-focus-meta strong,
    .tnx-focus-meta code {
      color: #ffda6a;
      font-size: 0.86rem;
      font-weight: 950;
      word-break: break-word;
    }

    .tnx-focus-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.55rem;
    }

    .tnx-focus-copy {
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.78rem 1rem;
      font-size: 0.82rem;
      font-weight: 950;
      cursor: pointer;
      transition: 180ms ease;
    }

    .tnx-focus-copy:hover,
    .tnx-focus-copy.is-copied {
      transform: translateY(-2px) scale(1.02);
      border-color: rgba(52, 211, 153, 0.55);
