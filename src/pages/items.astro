---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Items — TNX6',
  ignoreTitleTemplate: true,
  description: 'خزنة الأغراض والصناعة في مجتمع TNX6.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-items-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>
    <div class="tnx-glow-orb tnx-glow-orb-1"></div>
    <div class="tnx-glow-orb tnx-glow-orb-2"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX ITEM VAULT
        </div>

        <h1>خزنة الأغراض</h1>

        <p>
          أغراض البث، الصناديق، الرخص، المواد، ووصفات الدمج في مكان واحد. اضغط على أي غرض عشان تعرف قيمته، استخدامه، وطريقة الحصول عليه.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statItems">0</strong>
            <span>غرض</span>
          </div>
          <div>
            <strong id="statCrafting">0</strong>
            <span>وصفة دمج</span>
          </div>
          <div>
            <strong id="statTopValue">0</strong>
            <span>أغلى قيمة</span>
          </div>
        </div>
      </header>

      <section class="tnx-featured tnx-reveal">
        <div class="tnx-section-head tnx-center">
          <span>HIGH VALUE ITEMS</span>
          <h2>الأغراض الثقيلة</h2>
          <p>هنا تظهر الأغراض اللي لها تأثير قوي أو قيمة عالية في النظام.</p>
        </div>

        <div id="featuredGrid" class="tnx-featured-grid"></div>
      </section>

      <section class="tnx-vault tnx-reveal">
        <div class="tnx-vault-top">
          <div class="tnx-section-head">
            <span>ITEM DATABASE</span>
            <h2>كل الأغراض</h2>
            <p>ابحث، فلتر، واضغط على الغرض عشان تظهر تفاصيله.</p>
          </div>

          <div class="tnx-search">
            <span>⌕</span>
            <input id="itemSearch" type="search" autocomplete="off" placeholder="ابحث: نيوك، Vip، صندوق، خشب، رخصة..." />
            <button type="button" id="clearItemSearch">×</button>
          </div>
        </div>

        <div id="itemFilters" class="tnx-filter-row">
          <button type="button" class="is-active" data-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-filter="legendary"><span>أسطوري</span><small id="count-legendary">0</small></button>
          <button type="button" data-filter="interactive"><span>تفاعلي</span><small id="count-interactive">0</small></button>
          <button type="button" data-filter="loot"><span>صناديق</span><small id="count-loot">0</small></button>
          <button type="button" data-filter="material"><span>مواد</span><small id="count-material">0</small></button>
          <button type="button" data-filter="license"><span>رخص / رتب</span><small id="count-license">0</small></button>
          <button type="button" data-filter="purchasable"><span>قابل للشراء</span><small id="count-purchasable">0</small></button>
          <button type="button" data-filter="usable"><span>قابل للاستخدام</span><small id="count-usable">0</small></button>
          <button type="button" data-filter="limited"><span>محدود</span><small id="count-limited">0</small></button>
        </div>

        <div class="tnx-vault-layout">
          <div>
            <div id="itemsGrid" class="tnx-items-grid"></div>

            <div id="itemsEmpty" class="tnx-empty hidden">
              <strong>ما لقيت غرض مطابق</strong>
              <span>جرّب تبحث باسم أبسط أو غيّر الفلتر.</span>
            </div>
          </div>

          <aside id="itemFocusPanel" class="tnx-focus-panel">
            <div class="tnx-focus-placeholder">
              <div>🎒</div>
              <h3>اختر غرض</h3>
              <p>اضغط على أي غرض من القائمة عشان تظهر تفاصيله هنا.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="tnx-crafting tnx-reveal">
        <div class="tnx-section-head tnx-center">
          <span>CRAFTING RECIPES</span>
          <h2>وصفات الدمج</h2>
          <p>المكونات المطلوبة والنتيجة النهائية لكل وصفة.</p>
        </div>

        <div id="craftingGrid" class="tnx-crafting-grid"></div>
      </section>

      <section class="tnx-loot tnx-reveal">
        <div class="tnx-section-head tnx-center">
          <span>LOOT TABLES</span>
          <h2>جداول الصناديق</h2>
          <p>إذا عندك صناديق أو احتمالات، تظهر هنا من ملف البيانات.</p>
        </div>

        <div id="lootGrid" class="tnx-loot-grid"></div>
      </section>
    </section>
  </main>

  <style is:global>
    :root {
      --tnx-gold: #ffda6a;
      --tnx-gold-2: #c29200;
      --tnx-cream: #f7e6ac;
      --tnx-bg: #07050b;
      --tnx-panel: rgba(6, 6, 8, 0.78);
    }

    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.65) rgba(7, 5, 11, 0.95);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(7, 5, 11, 0.96);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(7, 5, 11, 0.96);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.9), rgba(194, 146, 0, 0.7));
    }

    .hidden { display: none !important; }

    .tnx-items-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: var(--tnx-bg);
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.16), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.14), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.10), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
      animation: tnxBgBreathe 13s ease-in-out infinite;
    }

    @keyframes tnxBgBreathe {
      0%, 100% { filter: brightness(1) saturate(1); transform: scale(1); }
      50% { filter: brightness(1.13) saturate(1.12); transform: scale(1.015); }
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.07;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.4) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-glow-orb {
      position: fixed;
      z-index: 0;
      pointer-events: none;
      width: 26rem;
      height: 26rem;
      border-radius: 999px;
      filter: blur(74px);
      opacity: 0.16;
      animation: tnxOrbFloat 18s ease-in-out infinite;
    }

    .tnx-glow-orb-1 {
      top: 12%;
      right: -10rem;
      background: rgba(255, 218, 106, 0.42);
    }

    .tnx-glow-orb-2 {
      bottom: 8%;
      left: -10rem;
      background: rgba(124, 58, 237, 0.4);
      animation-delay: -5s;
    }

    @keyframes tnxOrbFloat {
      0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
      50% { transform: translate3d(2rem, -1rem, 0) scale(1.08); }
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background: rgba(7, 5, 11, 0.88);
      color: var(--tnx-gold);
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow: 0 18px 40px rgba(0,0,0,.45), 0 0 22px rgba(255,218,106,.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 180ms ease;
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.75);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 600ms ease, transform 600ms ease;
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 920px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      border: 1px solid rgba(255,218,106,.28);
      border-radius: 999px;
      background: rgba(0,0,0,.36);
      color: var(--tnx-gold);
      padding: .55rem .9rem;
      font-size: .78rem;
      font-weight: 950;
      letter-spacing: .18em;
    }

    .tnx-eyebrow span {
      width: .48rem;
      height: .48rem;
      border-radius: 999px;
      background: var(--tnx-gold);
      box-shadow: 0 0 14px var(--tnx-gold);
      animation: tnxPulse 1.8s ease-in-out infinite;
    }

    @keyframes tnxPulse {
      0%, 100% { transform: scale(1); opacity: .95; }
      50% { transform: scale(1.35); opacity: .55; }
    }

    .tnx-hero h1 {
      margin: 1.15rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.2rem, 8vw, 6.8rem);
      font-weight: 950;
      line-height: .95;
      letter-spacing: -.06em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.03rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: .85rem;
      max-width: 760px;
      margin: 1.25rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-featured,
    .tnx-vault,
    .tnx-crafting,
    .tnx-loot,
    .tnx-focus-panel {
      border: 1px solid rgba(255,218,106,.18);
      background: linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.012)), rgba(6,6,8,.78);
      box-shadow: 0 24px 70px rgba(0,0,0,.44), inset 0 0 22px rgba(255,218,106,.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 1rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: var(--tnx-gold);
      font-size: 1.8rem;
      font-weight: 950;
      line-height: 1;
      direction: ltr;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: .35rem;
      color: rgb(156, 163, 175);
      font-size: .8rem;
      font-weight: 850;
    }

    .tnx-featured,
    .tnx-vault,
    .tnx-crafting,
    .tnx-loot {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head span {
      color: var(--tnx-gold-2);
      font-size: .78rem;
      font-weight: 950;
      letter-spacing: .12em;
    }

    .tnx-section-head h2 {
      margin: .3rem 0 0;
      color: var(--tnx-cream);
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: .5rem 0 0;
      color: rgb(156, 163, 175);
      font-size: .92rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-center { text-align: center; }

    .tnx-featured-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: .9rem;
      margin-top: 1rem;
    }

    .tnx-boss-card {
      position: relative;
      overflow: hidden;
      min-height: 210px;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 1.45rem;
      background: radial-gradient(circle at 30% 0%, rgba(255,218,106,.14), transparent 48%), rgba(0,0,0,.32);
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
    }

    .tnx-boss-card::before {
      content: '';
      position: absolute;
      inset: -45%;
      background: conic-gradient(from 180deg, transparent, rgba(255,218,106,.13), transparent 32%);
      animation: tnxCardShine 7s linear infinite;
      opacity: .8;
      pointer-events: none;
    }

    @keyframes tnxCardShine { to { transform: rotate(360deg); } }

    .tnx-boss-card:hover {
      transform: translateY(-4px) scale(1.012);
      border-color: rgba(255,218,106,.54);
      box-shadow: 0 18px 44px rgba(0,0,0,.44), 0 0 28px rgba(255,218,106,.12);
    }

    .tnx-boss-content {
      position: relative;
      z-index: 1;
      display: grid;
      gap: .75rem;
      height: 100%;
    }

    .tnx-boss-icon {
      display: grid;
      place-items: center;
      width: 4.2rem;
      height: 4.2rem;
      border: 1px solid rgba(255,218,106,.25);
      border-radius: 1.25rem;
      background: rgba(255,218,106,.08);
      font-size: 2.1rem;
      box-shadow: inset 0 0 24px rgba(255,218,106,.035);
    }

    .tnx-boss-card h3 {
      margin: 0;
      color: white;
      font-size: 1.2rem;
      font-weight: 950;
      line-height: 1.3;
    }

    .tnx-boss-card p {
      margin: 0;
      color: rgb(209,213,219);
      font-size: .82rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .tnx-boss-price {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: fit-content;
      gap: .35rem;
      border: 1px solid rgba(255,218,106,.26);
      border-radius: .85rem;
      background: rgba(255,218,106,.08);
      color: var(--tnx-gold);
      padding: .45rem .7rem;
      font-size: .82rem;
      font-weight: 950;
      direction: ltr;
    }

    .tnx-vault-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
      gap: 1rem;
      align-items: end;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255,218,106,.12);
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: .75rem;
      align-items: center;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 1.15rem;
      background: rgba(0,0,0,.32);
      padding: .85rem;
    }

    .tnx-search span {
      color: var(--tnx-gold);
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: .95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255,218,106,.2);
      border-radius: 999px;
      background: rgba(255,218,106,.08);
      color: var(--tnx-gold);
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
      transition: 180ms ease;
    }

    .tnx-search button:hover { transform: scale(1.06); border-color: rgba(255,218,106,.5); }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: .55rem;
      margin: 1rem 0;
      border: 1px solid rgba(255,218,106,.18);
      border-radius: 1rem;
      background: rgba(7,5,11,.9);
      padding: .7rem;
      box-shadow: 0 14px 40px rgba(0,0,0,.35);
      backdrop-filter: blur(14px);
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      border: 1px solid rgba(255,218,106,.24);
      border-radius: .9rem;
      background: rgba(255,218,106,.08);
      color: var(--tnx-cream);
      padding: .62rem .8rem;
      font-size: .82rem;
      font-weight: 950;
      cursor: pointer;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-2px) scale(1.015);
      border-color: rgba(255,218,106,.55);
      background: rgba(255,218,106,.14);
      color: var(--tnx-gold);
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0,0,0,.34);
      color: rgb(229,231,235);
      font-size: .68rem;
    }

    .tnx-vault-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 350px;
      gap: 1rem;
      align-items: start;
    }

    .tnx-items-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: .85rem;
    }

    .tnx-item-card {
      --stagger: 0ms;
      position: relative;
      display: grid;
      gap: .85rem;
      min-height: 235px;
      border: 1px solid rgba(255,218,106,.13);
      border-radius: 1.35rem;
      background: radial-gradient(circle at top right, rgba(255,218,106,.055), transparent 44%), rgba(0,0,0,.30);
      color: white;
      padding: .95rem;
      text-align: right;
      cursor: pointer;
      overflow: hidden;
      opacity: 0;
      animation: tnxCardIn 520ms ease forwards;
      animation-delay: var(--stagger);
      transition: transform 210ms ease, border-color 210ms ease, box-shadow 210ms ease, background 210ms ease;
      scroll-margin-top: 11rem;
    }

    @keyframes tnxCardIn {
      from { opacity: 0; transform: translateY(16px) scale(.985); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .tnx-item-card:hover,
    .tnx-item-card.is-selected {
      transform: translateY(-4px) scale(1.012);
      border-color: rgba(255,218,106,.54);
      box-shadow: 0 16px 38px rgba(0,0,0,.38), 0 0 26px rgba(255,218,106,.12);
      background: radial-gradient(circle at top right, rgba(255,218,106,.09), transparent 46%), rgba(0,0,0,.34);
    }

    .tnx-item-card.is-linked {
      border-color: rgba(255,218,106,.82);
      box-shadow: 0 0 0 1px rgba(255,218,106,.28), 0 0 34px rgba(255,218,106,.18);
    }

    .tnx-item-top {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: .75rem;
    }

    .tnx-item-icon {
      display: grid;
      place-items: center;
      width: 3.35rem;
      height: 3.35rem;
      border: 1px solid rgba(255,218,106,.22);
      border-radius: 1rem;
      background: rgba(255,218,106,.065);
      font-size: 1.65rem;
      box-shadow: inset 0 0 20px rgba(255,218,106,.025);
      flex: 0 0 auto;
    }

    .tnx-item-card:hover .tnx-item-icon {
      transform: rotate(-2deg) scale(1.04);
      transition: 210ms ease;
    }

    .tnx-item-price {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      border: 1px solid rgba(255,218,106,.25);
      border-radius: .82rem;
      background: rgba(255,218,106,.08);
      color: var(--tnx-gold);
      padding: .42rem .62rem;
      font-size: .75rem;
      font-weight: 950;
      direction: ltr;
      white-space: nowrap;
    }

    .tnx-item-card h3 {
      margin: 0;
      color: white;
      font-size: 1.05rem;
      font-weight: 950;
      line-height: 1.35;
    }

    .tnx-item-card p {
      margin: 0;
      color: rgb(156, 163, 175);
      font-size: .78rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .tnx-item-tags {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
      margin-top: auto;
    }

    .tnx-tag {
      display: inline-flex;
      align-items: center;
      gap: .25rem;
      border: 1px solid rgba(255,218,106,.12);
      border-radius: 999px;
      background: rgba(255,255,255,.035);
      color: rgb(209,213,219);
      padding: .3rem .5rem;
      font-size: .64rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .tnx-tag-gold { color: var(--tnx-gold); border-color: rgba(255,218,106,.22); background: rgba(255,218,106,.07); }
    .tnx-tag-green { color: rgb(167,243,208); border-color: rgba(52,211,153,.25); background: rgba(52,211,153,.08); }
