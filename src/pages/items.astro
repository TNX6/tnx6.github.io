---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Items — TNX6',
  ignoreTitleTemplate: true,
  description: 'صفحة أغراض مجتمع TNX6.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-items-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <button id="itemsBackToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">
      ↑
    </button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX6 ITEM VAULT
        </div>

        <h1>خزنة الأغراض</h1>

        <p>
          اعرف كل غرض وش يسوي، هل تقدر تشتريه أو تستخدمه أو تبيعه، وش وصفته في التصنيع.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statTotalItems">0</strong>
            <span>غرض</span>
          </div>

          <div>
            <strong id="statPurchasableItems">0</strong>
            <span>قابل للشراء</span>
          </div>

          <div>
            <strong id="statCraftingRecipes">0</strong>
            <span>وصفة تصنيع</span>
          </div>
        </div>
      </header>

      <section class="tnx-guide tnx-reveal">
        <div class="tnx-section-head">
          <span>ابدأ من هنا</span>
          <h2>كيف تقرأ الأغراض؟</h2>
          <p>الأغراض مقسمة حسب استخدامها. اضغط على أي غرض عشان تشوف التفاصيل والرابط المباشر.</p>
        </div>

        <div class="tnx-guide-grid">
          <button type="button" class="tnx-guide-card" data-guide-filter="purchasable">
            <b>₪</b>
            <div>
              <strong>أغراض الشراء</strong>
              <p>الأشياء اللي تقدر تشتريها مباشرة من النظام.</p>
            </div>
          </button>

          <button type="button" class="tnx-guide-card" data-guide-filter="usable">
            <b>⚡</b>
            <div>
              <strong>أغراض الاستخدام</strong>
              <p>الأشياء اللي لها تأثير مباشر داخل البث أو الشات.</p>
            </div>
          </button>

          <button type="button" class="tnx-guide-card" data-guide-filter="limited">
            <b>1</b>
            <div>
              <strong>أغراض محدودة</strong>
              <p>أغراض لها حد امتلاك أو شرط خاص.</p>
            </div>
          </button>
        </div>
      </section>

      <section class="tnx-vault tnx-reveal">
        <div class="tnx-vault-top">
          <div class="tnx-section-head">
            <span>كل الأغراض</span>
            <h2>استعرض الأغراض</h2>
            <p>فلتر، ابحث، واضغط على الغرض عشان تعرف قيمته وطريقة استخدامه.</p>
          </div>

          <div class="tnx-search">
            <span>⌕</span>
            <input
              id="itemSearch"
              type="search"
              autocomplete="off"
              placeholder="ابحث: Vip، نيوك، صندوق، سمعة، محامي..."
            />
            <button type="button" id="clearItemSearch">×</button>
          </div>
        </div>

        <div class="tnx-filter-row" id="itemFilters">
          <button type="button" class="is-active" data-item-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-item-filter="purchasable"><span>قابل للشراء</span><small id="count-purchasable">0</small></button>
          <button type="button" data-item-filter="usable"><span>قابل للاستخدام</span><small id="count-usable">0</small></button>
          <button type="button" data-item-filter="sellable"><span>قابل للبيع</span><small id="count-sellable">0</small></button>
          <button type="button" data-item-filter="limited"><span>محدود</span><small id="count-limited">0</small></button>
          <button type="button" data-item-filter="chests"><span>صناديق</span><small id="count-chests">0</small></button>
          <button type="button" data-item-filter="effects"><span>تأثيرات</span><small id="count-effects">0</small></button>
          <button type="button" data-item-filter="materials"><span>مواد</span><small id="count-materials">0</small></button>
          <button type="button" data-item-filter="licenses"><span>رخص / رتب</span><small id="count-licenses">0</small></button>
        </div>

        <div class="tnx-vault-layout">
          <div>
            <div id="itemsGrid" class="tnx-item-grid"></div>

            <div id="itemsEmpty" class="tnx-empty hidden">
              <strong>ما لقيت غرض مطابق</strong>
              <span>جرّب تبحث باسم أبسط مثل: صندوق، Vip، نيوك، سمعة.</span>
            </div>
          </div>

          <aside id="itemFocusPanel" class="tnx-focus-panel">
            <div class="tnx-focus-placeholder">
              <div>◆</div>
              <h3>اختر غرض</h3>
              <p>اضغط على أي غرض من القائمة عشان تظهر تفاصيله هنا.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="tnx-bottom-grid">
        <section class="tnx-panel tnx-reveal">
          <div class="tnx-section-head tnx-center">
            <span>الصناديق</span>
            <h2>Loot Tables</h2>
            <p>هنا تظهر احتمالات الصناديق أو الجداول العشوائية إذا كانت مضافة في ملف البيانات.</p>
          </div>

          <div id="lootTablesGrid" class="tnx-loot-grid"></div>
        </section>

        <section class="tnx-panel tnx-reveal">
          <div class="tnx-section-head tnx-center">
            <span>التصنيع</span>
            <h2>Crafting Recipes</h2>
            <p>الوصفات اللي تحول أغراضك إلى أغراض أقوى.</p>
          </div>

          <div id="craftingGrid" class="tnx-crafting-grid"></div>
        </section>
      </section>
    </section>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.75) rgba(7, 5, 11, 0.9);
    }

    html::-webkit-scrollbar,
    .tnx-user-card-container::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }

    html::-webkit-scrollbar-track,
    .tnx-user-card-container::-webkit-scrollbar-track {
      background: rgba(7, 5, 11, 0.9);
    }

    html::-webkit-scrollbar-thumb,
    .tnx-user-card-container::-webkit-scrollbar-thumb {
      border: 2px solid rgba(7, 5, 11, 0.9);
      border-radius: 999px;
      background: linear-gradient(180deg, #ffda6a, #c29200);
    }

    .hidden {
      display: none !important;
    }

    .tnx-items-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.18), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.16), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.12), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
      animation: tnxBgBreathe 12s ease-in-out infinite alternate;
    }

    @keyframes tnxBgBreathe {
      from {
        transform: scale(1);
        filter: saturate(1) brightness(1);
      }

      to {
        transform: scale(1.025);
        filter: saturate(1.08) brightness(1.05);
      }
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.07;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.4) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.4) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background:
        radial-gradient(circle at 35% 25%, rgba(255, 218, 106, 0.22), transparent 60%),
        rgba(7, 5, 11, 0.88);
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.45),
        0 0 22px rgba(255, 218, 106, 0.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 220ms ease;
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.75);
      box-shadow:
        0 22px 46px rgba(0, 0, 0, 0.5),
        0 0 30px rgba(255, 218, 106, 0.2);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 920px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.28);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.36);
      color: #ffda6a;
      padding: 0.55rem 0.9rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.18em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
    }

    .tnx-hero h1 {
      margin: 1.15rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.2rem, 8vw, 6.8rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.06em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.03rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 720px;
      margin: 1.25rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-guide,
    .tnx-vault,
    .tnx-panel,
    .tnx-focus-panel {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)),
        rgba(6, 6, 8, 0.78);
      box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.44),
        inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 1rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.8rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.8rem;
      font-weight: 850;
    }

    .tnx-guide,
    .tnx-vault,
    .tnx-panel {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.3rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.5rem 0 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-center {
      text-align: center;
    }

    .tnx-guide-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .tnx-guide-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.85rem;
      min-height: 138px;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.25rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.07), transparent 42%),
        rgba(0, 0, 0, 0.3);
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-guide-card:hover {
      transform: translateY(-4px) scale(1.01);
      border-color: rgba(255, 218, 106, 0.5);
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 42%),
        rgba(0, 0, 0, 0.38);
    }

    .tnx-guide-card b {
      display: grid;
      place-items: center;
      width: 3rem;
      height: 3rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 1rem;
      background:
        radial-gradient(circle at 35% 25%, rgba(255, 218, 106, 0.18), transparent 62%),
        rgba(255, 218, 106, 0.06);
      color: #ffda6a;
      font-size: 1rem;
      font-weight: 950;
      transition: 220ms ease;
    }

    .tnx-guide-card:hover b {
      transform: rotate(-3deg) scale(1.05);
      box-shadow: 0 0 20px rgba(255, 218, 106, 0.14);
    }

    .tnx-guide-card strong {
      display: block;
      color: white;
      font-size: 1.1rem;
      font-weight: 950;
      line-height: 1.35;
    }

    .tnx-guide-card p {
      margin: 0.45rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 0.86rem;
      font-weight: 800;
      line-height: 1.7;
    }

    .tnx-vault-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
      gap: 1rem;
      align-items: end;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 218, 106, 0.12);
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
      transition: 220ms ease;
    }

    .tnx-search:focus-within {
      border-color: rgba(255, 218, 106, 0.58);
      box-shadow: 0 0 0 3px rgba(255, 218, 106, 0.08);
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
      transition: 200ms ease;
    }

    .tnx-search button:hover {
      transform: scale(1.06);
      border-color: rgba(255, 218, 106, 0.5);
      background: rgba(255, 218, 106, 0.14);
    }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem 0;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.07), transparent 40%),
        rgba(7, 5, 11, 0.9);
      padding: 0.7rem;
      box-shadow: 0 14px 40px rgba(0, 0, 0, 0.35);
      backdrop-filter: blur(14px);
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.62rem 0.8rem;
      font-size: 0.82rem;
      font-weight: 950;
      cursor: pointer;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-2px) scale(1.02);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.68rem;
    }

    .tnx-vault-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 350px;
      gap: 1rem;
      align-items: start;
    }

    .tnx-item-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .tnx-item-card {
      position: relative;
      display: grid;
      gap: 0.85rem;
      min-height: 230px;
      border: 1px solid rgba(255, 218, 106, 0.15);
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.06), transparent 42%),
        rgba(0, 0, 0, 0.3);
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      overflow: hidden;
      transition: 240ms cubic-bezier(0.22, 1, 0.36, 1);
      animation: tnxItemCascade 560ms cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: calc(var(--stagger, 0) * 48ms);
      scroll-margin-top: 11rem;
    }

    @keyframes tnxItemCascade {
      from {
        opacity: 0;
        transform: translateY(18px) scale(0.985);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .tnx-item-card:hover,
    .tnx-item-card.is-selected {
      transform: translateY(-5px) scale(1.015);
      border-color: rgba(255, 218, 106, 0.56);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32), 0 0 28px rgba(255, 218, 106, 0.12);
    }

    .tnx-item-card.is-linked {
      border-color: rgba(255, 218, 106, 0.82);
      box-shadow:
        0 0 0 1px rgba(255, 218, 106, 0.28),
        0 0 34px rgba(255, 218, 106, 0.18);
    }

    .tnx-item-card::before {
      content: '';
      position: absolute;
      inset: -40%;
      background: conic-gradient(from 180deg, transparent, rgba(255, 218, 106, 0.12), transparent 34%);
      opacity: 0;
      transition: opacity 240ms ease;
      pointer-events: none;
    }

    .tnx-item-card:hover::before,
    .tnx-item-card.is-selected::before {
      opacity: 1;
      animation: tnxItemShine 4.5s linear infinite;
    }

    @keyframes tnxItemShine {
      to {
        transform: rotate(360deg);
      }
    }

    .tnx-item-card-top {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: flex-start;
    }

    .tnx-item-icon {
      display: grid;
      place-items: center;
      width: 3.6rem;
      height: 3.6rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 1.1rem;
      background:
        radial-gradient(circle at center, rgba(255, 218, 106, 0.16), transparent 64%),
        rgba(255, 218, 106, 0.055);
      color: #ffda6a;
      font-size: 1.7rem;
      flex: 0 0 auto;
      transition: 240ms ease;
    }

    .tnx-item-card:hover .tnx-item-icon {
      transform: rotate(-3deg) scale(1.06);
    }

    .tnx-item-info {
      min-width: 0;
    }

    .tnx-item-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.7rem;
    }

    .tnx-item-card strong {
      color: white;
      font-size: 1.15rem;
      font-weight: 950;
      line-height: 1.35;
      word-break: break-word;
    }

    .tnx-item-value {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
