---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Items — TNX6',
  ignoreTitleTemplate: true,
  description: 'سوق أغراض مجتمع TNX6 — تصنيفات، تركيب، صناديق وأكثر.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-items-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX6 ITEMS MARKET
        </div>

        <h1>سوق الأغراض</h1>

        <p>
          كل الأغراض المتاحة في الستريم. تتجمع، تتشترى، تتركّب، تنفجر، أو تنطبخ.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statItems">0</strong>
            <span>غرض</span>
          </div>
          <div>
            <strong id="statCategories">0</strong>
            <span>تصنيف</span>
          </div>
          <div>
            <strong id="statCrafting">0</strong>
            <span>وصفة تركيب</span>
          </div>
          <div>
            <strong id="statRare">0</strong>
            <span>نادر / خاص</span>
          </div>
        </div>
      </header>

      <section class="tnx-howto tnx-reveal">
        <div class="tnx-section-head">
          <span>طرق الحصول</span>
          <h2>كيف تحصل الأغراض؟</h2>
          <p>كل غرض تحصله بطريقة من ثلاث.</p>
        </div>

        <div class="tnx-howto-grid">
          <button type="button" class="tnx-howto-card" data-filter-mode="purchase">
            <div class="tnx-howto-icon" style="--tnx-c: #ffda6a;">🪙</div>
            <div>
              <strong>الشراء بالنقاط</strong>
              <p>أغراض متاحة في المتجر مباشرة برصيد النقاط.</p>
            </div>
          </button>

          <button type="button" class="tnx-howto-card" data-filter-mode="craft">
            <div class="tnx-howto-icon" style="--tnx-c: #34d399;">⚒️</div>
            <div>
              <strong>التركيب من السمعة</strong>
              <p>أغراض حصرية تركّبها من مكونات بعملة السمعة.</p>
            </div>
          </button>

          <button type="button" class="tnx-howto-card" data-filter-mode="box">
            <div class="tnx-howto-icon" style="--tnx-c: #c084fc;">🎁</div>
            <div>
              <strong>الصناديق</strong>
              <p>افتح صندوق وخذ غرض عشوائي حسب نوع الصندوق.</p>
            </div>
          </button>
        </div>
      </section>

      <section class="tnx-toolbar tnx-reveal">
        <div class="tnx-search">
          <span>⌕</span>
          <input id="itemSearch" type="search" autocomplete="off" placeholder="ابحث: نيوك، Vip، صندوق، خشب، سمعة..." />
          <button type="button" id="clearItemSearch">×</button>
        </div>

        <div class="tnx-filter-row" id="itemFilters">
          <button type="button" class="is-active" data-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-filter="status"><span>👑 مكانة</span><small id="count-status">0</small></button>
          <button type="button" data-filter="attacks"><span>💥 هجمات</span><small id="count-attacks">0</small></button>
          <button type="button" data-filter="pvp"><span>⚔️ PvP</span><small id="count-pvp">0</small></button>
          <button type="button" data-filter="luck"><span>🎲 حظ</span><small id="count-luck">0</small></button>
          <button type="button" data-filter="boxes"><span>🎁 صناديق</span><small id="count-boxes">0</small></button>
          <button type="button" data-filter="permits"><span>📜 رخص</span><small id="count-permits">0</small></button>
          <button type="button" data-filter="resources"><span>🌾 موارد</span><small id="count-resources">0</small></button>
          <button type="button" data-filter="fishing"><span>🎣 صيد</span><small id="count-fishing">0</small></button>
          <button type="button" data-filter="cooking"><span>🍳 طبخ</span><small id="count-cooking">0</small></button>
          <button type="button" data-filter="rare"><span>✨ نادر</span><small id="count-rare">0</small></button>
          <button type="button" data-filter="economy"><span>💎 اقتصاد</span><small id="count-economy">0</small></button>
        </div>
      </section>

      <section class="tnx-vault tnx-reveal">
        <div class="tnx-vault-layout">
          <div>
            <div id="itemsGrid" class="tnx-items-grid"></div>

            <div id="itemsEmpty" class="tnx-empty hidden">
              <strong>ما لقيت غرض مطابق</strong>
              <span>جرّب تبحث باسم أبسط مثل: نيوك، Vip، صندوق، خشب.</span>
            </div>
          </div>

          <aside id="itemFocusPanel" class="tnx-focus-panel">
            <div class="tnx-focus-placeholder">
              <div>⬟</div>
              <h3>اختر غرض</h3>
              <p>اضغط على أي غرض من القائمة عشان تظهر تفاصيله هنا.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="tnx-crafting tnx-reveal">
        <div class="tnx-section-head">
          <span>CRAFTING</span>
          <h2>وصفات التركيب</h2>
          <p>ركّب أغراض حصرية بمكونات معينة وعملة السمعة.</p>
        </div>

        <div id="craftingGrid" class="tnx-crafting-grid"></div>

        <div id="craftingEmpty" class="tnx-empty hidden">
          <strong>ما فيه وصفات تركيب</strong>
          <span>أضف crafting في items.json بتظهر هنا.</span>
        </div>
      </section>
    </section>
  </main>

  <style is:global>
    .hidden {
      display: none !important;
    }

    .tnx-items-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.13), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.12), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.09), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.055;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.42) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.42) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background: rgba(7, 5, 11, 0.9);
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 22px rgba(255, 218, 106, 0.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.78);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 650ms ease, transform 650ms ease;
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 940px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.4);
      color: #ffda6a;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.16em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
      animation: tnxPulse 1.8s ease-in-out infinite;
    }

    @keyframes tnxPulse {
      0%, 100% { opacity: 0.75; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.25); }
    }

    .tnx-hero h1 {
      margin: 1.1rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.1rem, 7vw, 6.6rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.055em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.04rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 860px;
      margin: 1.35rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-howto,
    .tnx-toolbar,
    .tnx-focus-panel,
    .tnx-crafting {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)), rgba(6, 6, 8, 0.78);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.44), inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 0.9rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.7rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.78rem;
      font-weight: 850;
    }

    .tnx-howto,
    .tnx-toolbar,
    .tnx-crafting {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head {
      text-align: center;
      margin-bottom: 1rem;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.35rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.45rem auto 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
      max-width: 560px;
    }

    .tnx-howto-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1rem;
    }

    .tnx-howto-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.85rem;
      min-height: 130px;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.25rem;
      background: radial-gradient(circle at top right, rgba(255, 218, 106, 0.07), transparent 42%), rgba(0, 0, 0, 0.3);
      color: white;
      padding: 1rem;
      text-align: right;
      cursor: pointer;
      transition: 200ms ease;
      align-items: center;
    }

    .tnx-howto-card:hover {
      transform: translateY(-3px);
      border-color: rgba(255, 218, 106, 0.5);
      background: radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 42%), rgba(0, 0, 0, 0.38);
    }

    .tnx-howto-icon {
      display: grid;
      place-items: center;
      width: 3.2rem;
      height: 3.2rem;
      border-radius: 1rem;
      border: 1px solid color-mix(in srgb, var(--tnx-c, #ffda6a) 40%, transparent);
      background: color-mix(in srgb, var(--tnx-c, #ffda6a) 12%, transparent);
      font-size: 1.6rem;
    }

    .tnx-howto-card strong {
      display: block;
      color: white;
      font-size: 1.1rem;
      font-weight: 950;
      line-height: 1.35;
    }

    .tnx-howto-card p {
      margin: 0.35rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 0.84rem;
      font-weight: 800;
      line-height: 1.65;
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
      max-width: 700px;
      margin: 0 auto;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem auto 0;
      justify-content: center;
      max-width: 1060px;
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.6rem 0.8rem;
      font-size: 0.8rem;
      font-weight: 950;
      cursor: pointer;
      transition: 200ms ease;
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.66rem;
    }

    .tnx-vault {
      margin-top: 1rem;
    }

    .tnx-vault-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1rem;
      align-items: start;
    }

    .tnx-items-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
    }

    /* ============ Category color tokens ============ */
    .tnx-item-card {
      --tnx-cat: #ffda6a;
      --tnx-cat-soft: rgba(255, 218, 106, 0.08);
      --tnx-cat-border: rgba(255, 218, 106, 0.18);
      --tnx-cat-glow: rgba(255, 218, 106, 0.12);
    }
    .tnx-item-card.cat-status { --tnx-cat: #c084fc; --tnx-cat-soft: rgba(192, 132, 252, 0.1); --tnx-cat-border: rgba(192, 132, 252, 0.32); --tnx-cat-glow: rgba(192, 132, 252, 0.15); }
    .tnx-item-card.cat-attacks { --tnx-cat: #f87171; --tnx-cat-soft: rgba(248, 113, 113, 0.1); --tnx-cat-border: rgba(248, 113, 113, 0.32); --tnx-cat-glow: rgba(248, 113, 113, 0.15); }
    .tnx-item-card.cat-pvp { --tnx-cat: #fb923c; --tnx-cat-soft: rgba(251, 146, 60, 0.1); --tnx-cat-border: rgba(251, 146, 60, 0.32); --tnx-cat-glow: rgba(251, 146, 60, 0.15); }
    .tnx-item-card.cat-luck { --tnx-cat: #fbbf24; --tnx-cat-soft: rgba(251, 191, 36, 0.1); --tnx-cat-border: rgba(251, 191, 36, 0.32); --tnx-cat-glow: rgba(251, 191, 36, 0.15); }
    .tnx-item-card.cat-boxes { --tnx-cat: #34d399; --tnx-cat-soft: rgba(52, 211, 153, 0.1); --tnx-cat-border: rgba(52, 211, 153, 0.32); --tnx-cat-glow: rgba(52, 211, 153, 0.15); }
    .tnx-item-card.cat-permits { --tnx-cat: #60a5fa; --tnx-cat-soft: rgba(96, 165, 250, 0.1); --tnx-cat-border: rgba(96, 165, 250, 0.32); --tnx-cat-glow: rgba(96, 165, 250, 0.15); }
    .tnx-item-card.cat-resources { --tnx-cat: #a3a3a3; --tnx-cat-soft: rgba(163, 163, 163, 0.08); --tnx-cat-border: rgba(163, 163, 163, 0.28); --tnx-cat-glow: rgba(163, 163, 163, 0.12); }
    .tnx-item-card.cat-fishing { --tnx-cat: #38bdf8; --tnx-cat-soft: rgba(56, 189, 248, 0.1); --tnx-cat-border: rgba(56, 189, 248, 0.32); --tnx-cat-glow: rgba(56, 189, 248, 0.15); }
    .tnx-item-card.cat-cooking { --tnx-cat: #fb7185; --tnx-cat-soft: rgba(251, 113, 133, 0.1); --tnx-cat-border: rgba(251, 113, 133, 0.32); --tnx-cat-glow: rgba(251, 113, 133, 0.15); }
    .tnx-item-card.cat-rare { --tnx-cat: #ffda6a; --tnx-cat-soft: rgba(255, 218, 106, 0.12); --tnx-cat-border: rgba(255, 218, 106, 0.5); --tnx-cat-glow: rgba(255, 218, 106, 0.22); }
    .tnx-item-card.cat-economy { --tnx-cat: #f7e6ac; --tnx-cat-soft: rgba(247, 230, 172, 0.1); --tnx-cat-border: rgba(247, 230, 172, 0.32); --tnx-cat-glow: rgba(247, 230, 172, 0.15); }

    .tnx-item-card {
      position: relative;
      display: grid;
      gap: 0.7rem;
      border: 1px solid var(--tnx-cat-border);
      border-radius: 1.25rem;
      background: linear-gradient(145deg, var(--tnx-cat-soft), rgba(0, 0, 0, 0.3) 70%);
      color: white;
      padding: 0.9rem;
      text-align: right;
      cursor: pointer;
      overflow: hidden;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
      scroll-margin-top: 9rem;
    }

    .tnx-item-card:hover,
    .tnx-item-card.is-selected {
      transform: translateY(-4px);
      border-color: var(--tnx-cat);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.35), 0 0 28px var(--tnx-cat-glow);
    }

    .tnx-item-card.cat-rare::before {
      content: '';
      position: absolute;
      inset: -40%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 218, 106, 0.18), transparent 32%);
      animation: tnxShine 5s linear infinite;
      pointer-events: none;
    }

    @keyframes tnxShine {
      to { transform: rotate(360deg); }
    }

    .tnx-item-card > * { position: relative; z-index: 1; }

    .tnx-item-flags {
      position: absolute;
      top: 0.55rem;
      right: 0.55rem;
      display: flex;
      gap: 0.3rem;
      z-index: 2;
    }

    .tnx-item-flag {
      display: grid;
      place-items: center;
      width: 1.5rem;
      height: 1.5rem;
      border-radius: 0.45rem;
      background: rgba(0, 0, 0, 0.5);
      color: var(--tnx-cat);
      font-size: 0.78rem;
      border: 1px solid color-mix(in srgb, var(--tnx-cat) 40%, transparent);
    }

    .tnx-item-icon {
      display: grid;
      place-items: center;
      height: 78px;
      border-radius: 0.95rem;
      background: radial-gradient(circle, var(--tnx-cat-soft), transparent 70%);
      font-size: 2.4rem;
      color: var(--tnx-cat);
    }

    .tnx-item-name {
      display: block;
      color: white;
      font-size: 1rem;
      font-weight: 950;
      line-height: 1.3;
    }

    .tnx-item-desc {
      margin: 0;
      color: rgb(180, 180, 195);
      font-size: 0.76rem;
      font-weight: 800;
      line-height: 1.55;
      min-height: 2.3em;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .tnx-item-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.5rem;
