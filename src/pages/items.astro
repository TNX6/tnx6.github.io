      .tnx-back-top { left: .9rem; bottom: .9rem; width: 2.8rem; height: 2.8rem; }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxItemsPageCleanup'

      if (window[cleanupKey]) window[cleanupKey]()

      const listeners = []
      const timers = []
      const observers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
        observers.forEach((observer) => observer.disconnect())
        observers.length = 0
      }

      const CATEGORY_META = {
        interactive: { label: 'تفاعلي', icon: '⚡' },
        loot: { label: 'صندوق', icon: '🎁' },
        material: { label: 'مادة', icon: '🧩' },
        license: { label: 'رخصة / رتبة', icon: '📜' },
        vip: { label: 'مكانة', icon: '💎' },
        economy: { label: 'اقتصاد', icon: '🪙' },
        general: { label: 'عام', icon: '🎒' },
      }

      const RARITY_META = {
        mythic: { label: 'Mythic', icon: '👑' },
        legendary: { label: 'Legendary', icon: '🔥' },
        epic: { label: 'Epic', icon: '🟣' },
        rare: { label: 'Rare', icon: '🔵' },
        common: { label: 'Common', icon: '⚪' },
        special: { label: 'Special', icon: '✨' },
      }

      const state = {
        items: [],
        crafting: [],
        lootTables: [],
        filter: 'all',
        search: '',
        selectedSlug: '',
      }

      const itemSearch = document.getElementById('itemSearch')
      const clearItemSearch = document.getElementById('clearItemSearch')
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'))
      const featuredGrid = document.getElementById('featuredGrid')
      const itemsGrid = document.getElementById('itemsGrid')
      const itemsEmpty = document.getElementById('itemsEmpty')
      const itemFocusPanel = document.getElementById('itemFocusPanel')
      const craftingGrid = document.getElementById('craftingGrid')
      const lootGrid = document.getElementById('lootGrid')
      const backToTop = document.getElementById('backToTop')
      const statItems = document.getElementById('statItems')
      const statCrafting = document.getElementById('statCrafting')
      const statTopValue = document.getElementById('statTopValue')

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function slugify(value) {
        const cleaned = String(value || '')
          .trim()
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')

        return `item-${cleaned || 'unknown'}`
      }

      function formatNumber(value) {
        return Number(value || 0).toLocaleString('de-DE')
      }

      function getCategory(item) {
        const text = normalize([item.text, item.description, item.option].join(' '))

        if (text.includes('vip')) return 'vip'
        if (text.includes('صندوق')) return 'loot'
        if (text.includes('رخصه') || text.includes('محامي') || text.includes('lawyer') || text.includes('مصرفي') || text.includes('تجاره') || text.includes('crown') || text.includes('عريف')) return 'license'
        if (['سمعه', 'علف', 'خشب', 'صناره', 'طعم', 'سمكه', 'طماط', 'يقطين', 'بصل', 'حليب', 'مرق', 'بقره', 'فاس'].some((word) => text.includes(word))) return 'material'
        if (['نيوك', 'عنوان', 'الحرامي', 'جرأه', 'جرأة', 'تجميد', 'نرد', 'قنبله', 'بطاطا', 'لا يكثر', 'البريد'].some((word) => text.includes(word))) return 'interactive'
        if (text.includes('نقاط') || text.includes('عملة') || text.includes('عمله')) return 'economy'
        return 'general'
      }

      function getRarity(item, category) {
        const value = Number(item.value || 0)
        const text = normalize([item.text, item.description].join(' '))

        if (text.includes('crown') || value >= 1000000) return 'mythic'
        if (value >= 150000 || text.includes('ذهبيه') || text.includes('اسطوري')) return 'legendary'
        if (value >= 50000) return 'epic'
        if (value >= 10000 || category === 'loot' || category === 'vip') return 'rare'
        if (value <= 0) return 'special'
        return 'common'
      }

      function getIcon(item, category, rarity) {
        const text = normalize(item.text)

        if (text.includes('crown')) return '👑'
        if (text.includes('نيوك')) return '💣'
        if (text.includes('محامي') || text.includes('lawyer')) return '⚖️'
        if (text.includes('vip')) return '💎'
        if (text.includes('صندوق')) return '🎁'
        if (text.includes('سمعه')) return '⭐'
        if (text.includes('عنوان')) return '📝'
        if (text.includes('الحرامي')) return '🖐️'
        if (text.includes('جرأه') || text.includes('جرأة')) return '🪙'
        if (text.includes('تجميد')) return '🧊'
        if (text.includes('نرد')) return '🎲'
        if (text.includes('قنبله')) return '💨'
        if (text.includes('بطاطا')) return '🥔'
        if (text.includes('بريد')) return '📬'
        if (text.includes('خشب')) return '🪵'
        if (text.includes('فاس')) return '🪓'
        if (text.includes('صناره')) return '🎣'
        if (text.includes('سمكه')) return '🐟'
        if (text.includes('بقره')) return '🐄'
        if (text.includes('حليب')) return '🥛'
        if (text.includes('طماط')) return '🍅'
        if (text.includes('بصل')) return '🧅'
        if (text.includes('يقطين')) return '🎃'
        if (text.includes('مرق')) return '🍲'
        if (text.includes('رخصه')) return '📜'
        if (rarity === 'mythic') return '👑'
        if (rarity === 'legendary') return '🔥'
        return CATEGORY_META[category]?.icon || '🎒'
      }

      function enrichItem(item, index) {
        const category = getCategory(item)
        const rarity = getRarity(item, category)
        const icon = getIcon(item, category, rarity)
        const slug = slugify(item.text)

        const canSell = !item.excludeSale
        const canBuy = !item.excludePurchase
        const canUse = !item.excludeUsage
        const limited = !!item.itemLimitEnabled

        const searchText = normalize([
          item.text,
          item.description,
          item.option,
          category,
          CATEGORY_META[category]?.label,
          rarity,
          RARITY_META[rarity]?.label,
          canSell ? 'sell sale بيع' : '',
          canBuy ? 'purchase buy شراء' : '',
          canUse ? 'use usage استخدام' : '',
          limited ? 'limited limit محدود' : '',
        ].join(' '))

        return {
          ...item,
          index,
          slug,
          category,
          categoryLabel: CATEGORY_META[category]?.label || 'عام',
          rarity,
          rarityLabel: RARITY_META[rarity]?.label || 'Common',
          icon,
          canSell,
          canBuy,
          canUse,
          limited,
          searchText,
        }
      }

      function updateStats() {
        const topValue = Math.max(0, ...state.items.map((item) => Number(item.value || 0)))
        statItems.textContent = formatNumber(state.items.length)
        statCrafting.textContent = formatNumber(state.crafting.length)
        statTopValue.textContent = formatNumber(topValue)

        const counts = {
          all: state.items.length,
          legendary: 0,
          interactive: 0,
          loot: 0,
          material: 0,
          license: 0,
          purchasable: 0,
          usable: 0,
          limited: 0,
        }

        state.items.forEach((item) => {
          if (item.rarity === 'legendary' || item.rarity === 'mythic') counts.legendary++
          if (item.category === 'interactive') counts.interactive++
          if (item.category === 'loot') counts.loot++
          if (item.category === 'material') counts.material++
          if (item.category === 'license' || item.category === 'vip') counts.license++
          if (item.canBuy) counts.purchasable++
          if (item.canUse) counts.usable++
          if (item.limited) counts.limited++
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function matchesFilter(item) {
        if (state.filter === 'all') return true
        if (state.filter === 'legendary') return item.rarity === 'legendary' || item.rarity === 'mythic'
        if (state.filter === 'purchasable') return item.canBuy
        if (state.filter === 'usable') return item.canUse
        if (state.filter === 'limited') return item.limited
        if (state.filter === 'license') return item.category === 'license' || item.category === 'vip'
        return item.category === state.filter
      }

      function getFilteredItems() {
        const q = normalize(state.search)
        return state.items.filter((item) => {
          return matchesFilter(item) && (!q || item.searchText.includes(q))
        })
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.filter === state.filter)
        })
      }

      function renderTags(item) {
        const tags = []
        tags.push(`<span class="tnx-tag tnx-tag-gold">${esc(item.rarityLabel)}</span>`)
        tags.push(`<span class="tnx-tag">${esc(item.categoryLabel)}</span>`)
        if (item.canBuy) tags.push(`<span class="tnx-tag tnx-tag-green">شراء</span>`)
        if (item.canUse) tags.push(`<span class="tnx-tag tnx-tag-blue">استخدام</span>`)
        if (!item.canSell) tags.push(`<span class="tnx-tag tnx-tag-red">لا يباع</span>`)
        if (item.limited) tags.push(`<span class="tnx-tag tnx-tag-blue">حد ${esc(item.itemLimitAmount || 1)}</span>`)
        return tags.join('')
      }

      function renderFeatured() {
        const preferred = ['Crown', 'نيوك', 'محامي', 'مطرقة ذهبية']
        const picked = []

        preferred.forEach((name) => {
          const item = state.items.find((i) => normalize(i.text) === normalize(name))
          if (item && !picked.includes(item)) picked.push(item)
        })

        state.items
          .slice()
          .sort((a, b) => Number(b.value || 0) - Number(a.value || 0))
          .forEach((item) => {
            if (picked.length < 4 && !picked.includes(item)) picked.push(item)
          })

        featuredGrid.innerHTML = picked.slice(0, 4).map((item) => `
          <button type="button" class="tnx-boss-card" data-item-slug="${esc(item.slug)}">
            <div class="tnx-boss-content">
              <div class="tnx-boss-icon">${esc(item.icon)}</div>
              <div>
                <h3>${esc(item.text)}</h3>
                <p>${esc(item.description || 'بدون وصف.')}</p>
              </div>
              <span class="tnx-boss-price">${formatNumber(item.value)} 🪙</span>
            </div>
          </button>
        `).join('')
      }

      function renderItems() {
        const items = getFilteredItems()
        itemsEmpty.classList.toggle('hidden', items.length > 0)

        itemsGrid.innerHTML = items.map((item, index) => {
          const selected = item.slug === state.selectedSlug ? ' is-selected' : ''
          const linked = window.location.hash === `#${item.slug}` ? ' is-linked' : ''

          return `
            <button
              type="button"
              id="${esc(item.slug)}"
              class="tnx-item-card${selected}${linked}"
              data-item-slug="${esc(item.slug)}"
              style="--stagger:${Math.min(index, 24) * 35}ms"
            >
              <div class="tnx-item-top">
                <div class="tnx-item-icon">${esc(item.icon)}</div>
                <span class="tnx-item-price">${formatNumber(item.value)} 🪙</span>
              </div>

              <div>
                <h3>${esc(item.text)}</h3>
                <p>${esc(item.description || 'No description available.')}</p>
              </div>

              <div class="tnx-item-tags">
                ${renderTags(item)}
              </div>
            </button>
          `
        }).join('')
      }

      function renderFocus(item) {
        if (!item) return

        const command = String(item.option || '').trim()
        const commandText = command && command !== 'Type to filter options...' ? command : 'غير محدد'

        itemFocusPanel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-hero">
              <div class="tnx-focus-icon">${esc(item.icon)}</div>
              <div>
                <span class="tnx-tag tnx-tag-gold">${esc(item.rarityLabel)}</span>
                <h3>${esc(item.text)}</h3>
              </div>
            </div>

            <p>${esc(item.description || 'بدون وصف.')}</p>

            <div class="tnx-focus-meta">
              <div>
                <span>القيمة</span>
                <strong>${formatNumber(item.value)} 🪙</strong>
              </div>
              <div>
                <span>التصنيف</span>
                <strong>${esc(item.categoryLabel)}</strong>
              </div>
              <div>
                <span>الأمر</span>
                <strong>${esc(commandText)}</strong>
              </div>
              <div>
                <span>الحد</span>
                <strong>${item.limited ? esc(item.itemLimitAmount || 1) : 'غير محدود'}</strong>
              </div>
            </div>

            <div class="tnx-item-tags">
              ${renderTags(item)}
            </div>

            <div class="tnx-focus-actions">
              <button type="button" class="tnx-focus-copy" data-copy-item-link="${esc(item.slug)}">نسخ رابط الغرض</button>
              ${command && commandText !== 'غير محدد' ? `<button type="button" class="tnx-focus-copy" data-copy-command="${esc(commandText)}">نسخ الأمر</button>` : ''}
            </div>
          </div>
        `
      }

      function selectItem(slug, options = {}) {
        const item = state.items.find((i) => i.slug === slug)
        if (!item) return

        state.selectedSlug = slug

        if (options.updateHash !== false) {
          history.replaceState(null, '', `${window.location.pathname}${window.location.search}#${item.slug}`)
        }

        renderItems()
        renderFocus(item)

        if (options.scrollToItem) {
          addTimer(window.setTimeout(() => {
            document.getElementById(item.slug)?.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }, 80))
        }
      }

      function openItemFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('item-')) return false

        const item = state.items.find((i) => i.slug === hash)
        if (!item) return false

        state.filter = 'all'
        state.search = ''
        if (itemSearch) itemSearch.value = ''
        renderFilterButtons()
        selectItem(item.slug, { updateHash: false, scrollToItem: options.scrollToItem !== false })

        document.querySelector('.tnx-vault')?.scrollIntoView({
          behavior: options.instant ? 'auto' : 'smooth',
          block: 'start',
        })

        return true
      }

      function getItemLink(slug) {
        return `${window.location.origin}${window.location.pathname}${window.location.search}#${slug}`
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent
        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')
          addTimer(window.setTimeout(() => {
            button.textContent = oldText
            button.classList.remove('is-copied')
          }, 1000))
        } catch {
          button.textContent = text
          addTimer(window.setTimeout(() => { button.textContent = oldText }, 1300))
        }
      }

      function renderCrafting() {
        if (!state.crafting.length) {
          craftingGrid.innerHTML = `<div class="tnx-empty"><strong>ما فيه وصفات</strong><span>أضف crafting في items.json عشان تظهر هنا.</span></div>`
          return
        }

        craftingGrid.innerHTML = state.crafting.map((recipe) => {
          const ingredients = Array.isArray(recipe.ingredients) ? recipe.ingredients : []
          return `
            <div class="tnx-recipe-card">
              <div class="tnx-recipe-flow">
                <div class="tnx-ingredients">
                  ${ingredients.map((ing) => {
                    const item = state.items.find((i) => normalize(i.text) === normalize(ing.item))
                    return `<span class="tnx-ingredient"><span>${esc(item?.icon || '🧩')}</span>${esc(ing.item)} <b>x${formatNumber(ing.amount)}</b></span>`
                  }).join('')}
                </div>
                <div class="tnx-arrow">←</div>
                <button type="button" class="tnx-result" data-result-item="${esc(slugify(recipe.result))}">
                  <span>النتيجة</span>
                  <strong>${esc(recipe.result)}</strong>
                </button>
              </div>
            </div>
          `
        }).join('')
      }

      function renderLootTables() {
        const validTables = state.lootTables.filter((table) => Array.isArray(table.items) && table.items.length)

        if (!validTables.length) {
          lootGrid.innerHTML = `<div class="tnx-empty"><strong>ما فيه جداول صناديق</strong><span>إذا أضفت lootTables في items.json بتظهر هنا.</span></div>`
          return
        }

        lootGrid.innerHTML = validTables.map((table, index) => {
          const name = String(table.name || '').trim() || `جدول صندوق ${index + 1}`
          return `
            <div class="tnx-loot-card">
              <h3>🎁 ${esc(name)}</h3>
              <div class="tnx-loot-list">
                ${table.items.map((row) => `
                  <div class="tnx-loot-row">
                    <span>${esc(row.option || 'Unknown')}</span>
                    <b>${formatNumber(row.value)}%</b>
                  </div>
                `).join('')}
              </div>
            </div>
          `
        }).join('')
      }

      async function loadData() {
        const res = await fetch('/api/items.json?v=' + Date.now())
        if (!res.ok) throw new Error(`items.json request failed: ${res.status}`)

        const data = await res.json()
        state.items = Array.isArray(data.items) ? data.items.map(enrichItem) : []
        state.crafting = Array.isArray(data.crafting) ? data.crafting : []
        state.lootTables = Array.isArray(data.lootTables) ? data.lootTables : []
      }

      function renderAll() {
        updateStats()
        renderFilterButtons()
        renderFeatured()
        renderItems()
        renderCrafting()
        renderLootTables()

        const opened = openItemFromHash({ instant: true, scrollToItem: true })
        if (!opened && state.items.length) {
          selectItem(state.items[0].slug, { updateHash: false })
        }
      }

      function setupReveal() {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.tnx-reveal').forEach((el) => el.classList.add('is-visible'))
          return
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              observer.unobserve(entry.target)
            }
          })
        }, { threshold: 0.12 })

        document.querySelectorAll('.tnx-reveal').forEach((el) => observer.observe(el))
        observers.push(observer)
      }

      function handleBackToTopVisibility() {
        if (!backToTop) return
        backToTop.classList.toggle('is-visible', window.scrollY > 520)
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTopVisibility, { passive: true })

      addListener(featuredGrid, 'click', (event) => {
        const button = event.target.closest('[data-item-slug]')
        if (!button) return
        selectItem(button.dataset.itemSlug, { updateHash: true, scrollToItem: true })
        document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      })

      addListener(itemsGrid, 'click', (event) => {
        const button = event.target.closest('[data-item-slug]')
        if (!button) return
        selectItem(button.dataset.itemSlug, { updateHash: true })
      })

      addListener(document, 'click', (event) => {
        const copyLinkButton = event.target.closest('[data-copy-item-link]')
        if (copyLinkButton) {
          copyText(getItemLink(copyLinkButton.dataset.copyItemLink), copyLinkButton, 'تم نسخ الرابط')
          return
        }

        const copyCommandButton = event.target.closest('[data-copy-command]')
        if (copyCommandButton) {
          copyText(copyCommandButton.dataset.copyCommand || '', copyCommandButton, 'تم نسخ الأمر')
          return
        }

        const resultButton = event.target.closest('[data-result-item]')
        if (resultButton) {
          const item = state.items.find((i) => i.slug === resultButton.dataset.resultItem)
          if (item) {
            state.filter = 'all'
            state.search = ''
            if (itemSearch) itemSearch.value = ''
            renderFilterButtons()
            selectItem(item.slug, { updateHash: true, scrollToItem: true })
            document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        }
      })

      addListener(window, 'hashchange', () => {
        openItemFromHash({ scrollToItem: true })
      })

      addListener(itemSearch, 'input', () => {
        state.search = itemSearch.value
        renderItems()
      })

      addListener(clearItemSearch, 'click', () => {
        if (!itemSearch) return
        itemSearch.value = ''
        state.search = ''
        itemSearch.focus()
        renderItems()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.filter || 'all'
          renderFilterButtons()
          renderItems()
        })
      })

      try {
        setupReveal()
        await loadData()
        renderAll()
        handleBackToTopVisibility()
      } catch (error) {
        console.error(error)
        itemsGrid.innerHTML = `<div class="tnx-empty"><strong>تعذر تحميل الأغراض</strong><span>تأكد من وجود public/api/items.json</span></div>`
      }
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
