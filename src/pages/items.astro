      background: rgba(19, 15, 28, 0.86);
    }

    .tnx-craft-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(150px, auto);
      gap: 0.85rem;
      align-items: center;
    }

    .tnx-ingredients {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      align-items: center;
    }

    .tnx-ingredient {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 0.75rem;
      background: rgba(0, 0, 0, 0.34);
      padding: 0.55rem 0.65rem;
      color: white;
      font-size: 0.8rem;
      font-weight: 900;
    }

    .tnx-ingredient b {
      display: inline-flex;
      border-radius: 0.5rem;
      background: rgba(255, 218, 106, 0.13);
      color: #ffda6a;
      padding: 0.16rem 0.35rem;
      font-size: 0.68rem;
      font-weight: 950;
    }

    .tnx-craft-arrow {
      color: rgba(255, 218, 106, 0.55);
      font-size: 1.35rem;
      font-weight: 950;
    }

    .tnx-craft-result {
      border: 1px solid rgba(255, 218, 106, 0.36);
      border-radius: 1rem;
      background: linear-gradient(135deg, rgba(255, 218, 106, 0.14), rgba(194, 146, 0, 0.04));
      padding: 0.75rem 0.9rem;
      text-align: center;
      box-shadow: 0 0 15px rgba(255, 218, 106, 0.08);
    }

    .tnx-craft-result span {
      display: block;
      color: rgba(255, 218, 106, 0.8);
      font-size: 0.67rem;
      font-weight: 950;
      margin-bottom: 0.25rem;
    }

    .tnx-craft-result strong {
      color: white;
      font-size: 1rem;
      font-weight: 950;
    }

    .tnx-loot-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.75rem;
      color: #f7e6ac;
      font-size: 1.05rem;
      font-weight: 950;
    }

    .tnx-loot-list {
      display: grid;
      gap: 0.5rem;
    }

    .tnx-loot-line {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 0.75rem;
      background: rgba(0, 0, 0, 0.28);
      padding: 0.55rem 0.65rem;
      color: rgb(209, 213, 219);
      font-size: 0.82rem;
      font-weight: 850;
    }

    .tnx-loot-line b {
      color: #ffda6a;
      font-weight: 950;
    }

    .tnx-empty {
      display: grid;
      place-items: center;
      gap: 0.35rem;
      border: 1px solid rgba(255, 218, 106, 0.13);
      border-radius: 1.5rem;
      background: rgba(0, 0, 0, 0.24);
      padding: 2rem;
      text-align: center;
      min-height: 220px;
    }

    .tnx-empty strong {
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
    }

    .tnx-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
      font-weight: 800;
    }

    @media (max-width: 1120px) {
      .tnx-items-layout {
        grid-template-columns: 1fr;
      }

      .tnx-focus-panel {
        position: static;
        min-height: auto;
      }

      .tnx-items-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 860px) {
      .tnx-hero-stats,
      .tnx-crafting-grid,
      .tnx-loot-grid {
        grid-template-columns: 1fr;
      }

      .tnx-craft-row {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .tnx-craft-arrow {
        transform: rotate(90deg);
      }

      .tnx-ingredients {
        justify-content: center;
      }
    }

    @media (max-width: 620px) {
      .tnx-shell {
        padding-top: 5.5rem;
      }

      .tnx-hero h1 {
        font-size: 3rem;
      }

      .tnx-items-grid {
        grid-template-columns: 1fr;
      }

      .tnx-focus-meta,
      .tnx-focus-actions {
        grid-template-columns: 1fr;
      }

      .tnx-section-line-head {
        grid-template-columns: 1fr;
      }

      .tnx-section-line-head div {
        display: none;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxItemsPageCleanup';

      if (window[cleanupKey]) {
        window[cleanupKey]();
      }

      const listeners = [];
      const timers = [];
      let revealObserver = null;

      function addListener(target, event, handler, options) {
        if (!target) return;
        target.addEventListener(event, handler, options);
        listeners.push(() => target.removeEventListener(event, handler, options));
      }

      function addTimer(id) {
        timers.push(id);
        return id;
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup());
        listeners.length = 0;
        timers.forEach((id) => window.clearTimeout(id));
        timers.length = 0;
        if (revealObserver) revealObserver.disconnect();
      };

      const state = {
        data: { items: [], crafting: [], lootTables: [] },
        items: [],
        filter: 'all',
        search: '',
        selectedItemName: '',
      };

      const itemsGrid = document.getElementById('itemsGrid');
      const itemsEmpty = document.getElementById('itemsEmpty');
      const itemFocusPanel = document.getElementById('itemFocusPanel');
      const itemSearch = document.getElementById('itemSearch');
      const clearItemSearch = document.getElementById('clearItemSearch');
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'));
      const backToTop = document.getElementById('backToTop');
      const craftingGrid = document.getElementById('craftingGrid');
      const craftingEmpty = document.getElementById('craftingEmpty');
      const lootGrid = document.getElementById('lootGrid');
      const lootEmpty = document.getElementById('lootEmpty');

      const statItems = document.getElementById('statItems');
      const statCrafting = document.getElementById('statCrafting');
      const statLimited = document.getElementById('statLimited');

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim();
      }

      function itemKey(value) {
        return normalize(value).replace(/\s+/g, '');
      }

      function itemSlug(name) {
        return `item-${String(name || '')
          .trim()
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')}`;
      }

      function formatNumber(n) {
        return Number(n || 0).toLocaleString('de-DE');
      }

      function isRealCommand(option) {
        const text = String(option || '').trim();
        if (!text) return false;
        if (normalize(text) === normalize('Type to filter options...')) return false;
        return true;
      }

      function getItemCategory(item) {
        const text = normalize(`${item.text} ${item.description} ${item.option}`);

        if (text.includes('صندوق')) return 'boxes';
        if (text.includes('رخصه') || text.includes('رخصة') || text.includes('محامي') || text.includes('vip') || text.includes('crown') || text.includes('exam')) return 'permits';
        if (text.includes('نيوك') || text.includes('عنوان') || text.includes('تجمد') || text.includes('تجميد') || text.includes('قنبله') || text.includes('قنبلة') || text.includes('بطاطا') || text.includes('جرأه') || text.includes('جرأة') || text.includes('نرد') || text.includes('حرامي')) return 'effects';
        if (!isRealCommand(item.option) || item.excludeUsage) return 'materials';

        return 'effects';
      }

      function enrichItem(item, index) {
        const name = String(item?.text || '').trim();
        const option = String(item?.option || '').trim();
        const description = String(item?.description || '').trim() || 'No description available.';
        const category = getItemCategory(item);
        const hashId = itemSlug(name);

        const searchText = normalize([
          name,
          option,
          description,
          category,
          item.excludeSale ? 'لا يباع not sale' : 'يباع sale',
          item.excludePurchase ? 'لا يشترى not purchase' : 'يشترى purchase',
          item.excludeUsage ? 'لا يستخدم not use' : 'يستخدم use',
          item.itemLimitEnabled ? 'محدود limit' : '',
        ].join(' '));

        return {
          ...item,
          index,
          name,
          option,
          description,
          category,
          hashId,
          value: Number(item?.value || 0),
          searchText,
        };
      }

      function matchesFilter(item, filter) {
        if (filter === 'all') return true;
        if (filter === 'purchase') return !item.excludePurchase;
        if (filter === 'use') return !item.excludeUsage;
        if (filter === 'sale') return !item.excludeSale;
        if (filter === 'limited') return !!item.itemLimitEnabled;
        return item.category === filter;
      }

      function updateStats() {
        const items = state.items;
        const counts = {
          all: items.length,
          purchase: items.filter((i) => !i.excludePurchase).length,
          use: items.filter((i) => !i.excludeUsage).length,
          sale: items.filter((i) => !i.excludeSale).length,
          limited: items.filter((i) => i.itemLimitEnabled).length,
          boxes: items.filter((i) => i.category === 'boxes').length,
          effects: items.filter((i) => i.category === 'effects').length,
          materials: items.filter((i) => i.category === 'materials').length,
          permits: items.filter((i) => i.category === 'permits').length,
        };

        if (statItems) statItems.textContent = String(items.length);
        if (statCrafting) statCrafting.textContent = String(state.data.crafting.length);
        if (statLimited) statLimited.textContent = String(counts.limited);

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`);
          if (el) el.textContent = String(value);
        });
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.filter === state.filter);
        });
      }

      function getFilteredItems() {
        return state.items.filter((item) => {
          const filterMatch = matchesFilter(item, state.filter);
          const searchMatch = !state.search || item.searchText.includes(normalize(state.search));
          return filterMatch && searchMatch;
        });
      }

      function getFlagsHtml(item) {
        const flags = [];

        flags.push(item.excludePurchase
          ? '<span class="tnx-flag bad">لا يشترى</span>'
          : '<span class="tnx-flag good">قابل للشراء</span>');

        flags.push(item.excludeSale
          ? '<span class="tnx-flag bad">لا يباع</span>'
          : '<span class="tnx-flag good">قابل للبيع</span>');

        flags.push(item.excludeUsage
          ? '<span class="tnx-flag bad">لا يستخدم مباشرة</span>'
          : '<span class="tnx-flag good">قابل للاستخدام</span>');

        if (item.itemLimitEnabled) {
          flags.push(`<span class="tnx-flag warn">الحد: ${esc(item.itemLimitAmount || 1)}</span>`);
        }

        return flags.join('');
      }

      function renderItems() {
        const items = getFilteredItems();

        if (!itemsGrid) return;

        itemsEmpty?.classList.toggle('hidden', items.length > 0);

        itemsGrid.innerHTML = items.map((item, visualIndex) => {
          const selected = item.name === state.selectedItemName ? ' is-selected' : '';
          const commandHtml = isRealCommand(item.option)
            ? `<div class="tnx-item-command"><span>الأمر البرمجي</span><code>${esc(item.option)}</code></div>`
            : '';

          return `
            <button
              type="button"
              id="${esc(item.hashId)}"
              class="tnx-item-card${selected}"
              data-item-name="${esc(item.name)}"
              style="--stagger:${visualIndex % 12}"
            >
              <div class="tnx-item-top">
                <strong class="tnx-item-name">${esc(item.name)}</strong>
                <span class="tnx-item-price">${formatNumber(item.value)} <span>🪙</span></span>
              </div>

              <p class="tnx-item-desc">${esc(item.description)}</p>

              ${commandHtml}

              <div class="tnx-item-flags">
                ${getFlagsHtml(item)}
              </div>
            </button>
          `;
        }).join('');
      }

      function getItemLink(hashId) {
        return `${window.location.origin}${window.location.pathname}#${hashId}`;
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent;

        try {
          await navigator.clipboard.writeText(text);
          button.textContent = doneText;
          button.classList.add('is-copied');

          addTimer(window.setTimeout(() => {
            button.textContent = oldText;
            button.classList.remove('is-copied');
          }, 1000));
        } catch {
          button.textContent = text;

          addTimer(window.setTimeout(() => {
            button.textContent = oldText;
          }, 1300));
        }
      }

      function renderFocus(item) {
        if (!itemFocusPanel || !item) return;

        const command = isRealCommand(item.option) ? item.option : 'لا يوجد أمر مباشر';
        const categoryLabel = {
          boxes: 'صناديق',
          permits: 'رخص / رتب',
          effects: 'تأثيرات',
          materials: 'مواد',
        }[item.category] || 'عام';

        itemFocusPanel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-icon">${item.category === 'boxes' ? '🎁' : item.category === 'permits' ? '📜' : item.category === 'materials' ? '🧱' : '⚡'}</div>

            <div>
              <span class="tnx-flag warn">${esc(categoryLabel)}</span>
              <h3>${esc(item.name)}</h3>
            </div>

            <p>${esc(item.description)}</p>

            <div class="tnx-focus-meta">
              <div>
                <span>القيمة</span>
                <strong>${formatNumber(item.value)} 🪙</strong>
              </div>

              <div>
                <span>الحد</span>
                <strong>${item.itemLimitEnabled ? `${esc(item.itemLimitAmount || 1)} فقط` : 'بدون حد'}</strong>
              </div>

              <div>
                <span>الشراء</span>
                <strong>${item.excludePurchase ? 'غير متاح' : 'متاح'}</strong>
              </div>

              <div>
                <span>البيع</span>
                <strong>${item.excludeSale ? 'غير متاح' : 'متاح'}</strong>
              </div>

              <div>
                <span>الاستخدام</span>
                <strong>${item.excludeUsage ? 'غير مباشر' : 'متاح'}</strong>
              </div>

              <div>
                <span>الأمر</span>
                <code>${esc(command)}</code>
              </div>
            </div>

            <div class="tnx-focus-actions">
              <button type="button" class="tnx-focus-copy" data-copy-item-link="${esc(item.hashId)}">نسخ رابط الغرض</button>
              <button type="button" class="tnx-focus-copy" data-copy-item-command="${esc(command)}">نسخ الأمر</button>
            </div>
          </div>
        `;
      }

      function selectItem(name, options = {}) {
        const item = state.items.find((entry) => entry.name === name);
        if (!item) return;

        state.selectedItemName = item.name;

        if (options.updateHash !== false) {
          history.replaceState(null, '', `#${item.hashId}`);
        }

        renderItems();
        renderFocus(item);

        if (options.scrollToItem) {
          addTimer(window.setTimeout(() => {
            document.getElementById(item.hashId)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 80));
        }
      }

      function openItemFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''));
        if (!hash || !hash.startsWith('item-')) return false;

        const item = state.items.find((entry) => entry.hashId === hash);
        if (!item) return false;

        state.filter = 'all';
        state.search = '';
        if (itemSearch) itemSearch.value = '';

        renderFilterButtons();
        selectItem(item.name, { updateHash: false, scrollToItem: options.scrollToItem !== false });
        return true;
      }

      function renderCrafting() {
        const crafting = Array.isArray(state.data.crafting) ? state.data.crafting : [];

        if (!craftingGrid) return;

        craftingEmpty?.classList.toggle('hidden', crafting.length > 0);

        craftingGrid.innerHTML = crafting.map((recipe) => {
          const ingredients = Array.isArray(recipe.ingredients) ? recipe.ingredients : [];

          return `
            <div class="tnx-craft-card">
              <div class="tnx-craft-row">
                <div class="tnx-ingredients">
                  ${ingredients.map((ing) => `
                    <span class="tnx-ingredient">${esc(ing.item)} <b>x${esc(ing.amount)}</b></span>
                  `).join('')}
                </div>

                <div class="tnx-craft-arrow">→</div>

                <div class="tnx-craft-result">
                  <span>النتيجة</span>
                  <strong>${esc(recipe.result)}</strong>
                </div>
              </div>
            </div>
          `;
        }).join('');
      }

      function renderLootTables() {
        const tables = Array.isArray(state.data.lootTables)
          ? state.data.lootTables.filter((table) => Array.isArray(table.items) && table.items.length > 0)
          : [];

        if (!lootGrid) return;

        lootEmpty?.classList.toggle('hidden', tables.length > 0);

        lootGrid.innerHTML = tables.map((table, index) => {
          const title = String(table.name || '').trim() || `Loot Table ${index + 1}`;

          return `
            <div class="tnx-loot-card">
              <div class="tnx-loot-title">
                <span>🎁 ${esc(title)}</span>
                <small>${table.items.length} عناصر</small>
              </div>

              <div class="tnx-loot-list">
                ${table.items.map((it) => `
                  <div class="tnx-loot-line">
                    <span>${esc(it.option)}</span>
                    <b>${esc(it.value)}%</b>
                  </div>
                `).join('')}
              </div>
            </div>
          `;
        }).join('');
      }

      function handleBackToTopVisibility() {
        if (!backToTop) return;
        backToTop.classList.toggle('is-visible', window.scrollY > 520);
      }

      async function loadData() {
        try {
          const res = await fetch('/api/items.json');
          if (!res.ok) throw new Error(`items.json request failed: ${res.status}`);

          const data = await res.json();
          state.data = {
            items: Array.isArray(data.items) ? data.items : [],
            crafting: Array.isArray(data.crafting) ? data.crafting : [],
            lootTables: Array.isArray(data.lootTables) ? data.lootTables : [],
          };

          state.items = state.data.items.map(enrichItem).filter((item) => item.name);

          updateStats();
          renderFilterButtons();
          renderItems();
          renderCrafting();
          renderLootTables();

          const opened = openItemFromHash({ scrollToItem: true });
          if (!opened && state.items.length > 0) {
            selectItem(state.items[0].name, { updateHash: false });
          }
        } catch (error) {
          console.error('Failed to load /api/items.json', error);
          if (itemsGrid) {
            itemsGrid.innerHTML = `
              <div class="tnx-empty">
                <strong>تعذر تحميل الأغراض</strong>
                <span>تأكد من وجود الملف public/api/items.json</span>
              </div>
            `;
          }
        }
      }

      function setupReveal() {
        const elements = Array.from(document.querySelectorAll('.tnx-reveal'));
        if (!elements.length) return;

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });

        elements.forEach((element) => revealObserver.observe(element));
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      addListener(window, 'scroll', handleBackToTopVisibility, { passive: true });

      addListener(itemsGrid, 'click', (event) => {
        const card = event.target.closest('[data-item-name]');
        if (!card) return;
        selectItem(card.dataset.itemName);
      });

      addListener(document, 'click', (event) => {
        const linkButton = event.target.closest('[data-copy-item-link]');
        if (linkButton) {
          copyText(getItemLink(linkButton.dataset.copyItemLink || ''), linkButton, 'تم نسخ الرابط');
          return;
        }

        const commandButton = event.target.closest('[data-copy-item-command]');
        if (commandButton) {
          copyText(commandButton.dataset.copyItemCommand || '', commandButton, 'تم نسخ الأمر');
        }
      });

      addListener(window, 'hashchange', () => {
        openItemFromHash({ scrollToItem: true });
      });

      addListener(itemSearch, 'input', () => {
        state.search = itemSearch.value;
        renderItems();
      });

      addListener(clearItemSearch, 'click', () => {
        if (!itemSearch) return;
        itemSearch.value = '';
        state.search = '';
        itemSearch.focus();
        renderItems();
      });

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.filter || 'all';
          renderFilterButtons();
          renderItems();
        });
      });

      await loadData();
      setupReveal();
      handleBackToTopVisibility();
    })();
  </script>

