        padding-top: 5.5rem;
      }

      .tnx-hero h1 {
        font-size: 3rem;
      }

      .tnx-item-grid {
        grid-template-columns: 1fr;
      }

      .tnx-focus-meta {
        grid-template-columns: 1fr;
      }

      .tnx-back-top {
        left: 0.9rem;
        bottom: 0.9rem;
        width: 2.8rem;
        height: 2.8rem;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxItemsPageCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      const timers = []
      const observers = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      function addTimer(id) {
        timers.push(id)
        return id
      }

      function addObserver(observer) {
        observers.push(observer)
        return observer
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        timers.forEach((id) => window.clearTimeout(id))
        timers.length = 0
        observers.forEach((observer) => observer.disconnect())
        observers.length = 0
      }

      const CATEGORY_META = {
        purchasable: { label: 'قابل للشراء', icon: '₪' },
        usable: { label: 'قابل للاستخدام', icon: '⚡' },
        sellable: { label: 'قابل للبيع', icon: '↗' },
        limited: { label: 'محدود', icon: '1' },
        chests: { label: 'صناديق', icon: '▣' },
        effects: { label: 'تأثيرات', icon: '✦' },
        materials: { label: 'مواد', icon: '◆' },
        licenses: { label: 'رخص / رتب', icon: '★' },
        special: { label: 'خاص', icon: '⬟' },
      }

      const state = {
        items: [],
        lootTables: [],
        crafting: [],
        filter: 'all',
        search: '',
        selectedItemName: '',
      }

      const itemsGrid = document.getElementById('itemsGrid')
      const itemsEmpty = document.getElementById('itemsEmpty')
      const itemSearch = document.getElementById('itemSearch')
      const clearItemSearch = document.getElementById('clearItemSearch')
      const filterButtons = Array.from(document.querySelectorAll('[data-item-filter]'))
      const guideButtons = Array.from(document.querySelectorAll('[data-guide-filter]'))
      const itemFocusPanel = document.getElementById('itemFocusPanel')
      const lootTablesGrid = document.getElementById('lootTablesGrid')
      const craftingGrid = document.getElementById('craftingGrid')
      const backToTop = document.getElementById('itemsBackToTop')

      const statTotalItems = document.getElementById('statTotalItems')
      const statPurchasableItems = document.getElementById('statPurchasableItems')
      const statCraftingRecipes = document.getElementById('statCraftingRecipes')

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function slugify(name) {
        return `item-${String(name || '')
          .trim()
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, '-')
          .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '')}`
      }

      function formatNumber(n) {
        return Number(n || 0).toLocaleString('de-DE')
      }

      function getItemCategory(rawItem) {
        const text = normalize(rawItem.text)
        const description = normalize(rawItem.description)
        const option = normalize(rawItem.option)
        const full = `${text} ${description} ${option}`

        if (full.includes('صندوق')) return 'chests'
        if (full.includes('رخص') || full.includes('محامي') || full.includes('vip') || full.includes('عريف') || full.includes('crown') || full.includes('exam')) return 'licenses'
        if (full.includes('نيوك') || full.includes('عنوان') || full.includes('قنبله') || full.includes('تجميد') || full.includes('بطاطا') || full.includes('نرد') || full.includes('جرأه') || full.includes('الحرامي') || full.includes('لا يكثر')) return 'effects'
        if (rawItem.excludeUsage && !rawItem.excludePurchase) return 'materials'
        if (rawItem.excludePurchase && rawItem.excludeUsage) return 'materials'
        return 'special'
      }

      function getItemIcon(item) {
        const text = normalize(item.text)
        const category = item.category

        if (text.includes('vip')) return '♛'
        if (text.includes('نيوك')) return '☢'
        if (text.includes('عنوان')) return '✎'
        if (text.includes('سمعه')) return '◆'
        if (text.includes('صندوق')) return '▣'
        if (text.includes('محامي') || text.includes('lawyer')) return '⚖'
        if (text.includes('حرامي')) return '🖐'
        if (text.includes('نرد')) return '⚂'
        if (text.includes('قنبله')) return '☁'
        if (text.includes('بطاطا')) return '●'
        if (text.includes('رخص')) return '★'
        if (category === 'materials') return '◇'
        if (category === 'effects') return '✦'
        if (category === 'licenses') return '★'
        return '⬟'
      }

      function enrichItem(item, index) {
        const name = String(item.text || '').trim()
        const category = getItemCategory(item)
        const hashId = slugify(name)
        const command = String(item.option || '').trim()
        const description = String(item.description || '').trim() || 'لا يوجد وصف متاح.'
        const value = Number(item.value || 0)

        const tags = []

        if (!item.excludePurchase) tags.push('purchasable')
        if (!item.excludeUsage) tags.push('usable')
        if (!item.excludeSale) tags.push('sellable')
        if (item.itemLimitEnabled) tags.push('limited')
        tags.push(category)

        const searchText = normalize([
          name,
          description,
          command,
          category,
          CATEGORY_META[category]?.label,
          value,
          item.excludePurchase ? 'not purchasable ممنوع شراء' : 'شراء',
          item.excludeUsage ? 'not usable ممنوع استخدام' : 'استخدام',
          item.excludeSale ? 'not sale ممنوع بيع' : 'بيع',
        ].join(' '))

        return {
          ...item,
          index,
          name,
          hashId,
          category,
          categoryLabel: CATEGORY_META[category]?.label || 'خاص',
          icon: getItemIcon({ ...item, category }),
          description,
          command,
          value,
          tags,
          searchText,
        }
      }

      function getStatusPills(item) {
        const pills = []

        pills.push({ label: item.excludePurchase ? 'غير قابل للشراء' : 'قابل للشراء', type: item.excludePurchase ? 'bad' : 'good' })
        pills.push({ label: item.excludeUsage ? 'غير قابل للاستخدام' : 'قابل للاستخدام', type: item.excludeUsage ? 'bad' : 'good' })
        pills.push({ label: item.excludeSale ? 'غير قابل للبيع' : 'قابل للبيع', type: item.excludeSale ? 'bad' : 'good' })

        if (item.itemLimitEnabled) {
          pills.push({ label: `حد: ${formatNumber(item.itemLimitAmount || 1)}`, type: 'warn' })
        }

        return pills
      }

      function updateStats() {
        const purchasable = state.items.filter((item) => !item.excludePurchase).length

        if (statTotalItems) statTotalItems.textContent = String(state.items.length)
        if (statPurchasableItems) statPurchasableItems.textContent = String(purchasable)
        if (statCraftingRecipes) statCraftingRecipes.textContent = String(state.crafting.length)

        const counts = {
          all: state.items.length,
          purchasable: 0,
          usable: 0,
          sellable: 0,
          limited: 0,
          chests: 0,
          effects: 0,
          materials: 0,
          licenses: 0,
        }

        state.items.forEach((item) => {
          if (!item.excludePurchase) counts.purchasable++
          if (!item.excludeUsage) counts.usable++
          if (!item.excludeSale) counts.sellable++
          if (item.itemLimitEnabled) counts.limited++
          if (counts[item.category] !== undefined) counts[item.category]++
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.itemFilter === state.filter)
        })
      }

      function getFilteredItems() {
        const query = normalize(state.search)

        return state.items.filter((item) => {
          const filterMatch = state.filter === 'all' || item.tags.includes(state.filter)
          const searchMatch = !query || item.searchText.includes(query)
          return filterMatch && searchMatch
        })
      }

      function renderItems() {
        if (!itemsGrid) return

        const items = getFilteredItems()
        itemsEmpty?.classList.toggle('hidden', items.length > 0)

        itemsGrid.innerHTML = items.map((item, renderIndex) => {
          const selected = item.name === state.selectedItemName ? ' is-selected' : ''
          const linked = window.location.hash === `#${item.hashId}` ? ' is-linked' : ''
          const pills = getStatusPills(item).slice(0, 4).map((pill) => `
            <span class="tnx-status-pill is-${esc(pill.type)}">${esc(pill.label)}</span>
          `).join('')

          return `
            <button
              type="button"
              id="${esc(item.hashId)}"
              class="tnx-item-card${selected}${linked}"
              style="--stagger:${renderIndex}"
              data-item-name="${esc(item.name)}"
            >
              <div class="tnx-item-card-top">
                <div class="tnx-item-info">
                  <div class="tnx-item-title-row">
                    <strong>${esc(item.name)}</strong>
                  </div>
                </div>

                <div class="tnx-item-icon">${esc(item.icon)}</div>
              </div>

              <span class="tnx-item-value">القيمة: ${formatNumber(item.value)}</span>

              <p>${esc(item.description)}</p>

              <div class="tnx-item-badges">
                <span class="tnx-status-pill is-warn">${esc(item.categoryLabel)}</span>
                ${pills}
              </div>
            </button>
          `
        }).join('')
      }

      function renderItemFocus(item) {
        if (!itemFocusPanel || !item) return

        const pills = getStatusPills(item).map((pill) => `
          <span class="tnx-status-pill is-${esc(pill.type)}">${esc(pill.label)}</span>
        `).join('')

        const commandText = item.command || 'لا يوجد أمر مباشر'

        itemFocusPanel.innerHTML = `
          <div class="tnx-focus-card">
            <div class="tnx-focus-main-icon">${esc(item.icon)}</div>

            <div>
              <span class="tnx-status-pill is-warn">${esc(item.categoryLabel)}</span>
              <h3>${esc(item.name)}</h3>
            </div>

            <p>${esc(item.description)}</p>

            <div class="tnx-item-badges">
              ${pills}
            </div>

            <div class="tnx-focus-meta">
              <div>
                <span>القيمة</span>
                <strong>${formatNumber(item.value)}</strong>
              </div>

              <div>
                <span>النوع</span>
                <strong>${esc(item.categoryLabel)}</strong>
              </div>

              <div>
                <span>الأمر / الخيار</span>
                <strong>${esc(commandText)}</strong>
              </div>

              <div>
                <span>الحد</span>
                <strong>${item.itemLimitEnabled ? formatNumber(item.itemLimitAmount || 1) : 'لا يوجد'}</strong>
              </div>
            </div>

            <button type="button" class="tnx-focus-copy" data-copy-item-link="${esc(item.hashId)}">
              نسخ رابط الغرض
            </button>
          </div>
        `
      }

      function selectItem(name, options = {}) {
        const item = state.items.find((entry) => entry.name === name)
        if (!item) return

        state.selectedItemName = item.name

        if (options.updateHash !== false) {
          history.replaceState(null, '', `${window.location.pathname}${window.location.search}#${item.hashId}`)
        }

        renderItems()
        renderItemFocus(item)

        if (options.scrollToItem) {
          addTimer(window.setTimeout(() => {
            document.getElementById(item.hashId)?.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }, 80))
        }
      }

      function openItemFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('item-')) return false

        const item = state.items.find((entry) => entry.hashId === hash)
        if (!item) return false

        state.filter = 'all'
        state.search = ''
        if (itemSearch) itemSearch.value = ''

        renderFilterButtons()
        selectItem(item.name, { updateHash: false, scrollToItem: options.scrollToItem !== false })

        document.querySelector('.tnx-vault')?.scrollIntoView({
          behavior: options.instant ? 'auto' : 'smooth',
          block: 'start',
        })

        return true
      }

      function getItemLink(hashId) {
        return `${window.location.origin}${window.location.pathname}${window.location.search}#${hashId}`
      }

      async function copyText(text, button, doneText = 'تم النسخ') {
        const oldText = button.textContent

        try {
          await navigator.clipboard.writeText(text)
          button.textContent = doneText
          button.classList.add('is-copied')

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
            button.classList.remove('is-copied')
          }, 1100))
        } catch {
          button.textContent = text

          addTimer(window.setTimeout(() => {
            button.textContent = oldText
          }, 1400))
        }
      }

      function renderLootTables() {
        if (!lootTablesGrid) return

        const tables = Array.isArray(state.lootTables) ? state.lootTables : []

        if (tables.length === 0) {
          lootTablesGrid.innerHTML = `
            <div class="tnx-empty">
              <strong>ما فيه Loot Tables</strong>
              <span>إذا أضفتها في items.json بتظهر هنا.</span>
            </div>
          `
          return
        }

        lootTablesGrid.innerHTML = tables.map((table, index) => {
          const name = String(table.name || '').trim() || `Loot Table ${index + 1}`
          const rows = Array.isArray(table.items) ? table.items : []

          return `
            <div class="tnx-loot-card">
              <h3>
                <span>${esc(name)}</span>
                <b>▣</b>
              </h3>

              <div class="tnx-loot-list">
                ${rows.map((row) => `
                  <div class="tnx-loot-row">
                    <span>${esc(row.option || 'غير محدد')}</span>
                    <b>${formatNumber(row.value)}%</b>
                  </div>
                `).join('')}
              </div>
            </div>
          `
        }).join('')
      }

      function renderCrafting() {
        if (!craftingGrid) return

        const recipes = Array.isArray(state.crafting) ? state.crafting : []

        if (recipes.length === 0) {
          craftingGrid.innerHTML = `
            <div class="tnx-empty">
              <strong>ما فيه وصفات تصنيع</strong>
              <span>إذا أضفت crafting في items.json بتظهر هنا.</span>
            </div>
          `
          return
        }

        craftingGrid.innerHTML = recipes.map((recipe) => {
          const ingredients = Array.isArray(recipe.ingredients) ? recipe.ingredients : []

          return `
            <div class="tnx-craft-card">
              <h3>
                <span>${esc(recipe.result || 'نتيجة غير محددة')}</span>
                <b>⚒</b>
              </h3>

              <div class="tnx-ingredient-list">
                ${ingredients.map((ingredient) => `
                  <div class="tnx-ingredient-row">
                    <span>${esc(ingredient.item || 'غير محدد')}</span>
                    <b>${formatNumber(ingredient.amount)}x</b>
                  </div>
                `).join('')}
              </div>
            </div>
          `
        }).join('')
      }

      async function loadData() {
        try {
          const res = await fetch('/api/items.json')
          if (!res.ok) throw new Error(`Items request failed: ${res.status}`)

          const data = await res.json()

          state.items = Array.isArray(data.items)
            ? data.items.map(enrichItem).filter((item) => item.name)
            : []

          state.lootTables = Array.isArray(data.lootTables) ? data.lootTables : []
          state.crafting = Array.isArray(data.crafting) ? data.crafting : []

          updateStats()
          renderFilterButtons()
          renderItems()
          renderLootTables()
          renderCrafting()

          const opened = openItemFromHash({ instant: true, scrollToItem: true })
          if (!opened && state.items.length > 0) {
            selectItem(state.items[0].name, { updateHash: false })
          }
        } catch (error) {
          console.error('Failed to load items.json', error)

          if (itemsGrid) {
            itemsGrid.innerHTML = `
              <div class="tnx-empty">
                <strong>تعذر تحميل الأغراض</strong>
                <span>تأكد من وجود الملف في public/api/items.json</span>
              </div>
            `
          }
        }
      }

      function handleBackToTopVisibility() {
        if (!backToTop) return
        backToTop.classList.toggle('is-visible', window.scrollY > 520)
      }

      function setupRevealObserver() {
        const revealEls = Array.from(document.querySelectorAll('.tnx-reveal'))

        if (!('IntersectionObserver' in window)) {
          revealEls.forEach((el) => el.classList.add('is-visible'))
          return
        }

        const observer = addObserver(new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              observer.unobserve(entry.target)
            }
          })
        }, { threshold: 0.14 }))

        revealEls.forEach((el) => observer.observe(el))
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTopVisibility, { passive: true })

      addListener(itemsGrid, 'click', (event) => {
        const card = event.target.closest('[data-item-name]')
        if (!card) return
        selectItem(card.dataset.itemName)
      })

      addListener(document, 'click', (event) => {
        const copyButton = event.target.closest('[data-copy-item-link]')

        if (copyButton) {
          const hashId = copyButton.dataset.copyItemLink || ''
          copyText(getItemLink(hashId), copyButton, 'تم نسخ الرابط')
          return
        }
      })

      addListener(window, 'hashchange', () => {
        openItemFromHash({ scrollToItem: true })
      })

      addListener(itemSearch, 'input', () => {
        state.search = itemSearch.value
        renderItems()
      })

      addListener(clearItemSearch, 'click', () => {
        if (!itemSearch) return
        itemSearch.value = ''
        state.search = ''
        itemSearch.focus()
        renderItems()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.itemFilter || 'all'
          renderFilterButtons()
          renderItems()
        })
      })

      guideButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.guideFilter || 'all'
          state.search = ''
          if (itemSearch) itemSearch.value = ''

          renderFilterButtons()
          renderItems()

          document.querySelector('.tnx-vault')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      })

      setupRevealObserver()
      await loadData()
      handleBackToTopVisibility()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
</Layout>
