---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Items — TNX6',
  ignoreTitleTemplate: true,
  description: 'قائمة الأغراض والصياغة في مجتمع TNX6.',
};

// تم نقل البيانات إلى الـ Frontmatter لكي يتم معالجتها برمجياً وبناء الصفحة بشكل تلقائي
const data = {
  items: [
    { text: "Vip", value: 10000, description: "تاخذ Vip لمدة 7أيام", option: "vip 7d", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "Vip+", value: 25000, description: "تاخذ Vip لمدة 30يوم", option: "vip 30d", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "سمعة", value: 1, description: "عملة من اجل التطوير", option: "", excludeSale: true, excludePurchase: true, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "نيوك", value: 500000, description: "تقفل البث ومانبث الا بكرا", option: "نيوك", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "تغير العنوان", value: 1500, description: "تخرب العنوان لمدة خمس دقايق", option: "تخريب العنوان", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "تغير العنوان مطور", value: 50000, description: "تخرب العنوان وتحط العنوان اللي تبيه", option: "تخريب العنوان مطور واحد", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "اقول لا يكثر", value: 250000, description: "تكنسل اي رهان قائم", option: "بطاقة اقول لا يكثر", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "يد الحرامي", value: 15000, description: "تسرق من احد نقاط", option: "يد الحرامي", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "محامي", value: 180000, description: "تاخذ رتبة محامي", option: "محامي", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "عملة الجرأة", value: 1000, description: "تحدى حظك ياتفوز بنقاط او تاكل تايم اوت", option: "عملة الجرأة", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "تجميد الشاشة", value: 500, description: "تجمد الشاشة", option: "تجميد الشاشة", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "رمي النرد", value: 1000, description: "جرب حظك", option: "رمي النرد", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "قنبلة دخانية", value: 500, description: "تحذف الشات", option: "قنبلة دخانية", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "عريف الفصل", value: 30000, description: "تكون مود لمدة", option: "عريف الفصل", excludeSale: false, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "صندوق", value: 0, description: "يجيك غرض عادي عشوائي", option: "صندوق", excludeSale: true, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "صندوق نادر", value: 0, description: "يجيك غرض نادر", option: "صندوق نادر", excludeSale: true, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "صندوق النقاط", value: 0, description: "يجيك مبلغ عشوائي", option: "صندوق نقاط", excludeSale: true, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "صندوق السمعة", value: 0, description: "يجيك نقاط سمعة عشوائي", option: "صندوق سمعة", excludeSale: true, excludePurchase: true, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "علف", value: 60, description: "علف حيوانات أساسي.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "خشب", value: 60, description: "مادة تصنيع مفيدة.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "صنارة صيد", value: 2000, description: "Allows fishing.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "طعم صيد", value: 60, description: "تُستخدم للصيد.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "سمكة", value: 125, description: "سمك طازج مُصاد.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "طماط", value: 60, description: "محصول مزرعة طازج.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "يقطين", value: 60, description: "خضار موسمية كبيرة.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "بصل", value: 60, description: "خضار ذو رائحة قوية.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "حليب", value: 125, description: "حليب بقري طازج.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "مرق خضار", value: 350, description: "مرق خضار لذيذة.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "مرق سمك", value: 500, description: "ممم… ريحته سمك!", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "بقرة", value: 5000, description: "تنتج الحليب.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "فأس", value: 4500, description: "يُستخدم لقطع الحطب.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "رخصة الطبخ", value: 25000, description: "Let him cook!", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "Lawyer's Exam", value: 100000, description: "Proof of legal qualification.", option: "", excludeSale: true, excludePurchase: true, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "رخصة مصرفي", value: 200000, description: "يمنح صلاحيات مصرفية.", option: "", excludeSale: true, excludePurchase: true, excludeUsage: true, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "مطرقة ذهبية", value: 150000, description: "أداة أسطورية نادرة.", option: "", excludeSale: true, excludePurchase: true, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "Crown", value: 1000000, description: "Symbol of ultimate authority.", option: "", excludeSale: true, excludePurchase: true, excludeUsage: true, itemLimitEnabled: false, itemLimitAmount: 1 },
    { text: "رخصة التجارة", value: 200000, description: "تصريح بالمشاركة في المبيعات الاحترافية.", option: "", excludeSale: false, excludePurchase: false, excludeUsage: true, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "البريد", value: 10000, description: "بريد خاص فيك لأستقبال الرسائل من اشخاص اخرين", option: "Mailbox - Activate", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: true, itemLimitAmount: 1 },
    { text: "البطاطا الحارة", value: 1500, description: "لعبة بسيطة لازم تعطي شخص ثاني البطاطا الحارة قبل تنفجر فيك", option: "البطاطا الحارة", excludeSale: false, excludePurchase: false, excludeUsage: false, itemLimitEnabled: false, itemLimitAmount: 1 }
  ],
  crafting: [
    { ingredients: [{ item: "Vip", amount: 1 }, { item: "سمعة", amount: 50 }], result: "Vip+" },
    { ingredients: [{ item: "سمعة", amount: 1500 }], result: "نيوك" },
    { ingredients: [{ item: "تغير العنوان", amount: 1 }, { item: "سمعة", amount: 100 }], result: "تغير العنوان مطور" },
    { ingredients: [{ item: "Vip+", amount: 1 }, { item: "سمعة", amount: 250 }], result: "عريف الفصل" },
    { ingredients: [{ item: "صندوق", amount: 1 }, { item: "سمعة", amount: 30 }], result: "صندوق نادر" },
    { ingredients: [{ item: "سمعة", amount: 1000 }], result: "اقول لا يكثر" }
  ]
};
---

<Layout metadata={metadata}>
  <main class="relative min-h-screen bg-[#07050b] overflow-hidden" dir="rtl">
    <!-- خلفيات الصفحة -->
    <div class="fixed inset-0 pointer-events-none z-0 bg-[radial-gradient(circle_at_12%_9%,rgba(255,218,106,0.12),transparent_28%),radial-gradient(circle_at_86%_14%,rgba(194,146,0,0.1),transparent_34%),linear-gradient(135deg,#07050b_0%,#050507_55%,#130c05_100%)]"></div>
    <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.05] bg-[linear-gradient(rgba(255,218,106,0.4)_1px,transparent_1px),linear-gradient(90deg,rgba(255,218,106,0.4)_1px,transparent_1px)] bg-[size:58px_58px] [mask-image:radial-gradient(circle_at_center,black_0%,transparent_74%)]"></div>

    <section class="relative z-10 max-w-7xl mx-auto py-20 px-4 sm:px-6 font-[Poppins] text-white">

      <!-- HEADER -->
      <header class="text-center mb-20">
        <div class="inline-flex items-center gap-2 border border-[#ffda6a]/30 rounded-full bg-black/40 text-[#ffda6a] px-4 py-2 text-sm font-bold tracking-[0.15em] uppercase mb-6 shadow-[0_0_15px_rgba(255,218,106,0.1)]">
          <span class="w-2 h-2 rounded-full bg-[#ffda6a] shadow-[0_0_10px_#ffda6a] animate-pulse"></span>
          TNX ITEMS VAULT
        </div>
        <h1 class="text-5xl md:text-7xl font-black bg-gradient-to-r from-[#fff1a8] via-[#ffda6a] to-[#c29200] bg-clip-text text-transparent drop-shadow-sm tracking-tight mb-6">
          خزنة الأغراض
        </h1>
        <p class="max-w-2xl mx-auto text-gray-400 text-lg font-medium">
          استكشف جميع الأغراض المتاحة في النظام، أسعارها، استخداماتها، وكيفية دمجها وصناعتها للحصول على أدوات أندر.
        </p>
      </header>

      <!-- SECTION: ITEMS -->
      <div class="mb-32">
        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="h-[1px] flex-grow bg-gradient-to-r from-transparent to-[#ffda6a]/30 max-w-[200px]"></div>
          <h2 class="text-3xl font-black text-[#f7e6ac] tracking-wide">قائمة الأغراض المتاحة</h2>
          <div class="h-[1px] flex-grow bg-gradient-to-l from-transparent to-[#ffda6a]/30 max-w-[200px]"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {data.items.map((item) => (
            <div class="group relative flex flex-col h-full bg-[#0d0a14]/80 backdrop-blur-xl border border-[#ffda6a]/10 rounded-2xl p-6 transition-all duration-300 hover:border-[#ffda6a]/40 hover:-translate-y-1 hover:shadow-[0_15px_40px_rgba(0,0,0,0.4),0_0_20px_rgba(255,218,106,0.05)]">
              
              <div class="flex justify-between items-start mb-4 gap-4">
                <h3 class="text-xl font-bold text-white group-hover:text-[#ffda6a] transition-colors">{item.text}</h3>
                <div class="shrink-0 bg-[#c29200]/10 text-[#ffda6a] text-sm font-black px-3 py-1.5 rounded-lg border border-[#c29200]/30 shadow-inner flex items-center gap-1.5">
                  {item.value.toLocaleString()} <span class="text-lg">🪙</span>
                </div>
              </div>
              
              <p class="text-gray-400 text-sm font-medium leading-relaxed flex-grow mb-6">
                {item.description}
              </p>

              <div class="mt-auto space-y-4">
                {item.option && item.option !== "Type to filter options..." && (
                  <div class="bg-black/40 border border-white/5 rounded-lg p-3">
                    <span class="block text-[11px] text-gray-500 font-bold mb-1">الأمر البرمجي:</span>
                    <code class="text-[#ffda6a] text-sm font-mono">{item.option}</code>
                  </div>
                )}
                
                <div class="flex flex-wrap gap-2">
                  {item.excludeSale && <span class="text-[11px] font-bold px-2.5 py-1 rounded bg-red-500/10 text-red-400 border border-red-500/20">لا يباع</span>}
                  {item.excludePurchase && <span class="text-[11px] font-bold px-2.5 py-1 rounded bg-orange-500/10 text-orange-400 border border-orange-500/20">لا يشترى</span>}
                  {item.excludeUsage && <span class="text-[11px] font-bold px-2.5 py-1 rounded bg-gray-500/10 text-gray-400 border border-gray-500/20">لا يستخدم مباشرة</span>}
                  {item.itemLimitEnabled && <span class="text-[11px] font-bold px-2.5 py-1 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">الحد الأقصى: {item.itemLimitAmount}</span>}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- SECTION: CRAFTING -->
      <div class="mb-20">
        <div class="flex items-center justify-center gap-4 mb-12">
          <div class="h-[1px] flex-grow bg-gradient-to-r from-transparent to-[#ffda6a]/30 max-w-[200px]"></div>
          <h2 class="text-3xl font-black text-[#f7e6ac] tracking-wide">وصفات الدمج (Crafting)</h2>
          <div class="h-[1px] flex-grow bg-gradient-to-l from-transparent to-[#ffda6a]/30 max-w-[200px]"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {data.crafting.map((recipe) => (
            <div class="flex flex-col sm:flex-row items-center gap-4 bg-[#0d0a14]/80 backdrop-blur-xl border border-[#ffda6a]/15 rounded-2xl p-6 transition-all hover:border-[#ffda6a]/40 hover:bg-[#130f1c]/90">
              
              <!-- المكونات -->
              <div class="flex flex-wrap items-center justify-center sm:justify-start gap-3 flex-grow">
                {recipe.ingredients.map((ing, idx) => (
                  <div class="flex items-center gap-3">
                    <div class="flex items-center gap-2 bg-black/40 border border-white/10 px-3 py-2 rounded-lg">
                      <span class="text-white font-bold text-sm">{ing.item}</span>
                      <span class="bg-[#ffda6a]/20 text-[#ffda6a] text-xs font-black px-1.5 py-0.5 rounded">x{ing.amount}</span>
                    </div>
                    {idx < recipe.ingredients.length - 1 && (
                      <span class="text-gray-500 font-bold text-lg">+</span>
                    )}
                  </div>
                ))}
              </div>

              <!-- السهم -->
              <div class="text-[#ffda6a] opacity-50 rotate-90 sm:rotate-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>

              <!-- النتيجة -->
              <div class="bg-[linear-gradient(135deg,rgba(255,218,106,0.15),rgba(194,146,0,0.05))] border border-[#ffda6a]/40 px-5 py-3 rounded-xl min-w-[140px] text-center shadow-[0_0_15px_rgba(255,218,106,0.1)]">
                <span class="block text-xs text-[#ffda6a] font-bold mb-1 opacity-80">النتيجة</span>
                <strong class="text-white text-lg">{recipe.result}</strong>
              </div>

            </div>
          ))}
        </div>
      </div>

    </section>
  </main>
</Layout>
