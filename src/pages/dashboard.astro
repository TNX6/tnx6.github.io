---
import PageLayout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'حسابي | TNX6',
  description: 'لوحة حساب TNX6 للمشاهد.',
};
---

<PageLayout metadata={metadata}>
  <section class="relative isolate min-h-[86vh] overflow-hidden px-4 py-12 text-white">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute right-0 top-16 h-96 w-96 rounded-full bg-yellow-400/15 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-purple-700/15 blur-3xl"></div>
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-yellow-300/40 to-transparent"></div>
    </div>

    <div class="mx-auto max-w-7xl">
      <div id="loadingState" class="grid min-h-[62vh] place-items-center">
        <div class="w-full max-w-md rounded-[2rem] border border-yellow-300/20 bg-black/55 p-8 text-center shadow-2xl shadow-black/40 backdrop-blur-xl">
          <div class="mx-auto mb-5 h-12 w-12 animate-spin rounded-full border-4 border-white/15 border-t-yellow-300"></div>
          <h1 class="text-2xl font-black">جاري التحقق</h1>
          <p class="mt-2 text-sm text-white/50">نشيك على جلسة تسجيل الدخول...</p>
        </div>
      </div>

      <div id="guestState" class="hidden">
        <div class="mx-auto max-w-4xl rounded-[2.25rem] border border-red-400/20 bg-black/60 p-8 text-right shadow-2xl shadow-black/40 backdrop-blur-xl md:p-12">
          <div class="mb-6 inline-flex rounded-full border border-red-400/25 bg-red-500/10 px-4 py-2 text-sm font-bold text-red-100">
            غير مسجل دخول
          </div>

          <h1 class="text-5xl font-black leading-tight md:text-6xl">
            لوحة الحساب تحتاج
            <span class="text-yellow-300">تسجيل دخول</span>
          </h1>

          <p class="mt-5 max-w-2xl text-lg leading-9 text-white/60">
            سجّل بحساب Twitch عشان نقدر نعرض حسابك ونجهز لك الأغراض والبادجات لاحقًا.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row-reverse sm:justify-end">
            <a
              href="https://tnx6-api.ddxdx240.workers.dev/auth/twitch/login"
              class="inline-flex items-center justify-center rounded-3xl bg-[#9146FF] px-7 py-4 font-black text-white transition hover:-translate-y-0.5 hover:bg-[#7b36dd]"
            >
              تسجيل الدخول عبر Twitch
            </a>

            <a
              href="/"
              class="inline-flex items-center justify-center rounded-3xl border border-white/10 bg-white/5 px-7 py-4 font-bold text-white/75 transition hover:bg-white/10 hover:text-white"
            >
              الرئيسية
            </a>
          </div>
        </div>
      </div>

      <div id="dashboardState" class="hidden space-y-6">
        <div class="grid gap-6 lg:grid-cols-[390px_1fr]">
          <aside class="rounded-[2.25rem] border border-yellow-300/20 bg-black/60 p-6 shadow-2xl shadow-black/35 backdrop-blur-xl">
            <div class="text-right">
              <div class="mb-6 flex items-center justify-between border-b border-white/10 pb-5">
                <span class="rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-black text-emerald-200">
                  Online
                </span>
                <p class="text-sm font-bold text-white/40">حساب TNX6</p>
              </div>

              <div class="flex flex-col items-center text-center">
                <div class="relative">
                  <div class="absolute -inset-2 rounded-[2rem] bg-gradient-to-br from-yellow-300/35 to-purple-600/20 blur-lg"></div>
                  <img
                    id="profileImage"
                    src=""
                    alt=""
                    class="relative h-32 w-32 rounded-[2rem] border border-yellow-200/30 bg-white/10 object-cover shadow-xl"
                  />
                </div>

                <h1 id="displayName" class="mt-6 text-4xl font-black">...</h1>
                <p id="loginName" class="mt-2 text-sm font-bold text-yellow-200"></p>
              </div>

              <div class="mt-7 space-y-3">
                <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-xs text-white/35">Twitch ID</p>
                  <p id="twitchId" class="mt-1 break-all text-sm font-bold text-white/80"></p>
                </div>

                <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-xs text-white/35">حالة الربط</p>
                  <p class="mt-1 text-sm font-bold text-emerald-200">مربوط بالـ Backend</p>
                </div>
              </div>

              <div class="mt-7 grid gap-3">
                <a
                  href="/"
                  class="rounded-3xl border border-white/10 bg-white/5 px-5 py-3 text-center font-bold text-white/75 transition hover:bg-white/10 hover:text-white"
                >
                  الرئيسية
                </a>

                <button
                  id="logoutButton"
                  type="button"
                  class="rounded-3xl border border-red-400/25 bg-red-500/10 px-5 py-3 text-center font-black text-red-100 transition hover:bg-red-500/20"
                >
                  تسجيل الخروج
                </button>
              </div>
            </div>
          </aside>

          <main class="space-y-6">
            <div class="rounded-[2.25rem] border border-white/10 bg-black/55 p-6 shadow-2xl shadow-black/35 backdrop-blur-xl md:p-8">
              <div class="flex flex-col gap-6 text-right md:flex-row-reverse md:items-end md:justify-between">
                <div>
                  <div class="mb-4 inline-flex rounded-full border border-yellow-300/25 bg-yellow-300/10 px-4 py-2 text-sm font-bold text-yellow-100">
                    Dashboard
                  </div>

                  <h2 class="text-4xl font-black leading-tight md:text-5xl">
                    لوحة تحكم المشاهد
                  </h2>

                  <p class="mt-4 max-w-2xl text-base leading-8 text-white/55">
                    هذه الصفحة أساس النظام. الآن الدخول شغال. المرحلة الجاية نربط الأغراض والبادجات بدون ما نفتح ثغرات في البيع أو المقايضة.
                  </p>
                </div>

                <div class="grid grid-cols-3 gap-3 text-center">
                  <div class="rounded-3xl border border-yellow-300/15 bg-yellow-300/[0.06] px-5 py-4">
                    <p class="text-2xl font-black text-yellow-200">0</p>
                    <p class="mt-1 text-xs text-white/40">أغراض</p>
                  </div>

                  <div class="rounded-3xl border border-yellow-300/15 bg-yellow-300/[0.06] px-5 py-4">
                    <p class="text-2xl font-black text-yellow-200">0</p>
                    <p class="mt-1 text-xs text-white/40">بادجات</p>
                  </div>

                  <div class="rounded-3xl border border-yellow-300/15 bg-yellow-300/[0.06] px-5 py-4">
                    <p class="text-2xl font-black text-yellow-200">0</p>
                    <p class="mt-1 text-xs text-white/40">مقايضات</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="grid gap-5 md:grid-cols-3">
              <div class="group rounded-[2rem] border border-white/10 bg-black/50 p-6 text-right backdrop-blur-xl transition hover:-translate-y-1 hover:border-yellow-300/25 hover:bg-black/60">
                <div class="mb-5 flex items-center justify-between">
                  <span class="rounded-full bg-yellow-300/10 px-3 py-1 text-xs font-black text-yellow-200">المرحلة 2</span>
                  <div class="grid h-12 w-12 place-items-center rounded-2xl bg-white/10 text-xl">🎒</div>
                </div>
                <h3 class="text-2xl font-black">الأغراض</h3>
                <p class="mt-3 min-h-[84px] leading-7 text-white/50">
                  عرض أغراضك من نظام TNX6. بالبداية عرض فقط، ثم نضيف البيع بعد التحقق.
                </p>
                <button disabled class="mt-5 w-full cursor-not-allowed rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white/35">
                  قريبًا
                </button>
              </div>

              <div class="group rounded-[2rem] border border-white/10 bg-black/50 p-6 text-right backdrop-blur-xl transition hover:-translate-y-1 hover:border-yellow-300/25 hover:bg-black/60">
                <div class="mb-5 flex items-center justify-between">
                  <span class="rounded-full bg-yellow-300/10 px-3 py-1 text-xs font-black text-yellow-200">المرحلة 3</span>
                  <div class="grid h-12 w-12 place-items-center rounded-2xl bg-white/10 text-xl">🏅</div>
                </div>
                <h3 class="text-2xl font-black">تثبيت البادجات</h3>
                <p class="mt-3 min-h-[84px] leading-7 text-white/50">
                  تختار البادجات اللي تبيها تظهر في بروفايلك، والنظام يحفظها تلقائيًا.
                </p>
                <button disabled class="mt-5 w-full cursor-not-allowed rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white/35">
                  قريبًا
                </button>
              </div>

              <div class="group rounded-[2rem] border border-white/10 bg-black/50 p-6 text-right backdrop-blur-xl transition hover:-translate-y-1 hover:border-yellow-300/25 hover:bg-black/60">
                <div class="mb-5 flex items-center justify-between">
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-black text-white/45">المرحلة 5</span>
                  <div class="grid h-12 w-12 place-items-center rounded-2xl bg-white/10 text-xl">🔁</div>
                </div>
                <h3 class="text-2xl font-black">المقايضة</h3>
                <p class="mt-3 min-h-[84px] leading-7 text-white/50">
                  نظام تبادل بين المشاهدين، لكن ما نفعله إلا بعد ما نضبط الحماية كاملة.
                </p>
                <button disabled class="mt-5 w-full cursor-not-allowed rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-bold text-white/35">
                  لاحقًا
                </button>
              </div>
            </div>

            <div class="rounded-[2rem] border border-yellow-300/15 bg-gradient-to-l from-yellow-300/10 to-transparent p-6 text-right backdrop-blur-xl">
              <div class="flex flex-col gap-4 md:flex-row-reverse md:items-center md:justify-between">
                <div>
                  <h3 class="text-2xl font-black text-yellow-100">النظام في وضع التأسيس</h3>
                  <p class="mt-2 leading-7 text-white/55">
                    ما فيه أي تعديل على أغراضك الآن. كل شيء متعلق بالاقتصاد بنفعله بعد التحقق والسجلات.
                  </p>
                </div>

                <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-5 py-3 text-sm font-black text-emerald-100">
                  Login System Active
                </div>
              </div>
            </div>
          </main>
        </div>
      </div>
    </div>

    <script is:inline data-reinit>
      (() => {
        const API_BASE = 'https://tnx6-api.ddxdx240.workers.dev';

        const loadingState = document.getElementById('loadingState');
        const guestState = document.getElementById('guestState');
        const dashboardState = document.getElementById('dashboardState');

        const profileImage = document.getElementById('profileImage');
        const displayName = document.getElementById('displayName');
        const loginName = document.getElementById('loginName');
        const twitchId = document.getElementById('twitchId');
        const logoutButton = document.getElementById('logoutButton');

        function show(el) {
          if (el) el.classList.remove('hidden');
        }

        function hide(el) {
          if (el) el.classList.add('hidden');
        }

        async function loadMe() {
          try {
            const response = await fetch(`${API_BASE}/api/me`, {
              method: 'GET',
              credentials: 'include',
            });

            const data = await response.json().catch(() => null);

            hide(loadingState);

            if (!response.ok || !data || !data.authenticated || !data.user) {
              show(guestState);
              return;
            }

            const user = data.user;

            if (profileImage) {
              profileImage.src = user.profileImageUrl || '';
              profileImage.alt = user.displayName || user.login || 'Twitch user';
            }

            if (displayName) displayName.textContent = user.displayName || user.login || 'مستخدم Twitch';
            if (loginName) loginName.textContent = `@${user.login}`;
            if (twitchId) twitchId.textContent = user.twitchId;

            show(dashboardState);
          } catch (error) {
            hide(loadingState);
            show(guestState);
          }
        }

        if (logoutButton) {
          logoutButton.addEventListener('click', async () => {
            logoutButton.disabled = true;
            logoutButton.textContent = 'جاري تسجيل الخروج...';

            try {
              await fetch(`${API_BASE}/auth/logout`, {
                method: 'POST',
                credentials: 'include',
              });
            } catch (error) {}

            window.location.href = '/login?logout=success';
          });
        }

        loadMe();
      })();
    </script>
  </section>
</PageLayout>
