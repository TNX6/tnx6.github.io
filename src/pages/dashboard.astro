---
import PageLayout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'تحويل إلى البروفايل | TNX6',
  description: 'يتم تحويلك إلى صفحة البروفايل.',
};
---

<PageLayout metadata={metadata}>
  <section class="min-h-[70vh] px-4 py-24 text-center text-white">
    <div class="mx-auto max-w-xl rounded-[2rem] border border-yellow-300/20 bg-black/60 p-8 shadow-2xl shadow-black/40 backdrop-blur">
      <h1 class="text-3xl font-black text-yellow-100">يتم تحويلك إلى البروفايل</h1>
      <p class="mt-3 text-white/60">صفحة الحساب الرئيسية صارت /profile بدل /dashboard.</p>
      <a href="/profile" class="mt-6 inline-flex rounded-2xl bg-yellow-300 px-6 py-3 font-black text-black">
        فتح البروفايل
      </a>
    </div>

    <script is:inline>
      const target = '/profile' + window.location.search
      window.location.replace(target)
    </script>
  </section>
</PageLayout>
