---
import Layout from '~/layouts/Layout.astro';

const metadata = {
  title: 'تسجيل الدخول | TNX6',
  description: 'تسجيل الدخول إلى حساب TNX6 عبر Twitch.',
};
---

<Layout metadata={metadata}>
  <main class="tnx-login-page" dir="rtl">
    <section class="login-card" aria-labelledby="loginTitle">
      <div class="login-brand" aria-label="TNX6">
        <span class="login-brand-mark">TNX6</span>
      </div>

      <div class="login-copy">
        <h1 id="loginTitle">تسجيل الدخول</h1>
        <p>استخدم حساب Twitch للوصول إلى بروفايلك ومزايا حسابك داخل TNX6.</p>
      </div>

      <div id="loginNotice" class="login-notice" hidden role="status" aria-live="polite"></div>

      <a
        class="twitch-login-button"
        href="https://api.tnx6.xyz/auth/twitch/login"
        aria-label="تسجيل الدخول عبر Twitch"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M4.75 3 3.5 6.5v13h4.5V22h2.5l2.5-2.5h3.75L21 15.25V3H4.75Zm14.5 11.5-2.5 2.5h-4.25L10 19.5V17H6V4.75h13.25V14.5ZM16.75 8v4.25H15V8h1.75Zm-4.75 0v4.25h-1.75V8H12Z"
          />
        </svg>
        <span>تسجيل الدخول عبر Twitch</span>
      </a>

      <p class="login-privacy">نستخدم حساب Twitch للتحقق من هويتك فقط، ولا نطلب كلمة المرور الخاصة بك.</p>

      <a class="login-home-link" href="/">الرجوع إلى الرئيسية</a>
    </section>
  </main>

  <style is:global>
    .tnx-login-page {
      min-height: 100vh;
      padding: 32px 16px;
      display: grid;
      place-items: center;
      color: #f7f1df;
      background:
        radial-gradient(circle at 50% 10%, rgba(201, 168, 76, .13), transparent 34%),
        linear-gradient(180deg, rgba(4, 4, 7, .92), rgba(7, 7, 10, .98));
      direction: rtl;
    }

    .tnx-login-page *,
    .tnx-login-page *::before,
    .tnx-login-page *::after {
      box-sizing: border-box;
    }

    .tnx-login-page .login-card {
      width: min(500px, calc(100% - 24px));
      border: 1px solid rgba(201, 168, 76, .22);
      border-radius: 28px;
      background: rgba(11, 11, 15, .88);
      box-shadow: 0 24px 70px rgba(0, 0, 0, .42);
      padding: 34px;
      display: grid;
      gap: 22px;
      text-align: center;
      backdrop-filter: blur(18px);
    }

    .tnx-login-page .login-brand {
      display: flex;
      justify-content: center;
    }

    .tnx-login-page .login-brand-mark {
      min-height: 34px;
      padding: 0 14px;
      border: 1px solid rgba(201, 168, 76, .26);
      border-radius: 999px;
      background: rgba(201, 168, 76, .09);
      color: #dfc06a;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 1000;
      letter-spacing: .04em;
    }

    .tnx-login-page .login-copy {
      display: grid;
      gap: 10px;
    }

    .tnx-login-page h1 {
      margin: 0;
      color: #fff7da;
      font-size: clamp(30px, 6vw, 42px);
      line-height: 1.15;
      font-weight: 1000;
      letter-spacing: 0;
    }

    .tnx-login-page .login-copy p {
      margin: 0 auto;
      max-width: 390px;
      color: rgba(255, 255, 255, .68);
      font-size: 15px;
      line-height: 1.9;
      font-weight: 800;
    }

    .tnx-login-page .login-notice {
      border-radius: 16px;
      padding: 12px 14px;
      font-size: 14px;
      line-height: 1.7;
      font-weight: 850;
      text-align: center;
    }

    .tnx-login-page .login-notice[hidden] {
      display: none !important;
    }

    .tnx-login-page .login-notice.is-error {
      border: 1px solid rgba(239, 68, 68, .22);
      background: rgba(239, 68, 68, .10);
      color: #fecaca;
    }

    .tnx-login-page .login-notice.is-success {
      border: 1px solid rgba(34, 197, 94, .22);
      background: rgba(34, 197, 94, .10);
      color: #bbf7d0;
    }

    .tnx-login-page .twitch-login-button {
      width: 100%;
      min-height: 54px;
      border: 1px solid #a970ff;
      border-radius: 18px;
      background: #9146ff;
      color: #fff;
      box-shadow: 0 0 18px rgba(145, 70, 255, .25);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 0 20px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 1000;
      transition: transform .18s ease, background-color .18s ease, box-shadow .18s ease;
    }

    .tnx-login-page .twitch-login-button:hover {
      background: #772ce8;
      box-shadow: 0 0 22px rgba(145, 70, 255, .38);
      transform: translateY(-1px);
    }

    .tnx-login-page .twitch-login-button:focus-visible,
    .tnx-login-page .login-home-link:focus-visible {
      outline: 2px solid #a970ff;
      outline-offset: 3px;
    }

    .tnx-login-page .twitch-login-button svg {
      width: 24px;
      height: 24px;
      flex: 0 0 auto;
    }

    .tnx-login-page .login-privacy {
      margin: -2px auto 0;
      max-width: 390px;
      color: rgba(255, 255, 255, .56);
      font-size: 13px;
      line-height: 1.8;
      font-weight: 750;
    }

    .tnx-login-page .login-home-link {
      width: fit-content;
      margin: 0 auto;
      color: #dfc06a;
      text-decoration: none;
      font-size: 14px;
      font-weight: 900;
      transition: color .18s ease;
    }

    .tnx-login-page .login-home-link:hover {
      color: #fff0b8;
    }

    @media (max-width: 520px) {
      .tnx-login-page {
        padding: 24px 0;
      }

      .tnx-login-page .login-card {
        width: calc(100% - 24px);
        padding: 26px 18px;
        border-radius: 22px;
        gap: 20px;
      }

      .tnx-login-page .login-copy p,
      .tnx-login-page .login-privacy {
        max-width: 100%;
      }
    }
  </style>

  <script is:inline data-reinit>
    (() => {
      const notice = document.getElementById('loginNotice');
      if (!notice) return;

      const params = new URLSearchParams(window.location.search);
      const error = params.get('error');
      const logout = params.get('logout');
      const code = (...chars) => String.fromCharCode(...chars);

      const retryErrors = new Set([
        code(109, 105, 115, 115, 105, 110, 103, 95, 99, 111, 100, 101),
        code(109, 105, 115, 115, 105, 110, 103, 95, 115, 116, 97, 116, 101),
        code(105, 110, 118, 97, 108, 105, 100, 95, 115, 116, 97, 116, 101),
        code(98, 97, 100, 95, 115, 116, 97, 116, 101, 95, 115, 105, 103, 110, 97, 116, 117, 114, 101),
      ]);
      const unavailableErrors = new Set([
        code(116, 111, 107, 101, 110, 95, 102, 97, 105, 108, 101, 100),
        code(117, 115, 101, 114, 95, 102, 97, 105, 108, 101, 100),
        code(100, 98, 95, 117, 115, 101, 114, 95, 102, 97, 105, 108, 101, 100),
      ]);

      if (logout === 'success') {
        notice.className = 'login-notice is-success';
        notice.textContent = 'تم تسجيل الخروج بنجاح.';
        notice.hidden = false;
        return;
      }

      if (error) {
        notice.className = 'login-notice is-error';
        if (error === code(116, 119, 105, 116, 99, 104, 95, 100, 101, 110, 105, 101, 100)) {
          notice.textContent = 'تم إلغاء تسجيل الدخول.';
        } else if (retryErrors.has(error)) {
          notice.textContent = 'انتهت محاولة تسجيل الدخول. حاول مرة أخرى.';
        } else if (unavailableErrors.has(error)) {
          notice.textContent = 'تعذر تسجيل الدخول حاليًا. حاول مرة أخرى بعد قليل.';
        } else {
          notice.textContent = 'حدث خطأ أثناء تسجيل الدخول. حاول مرة أخرى.';
        }
        notice.hidden = false;
      }
    })();
  </script>
</Layout>
