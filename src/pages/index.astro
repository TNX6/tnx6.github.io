---
import Layout from '~/layouts/PageLayout.astro'
import fs from 'node:fs'
import path from 'node:path'

const metadata = {
  title: 'TNX6 — Streamer Hub',
  ignoreTitleTemplate: true,
  description:
    'موقع TNX6 الرسمي: البث، جدول البث، الأوامر، الترتيب، الأغراض، البدجات، الرسمات، والفائزين.',
}

const fanArtDir = path.join(process.cwd(), 'public', 'FANART')

const fanArtImages = fs.existsSync(fanArtDir)
  ? fs
      .readdirSync(fanArtDir)
      .filter((file) => /\.(png|jpe?g|webp|gif)$/i.test(file))
      .map((file) => `/FANART/${file}`)
  : []

const twitchStatusUrl = 'https://tnx6-twitch-status.ddxdx240.workers.dev'
const socialStatsUrl = 'https://tnx6-social-stats.ddxdx240.workers.dev/stats'

const streamConfig = {
  startHour: 21,
  startMinute: 0,
  endHour: 2,
  days: [6, 0, 2, 3],
}

const scheduleItems = [
  {
    day: 6,
    name: 'السبت',
    time: '9:00 م',
    description: 'لعب وسوالف',
  },
  {
    day: 0,
    name: 'الأحد',
    time: '9:00 م',
    description: 'لعب وسوالف',
  },
  {
    day: 2,
    name: 'الثلاثاء',
    time: '9:00 م',
    description: 'لعب وسوالف',
  },
  {
    day: 3,
    name: 'الأربعاء',
    time: '9:00 م',
    description: 'لعب وسوالف',
  },
]

const shortcutCards = [
  {
    title: 'الترتيب',
    label: 'مين متصدر؟',
    description: 'النقاط، الذهب، والمشاهدة.',
    href: '/leaderboards',
    icon: 'tabler:trophy',
  },
  {
    title: 'الأغراض',
    label: 'وش أغراضك؟',
    description: 'الصناديق وأغراض المجتمع.',
    href: '/items',
    icon: 'tabler:backpack',
  },
  {
    title: 'البدجات',
    label: 'إنجازاتك',
    description: 'الشارات والبدجات النادرة.',
    href: '/badges',
    icon: 'tabler:badge',
  },
  {
    title: 'الرسمات',
    label: 'فن المجتمع',
    description: 'رسمات ومشاركات المتابعين.',
    href: '/fan-art',
    icon: 'tabler:photo',
  },
]

const socialLinks = [
  {
    href: 'https://www.twitch.tv/tnx_6',
    label: 'Twitch',
    icon: 'tabler:brand-twitch',
  },
  {
    href: 'https://kick.com/tnx6',
    label: 'Kick',
    icon: 'tabler:letter-k',
  },
  {
    href: 'https://www.youtube.com/@TNX66',
    label: 'YouTube',
    icon: 'tabler:brand-youtube',
  },
  {
    href: 'https://www.tiktok.com/@itstnx',
    label: 'TikTok',
    icon: 'tabler:brand-tiktok',
  },
  {
    href: 'https://discord.gg/x7FtrfM6Sk',
    label: 'Discord',
    icon: 'tabler:brand-discord',
  },
]
---

<Layout metadata={metadata}>
  <main class="relative min-h-screen overflow-hidden bg-[#08050d] text-white">
    <div class="tnx-page-bg pointer-events-none fixed inset-0 z-0"></div>
    <div class="tnx-page-grid pointer-events-none fixed inset-0 z-0"></div>

    <section class="relative z-10 px-4 pb-10 pt-20 md:px-6 md:pb-14 md:pt-24">
      <div
        class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-[#c29200]/25 bg-[#050505]/88 shadow-[0_0_55px_rgba(0,0,0,0.65)] backdrop-blur"
        dir="rtl"
      >
        <div class="grid gap-0 lg:grid-cols-[1.05fr_0.95fr]">
          <div class="relative p-6 md:p-10 lg:p-12">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,218,106,0.12),transparent_34%)]"></div>

            <div class="relative">
              <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#c29200]/40 bg-black/50 px-4 py-2 text-xs font-bold tracking-[0.24em] text-[#ffda6a]">
                <span class="h-2 w-2 rounded-full bg-[#ffda6a] shadow-[0_0_12px_#ffda6a]"></span>
                TNX6
              </div>

              <h1 class="mb-5 text-5xl font-black leading-[1.05] tracking-tight text-white md:text-7xl">
                حياكم في
                <br />
                <span class="glow-text text-[#ffda6a]">
                  موقع TNX6
                </span>
              </h1>

              <p class="mb-8 max-w-2xl text-lg leading-relaxed text-gray-200">
                هنا تلقى جدول البث، الأوامر، الترتيب، الأغراض، البدجات، والرسمات.
              </p>

              <div class="mb-8 flex flex-wrap gap-3">
                <a
                  href="https://www.twitch.tv/tnx_6"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-[#ffda6a] to-[#c29200] px-6 py-3 font-black text-black shadow-lg shadow-[#c29200]/20 transition hover:-translate-y-0.5 hover:opacity-90"
                >
                  <iconify-icon icon="tabler:brand-twitch" class="text-xl"></iconify-icon>
                  شاهد البث
                </a>

                <a
                  href="/commands"
                  class="inline-flex items-center gap-2 rounded-xl border border-[#c29200]/65 bg-black/30 px-6 py-3 font-bold text-[#ffda6a] transition hover:-translate-y-0.5 hover:bg-[#c29200]/10"
                >
                  <iconify-icon icon="tabler:terminal-2" class="text-xl"></iconify-icon>
                  الأوامر
                </a>

                <a
                  href="/links"
                  class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-black/30 px-6 py-3 font-bold text-gray-200 transition hover:-translate-y-0.5 hover:border-[#c29200]/65 hover:text-[#ffda6a]"
                >
                  <iconify-icon icon="tabler:link" class="text-xl"></iconify-icon>
                  الروابط
                </a>
              </div>

              <div class="rounded-2xl border border-white/10 bg-black/45 p-4">
                <p class="mb-3 text-sm font-bold text-[#ffda6a]">
                  جديد على البث؟
                </p>

                <div class="grid gap-2 sm:grid-cols-4">
                  <a href="/commands" class="start-pill">
                    <span>1</span>
                    الأوامر
                  </a>
                  <a href="/leaderboards" class="start-pill">
                    <span>2</span>
                    الترتيب
                  </a>
                  <a href="/items" class="start-pill">
                    <span>3</span>
                    الأغراض
                  </a>
                  <a href="/badges" class="start-pill">
                    <span>4</span>
                    البدجات
                  </a>
                </div>
              </div>

              <section class="tnx-top-leaders" aria-label="توب 3 المتصدرين">
                <div class="mb-4 flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-black tracking-[0.24em] text-[#c29200]">
                      TOP 3
                    </p>
                    <h2 class="heading-gold-glow mt-1 text-2xl font-black text-[#ffda6a]">
                      متصدرين المجتمع
                    </h2>
                  </div>

                  <a href="/leaderboards" class="tnx-top-leaders-link">
                    صفحة الترتيب
                    <iconify-icon icon="tabler:arrow-left" class="text-base"></iconify-icon>
                  </a>
                </div>

                <div id="top-leaders-list" class="tnx-top-leaders-grid">
                  <article class="tnx-leader-card tnx-leader-card--first">
                    <span class="tnx-leader-rank">#1</span>
                    <div class="tnx-leader-medal">
                      <iconify-icon icon="tabler:crown"></iconify-icon>
                    </div>
                    <p class="tnx-leader-name">جاري التحميل...</p>
                    <p class="tnx-leader-score">--</p>
                  </article>

                  <article class="tnx-leader-card">
                    <span class="tnx-leader-rank">#2</span>
                    <div class="tnx-leader-medal">
                      <iconify-icon icon="tabler:medal-2"></iconify-icon>
                    </div>
                    <p class="tnx-leader-name">جاري التحميل...</p>
                    <p class="tnx-leader-score">--</p>
                  </article>

                  <article class="tnx-leader-card">
                    <span class="tnx-leader-rank">#3</span>
                    <div class="tnx-leader-medal">
                      <iconify-icon icon="tabler:medal"></iconify-icon>
                    </div>
                    <p class="tnx-leader-name">جاري التحميل...</p>
                    <p class="tnx-leader-score">--</p>
                  </article>
                </div>
              </section>
            </div>
          </div>

          <div class="relative border-t border-[#c29200]/20 bg-black/45 p-5 md:p-7 lg:border-r lg:border-t-0">
            <div class="grid h-full gap-4">
              <div
                id="hero-live-card"
                class="rounded-[1.7rem] border border-[#c29200]/30 bg-[#080808]/95 p-5 shadow-[0_0_35px_rgba(0,0,0,0.45)]"
              >
                <div class="mb-4 flex items-start justify-between gap-4">
                  <div>
                    <p
                      id="hero-live-kicker"
                      class="text-xs font-bold tracking-[0.2em] text-gray-400"
                    >
                      حالة البث
                    </p>

                    <h2
                      id="hero-live-title"
                      class="mt-2 text-2xl font-black leading-snug text-[#ffda6a]"
                    >
                      جاري التحقق من Twitch...
                    </h2>
                  </div>

                  <div
                    id="hero-live-dot"
                    class="mt-2 h-3 w-3 rounded-full bg-gray-500"
                  ></div>
                </div>

                <p id="hero-live-meta" class="mb-4 text-sm leading-relaxed text-gray-300">
                  بنعرض لك حالة البث الفعلية هنا.
                </p>

                <div
                  id="hero-countdown"
                  class="rounded-2xl border border-[#c29200]/20 bg-black/60 px-4 py-3"
                >
                  <div
                    id="hero-countdown-value"
                    class="font-mono text-2xl font-black text-[#ffda6a] md:text-3xl"
                  >
                    -- : -- : --
                  </div>

                  <div
                    id="hero-countdown-label"
                    class="mt-1 text-xs font-semibold text-gray-400"
                  >
                    موعد البث القادم
                  </div>
                </div>

                <a
                  id="hero-live-button"
                  href="https://www.twitch.tv/tnx_6"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hero-live-button mt-4"
                >
                  <iconify-icon icon="tabler:brand-twitch" class="text-lg"></iconify-icon>
                  <span>ادخل البث</span>
                </a>
              </div>

              <div class="relative overflow-hidden rounded-[1.7rem] border border-[#c29200]/30 bg-[#080808]/95 p-3 shadow-[0_0_35px_rgba(0,0,0,0.45)]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-transparent to-transparent"></div>

                <img
                  id="random-fanart-image-top"
                  src="/assets/images/tnx-min.jpg"
                  alt="TNX6"
                  class="aspect-[16/12] w-full rounded-[1.25rem] object-cover md:aspect-[16/11]"
                  width="620"
                  height="460"
                />

                <div class="absolute bottom-6 right-6">
                  <p class="fanart-kicker text-sm font-black text-[#ffda6a]">من رسم المجتمع</p>
                  <p class="text-xs text-gray-300">صورة عشوائية من معرض الرسمات</p>
                </div>

                <a
                  href="/fan-art"
                  class="absolute bottom-6 left-6 rounded-lg border border-[#c29200]/50 bg-black/65 px-4 py-2 text-xs font-bold text-[#ffda6a] transition hover:bg-[#c29200]/10"
                >
                  المعرض
                </a>
              </div>

              <div class="flex justify-center gap-3">
                {socialLinks.map((link) => (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={link.label}
                    class="social-icon flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-black/50 transition hover:border-[#c29200]/60 hover:bg-[#c29200]/10"
                  >
                    <iconify-icon
                      icon={link.icon}
                      class="text-2xl text-gray-300 transition hover:text-[#ffda6a]"
                    ></iconify-icon>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative z-40 px-4 pb-6 md:px-6" dir="rtl" data-reveal="up">
      <div class="mx-auto max-w-7xl">
        <div class="tnx-stats-strip">
          <div class="tnx-stat-card">
            <div class="tnx-stat-icon">
              <iconify-icon icon="tabler:clock-hour-4"></iconify-icon>
            </div>

            <div>
              <p class="tnx-stat-label">ساعات البث</p>
              <p id="stat-stream-hours" class="tnx-stat-value">--</p>
              <p id="stat-stream-hours-meta" class="tnx-stat-meta">آخر 30 يوم</p>
            </div>
          </div>

          <button
            id="community-stat-card"
            type="button"
            class="tnx-stat-card tnx-stat-card--interactive"
            aria-expanded="false"
            aria-controls="community-breakdown"
          >
            <div class="tnx-stat-icon">
              <iconify-icon icon="tabler:users-group"></iconify-icon>
            </div>

            <div class="min-w-0">
              <p class="tnx-stat-label">إجمالي المجتمع</p>
              <p id="stat-community-total" class="tnx-stat-value">--</p>
              <p class="tnx-stat-meta">مرر الماوس للتفاصيل</p>
            </div>

            <div id="community-breakdown" class="tnx-community-popover" role="dialog" aria-label="تفصيل إجمالي المجتمع">
              <div class="mb-3 flex items-center justify-between gap-3">
                <p class="text-sm font-black text-[#ffda6a]">تفصيل المنصات</p>
                <span class="rounded-full border border-[#c29200]/30 px-2 py-1 text-[10px] font-bold text-gray-400">LIVE STATS</span>
              </div>

              <div id="community-breakdown-list" class="space-y-2">
                <div class="tnx-community-row">
                  <span class="tnx-community-platform">
                    <span class="tnx-community-platform-icon">
                      <iconify-icon icon="tabler:loader-2"></iconify-icon>
                    </span>
                    <span>جاري التحميل</span>
                  </span>
                  <strong>--</strong>
                </div>
              </div>
            </div>
          </button>

          <a href="/winners" class="tnx-stat-card">
            <div class="tnx-stat-icon">
              <iconify-icon icon="tabler:crown"></iconify-icon>
            </div>

            <div>
              <p class="tnx-stat-label">إجمالي الفائزين</p>
              <p id="stat-winners-total" class="tnx-stat-value">--</p>
              <p class="tnx-stat-meta">من صفحة الجوائز</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section id="live" class="relative z-20 px-4 py-10 md:px-6">
      <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[1fr_360px]" dir="rtl">
        <div
          class="rounded-[2rem] border border-[#c29200]/25 bg-[#050505]/90 p-4 shadow-[0_0_45px_rgba(0,0,0,0.45)]"
          data-reveal="up"
        >
          <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-bold tracking-[0.25em] text-[#c29200]">
                LIVE
              </p>

              <h2 class="heading-gold-glow mt-1 text-2xl font-black text-[#ffda6a]">
                البث
              </h2>
            </div>

            <div
              id="next-stream-wrapper"
              class="inline-flex items-center justify-center rounded-full border border-[#c29200]/50 bg-black/70 px-4 py-2 text-xs shadow-[0_0_20px_rgba(0,0,0,0.45)] md:text-sm"
            >
              <span
                id="next-stream-timer"
                class="font-mono text-sm font-bold text-[#ffda6a] md:text-base"
              >
                -- : -- : --
              </span>
            </div>
          </div>

          <div
            id="live-details"
            class="mb-4 hidden rounded-2xl border border-[#c29200]/20 bg-black/60 px-4 py-3 text-sm text-gray-300"
          >
            <span id="live-title" class="text-[#ffda6a]"></span>
            <span id="live-game" class="text-gray-400"></span>
          </div>

          <div class="aspect-video w-full overflow-hidden rounded-2xl border border-[#c29200]/25 bg-black shadow-2xl">
            <iframe
              src="https://player.twitch.tv/?channel=tnx_6&parent=tnx6.xyz&parent=www.tnx6.xyz&parent=tnx6.github.io"
              allowfullscreen
              frameborder="0"
              scrolling="no"
              width="100%"
              height="100%"
              title="TNX6 Twitch Stream"
            ></iframe>
          </div>
        </div>

        <aside
          class="rounded-[2rem] border border-[#c29200]/25 bg-[#050505]/90 p-5 shadow-[0_0_45px_rgba(0,0,0,0.45)]"
          data-reveal="up"
          style="--reveal-delay: 90ms"
        >
          <div class="mb-5 flex items-center justify-between gap-3">
            <div>
              <p class="text-xs font-bold tracking-[0.25em] text-[#c29200]">
                SCHEDULE
              </p>

              <h2 class="heading-gold-glow mt-1 text-2xl font-black text-[#ffda6a]">
                جدول البث
              </h2>
            </div>

            <iconify-icon
              icon="tabler:calendar-time"
              class="text-3xl text-[#ffda6a]"
            ></iconify-icon>
          </div>

          <div class="space-y-3">
            {scheduleItems.map((item, index) => (
              <div
                class="tnx-schedule-card flex items-center justify-between gap-4 rounded-2xl border border-[#c29200]/15 px-4 py-4 text-sm text-gray-200"
                data-schedule-day={item.day}
                data-reveal="up"
                style={`--reveal-delay: ${140 + index * 70}ms`}
              >
                <div>
                  <div class="font-bold text-white">
                    {item.name}
                  </div>

                  <div class="mt-1 text-xs text-gray-400">
                    {item.description}
                  </div>
                </div>

                <div class="shrink-0 rounded-xl border border-[#c29200]/30 bg-black/60 px-3 py-2 font-black text-[#ffda6a]">
                  {item.time}
                </div>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="relative z-10 px-4 py-10 md:px-6">
      <div class="mx-auto max-w-7xl" dir="rtl">
        <div class="mb-6" data-reveal="up">
          <p class="text-xs font-bold tracking-[0.25em] text-[#c29200]">
            COMMUNITY
          </p>

          <h2 class="heading-gold-glow mt-1 text-3xl font-black text-[#ffda6a]">
            اختصارات المجتمع
          </h2>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
          <a
            href="/commands"
            class="group relative overflow-hidden rounded-[2rem] border border-[#c29200]/35 bg-[#070707] p-6 text-right shadow-[0_0_35px_rgba(0,0,0,0.35)] transition hover:-translate-y-1 hover:border-[#c29200]/80 lg:row-span-2"
            data-reveal="up"
          >
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,218,106,0.16),transparent_36%)]"></div>

            <div class="relative">
              <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-[#c29200]/35 bg-black text-[#ffda6a]">
                <iconify-icon icon="tabler:terminal-2" class="text-3xl"></iconify-icon>
              </div>

              <p class="mb-2 text-xs font-bold tracking-[0.2em] text-[#c29200]">
                START HERE
              </p>

              <h3 class="mb-3 text-3xl font-black text-white group-hover:text-[#ffda6a]">
                الأوامر
              </h3>

              <p class="mb-7 max-w-sm text-sm leading-relaxed text-gray-400">
                أول صفحة تدخلها إذا أنت جديد. تعرف وش تكتب بالشات وكيف تستخدم أنظمة البث.
              </p>

              <span class="inline-flex items-center gap-2 rounded-xl border border-[#c29200]/50 px-4 py-2 text-sm font-bold text-[#ffda6a]">
                افتح صفحة الأوامر
                <iconify-icon icon="tabler:arrow-left" class="text-lg"></iconify-icon>
              </span>
            </div>
          </a>

          {shortcutCards.map((card, index) => (
            <a
              href={card.href}
              class="group rounded-[2rem] border border-[#c29200]/18 bg-[#070707] p-5 text-right shadow-[0_0_30px_rgba(0,0,0,0.28)] transition hover:-translate-y-1 hover:border-[#c29200]/70 hover:shadow-[0_0_24px_rgba(194,146,0,0.22)]"
              data-reveal="up"
              style={`--reveal-delay: ${90 + index * 70}ms`}
            >
              <div class="mb-4 flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[#c29200]/30 bg-black text-[#ffda6a]">
                  <iconify-icon icon={card.icon} class="text-2xl"></iconify-icon>
                </div>

                <span class="rounded-full border border-white/10 px-3 py-1 text-[11px] font-bold text-gray-400">
                  {card.label}
                </span>
              </div>

              <h3 class="mb-2 text-xl font-black text-white group-hover:text-[#ffda6a]">
                {card.title}
              </h3>

              <p class="text-sm leading-relaxed text-gray-400">
                {card.description}
              </p>
            </a>
          ))}

          <a
            href="/winners"
            class="group rounded-[2rem] border border-[#c29200]/18 bg-[#070707] p-5 text-right shadow-[0_0_30px_rgba(0,0,0,0.28)] transition hover:-translate-y-1 hover:border-[#c29200]/70 hover:shadow-[0_0_24px_rgba(194,146,0,0.22)]"
            data-reveal="up"
            style="--reveal-delay: 380ms"
          >
            <div class="mb-4 flex items-start justify-between gap-4">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[#c29200]/30 bg-black text-[#ffda6a]">
                <iconify-icon icon="tabler:crown" class="text-2xl"></iconify-icon>
              </div>

              <span class="rounded-full border border-white/10 px-3 py-1 text-[11px] font-bold text-gray-400">
                لوحة الشرف
              </span>
            </div>

