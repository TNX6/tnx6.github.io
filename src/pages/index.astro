      opacity: 0;
      transform: translate3d(0, 26px, 0);
      filter: blur(6px);
      transition:
        opacity 650ms cubic-bezier(0.2, 0.8, 0.2, 1),
        transform 650ms cubic-bezier(0.2, 0.8, 0.2, 1),
        filter 650ms cubic-bezier(0.2, 0.8, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
      will-change: opacity, transform, filter;
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }

    .back-to-top-button {
      position: fixed;
      right: 1.25rem;
      bottom: 1.25rem;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border-radius: 999px;
      border: 1px solid rgba(194, 146, 0, 0.65);
      background: linear-gradient(135deg, rgba(255, 218, 106, 0.96), rgba(194, 146, 0, 0.95));
      color: #08050d;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      font-weight: 900;
      box-shadow:
        0 0 18px rgba(255, 218, 106, 0.25),
        0 14px 35px rgba(0, 0, 0, 0.45);
      opacity: 0;
      pointer-events: none;
      transform: translateY(12px);
      transition:
        opacity 180ms ease,
        transform 180ms ease,
        box-shadow 180ms ease;
    }

    .back-to-top-button:hover {
      box-shadow:
        0 0 24px rgba(255, 218, 106, 0.42),
        0 16px 38px rgba(0, 0, 0, 0.48);
    }

    .back-to-top-button--visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .back-to-top-button--visible:hover {
      transform: translateY(-2px);
    }

    @media (max-width: 860px) {
      .tnx-stats-strip {
        grid-template-columns: 1fr;
      }

      .tnx-stat-card {
        min-height: 96px;
      }

      .tnx-community-popover {
        right: 0;
        transform: translateY(8px) scale(0.98);
      }

      .tnx-community-popover::before {
        right: 2rem;
        transform: rotate(45deg);
      }

      .tnx-stat-card--interactive:hover .tnx-community-popover,
      .tnx-stat-card--interactive:focus-visible .tnx-community-popover,
      .tnx-stat-card--interactive.is-open .tnx-community-popover {
        transform: translateY(0) scale(1);
      }
    }

    @media (max-width: 760px) {
      .tnx-top-leaders-grid {
        grid-template-columns: 1fr;
      }

      .tnx-leader-card {
        min-height: 118px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        filter: none;
        transition: none;
      }
    }
  </style>

  <script define:vars={{ streamConfig, fanArtImages, twitchStatusUrl, socialStatsUrl }} data-reinit>
    ;(() => {
      const STREAM_START_HOUR = streamConfig.startHour
      const STREAM_START_MINUTE = streamConfig.startMinute
      const STREAM_END_HOUR = streamConfig.endHour
      const STREAM_DAYS = streamConfig.days
      const TWITCH_STATUS_URL = twitchStatusUrl
      const SOCIAL_STATS_URL = socialStatsUrl

      const cleanupKey = '__tnxHomeCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const intervals = []
      const cleanups = []

      let twitchLiveStatus = {
        checked: false,
        live: false,
        title: null,
        game: null,
        viewers: 0,
      }

      function setIntervalSafe(callback, ms) {
        const id = window.setInterval(callback, ms)
        intervals.push(id)
        return id
      }

      function addCleanup(callback) {
        cleanups.push(callback)
      }

      window[cleanupKey] = () => {
        intervals.forEach((id) => window.clearInterval(id))
        intervals.length = 0

        cleanups.forEach((callback) => callback())
        cleanups.length = 0
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;')
      }

      function isStreamDay(date) {
        return STREAM_DAYS.includes(date.getDay())
      }

      function getNextStreamStart(now) {
        for (let offset = 0; offset < 14; offset++) {
          const candidateDay = new Date(now)
          candidateDay.setDate(candidateDay.getDate() + offset)

          if (!isStreamDay(candidateDay)) continue

          const start = new Date(candidateDay)
          start.setHours(STREAM_START_HOUR, STREAM_START_MINUTE, 0, 0)

          if (start > now) return start
        }

        return null
      }

      function getNextStreamText(next) {
        if (!next) return 'موعد البث القادم'

        const dayNames = [
          'الأحد',
          'الاثنين',
          'الثلاثاء',
          'الأربعاء',
          'الخميس',
          'الجمعة',
          'السبت',
        ]

        return `${dayNames[next.getDay()]} — 9:00 م`
      }

      function getCountdownParts(totalSeconds) {
        const h = Math.floor(totalSeconds / 3600)
        const m = Math.floor((totalSeconds % 3600) / 60)
        const s = totalSeconds % 60

        return {
          h: String(h).padStart(2, '0'),
          m: String(m).padStart(2, '0'),
          s: String(s).padStart(2, '0'),
        }
      }

      function renderCountdown(totalSeconds) {
        const { h, m, s } = getCountdownParts(totalSeconds)

        return `
          <span class="tnx-countdown-row" dir="ltr">
            <span class="tnx-countdown-number">${h}</span>
            <span class="tnx-countdown-separator">:</span>
            <span class="tnx-countdown-number">${m}</span>
            <span class="tnx-countdown-separator">:</span>
            <span class="tnx-countdown-number">${s}</span>
          </span>
        `
      }

      function formatNumber(value) {
        const number = Number(String(value).replaceAll(',', ''))

        if (!Number.isFinite(number)) return '--'

        return new Intl.NumberFormat('en-US').format(number)
      }

      function formatStatHours(value) {
        const number = Number(value)

        if (!Number.isFinite(number)) return '--'

        return `${number.toFixed(1)} ساعة`
      }

      function getPlatformLabel(key, fallbackLabel) {
        const labels = {
          twitch: 'Twitch',
          youtube: 'YouTube',
          discord: 'Discord',
          instagram: 'Instagram',
          tiktok: 'TikTok',
          kick: 'Kick',
        }

        return labels[key] || fallbackLabel || key
      }

      async function fetchTwitchLiveStatus() {
        try {
          const response = await fetch(TWITCH_STATUS_URL, {
            cache: 'no-store',
          })

          if (!response.ok) return

          const data = await response.json()

          twitchLiveStatus = {
            checked: true,
            live: Boolean(data.live),
            title: data.title || null,
            game: data.game || null,
            viewers: Number(data.viewers || 0),
          }
        } catch {
          twitchLiveStatus = {
            checked: false,
            live: false,
            title: null,
            game: null,
            viewers: 0,
          }
        }
      }

      async function loadSiteUpdates() {
        const listEl = document.getElementById('site-updates-list')

        if (!listEl) return

        try {
          const response = await fetch('/api/site-updates.json', {
            cache: 'no-store',
          })

          if (!response.ok) {
            throw new Error('Failed to load updates')
          }

          const updates = await response.json()

          if (!Array.isArray(updates) || updates.length === 0) {
            listEl.innerHTML = `
              <li class="flex gap-2">
                <span class="text-[#ffda6a]">•</span>
                لا توجد تحديثات حالية.
              </li>
            `
            return
          }

          const latestUpdates = updates.slice(0, 3)

          listEl.innerHTML = latestUpdates
            .map((update) => {
              const title = String(update.title || '').trim()
              const type = String(update.type || 'تحديث').trim()
              const date = String(update.date || '').trim()

              if (!title) return ''

              const meta = [type, date].filter(Boolean).join(' — ')

              return `
                <li class="flex items-start gap-2">
                  <span class="mt-1 text-[#ffda6a]">•</span>
                  <span class="leading-relaxed">
                    <span>${escapeHtml(title)}</span>
                    ${
                      meta
                        ? `<span class="mr-2 text-xs text-gray-500">${escapeHtml(meta)}</span>`
                        : ''
                    }
                  </span>
                </li>
              `
            })
            .join('')
        } catch {
          listEl.innerHTML = `
            <li class="flex gap-2">
              <span class="text-[#ffda6a]">•</span>
              تعذر تحميل تحديثات الموقع.
            </li>
          `
        }
      }

      async function loadSocialStats() {
        const streamHoursEl = document.getElementById('stat-stream-hours')
        const streamHoursMetaEl = document.getElementById('stat-stream-hours-meta')
        const communityTotalEl = document.getElementById('stat-community-total')
        const breakdownListEl = document.getElementById('community-breakdown-list')

        if (!streamHoursEl || !communityTotalEl || !breakdownListEl) return

        try {
          const response = await fetch(`${SOCIAL_STATS_URL}?site=${Date.now()}`, {
            cache: 'no-store',
          })

          if (!response.ok) {
            throw new Error('Failed to load social stats')
          }

          const data = await response.json()
          const hoursData = data.last30DaysStreamHours || data.monthlyStreamHours || null
          const hoursValue = hoursData && typeof hoursData.value === 'number' ? hoursData.value : null
          const stats = Array.isArray(data.stats) ? data.stats : []
          const communityTotal =
            typeof data.communityTotal === 'number'
              ? data.communityTotal
              : stats.reduce((total, item) => total + (typeof item.value === 'number' ? item.value : 0), 0)

          const platformOrder = ['twitch', 'youtube', 'discord', 'instagram', 'tiktok', 'kick']
          const platformIconMap = {
            twitch: 'tabler:brand-twitch',
            youtube: 'tabler:brand-youtube',
            discord: 'tabler:brand-discord',
            instagram: 'tabler:brand-instagram',
            tiktok: 'tabler:brand-tiktok',
            kick: 'tabler:letter-k',
          }

          streamHoursEl.textContent = formatStatHours(hoursValue)

          if (streamHoursMetaEl) {
            streamHoursMetaEl.textContent = 'آخر 30 يوم'
          }

          communityTotalEl.textContent = formatNumber(communityTotal)

          const sortedStats = stats
            .filter((item) => item && item.key)
            .sort((a, b) => {
              const aIndex = platformOrder.indexOf(a.key)
              const bIndex = platformOrder.indexOf(b.key)

              return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex)
            })

          breakdownListEl.innerHTML = sortedStats
            .map((item) => {
              const key = String(item.key || '').trim()
              const label = escapeHtml(getPlatformLabel(item.key, item.label))
              const value = typeof item.value === 'number' ? formatNumber(item.value) : '--'
              const icon = platformIconMap[key] || 'tabler:circle'

              return `
                <div class="tnx-community-row">
                  <span class="tnx-community-platform">
                    <span class="tnx-community-platform-icon">
                      <iconify-icon icon="${icon}"></iconify-icon>
                    </span>
                    <span>${label}</span>
                  </span>
                  <strong>${value}</strong>
                </div>
              `
            })
            .join('')
        } catch {
          streamHoursEl.textContent = '--'
          communityTotalEl.textContent = '--'

          if (streamHoursMetaEl) {
            streamHoursMetaEl.textContent = 'آخر 30 يوم'
          }

          breakdownListEl.innerHTML = `
            <div class="tnx-community-row">
              <span class="tnx-community-platform">
                <span class="tnx-community-platform-icon">
                  <iconify-icon icon="tabler:alert-circle"></iconify-icon>
                </span>
                <span>تعذر تحميل الإحصائيات</span>
              </span>
              <strong>--</strong>
            </div>
          `
        }
      }

      async function loadTopLeaders() {
        const listEl = document.getElementById('top-leaders-list')

        if (!listEl) return

        try {
          const leaders = await getTopLeaders()

          if (!leaders.length) {
            throw new Error('No leaders found')
          }

          const medals = ['tabler:crown', 'tabler:medal-2', 'tabler:medal']

          listEl.innerHTML = leaders
            .slice(0, 3)
            .map((leader, index) => {
              const rank = index + 1
              const safeName = escapeHtml(leader.name || `المركز ${rank}`)
              const safeScore = leader.score ? escapeHtml(leader.score) : '--'
              const firstClass = index === 0 ? ' tnx-leader-card--first' : ''

              return `
                <article class="tnx-leader-card${firstClass}">
                  <span class="tnx-leader-rank">#${rank}</span>
                  <div class="tnx-leader-medal">
                    <iconify-icon icon="${medals[index]}"></iconify-icon>
                  </div>
                  <p class="tnx-leader-name" title="${safeName}">${safeName}</p>
                  <p class="tnx-leader-score">${safeScore}</p>
                </article>
              `
            })
            .join('')
        } catch {
          listEl.innerHTML = `
            <article class="tnx-leader-card tnx-leader-card--first">
              <span class="tnx-leader-rank">TOP</span>
              <div class="tnx-leader-medal">
                <iconify-icon icon="tabler:trophy"></iconify-icon>
              </div>
              <p class="tnx-leader-name">تعذر تحميل الترتيب</p>
              <p class="tnx-leader-score">راجع صفحة الترتيب</p>
            </article>
          `
        }
      }

      async function getTopLeaders() {
        const apiLeaders = await tryLoadLeadersFromApi()

        if (apiLeaders.length) {
          return apiLeaders
        }

        return tryLoadLeadersFromPage()
      }

      async function tryLoadLeadersFromApi() {
        const urls = [
          '/api/leaderboards.json',
          '/api/leaderboard.json',
          '/leaderboards.json',
        ]

        for (const url of urls) {
          try {
            const response = await fetch(`${url}?site=${Date.now()}`, {
              cache: 'no-store',
            })

            if (!response.ok) continue

            const data = await response.json()
            const rawList =
              Array.isArray(data)
                ? data
                : Array.isArray(data.leaders)
                  ? data.leaders
                  : Array.isArray(data.leaderboard)
                    ? data.leaderboard
                    : Array.isArray(data.data)
                      ? data.data
                      : Array.isArray(data.points)
                        ? data.points
                        : []

            const parsed = rawList.map(parseLeaderObject).filter(Boolean)

            if (parsed.length) {
              return parsed
            }
          } catch {
            // Try next endpoint.
          }
        }

        return []
      }

      function parseLeaderObject(item) {
        if (!item || typeof item !== 'object') return null

        const name =
          item.name ||
          item.username ||
          item.user ||
          item.displayName ||
          item.display_name ||
          item.login ||
          item.twitchName ||
          item.twitch_name

        const score =
          item.points ??
          item.score ??
          item.value ??
          item.total ??
          item.gold ??
          item.balance ??
          item.amount

        if (!name || score === undefined || score === null) return null

        return {
          name: cleanLeaderName(name),
          score: `${formatNumber(score)} نقطة`,
        }
      }

      async function tryLoadLeadersFromPage() {
        try {
          const response = await fetch(`/leaderboards?site=${Date.now()}`, {
            cache: 'no-store',
          })

          if (!response.ok) {
            throw new Error('Failed to load leaderboards page')
          }

          const html = await response.text()
          const doc = new DOMParser().parseFromString(html, 'text/html')

          return extractTopLeadersFromDocument(doc).slice(0, 3)
        } catch {
          return []
        }
      }

      function extractTopLeadersFromDocument(doc) {
        const selectors = [
          '[data-rank]',
          '[data-leaderboard-rank]',
          '.leaderboard-row',
          '.leaderboard-card',
          '.rank-row',
          '.user-card',
          'tbody tr',
          'tr',
        ]

        for (const selector of selectors) {
          const items = Array.from(doc.querySelectorAll(selector))
          const parsed = items.map(parseLeaderElement).filter(Boolean)

          if (parsed.length >= 3) {
            return parsed
          }
        }

        const bodyText = doc.body?.innerText || ''
        return parseLeadersFromText(bodyText)
      }

      function parseLeaderElement(element) {
        const nameSelectors = [
          '[data-name]',
          '[data-username]',
          '.username',
          '.user-name',
          '.name',
          '.display-name',
          'td:nth-child(2)',
        ]

        const scoreSelectors = [
          '[data-points]',
          '[data-score]',
          '[data-value]',
          '.points',
          '.score',
          '.value',
          'td:last-child',
        ]

        let name = ''
        let score = ''

        for (const selector of nameSelectors) {
          const target = element.matches(selector) ? element : element.querySelector(selector)
          const value =
            target?.getAttribute('data-name') ||
            target?.getAttribute('data-username') ||
            target?.textContent

          if (value && String(value).trim()) {
            name = String(value).trim()
            break
          }
        }

        for (const selector of scoreSelectors) {
          const target = element.matches(selector) ? element : element.querySelector(selector)
          const value =
            target?.getAttribute('data-points') ||
            target?.getAttribute('data-score') ||
            target?.getAttribute('data-value') ||
            target?.textContent

          if (value && /\d/.test(String(value))) {
            score = cleanLeaderScore(value)
            break
          }
        }

        if (!name || !score) {
          const text = String(element.innerText || element.textContent || '')
            .replace(/\s+/g, ' ')
            .trim()

          if (!text) return null

          const numberMatches = text.match(/[\d,]+(?:\.\d+)?/g) || []
          const scoreCandidate = numberMatches[numberMatches.length - 1]

          if (!score && scoreCandidate) {
            score = cleanLeaderScore(scoreCandidate)
          }

          if (!name && scoreCandidate) {
            name = text
              .replace(scoreCandidate, '')
              .replace(/^#?\d+\s*/g, '')
              .replace(/نقطة|نقاط|ذهب|مشاهدة|ساعة/gi, '')
              .trim()
          }
        }

        name = cleanLeaderName(name)

        if (!name || !score || name.length > 32) return null

        return {
          name,
          score,
        }
      }

      function parseLeadersFromText(text) {
        return String(text || '')
          .split('\n')
          .map((line) => line.replace(/\s+/g, ' ').trim())
          .filter(Boolean)
          .map((line) => {
            const scoreMatch = line.match(/[\d,]+(?:\.\d+)?/)
            if (!scoreMatch) return null

            const score = cleanLeaderScore(scoreMatch[0])
            const name = cleanLeaderName(
              line
                .replace(scoreMatch[0], '')
                .replace(/^#?\d+\s*/g, '')
                .replace(/نقطة|نقاط|ذهب|مشاهدة|ساعة/gi, '')
                .trim()
            )

            if (!name || !score || name.length > 32) return null

            return {
              name,
              score,
            }
          })
          .filter(Boolean)
      }

      function cleanLeaderName(value) {
        return String(value || '')
          .replace(/[#•|]/g, ' ')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function cleanLeaderScore(value) {
        const numberText = String(value || '').match(/[\d,]+(?:\.\d+)?/)?.[0]
        if (!numberText) return ''

        return `${formatNumber(numberText.replaceAll(',', ''))} نقطة`
      }

      async function loadWinnersCount() {
        const winnersTotalEl = document.getElementById('stat-winners-total')

        if (!winnersTotalEl) return

        try {
          const response = await fetch('/winners', {
            cache: 'no-store',
          })

          if (!response.ok) {
            throw new Error('Failed to load winners page')
          }

          const html = await response.text()
          const doc = new DOMParser().parseFromString(html, 'text/html')
          const count = doc.querySelectorAll('.user-card[data-name]').length

          winnersTotalEl.textContent = count > 0 ? formatNumber(count) : '--'
        } catch {
          winnersTotalEl.textContent = '--'
        }
      }

      function initCommunityStatsPopover() {
        const card = document.getElementById('community-stat-card')

        if (!card) return

        function togglePopover(event) {
          event.stopPropagation()
          const isOpen = card.classList.toggle('is-open')
          card.setAttribute('aria-expanded', String(isOpen))
        }

        function closePopover() {
          card.classList.remove('is-open')
          card.setAttribute('aria-expanded', 'false')
        }

        function closeOnEscape(event) {
          if (event.key === 'Escape') {
            closePopover()
          }
        }

        card.addEventListener('click', togglePopover)
        document.addEventListener('click', closePopover)
        document.addEventListener('keydown', closeOnEscape)

        addCleanup(() => {
          card.removeEventListener('click', togglePopover)
          document.removeEventListener('click', closePopover)
          document.removeEventListener('keydown', closeOnEscape)
        })
      }

      function highlightActiveScheduleCard(now = new Date()) {
        const activeDate = twitchLiveStatus.live ? now : getNextStreamStart(now)
        const activeDay = activeDate ? activeDate.getDay() : null

        document.querySelectorAll('.tnx-schedule-card').forEach((card) => {
          card.classList.remove('tnx-schedule-card--active')

          const dayAttr = card.getAttribute('data-schedule-day')
          if (!dayAttr || activeDay === null) return

          if (Number.parseInt(dayAttr, 10) === activeDay) {
            card.classList.add('tnx-schedule-card--active')
          }
        })
      }

      function updateLiveDetails() {
        const detailsEl = document.getElementById('live-details')
        const titleEl = document.getElementById('live-title')
        const gameEl = document.getElementById('live-game')

        if (!detailsEl || !titleEl || !gameEl) return

        if (!twitchLiveStatus.live) {
          detailsEl.classList.add('hidden')
          titleEl.textContent = ''
          gameEl.textContent = ''
          return
        }

        titleEl.textContent = twitchLiveStatus.title || 'البث مباشر الآن'
        gameEl.textContent = twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''
        detailsEl.classList.remove('hidden')
      }

      function updateHeroCard(next, totalSeconds) {
        const cardEl = document.getElementById('hero-live-card')
        const kickerEl = document.getElementById('hero-live-kicker')
        const titleEl = document.getElementById('hero-live-title')
        const metaEl = document.getElementById('hero-live-meta')
        const dotEl = document.getElementById('hero-live-dot')
        const countdownValueEl = document.getElementById('hero-countdown-value')
        const countdownLabelEl = document.getElementById('hero-countdown-label')
        const liveButtonEl = document.getElementById('hero-live-button')

        if (!cardEl || !kickerEl || !titleEl || !metaEl || !dotEl || !countdownValueEl || !countdownLabelEl) {
          return
        }

        if (twitchLiveStatus.live) {
          kickerEl.textContent = 'مباشر الآن'
          titleEl.textContent = twitchLiveStatus.title || 'البث شغال'
          metaEl.textContent =
            twitchLiveStatus.viewers > 0
              ? `${twitchLiveStatus.viewers} مشاهد على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`
              : `على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`

          countdownValueEl.textContent = 'LIVE'
          countdownLabelEl.textContent = 'ادخل البث من Twitch'

          dotEl.className =
            'mt-2 h-3 w-3 rounded-full bg-red-500 shadow-[0_0_14px_rgba(239,68,68,0.9)]'
          cardEl.classList.add('border-red-500/40')
          liveButtonEl?.classList.add('is-live')
          return
        }

        cardEl.classList.remove('border-red-500/40')
        liveButtonEl?.classList.remove('is-live')
        dotEl.className =
          'mt-2 h-3 w-3 rounded-full bg-[#ffda6a] shadow-[0_0_14px_rgba(255,218,106,0.7)]'

        kickerEl.textContent = 'البث القادم'

        if (!next || typeof totalSeconds !== 'number') {
          titleEl.textContent = 'حسب الجدول'
          metaEl.textContent = ''
          countdownValueEl.textContent = '-- : -- : --'
          countdownLabelEl.textContent = 'موعد البث القادم'
          return
        }

        titleEl.textContent = getNextStreamText(next)
        metaEl.textContent = ''
        countdownValueEl.innerHTML = renderCountdown(totalSeconds)
        countdownLabelEl.textContent = 'العد التنازلي'
      }

      function updateStreamPanel() {
        const timerEl = document.getElementById('next-stream-timer')
        const wrapperEl = document.getElementById('next-stream-wrapper')

        if (!timerEl) return

        const now = new Date()

        highlightActiveScheduleCard(now)
        updateLiveDetails()

        if (twitchLiveStatus.live) {
          timerEl.textContent = 'البث مباشر الآن'
          timerEl.classList.remove('font-mono')
          timerEl.classList.add('font-bold', 'tnx-live-glow')

          wrapperEl?.classList.add('ring-1', 'ring-red-400/60')
          updateHeroCard(null, null)
          return
        }

        const next = getNextStreamStart(now)

        if (!next) {
          timerEl.textContent = '-- : -- : --'
          timerEl.classList.add('font-mono')
          timerEl.classList.remove('font-bold', 'tnx-live-glow')
          wrapperEl?.classList.remove('ring-1', 'ring-red-400/60')
          updateHeroCard(null, null)
          return
        }

        const totalSeconds = Math.max(0, Math.floor((next.getTime() - now.getTime()) / 1000))

        timerEl.innerHTML = renderCountdown(totalSeconds)
        timerEl.classList.add('font-mono')
        timerEl.classList.remove('font-bold', 'tnx-live-glow')

        wrapperEl?.classList.remove('ring-1', 'ring-red-400/60')
        updateHeroCard(next, totalSeconds)
      }

      function getStorageItem(key) {
        try {
          return window.localStorage.getItem(key)
        } catch {
          return null
        }
      }

      function setStorageItem(key, value) {
        try {
          window.localStorage.setItem(key, value)
        } catch {
          // Ignore storage errors.
        }
      }

      function updateRandomFanArt() {
        const topImg = document.getElementById('random-fanart-image-top')
        const bottomImg = document.getElementById('random-fanart-image-bottom')

        if (!Array.isArray(fanArtImages) || fanArtImages.length === 0) return

        const lastImage = getStorageItem('tnx-last-fanart')
        let availableImages = fanArtImages

        if (fanArtImages.length > 1 && lastImage) {
          availableImages = fanArtImages.filter((image) => image !== lastImage)
        }

        const randomImage = availableImages[Math.floor(Math.random() * availableImages.length)]

        if (!randomImage) return

        if (topImg) {
          topImg.setAttribute('src', randomImage)
          topImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        if (bottomImg) {
          bottomImg.setAttribute('src', randomImage)
          bottomImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        setStorageItem('tnx-last-fanart', randomImage)
      }

      function initScrollReveal() {
        const revealElements = Array.from(document.querySelectorAll('[data-reveal]'))

        if (revealElements.length === 0) return

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        if (reduceMotion || !('IntersectionObserver' in window)) {
          revealElements.forEach((element) => element.classList.add('is-visible'))
          return
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return

              entry.target.classList.add('is-visible')
              observer.unobserve(entry.target)
            })
          },
          {
            threshold: 0.12,
            rootMargin: '0px 0px -70px 0px',
          }
        )

        revealElements.forEach((element) => observer.observe(element))

        addCleanup(() => {
          observer.disconnect()
        })
      }

      function initBackToTopButton() {
        const button = document.getElementById('back-to-top')

        if (!button) return

        function updateButtonVisibility() {
          if (window.scrollY > 520) {
            button.classList.add('back-to-top-button--visible')
          } else {
            button.classList.remove('back-to-top-button--visible')
          }
        }

        function scrollToTop() {
          window.scrollTo({
            top: 0,
            behavior: 'smooth',
          })
        }

        window.addEventListener('scroll', updateButtonVisibility, { passive: true })
        button.addEventListener('click', scrollToTop)

        addCleanup(() => {
          window.removeEventListener('scroll', updateButtonVisibility)
          button.removeEventListener('click', scrollToTop)
        })

        updateButtonVisibility()
      }

      function init() {
        highlightActiveScheduleCard(new Date())
        updateRandomFanArt()
        loadSiteUpdates()
        loadSocialStats()
        loadTopLeaders()
        loadWinnersCount()
        initCommunityStatsPopover()
        initScrollReveal()
        initBackToTopButton()

        fetchTwitchLiveStatus().then(updateStreamPanel)
        updateStreamPanel()

        setIntervalSafe(updateStreamPanel, 1000)

        setIntervalSafe(() => {
          fetchTwitchLiveStatus().then(updateStreamPanel)
        }, 30000)
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true })
      } else {
        init()
      }
    })()
  </script>
</Layout>
