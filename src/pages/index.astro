  </style>

  <style is:global>
    .tnx-live-glow {
      color: #fef08a;
      text-shadow:
        0 0 5px #facc15,
        0 0 12px #facc15,
        0 0 20px #facc15;
      animation: tnx-live-pulse 1.4s ease-in-out infinite;
    }

    @keyframes tnx-live-pulse {
      0%,
      100% {
        text-shadow:
          0 0 4px #facc15,
          0 0 10px #facc15,
          0 0 18px #facc15;
      }

      50% {
        text-shadow:
          0 0 8px #fde68a,
          0 0 18px #facc15,
          0 0 28px #fbbf24;
      }
    }

    .tnx-schedule-card {
      background: linear-gradient(
        180deg,
        rgba(12, 15, 24, 0.96) 0%,
        rgba(7, 9, 15, 0.98) 100%
      );
      backdrop-filter: blur(8px);
      transition: all 0.25s ease;
    }

    .tnx-schedule-card:hover {
      transform: translateY(-2px);
      border-color: rgba(194, 146, 0, 0.35);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .tnx-schedule-card--active {
      border-color: rgba(194, 146, 0, 0.9) !important;
      box-shadow: 0 0 22px rgba(194, 146, 0, 0.45);
    }
  </style>

  <script define:vars={{ streamConfig, fanArtImages, twitchStatusUrl }} data-reinit>
    ;(() => {
      const STREAM_START_HOUR = streamConfig.startHour
      const STREAM_START_MINUTE = streamConfig.startMinute
      const STREAM_END_HOUR = streamConfig.endHour
      const STREAM_DAYS = streamConfig.days
      const TWITCH_STATUS_URL = twitchStatusUrl

      const cleanupKey = '__tnxHomeCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const intervals = []
      const cleanups = []

      let twitchLiveStatus = {
        checked: false,
        live: false,
        title: null,
        game: null,
        viewers: 0,
      }

      function setIntervalSafe(callback, ms) {
        const id = window.setInterval(callback, ms)
        intervals.push(id)
        return id
      }

      function addCleanup(callback) {
        cleanups.push(callback)
      }

      window[cleanupKey] = () => {
        intervals.forEach((id) => window.clearInterval(id))
        intervals.length = 0

        cleanups.forEach((callback) => callback())
        cleanups.length = 0
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;')
      }

      function isStreamDay(date) {
        return STREAM_DAYS.includes(date.getDay())
      }

      function getNextStreamStart(now) {
        for (let offset = 0; offset < 14; offset++) {
          const candidateDay = new Date(now)
          candidateDay.setDate(candidateDay.getDate() + offset)

          if (!isStreamDay(candidateDay)) continue

          const start = new Date(candidateDay)
          start.setHours(STREAM_START_HOUR, STREAM_START_MINUTE, 0, 0)

          if (start > now) return start
        }

        return null
      }

      function getNextStreamText(next) {
        if (!next) return 'موعد البث القادم'

        const dayNames = [
          'الأحد',
          'الاثنين',
          'الثلاثاء',
          'الأربعاء',
          'الخميس',
          'الجمعة',
          'السبت',
        ]

        return `${dayNames[next.getDay()]} — 9:00 م`
      }

      function getCountdownParts(totalSeconds) {
        const h = Math.floor(totalSeconds / 3600)
        const m = Math.floor((totalSeconds % 3600) / 60)
        const s = totalSeconds % 60

        return {
          h: String(h).padStart(2, '0'),
          m: String(m).padStart(2, '0'),
          s: String(s).padStart(2, '0'),
        }
      }

      function renderCountdown(totalSeconds) {
        const { h, m, s } = getCountdownParts(totalSeconds)

        return `
          <span class="tnx-countdown-row" dir="ltr">
            <span class="tnx-countdown-number">${h}</span>
            <span class="tnx-countdown-separator">:</span>
            <span class="tnx-countdown-number">${m}</span>
            <span class="tnx-countdown-separator">:</span>
            <span class="tnx-countdown-number">${s}</span>
          </span>
        `
      }

      async function fetchTwitchLiveStatus() {
        try {
          const response = await fetch(TWITCH_STATUS_URL, {
            cache: 'no-store',
          })

          if (!response.ok) return

          const data = await response.json()

          twitchLiveStatus = {
            checked: true,
            live: Boolean(data.live),
            title: data.title || null,
            game: data.game || null,
            viewers: Number(data.viewers || 0),
          }
        } catch {
          twitchLiveStatus = {
            checked: false,
            live: false,
            title: null,
            game: null,
            viewers: 0,
          }
        }
      }

      async function loadSiteUpdates() {
        const listEl = document.getElementById('site-updates-list')

        if (!listEl) return

        try {
          const response = await fetch('/api/site-updates.json', {
            cache: 'no-store',
          })

          if (!response.ok) {
            throw new Error('Failed to load updates')
          }

          const updates = await response.json()

          if (!Array.isArray(updates) || updates.length === 0) {
            listEl.innerHTML = `
              <li class="flex gap-2">
                <span class="text-[#ffda6a]">•</span>
                لا توجد تحديثات حالية.
              </li>
            `
            return
          }

          const latestUpdates = updates.slice(0, 3)

          listEl.innerHTML = latestUpdates
            .map((update) => {
              const title = String(update.title || '').trim()
              const type = String(update.type || 'تحديث').trim()
              const date = String(update.date || '').trim()

              if (!title) return ''

              const meta = [type, date].filter(Boolean).join(' — ')

              return `
                <li class="flex items-start gap-2">
                  <span class="mt-1 text-[#ffda6a]">•</span>
                  <span class="leading-relaxed">
                    <span>${escapeHtml(title)}</span>
                    ${
                      meta
                        ? `<span class="mr-2 text-xs text-gray-500">${escapeHtml(meta)}</span>`
                        : ''
                    }
                  </span>
                </li>
              `
            })
            .join('')
        } catch {
          listEl.innerHTML = `
            <li class="flex gap-2">
              <span class="text-[#ffda6a]">•</span>
              تعذر تحميل تحديثات الموقع.
            </li>
          `
        }
      }

      function highlightTodayScheduleCard() {
        const todayDay = new Date().getDay()

        document.querySelectorAll('.tnx-schedule-card').forEach((card) => {
          card.classList.remove('tnx-schedule-card--active')

          const dayAttr = card.getAttribute('data-schedule-day')
          if (!dayAttr) return

          if (Number.parseInt(dayAttr, 10) === todayDay) {
            card.classList.add('tnx-schedule-card--active')
          }
        })
      }

      function updateLiveDetails() {
        const detailsEl = document.getElementById('live-details')
        const titleEl = document.getElementById('live-title')
        const gameEl = document.getElementById('live-game')

        if (!detailsEl || !titleEl || !gameEl) return

        if (!twitchLiveStatus.live) {
          detailsEl.classList.add('hidden')
          titleEl.textContent = ''
          gameEl.textContent = ''
          return
        }

        titleEl.textContent = twitchLiveStatus.title || 'البث مباشر الآن'
        gameEl.textContent = twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''
        detailsEl.classList.remove('hidden')
      }

      function updateHeroCard(next, totalSeconds) {
        const cardEl = document.getElementById('hero-live-card')
        const kickerEl = document.getElementById('hero-live-kicker')
        const titleEl = document.getElementById('hero-live-title')
        const metaEl = document.getElementById('hero-live-meta')
        const dotEl = document.getElementById('hero-live-dot')
        const countdownValueEl = document.getElementById('hero-countdown-value')
        const countdownLabelEl = document.getElementById('hero-countdown-label')
        const liveButtonEl = document.getElementById('hero-live-button')

        if (!cardEl || !kickerEl || !titleEl || !metaEl || !dotEl || !countdownValueEl || !countdownLabelEl) {
          return
        }

        if (twitchLiveStatus.live) {
          kickerEl.textContent = 'مباشر الآن'
          titleEl.textContent = twitchLiveStatus.title || 'البث شغال'
          metaEl.textContent =
            twitchLiveStatus.viewers > 0
              ? `${twitchLiveStatus.viewers} مشاهد على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`
              : `على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`

          countdownValueEl.textContent = 'LIVE'
          countdownLabelEl.textContent = 'ادخل البث من Twitch'

          dotEl.className =
            'mt-2 h-3 w-3 rounded-full bg-red-500 shadow-[0_0_14px_rgba(239,68,68,0.9)]'
          cardEl.classList.add('border-red-500/40')
          liveButtonEl?.classList.add('is-live')
          return
        }

        cardEl.classList.remove('border-red-500/40')
        liveButtonEl?.classList.remove('is-live')
        dotEl.className =
          'mt-2 h-3 w-3 rounded-full bg-[#ffda6a] shadow-[0_0_14px_rgba(255,218,106,0.7)]'

        kickerEl.textContent = 'البث القادم'

        if (!next || typeof totalSeconds !== 'number') {
          titleEl.textContent = 'حسب الجدول'
          metaEl.textContent = ''
          countdownValueEl.textContent = '-- : -- : --'
          countdownLabelEl.textContent = 'موعد البث القادم'
          return
        }

        titleEl.textContent = getNextStreamText(next)
        metaEl.textContent = ''
        countdownValueEl.innerHTML = renderCountdown(totalSeconds)
        countdownLabelEl.textContent = 'العد التنازلي'
      }

      function updateStreamPanel() {
        const timerEl = document.getElementById('next-stream-timer')
        const wrapperEl = document.getElementById('next-stream-wrapper')

        if (!timerEl) return

        const now = new Date()

        updateLiveDetails()

        if (twitchLiveStatus.live) {
          timerEl.textContent = 'البث مباشر الآن'
          timerEl.classList.remove('font-mono')
          timerEl.classList.add('font-bold', 'tnx-live-glow')

          wrapperEl?.classList.add('ring-1', 'ring-red-400/60')
          updateHeroCard(null, null)
          return
        }

        const next = getNextStreamStart(now)

        if (!next) {
          timerEl.textContent = '-- : -- : --'
          timerEl.classList.add('font-mono')
          timerEl.classList.remove('font-bold', 'tnx-live-glow')
          wrapperEl?.classList.remove('ring-1', 'ring-red-400/60')
          updateHeroCard(null, null)
          return
        }

        const totalSeconds = Math.max(0, Math.floor((next.getTime() - now.getTime()) / 1000))

        timerEl.innerHTML = renderCountdown(totalSeconds)
        timerEl.classList.add('font-mono')
        timerEl.classList.remove('font-bold', 'tnx-live-glow')

        wrapperEl?.classList.remove('ring-1', 'ring-red-400/60')
        updateHeroCard(next, totalSeconds)
      }

      function getStorageItem(key) {
        try {
          return window.localStorage.getItem(key)
        } catch {
          return null
        }
      }

      function setStorageItem(key, value) {
        try {
          window.localStorage.setItem(key, value)
        } catch {
          // Ignore storage errors.
        }
      }

      function updateRandomFanArt() {
        const topImg = document.getElementById('random-fanart-image-top')
        const bottomImg = document.getElementById('random-fanart-image-bottom')

        if (!Array.isArray(fanArtImages) || fanArtImages.length === 0) return

        const lastImage = getStorageItem('tnx-last-fanart')

        let availableImages = fanArtImages

        if (fanArtImages.length > 1 && lastImage) {
          availableImages = fanArtImages.filter((image) => image !== lastImage)
        }

        const randomImage = availableImages[Math.floor(Math.random() * availableImages.length)]

        if (!randomImage) return

        if (topImg) {
          topImg.setAttribute('src', randomImage)
          topImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        if (bottomImg) {
          bottomImg.setAttribute('src', randomImage)
          bottomImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        setStorageItem('tnx-last-fanart', randomImage)
      }

      function initScrollReveal() {
        const revealElements = Array.from(document.querySelectorAll('[data-reveal]'))

        if (revealElements.length === 0) return

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        if (reduceMotion || !('IntersectionObserver' in window)) {
          revealElements.forEach((element) => element.classList.add('is-visible'))
          return
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return

              entry.target.classList.add('is-visible')
              observer.unobserve(entry.target)
            })
          },
          {
            threshold: 0.12,
            rootMargin: '0px 0px -70px 0px',
          }
        )

        revealElements.forEach((element) => observer.observe(element))

        addCleanup(() => {
          observer.disconnect()
        })
      }

      function initBackToTopButton() {
        const button = document.getElementById('back-to-top')

        if (!button) return

        function updateButtonVisibility() {
          if (window.scrollY > 520) {
            button.classList.add('back-to-top-button--visible')
          } else {
            button.classList.remove('back-to-top-button--visible')
          }
        }

        function scrollToTop() {
          window.scrollTo({
            top: 0,
            behavior: 'smooth',
          })
        }

        window.addEventListener('scroll', updateButtonVisibility, { passive: true })
        button.addEventListener('click', scrollToTop)

        addCleanup(() => {
          window.removeEventListener('scroll', updateButtonVisibility)
          button.removeEventListener('click', scrollToTop)
        })

        updateButtonVisibility()
      }

      function init() {
        highlightTodayScheduleCard()
        updateRandomFanArt()
        loadSiteUpdates()
        initScrollReveal()
        initBackToTopButton()

        fetchTwitchLiveStatus().then(updateStreamPanel)
        updateStreamPanel()

        setIntervalSafe(updateStreamPanel, 1000)

        setIntervalSafe(() => {
          fetchTwitchLiveStatus().then(updateStreamPanel)
        }, 30000)
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init, { once: true })
      } else {
        init()
      }
    })()
  </script>
