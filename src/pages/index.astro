---
import Layout from '~/layouts/PageLayout.astro'
import fs from 'node:fs'
import path from 'node:path'

const metadata = {
  title: 'TNX6 — Streamer Hub',
  ignoreTitleTemplate: true,
  description:
    'موقع TNX6 الرسمي: البث، جدول البث، الأوامر، الترتيب، الأغراض، البدجات، الرسمات، والفائزين.',
}

const fanArtDir = path.join(process.cwd(), 'public', 'FANART')

const fanArtImages = fs.existsSync(fanArtDir)
  ? fs
      .readdirSync(fanArtDir)
      .filter((file) => /\.(png|jpe?g|webp|gif)$/i.test(file))
      .map((file) => `/FANART/${file}`)
  : []

const streamConfig = {
  startHour: 21,
  startMinute: 0,
  endHour: 2,
  days: [6, 0, 2, 3],
}

const scheduleItems = [
  {
    day: 6,
    name: 'السبت',
    time: '9:00 م',
    description: 'قصص وسوالف',
  },
  {
    day: 0,
    name: 'الأحد',
    time: '9:00 م',
    description: 'رعب وتجارب',
  },
  {
    day: 2,
    name: 'الثلاثاء',
    time: '9:00 م',
    description: 'تحديات المجتمع',
  },
  {
    day: 3,
    name: 'الأربعاء',
    time: '9:00 م',
    description: 'بث مفتوح',
  },
]

const shortcuts = [
  {
    title: 'الأوامر',
    eyebrow: 'ابدأ من هنا',
    description: 'كل أوامر الشات في صفحة واحدة.',
    href: '/commands',
    icon: 'tabler:terminal-2',
  },
  {
    title: 'الترتيب',
    eyebrow: 'مين متصدر؟',
    description: 'النقاط، الذهب، والمشاهدة.',
    href: '/leaderboards',
    icon: 'tabler:trophy',
  },
  {
    title: 'الأغراض',
    eyebrow: 'وش عندك؟',
    description: 'الصناديق وأغراض المجتمع.',
    href: '/items',
    icon: 'tabler:backpack',
  },
  {
    title: 'البدجات',
    eyebrow: 'إنجازاتك',
    description: 'الشارات والبدجات النادرة.',
    href: '/badges',
    icon: 'tabler:badge',
  },
  {
    title: 'الرسمات',
    eyebrow: 'فن المجتمع',
    description: 'رسمات ومشاركات المتابعين.',
    href: '/fan-art',
    icon: 'tabler:photo',
  },
  {
    title: 'الفائزون',
    eyebrow: 'لوحة الشرف',
    description: 'أسماء لها بصمة في المجتمع.',
    href: '/winners',
    icon: 'tabler:crown',
  },
]

const socialLinks = [
  {
    href: 'https://www.twitch.tv/tnx_6',
    label: 'Twitch',
    icon: 'tabler:brand-twitch',
  },
  {
    href: 'https://kick.com/tnx6',
    label: 'Kick',
    icon: 'tabler:letter-k',
  },
  {
    href: 'https://www.youtube.com/@TNX66',
    label: 'YouTube',
    icon: 'tabler:brand-youtube',
  },
  {
    href: 'https://www.tiktok.com/@itstnx',
    label: 'TikTok',
    icon: 'tabler:brand-tiktok',
  },
  {
    href: 'https://discord.gg/x7FtrfM6Sk',
    label: 'Discord',
    icon: 'tabler:brand-discord',
  },
]
---

<Layout metadata={metadata}>
  <main class="min-h-screen bg-black text-white">
    <section class="relative overflow-hidden px-6 pb-16 pt-24 md:pb-20 md:pt-28">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,218,106,0.17),transparent_32%),radial-gradient(circle_at_bottom_right,rgba(194,146,0,0.12),transparent_36%)]"></div>
      <div class="absolute inset-0 bg-black/70"></div>

      <div
        class="relative mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]"
        dir="rtl"
      >
        <div class="text-center lg:text-right">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#c29200]/35 bg-black/50 px-4 py-2 text-xs font-semibold text-[#ffda6a] shadow-[0_0_18px_rgba(194,146,0,0.18)]">
            <span class="h-2 w-2 rounded-full bg-[#ffda6a] shadow-[0_0_10px_#ffda6a]"></span>
            TNX6 STREAM HUB
          </div>

          <h1 class="mb-5 text-5xl font-extrabold leading-tight tracking-wide text-white md:text-7xl">
            TNX6
            <br />
            <span class="glow-text text-[#ffda6a]">
              <span
                id="changing-title"
                class="border-l-4 border-[#ffda6a] pl-1"
                dir="rtl"
              ></span>
            </span>
          </h1>

          <p class="mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-gray-200 lg:mx-0">
            رعب، قصص، سوالف، وتفاعل يخلي الشات جزء من البث.
            هنا تلقى الجدول، الأوامر، الترتيب، الأغراض، البدجات، والرسمات.
          </p>

          <div class="mb-8 flex flex-wrap justify-center gap-4 lg:justify-start">
            <a
              href="https://www.twitch.tv/tnx_6"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xl bg-gradient-to-r from-[#ffda6a] to-[#c29200] px-7 py-3 font-bold text-black shadow-lg shadow-[#c29200]/25 transition hover:-translate-y-0.5 hover:opacity-90"
            >
              شاهد البث
            </a>

            <a
              href="#live"
              class="rounded-xl border border-[#c29200]/70 px-7 py-3 font-semibold text-[#ffda6a] transition hover:-translate-y-0.5 hover:bg-[#c29200]/10"
            >
              حالة البث
            </a>

            <a
              href="/links"
              class="rounded-xl border border-white/15 px-7 py-3 font-semibold text-gray-200 transition hover:-translate-y-0.5 hover:border-[#c29200]/70 hover:text-[#ffda6a]"
            >
              الروابط
            </a>
          </div>

          <div class="flex justify-center gap-4 lg:justify-start">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
                class="social-icon flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-black/50 transition hover:border-[#c29200]/60 hover:bg-[#c29200]/10"
              >
                <iconify-icon
                  icon={link.icon}
                  class="text-2xl text-gray-300 transition hover:text-[#ffda6a]"
                ></iconify-icon>
              </a>
            ))}
          </div>
        </div>

        <div class="grid gap-5">
          <div class="relative mx-auto w-full max-w-md">
            <div class="absolute -inset-1 rounded-[2rem] bg-gradient-to-br from-[#ffda6a]/50 via-[#c29200]/15 to-transparent blur-xl"></div>

            <div class="relative rounded-[2rem] border border-[#c29200]/35 bg-[#060606]/90 p-4 shadow-2xl">
              <img
                id="random-fanart-image-top"
                src="/assets/images/tnx-min.jpg"
                alt="TNX6"
                class="aspect-square w-full rounded-[1.5rem] object-cover"
                width="460"
                height="460"
              />

              <div class="mt-4 flex items-center justify-between gap-3" dir="rtl">
                <div>
                  <p class="text-sm font-bold text-[#ffda6a]">من المجتمع</p>
                  <p class="text-xs text-gray-400">صورة عشوائية من معرض الرسمات</p>
                </div>

                <a
                  href="/fan-art"
                  class="rounded-lg border border-[#c29200]/50 px-4 py-2 text-xs font-semibold text-[#ffda6a] transition hover:bg-[#c29200]/10"
                >
                  المعرض
                </a>
              </div>
            </div>
          </div>

          <div
            id="hero-live-card"
            class="mx-auto w-full max-w-md rounded-3xl border border-[#c29200]/30 bg-black/70 p-5 shadow-[0_0_30px_rgba(0,0,0,0.45)]"
            dir="rtl"
          >
            <div class="mb-3 flex items-center justify-between gap-3">
              <div>
                <p id="hero-live-kicker" class="text-xs font-semibold text-gray-400">
                  حالة البث
                </p>
                <h2 id="hero-live-title" class="mt-1 text-xl font-extrabold text-[#ffda6a]">
                  جاري التحقق من Twitch...
                </h2>
              </div>

              <div
                id="hero-live-dot"
                class="h-3 w-3 rounded-full bg-gray-500"
              ></div>
            </div>

            <p id="hero-live-meta" class="text-sm leading-relaxed text-gray-300">
              بنعرض لك حالة البث الفعلية هنا.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      id="live"
      class="relative border-y border-[#c29200]/10 bg-black/85 px-6 py-14 md:py-16"
    >
      <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1fr_360px]" dir="rtl">
        <div class="rounded-[2rem] border border-[#c29200]/30 bg-[#050505]/90 p-4 shadow-2xl">
          <div class="mb-4 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-semibold tracking-[0.25em] text-[#c29200]">
                LIVE
              </p>
              <h2 class="heading-gold-glow mt-1 text-2xl font-extrabold text-[#ffda6a]">
                البث
              </h2>
            </div>

            <div
              id="next-stream-wrapper"
              class="inline-flex flex-wrap items-center justify-center gap-3 rounded-full border border-[#c29200]/60 bg-black/70 px-4 py-2 text-xs shadow-[0_0_20px_rgba(0,0,0,0.45)] md:text-sm"
            >
              <span
                id="next-stream-timer"
                class="font-mono text-sm font-semibold text-[#ffda6a] md:text-base"
              >
                -- : -- : --
              </span>

              <span id="next-stream-label" class="text-[13px] text-slate-100 md:text-sm">
                موعد البث القادم
              </span>

              <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-[#c29200]/60 bg-black/60 text-[12px] text-[#ffda6a]">
                🎥
              </span>
            </div>
          </div>

          <div
            id="live-details"
            class="mb-4 hidden rounded-2xl border border-[#c29200]/20 bg-black/60 px-4 py-3 text-sm text-gray-300"
          >
            <span id="live-title" class="text-[#ffda6a]"></span>
            <span id="live-game" class="text-gray-400"></span>
          </div>

          <div class="aspect-video w-full overflow-hidden rounded-2xl border border-[#c29200]/30 bg-black shadow-2xl">
            <iframe
              src="https://player.twitch.tv/?channel=tnx_6&parent=tnx6.xyz&parent=www.tnx6.xyz&parent=tnx6.github.io"
              allowfullscreen
              frameborder="0"
              scrolling="no"
              width="100%"
              height="100%"
              title="TNX6 Twitch Stream"
            ></iframe>
          </div>
        </div>

        <aside class="rounded-[2rem] border border-[#c29200]/30 bg-[#050505]/90 p-5 shadow-2xl">
          <div class="mb-5 flex items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold tracking-[0.25em] text-[#c29200]">
                SCHEDULE
              </p>
              <h2 class="heading-gold-glow mt-1 text-2xl font-extrabold text-[#ffda6a]">
                جدول البث
              </h2>
            </div>

            <iconify-icon
              icon="tabler:calendar-time"
              class="text-3xl text-[#ffda6a]"
            ></iconify-icon>
          </div>

          <div class="space-y-3">
            {scheduleItems.map((item) => (
              <div
                class="tnx-schedule-card flex items-center justify-between gap-4 rounded-2xl border border-[#c29200]/15 px-4 py-4 text-sm text-gray-200"
                data-schedule-day={item.day}
              >
                <div>
                  <div class="font-bold text-white">
                    {item.name}
                  </div>

                  <div class="mt-1 text-xs text-gray-400">
                    {item.description}
                  </div>
                </div>

                <div class="shrink-0 rounded-xl border border-[#c29200]/30 bg-black/60 px-3 py-2 font-bold text-[#ffda6a]">
                  {item.time}
                </div>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="relative bg-black px-6 py-16">
      <div class="mx-auto max-w-7xl" dir="rtl">
        <div class="mb-7 flex flex-col gap-2 text-center md:text-right">
          <p class="text-xs font-semibold tracking-[0.25em] text-[#c29200]">
            QUICK ACCESS
          </p>

          <h2 class="heading-gold-glow text-3xl font-extrabold text-[#ffda6a]">
            اختصارات المجتمع
          </h2>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {shortcuts.map((card) => (
            <a
              href={card.href}
              class="group rounded-3xl border border-[#c29200]/18 bg-[#070707] p-5 text-right transition hover:-translate-y-1 hover:border-[#c29200]/70 hover:shadow-[0_0_24px_rgba(194,146,0,0.22)]"
            >
              <div class="mb-4 flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[#c29200]/30 bg-black text-[#ffda6a]">
                  <iconify-icon icon={card.icon} class="text-2xl"></iconify-icon>
                </div>

                <span class="rounded-full border border-white/10 px-3 py-1 text-[11px] font-semibold text-gray-400">
                  {card.eyebrow}
                </span>
              </div>

              <h3 class="mb-2 text-xl font-bold text-white group-hover:text-[#ffda6a]">
                {card.title}
              </h3>

              <p class="text-sm leading-relaxed text-gray-400">
                {card.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="relative bg-black/85 px-6 py-16">
      <div
        class="mx-auto grid max-w-7xl overflow-hidden rounded-[2rem] border border-[#c29200]/30 bg-[#050505]/90 shadow-2xl md:grid-cols-[0.9fr_1.1fr]"
        dir="rtl"
      >
        <div class="relative min-h-[320px] border-b border-[#c29200]/20 md:border-b-0 md:border-l">
          <img
            id="random-fanart-image-bottom"
            src="/assets/images/tnx-min.jpg"
            alt="TNX6 Fan Art"
            class="h-full min-h-[320px] w-full object-cover"
            width="620"
            height="620"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
          <div class="absolute bottom-5 right-5">
            <p class="text-sm font-bold text-[#ffda6a]">من رسم المجتمع</p>
            <p class="text-xs text-gray-300">الصورة تتغير من معرض الرسمات</p>
          </div>
        </div>

        <div class="p-7 md:p-10">
          <p class="mb-3 text-xs font-semibold tracking-[0.25em] text-[#c29200]">
            ABOUT
          </p>

          <h2 class="heading-gold-glow mb-5 text-3xl font-extrabold text-[#ffda6a]">
            عن TNX6
          </h2>

          <p class="mb-8 max-w-2xl text-lg leading-relaxed text-gray-200">
            بثوث رعب وقصص وسوالف، لكن التفاعل هو الأساس.
            النقاط، الأغراض، البدجات، والتحديات تخلي المشاهد جزء من البث، مو مجرد اسم في الشات.
          </p>

          <div class="mb-8 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-black/60 p-4 text-center">
              <iconify-icon
                icon="tabler:ghost-2"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                رعب
              </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-black/60 p-4 text-center">
              <iconify-icon
                icon="tabler:message-circle"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                سوالف
              </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-black/60 p-4 text-center">
              <iconify-icon
                icon="tabler:users"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                مجتمع
              </div>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href="/fan-art"
              class="rounded-xl border border-[#c29200]/70 px-6 py-3 font-semibold text-[#ffda6a] transition hover:bg-[#c29200]/10"
            >
              معرض الرسمات
            </a>

            <a
              href="/winners"
              class="rounded-xl border border-white/15 px-6 py-3 font-semibold text-gray-200 transition hover:border-[#c29200]/70 hover:text-[#ffda6a]"
            >
              الفائزون
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    .glow-text {
      text-shadow:
        0 0 5px rgba(255, 218, 106, 0.7),
        0 0 15px rgba(194, 146, 0, 0.7);
    }

    .heading-gold-glow {
      text-shadow:
        0 0 6px rgba(255, 218, 106, 0.55),
        0 0 14px rgba(255, 218, 106, 0.35),
        0 0 24px rgba(194, 146, 0, 0.3);
    }

    .social-icon:hover iconify-icon {
      filter: drop-shadow(0 0 4px #ffda6a);
    }

    #changing-title {
      animation: cursor-blink 1s step-end infinite;
    }

    @keyframes cursor-blink {
      from,
      to {
        border-color: transparent;
      }

      50% {
        border-color: #ffda6a;
      }
    }
  </style>

  <style is:global>
    .tnx-live-glow {
      color: #fef08a;
      text-shadow:
        0 0 5px #facc15,
        0 0 12px #facc15,
        0 0 20px #facc15;
      animation: tnx-live-pulse 1.4s ease-in-out infinite;
    }

    @keyframes tnx-live-pulse {
      0%,
      100% {
        text-shadow:
          0 0 4px #facc15,
          0 0 10px #facc15,
          0 0 18px #facc15;
      }

      50% {
        text-shadow:
          0 0 8px #fde68a,
          0 0 18px #facc15,
          0 0 28px #fbbf24;
      }
    }

    .tnx-schedule-card {
      background: linear-gradient(
        180deg,
        rgba(12, 15, 24, 0.96) 0%,
        rgba(7, 9, 15, 0.98) 100%
      );
      backdrop-filter: blur(8px);
      transition: all 0.25s ease;
    }

    .tnx-schedule-card:hover {
      transform: translateY(-2px);
      border-color: rgba(194, 146, 0, 0.35);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .tnx-schedule-card--active {
      border-color: rgba(194, 146, 0, 0.9) !important;
      box-shadow: 0 0 22px rgba(194, 146, 0, 0.45);
    }
  </style>

  <script>
    const titles = ['رعب وقصص', 'سوالف وتحديات', 'مجتمع حي']
    const titleElement = document.getElementById('changing-title')

    let currentTitleIndex = 0
    let charIndex = 0
    let isDeleting = false
    let typingSpeed = 100
    const delayAfterTyping = 1500

    function typeWriterEffect() {
      if (!titleElement) return

      const currentTitle = titles[currentTitleIndex]

      if (isDeleting) {
        titleElement.textContent = currentTitle.substring(0, charIndex - 1)
        charIndex--
        typingSpeed = 50
      } else {
        titleElement.textContent = currentTitle.substring(0, charIndex + 1)
        charIndex++
        typingSpeed = 100
      }

      if (!isDeleting && charIndex === currentTitle.length) {
        isDeleting = true
        typingSpeed = delayAfterTyping
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false
        currentTitleIndex = (currentTitleIndex + 1) % titles.length
        typingSpeed = 200
      }

      window.setTimeout(typeWriterEffect, typingSpeed)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', typeWriterEffect)
    } else {
      typeWriterEffect()
    }
  </script>

  <script define:vars={{ streamConfig }}>
    const STREAM_START_HOUR = streamConfig.startHour
    const STREAM_START_MINUTE = streamConfig.startMinute
    const STREAM_END_HOUR = streamConfig.endHour
    const STREAM_DAYS = streamConfig.days

    const TWITCH_STATUS_URL = 'https://tnx6-twitch-status.ddxdx240.workers.dev'

    let twitchLiveStatus = {
      checked: false,
      live: false,
      title: null,
      game: null,
      viewers: 0,
    }

    async function fetchTwitchLiveStatus() {
      try {
        const response = await fetch(TWITCH_STATUS_URL, {
          cache: 'no-store',
        })

        if (!response.ok) return

        const data = await response.json()

        twitchLiveStatus = {
          checked: true,
          live: Boolean(data.live),
          title: data.title || null,
          game: data.game || null,
          viewers: Number(data.viewers || 0),
        }
      } catch {
        twitchLiveStatus = {
          checked: false,
          live: false,
          title: null,
          game: null,
          viewers: 0,
        }
      }
    }

    function isStreamDay(date) {
      return STREAM_DAYS.includes(date.getDay())
    }

    function getNextStreamStart(now) {
      for (let offset = 0; offset < 14; offset++) {
        const candidateDay = new Date(now)
        candidateDay.setDate(candidateDay.getDate() + offset)

        if (!isStreamDay(candidateDay)) continue

        const start = new Date(candidateDay)
        start.setHours(STREAM_START_HOUR, STREAM_START_MINUTE, 0, 0)

        if (start > now) return start
      }

      return null
    }

    function getNextStreamText(next, now) {
      if (!next) return 'موعد البث القادم'

      const dayNames = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت']
      const isToday = next.toDateString() === now.toDateString()

      return isToday
        ? 'بث اليوم'
        : `${dayNames[next.getDay()]} — 9:00 م`
    }

    function highlightTodayScheduleCard() {
      const todayDay = new Date().getDay()

      document.querySelectorAll('.tnx-schedule-card').forEach((card) => {
        card.classList.remove('tnx-schedule-card--active')

        const dayAttr = card.getAttribute('data-schedule-day')
        if (!dayAttr) return

        if (Number.parseInt(dayAttr, 10) === todayDay) {
          card.classList.add('tnx-schedule-card--active')
        }
      })
    }

    function updateLiveDetails() {
      const detailsEl = document.getElementById('live-details')
      const titleEl = document.getElementById('live-title')
      const gameEl = document.getElementById('live-game')

      if (!detailsEl || !titleEl || !gameEl) return

      if (!twitchLiveStatus.live) {
        detailsEl.classList.add('hidden')
        titleEl.textContent = ''
        gameEl.textContent = ''
        return
      }

      titleEl.textContent = twitchLiveStatus.title || 'البث مباشر الآن'
      gameEl.textContent = twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''
      detailsEl.classList.remove('hidden')
    }

    function updateHeroLiveCard(next, totalSeconds) {
      const cardEl = document.getElementById('hero-live-card')
      const kickerEl = document.getElementById('hero-live-kicker')
      const titleEl = document.getElementById('hero-live-title')
      const metaEl = document.getElementById('hero-live-meta')
      const dotEl = document.getElementById('hero-live-dot')

      if (!cardEl || !kickerEl || !titleEl || !metaEl || !dotEl) return

      if (twitchLiveStatus.live) {
        kickerEl.textContent = 'مباشر الآن'
        titleEl.textContent = twitchLiveStatus.title || 'البث شغال'
        metaEl.textContent =
          twitchLiveStatus.viewers > 0
            ? `${twitchLiveStatus.viewers} مشاهد على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`
            : `على Twitch${twitchLiveStatus.game ? ` — ${twitchLiveStatus.game}` : ''}`

        dotEl.className = 'h-3 w-3 rounded-full bg-red-500 shadow-[0_0_14px_rgba(239,68,68,0.9)]'
        cardEl.classList.add('border-red-500/40')
        return
      }

      cardEl.classList.remove('border-red-500/40')
      dotEl.className = 'h-3 w-3 rounded-full bg-[#ffda6a] shadow-[0_0_14px_rgba(255,218,106,0.7)]'

      kickerEl.textContent = 'البث القادم'

      if (!next || typeof totalSeconds !== 'number') {
        titleEl.textContent = 'حسب الجدول'
        metaEl.textContent = 'العداد يظهر عند توفر الموعد القادم.'
        return
      }

      const hours = Math.floor(totalSeconds / 3600)
      const minutes = Math.floor((totalSeconds % 3600) / 60)

      titleEl.textContent = getNextStreamText(next, new Date())
      metaEl.textContent = `باقي تقريبًا ${hours} ساعة و ${minutes} دقيقة`
    }

    function startNextStreamCountdown() {
      const timerEl = document.getElementById('next-stream-timer')
      const wrapperEl = document.getElementById('next-stream-wrapper')
      const labelEl = document.getElementById('next-stream-label')

      if (!timerEl) return

      function resetLiveStyles() {
        timerEl.classList.add('font-mono')
        timerEl.classList.remove('font-bold', 'tnx-live-glow')
        wrapperEl?.classList.remove('ring-1', 'ring-red-400/60')
      }

      function update() {
        const now = new Date()

        updateLiveDetails()

        if (twitchLiveStatus.live) {
          timerEl.textContent = 'البث مباشر الآن'
          timerEl.classList.remove('font-mono')
          timerEl.classList.add('font-bold', 'tnx-live-glow')

          if (labelEl) {
            labelEl.textContent =
              twitchLiveStatus.viewers > 0
                ? `${twitchLiveStatus.viewers} مشاهد`
                : 'على Twitch'
          }

          wrapperEl?.classList.add('ring-1', 'ring-red-400/60')
          updateHeroLiveCard(null, null)
          return
        }

        const next = getNextStreamStart(now)

        if (!next) {
          timerEl.textContent = '-- : -- : --'

          if (labelEl) {
            labelEl.textContent = 'موعد البث القادم'
          }

          resetLiveStyles()
          updateHeroLiveCard(null, null)
          return
        }

        const totalSeconds = Math.max(0, Math.floor((next.getTime() - now.getTime()) / 1000))
        const h = Math.floor(totalSeconds / 3600)
        const m = Math.floor((totalSeconds % 3600) / 60)
        const s = totalSeconds % 60

        timerEl.textContent =
          String(h).padStart(2, '0') +
          ' : ' +
          String(m).padStart(2, '0') +
          ' : ' +
          String(s).padStart(2, '0')

        if (labelEl) {
          labelEl.textContent = getNextStreamText(next, now)
        }

        resetLiveStyles()
        updateHeroLiveCard(next, totalSeconds)
      }

      fetchTwitchLiveStatus().then(update)

      window.setInterval(update, 1000)

      window.setInterval(() => {
        fetchTwitchLiveStatus().then(update)
      }, 30000)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        startNextStreamCountdown()
        highlightTodayScheduleCard()
      })
    } else {
      startNextStreamCountdown()
      highlightTodayScheduleCard()
    }
  </script>

  <script define:vars={{ fanArtImages }}>
    const topImg = document.getElementById('random-fanart-image-top')
    const bottomImg = document.getElementById('random-fanart-image-bottom')

    function getStorageItem(key) {
      try {
        return window.localStorage.getItem(key)
      } catch {
        return null
      }
    }

    function setStorageItem(key, value) {
      try {
        window.localStorage.setItem(key, value)
      } catch {
        // Ignore storage errors.
      }
    }

    if (Array.isArray(fanArtImages) && fanArtImages.length > 0) {
      const lastImage = getStorageItem('tnx-last-fanart')

      let availableImages = fanArtImages

      if (fanArtImages.length > 1 && lastImage) {
        availableImages = fanArtImages.filter((image) => image !== lastImage)
      }

      const randomImage = availableImages[Math.floor(Math.random() * availableImages.length)]

      if (randomImage) {
        if (topImg) {
          topImg.setAttribute('src', randomImage)
          topImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        if (bottomImg) {
          bottomImg.setAttribute('src', randomImage)
          bottomImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        setStorageItem('tnx-last-fanart', randomImage)
      }
    }
  </script>
</Layout>
