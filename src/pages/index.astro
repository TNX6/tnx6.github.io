---
import Layout from '~/layouts/PageLayout.astro'
import fs from 'node:fs'
import path from 'node:path'

const metadata = {
  title: 'TNX6 — Streamer Hub',
  ignoreTitleTemplate: true,
  description:
    'موقع TNX6 الرسمي: البث، جدول البث، الأوامر، الترتيب، الأغراض، البدجات، الرسمات، والفائزين.',
}

const fanArtDir = path.join(process.cwd(), 'public', 'FANART')

const fanArtImages = fs.existsSync(fanArtDir)
  ? fs
      .readdirSync(fanArtDir)
      .filter((file) => /\.(png|jpe?g|webp|gif)$/i.test(file))
      .map((file) => `/FANART/${file}`)
  : []

const streamConfig = {
  startHour: 21,
  startMinute: 0,
  endHour: 2,
  days: [6, 0, 2, 3],
}

const scheduleItems = [
  {
    day: 6,
    name: 'السبت',
    time: '9:00 م',
    description: 'قصص وسوالف',
  },
  {
    day: 0,
    name: 'الأحد',
    time: '9:00 م',
    description: 'رعب وتجارب',
  },
  {
    day: 2,
    name: 'الثلاثاء',
    time: '9:00 م',
    description: 'تحديات المجتمع',
  },
  {
    day: 3,
    name: 'الأربعاء',
    time: '9:00 م',
    description: 'بث مفتوح',
  },
]

const shortcuts = [
  {
    title: 'الأوامر',
    description: 'كل أوامر الشات.',
    href: '/commands',
    icon: 'tabler:terminal-2',
  },
  {
    title: 'الترتيب',
    description: 'النقاط، الذهب، والمشاهدة.',
    href: '/leaderboards',
    icon: 'tabler:trophy',
  },
  {
    title: 'الأغراض',
    description: 'الصناديق وأغراض المجتمع.',
    href: '/items',
    icon: 'tabler:backpack',
  },
  {
    title: 'البدجات',
    description: 'الشارات والإنجازات.',
    href: '/badges',
    icon: 'tabler:badge',
  },
  {
    title: 'الرسمات',
    description: 'إبداعات المجتمع.',
    href: '/fan-art',
    icon: 'tabler:photo',
  },
  {
    title: 'الفائزون',
    description: 'أسماء لها بصمة.',
    href: '/winners',
    icon: 'tabler:crown',
  },
]

const socialLinks = [
  {
    href: 'https://www.twitch.tv/tnx_6',
    label: 'Twitch',
    icon: 'tabler:brand-twitch',
  },
  {
    href: 'https://kick.com/tnx6',
    label: 'Kick',
    icon: 'tabler:letter-k',
  },
  {
    href: 'https://www.youtube.com/@TNX66',
    label: 'YouTube',
    icon: 'tabler:brand-youtube',
  },
  {
    href: 'https://www.tiktok.com/@itstnx',
    label: 'TikTok',
    icon: 'tabler:brand-tiktok',
  },
  {
    href: 'https://discord.gg/x7FtrfM6Sk',
    label: 'Discord',
    icon: 'tabler:brand-discord',
  },
]
---

<Layout metadata={metadata}>
  <main class="min-h-screen bg-black text-white">
    <section class="relative overflow-hidden px-6 py-24 md:py-28">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,218,106,0.16),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(194,146,0,0.12),transparent_38%)]"></div>
      <div class="absolute inset-0 bg-black/65"></div>

      <div
        class="relative mx-auto grid max-w-7xl items-center gap-12 text-center md:grid-cols-2 md:text-right"
        dir="rtl"
      >
        <div class="relative flex justify-center md:order-2">
          <div class="tnx-avatar-animation group relative w-full max-w-sm">
            <img
              id="random-fanart-image-top"
              src="/assets/images/tnx-min.jpg"
              alt="TNX6"
              class="aspect-square w-full rounded-full border-2 border-[#ffda6a]/80 object-cover shadow-lg transition-transform duration-500 group-hover:scale-105"
              width="400"
              height="400"
            />

            <div class="pointer-events-none absolute inset-0 rounded-full opacity-80 shadow-[0_0_20px_#ffda6a,0_0_52px_#c29200]"></div>
          </div>
        </div>

        <div class="md:order-1">
          <p class="mb-3 text-sm font-semibold tracking-[0.35em] text-[#ffda6a] md:text-base">
            TNX6
          </p>

          <h1 class="mb-6 text-5xl font-extrabold leading-tight tracking-wide text-white drop-shadow-lg md:text-6xl">
            مو مجرد بث.
            <br />
            <span class="text-[#ffda6a] glow-text">
              <span
                id="changing-title"
                class="border-l-4 border-[#ffda6a] pl-1"
                dir="rtl"
              ></span>
            </span>
          </h1>

          <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-gray-200 md:mx-0">
            قصص، رعب، سوالف، وتحديات مجتمع. هنا تلقى كل شيء يخص TNX6:
            البث، الجدول، الأوامر، الترتيب، الأغراض، البدجات، والرسمات.
          </p>

          <div class="flex flex-wrap justify-center gap-4 md:justify-start">
            <a
              href="https://www.twitch.tv/tnx_6"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg bg-gradient-to-r from-[#ffda6a] to-[#c29200] px-8 py-3 font-semibold text-black shadow-lg shadow-[#c29200]/30 transition hover:opacity-90"
            >
              شاهد البث
            </a>

            <a
              href="#stream"
              class="rounded-lg border border-[#c29200] px-8 py-3 text-[#ffda6a] transition hover:bg-[#c29200]/10"
            >
              جدول البث
            </a>

            <a
              href="/links"
              class="rounded-lg border border-white/15 px-8 py-3 text-gray-200 transition hover:border-[#c29200]/70 hover:text-[#ffda6a]"
            >
              الروابط
            </a>
          </div>

          <div class="mt-8 flex justify-center gap-4 md:justify-start">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
                class="social-icon"
              >
                <iconify-icon
                  icon={link.icon}
                  class="text-3xl text-gray-400 transition hover:text-[#ffda6a]"
                ></iconify-icon>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section
      id="stream"
      class="relative border-y border-[#c29200]/10 bg-black/85 px-6 py-20 text-center"
    >
      <div class="mx-auto max-w-5xl">
        <div class="mb-5 flex justify-center">
          <div
            id="next-stream-wrapper"
            class="inline-flex flex-wrap items-center justify-center gap-3 rounded-full border border-[#c29200]/70 bg-black/70 px-5 py-2 text-xs shadow-[0_0_25px_rgba(0,0,0,0.7)] md:text-sm"
          >
            <span
              id="next-stream-timer"
              class="font-mono text-sm font-semibold text-[#ffda6a] md:text-base"
            >
              -- : -- : --
            </span>

            <span id="next-stream-label" class="text-[13px] text-slate-100 md:text-sm">
              موعد البث القادم
            </span>

            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-[#c29200]/70 bg-black/60 text-[12px] text-[#ffda6a]">
              🎥
            </span>
          </div>
        </div>

        <div class="mx-auto aspect-video w-full max-w-4xl overflow-hidden rounded-2xl border border-[#c29200]/40 shadow-2xl">
          <iframe
            src="https://player.twitch.tv/?channel=tnx_6&parent=tnx6.xyz&parent=www.tnx6.xyz&parent=tnx6.github.io"
            allowfullscreen
            frameborder="0"
            scrolling="no"
            width="100%"
            height="100%"
            title="TNX6 Twitch Stream"
          ></iframe>
        </div>

        <div class="mx-auto mt-10 w-full max-w-5xl" dir="rtl">
          <div class="rounded-3xl border border-[#c29200]/40 bg-black/70 px-5 py-4 shadow-[0_0_25px_rgba(0,0,0,0.65)] md:px-8 md:py-6">
            <div class="mb-4 flex items-center justify-center">
              <div class="flex items-center gap-2 text-sm md:text-base">
                <iconify-icon
                  icon="tabler:calendar-time"
                  class="text-lg text-[#ffda6a] md:text-xl"
                ></iconify-icon>

                <h2 class="heading-gold-glow text-base font-bold text-[#ffda6a] md:text-lg">
                  جدول البث الأسبوعي
                </h2>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
              {scheduleItems.map((item) => (
                <div
                  class="tnx-schedule-card flex min-h-[125px] flex-col items-center justify-center gap-2 rounded-2xl border border-[#c29200]/15 px-4 py-4 text-center text-xs text-gray-200 md:px-5 md:py-5 md:text-sm"
                  data-schedule-day={item.day}
                >
                  <div class="text-sm font-bold text-white md:text-base">
                    {item.name}
                  </div>

                  <div class="flex items-center justify-center text-sm font-semibold text-[#ffda6a] md:text-base">
                    <span>{item.time}</span>
                  </div>

                  <div class="text-[11px] leading-relaxed text-gray-400 md:text-xs">
                    {item.description}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="relative bg-black px-6 py-24">
      <div class="mx-auto max-w-6xl" dir="rtl">
        <div class="mb-10 text-center">
          <p class="mb-3 text-sm font-semibold tracking-[0.25em] text-[#c29200]">
            TNX6 HUB
          </p>

          <h2 class="heading-gold-glow mb-3 text-3xl font-extrabold text-[#ffda6a] md:text-4xl">
            استكشف الموقع
          </h2>

          <p class="mx-auto max-w-2xl text-gray-300">
            اختصارات سريعة لأهم صفحات المجتمع.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {shortcuts.map((card) => (
            <a
              href={card.href}
              class="group rounded-2xl border border-[#c29200]/20 bg-[#080808] p-5 text-right transition hover:-translate-y-1 hover:border-[#c29200]/70 hover:shadow-[0_0_22px_rgba(194,146,0,0.25)]"
            >
              <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl border border-[#c29200]/30 bg-black text-[#ffda6a]">
                <iconify-icon icon={card.icon} class="text-2xl"></iconify-icon>
              </div>

              <h3 class="mb-2 text-xl font-bold text-white group-hover:text-[#ffda6a]">
                {card.title}
              </h3>

              <p class="text-sm leading-relaxed text-gray-400">
                {card.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="relative border-y border-[#c29200]/10 bg-black/85 px-6 py-24">
      <div class="mx-auto grid max-w-6xl items-center gap-16 md:grid-cols-2">
        <div class="relative">
          <img
            id="random-fanart-image-bottom"
            src="/assets/images/tnx-min.jpg"
            alt="TNX6 Fan Art"
            class="mx-auto aspect-square w-full max-w-sm rounded-2xl border border-[#c29200]/40 object-cover shadow-lg transition-transform duration-500 hover:scale-105"
            width="300"
            height="300"
            loading="lazy"
          />

          <div class="mx-auto mt-4 max-w-sm text-center text-sm text-gray-400">
            من رسم المجتمع
          </div>
        </div>

        <div dir="rtl">
          <p class="mb-3 text-sm font-semibold tracking-[0.25em] text-[#c29200]">
            ABOUT
          </p>

          <h2 class="heading-gold-glow mb-6 text-3xl font-bold text-[#ffda6a]">
            مين TNX6؟
          </h2>

          <p class="mb-8 text-lg leading-relaxed text-gray-200">
            ستريمر عربي يقدم بثوث تجمع بين القصص، الرعب، السوالف، وتحديات المجتمع.
            الموقع هذا معمول عشان يكون مدخل واضح لكل شيء يصير حول البث.
          </p>

          <div class="grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl border border-white/10 bg-[#090909] p-4 text-center">
              <iconify-icon
                icon="tabler:message-circle"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                سوالف
              </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-[#090909] p-4 text-center">
              <iconify-icon
                icon="tabler:ghost-2"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                رعب
              </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-[#090909] p-4 text-center">
              <iconify-icon
                icon="tabler:users"
                class="mb-2 text-2xl text-[#ffda6a]"
              ></iconify-icon>
              <div class="text-sm font-semibold text-gray-200">
                مجتمع
              </div>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/fan-art"
              class="inline-flex rounded-lg border border-[#c29200] px-6 py-3 text-[#ffda6a] transition hover:bg-[#c29200]/10"
            >
              معرض الرسمات
            </a>

            <a
              href="/winners"
              class="inline-flex rounded-lg border border-white/15 px-6 py-3 text-gray-200 transition hover:border-[#c29200]/70 hover:text-[#ffda6a]"
            >
              الفائزون
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    @keyframes float-up-down {
      0% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-10px);
      }

      100% {
        transform: translateY(0);
      }
    }

    .tnx-avatar-animation {
      animation: float-up-down 4s ease-in-out infinite;
    }

    .glow-text {
      text-shadow:
        0 0 5px rgba(255, 218, 106, 0.7),
        0 0 15px rgba(194, 146, 0, 0.7);
    }

    .heading-gold-glow {
      text-shadow:
        0 0 6px rgba(255, 218, 106, 0.55),
        0 0 14px rgba(255, 218, 106, 0.35),
        0 0 24px rgba(194, 146, 0, 0.3);
    }

    .social-icon:hover iconify-icon {
      filter: drop-shadow(0 0 4px #ffda6a);
    }

    #changing-title {
      animation: cursor-blink 1s step-end infinite;
    }

    @keyframes cursor-blink {
      from,
      to {
        border-color: transparent;
      }

      50% {
        border-color: #ffda6a;
      }
    }
  </style>

  <style is:global>
    .tnx-live-glow {
      color: #fef08a;
      text-shadow:
        0 0 5px #facc15,
        0 0 12px #facc15,
        0 0 20px #facc15;
      animation: tnx-live-pulse 1.4s ease-in-out infinite;
    }

    @keyframes tnx-live-pulse {
      0%,
      100% {
        text-shadow:
          0 0 4px #facc15,
          0 0 10px #facc15,
          0 0 18px #facc15;
        transform: translateY(0);
      }

      50% {
        text-shadow:
          0 0 8px #fde68a,
          0 0 18px #facc15,
          0 0 28px #fbbf24;
        transform: translateY(-0.5px);
      }
    }

    .tnx-schedule-card {
      background: linear-gradient(
        180deg,
        rgba(12, 15, 24, 0.96) 0%,
        rgba(7, 9, 15, 0.98) 100%
      );
      backdrop-filter: blur(8px);
      transition: all 0.25s ease;
    }

    .tnx-schedule-card:hover {
      transform: translateY(-3px);
      border-color: rgba(194, 146, 0, 0.35);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .tnx-schedule-card--active {
      border-color: rgba(194, 146, 0, 0.9) !important;
      box-shadow: 0 0 22px rgba(194, 146, 0, 0.45);
    }
  </style>

  <script>
    const titles = ['قصص ورعب', 'سوالف وتحديات', 'مجتمع داخل القصة']
    const titleElement = document.getElementById('changing-title')

    let currentTitleIndex = 0
    let charIndex = 0
    let isDeleting = false
    let typingSpeed = 100
    const delayAfterTyping = 1500

    function typeWriterEffect() {
      if (!titleElement) return

      const currentTitle = titles[currentTitleIndex]

      if (isDeleting) {
        titleElement.textContent = currentTitle.substring(0, charIndex - 1)
        charIndex--
        typingSpeed = 50
      } else {
        titleElement.textContent = currentTitle.substring(0, charIndex + 1)
        charIndex++
        typingSpeed = 100
      }

      if (!isDeleting && charIndex === currentTitle.length) {
        isDeleting = true
        typingSpeed = delayAfterTyping
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false
        currentTitleIndex = (currentTitleIndex + 1) % titles.length
        typingSpeed = 200
      }

      window.setTimeout(typeWriterEffect, typingSpeed)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', typeWriterEffect)
    } else {
      typeWriterEffect()
    }
  </script>

  <script define:vars={{ streamConfig }}>
    const STREAM_START_HOUR = streamConfig.startHour
    const STREAM_START_MINUTE = streamConfig.startMinute
    const STREAM_END_HOUR = streamConfig.endHour
    const STREAM_DAYS = streamConfig.days

    function isStreamDay(date) {
      return STREAM_DAYS.includes(date.getDay())
    }

    function isInStreamWindow(now) {
      const today = new Date(now)
      const yesterday = new Date(now)
      yesterday.setDate(yesterday.getDate() - 1)

      function inWindowFor(dateObj) {
        if (!isStreamDay(dateObj)) return false

        const start = new Date(dateObj)
        start.setHours(STREAM_START_HOUR, STREAM_START_MINUTE, 0, 0)

        const end = new Date(start)
        end.setDate(end.getDate() + 1)
        end.setHours(STREAM_END_HOUR, 0, 0, 0)

        return now >= start && now < end
      }

      return inWindowFor(today) || inWindowFor(yesterday)
    }

    function getNextStreamStart(now) {
      for (let offset = 0; offset < 14; offset++) {
        const candidateDay = new Date(now)
        candidateDay.setDate(candidateDay.getDate() + offset)

        if (!isStreamDay(candidateDay)) continue

        const start = new Date(candidateDay)
        start.setHours(STREAM_START_HOUR, STREAM_START_MINUTE, 0, 0)

        if (start > now) return start
      }

      return null
    }

    function highlightTodayScheduleCard() {
      const todayDay = new Date().getDay()

      document.querySelectorAll('.tnx-schedule-card').forEach((card) => {
        card.classList.remove('tnx-schedule-card--active')

        const dayAttr = card.getAttribute('data-schedule-day')
        if (!dayAttr) return

        if (Number.parseInt(dayAttr, 10) === todayDay) {
          card.classList.add('tnx-schedule-card--active')
        }
      })
    }

    function startNextStreamCountdown() {
      const timerEl = document.getElementById('next-stream-timer')
      const wrapperEl = document.getElementById('next-stream-wrapper')
      const labelEl = document.getElementById('next-stream-label')

      if (!timerEl) return

      function resetLiveStyles() {
        timerEl.classList.add('font-mono')
        timerEl.classList.remove('font-bold', 'tnx-live-glow')
        wrapperEl?.classList.remove('ring-1', 'ring-yellow-400/60')
      }

      function update() {
        const now = new Date()

        if (isInStreamWindow(now)) {
          timerEl.textContent = 'البث غالبًا شغّال الآن'
          timerEl.classList.remove('font-mono')
          timerEl.classList.add('font-bold', 'tnx-live-glow')

          if (labelEl) {
            labelEl.textContent = 'حسب الجدول'
          }

          wrapperEl?.classList.add('ring-1', 'ring-yellow-400/60')
          return
        }

        const next = getNextStreamStart(now)

        if (!next) {
          timerEl.textContent = '-- : -- : --'

          if (labelEl) {
            labelEl.textContent = 'موعد البث القادم'
          }

          resetLiveStyles()
          return
        }

        const totalSeconds = Math.max(0, Math.floor((next.getTime() - now.getTime()) / 1000))
        const h = Math.floor(totalSeconds / 3600)
        const m = Math.floor((totalSeconds % 3600) / 60)
        const s = totalSeconds % 60

        timerEl.textContent =
          String(h).padStart(2, '0') +
          ' : ' +
          String(m).padStart(2, '0') +
          ' : ' +
          String(s).padStart(2, '0')

        if (labelEl) {
          labelEl.textContent = isStreamDay(now)
            ? 'موعد البث القادم'
            : 'البث القادم حسب الجدول'
        }

        resetLiveStyles()
      }

      update()
      window.setInterval(update, 1000)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        startNextStreamCountdown()
        highlightTodayScheduleCard()
      })
    } else {
      startNextStreamCountdown()
      highlightTodayScheduleCard()
    }
  </script>

  <script define:vars={{ fanArtImages }}>
    const topImg = document.getElementById('random-fanart-image-top')
    const bottomImg = document.getElementById('random-fanart-image-bottom')

    function getStorageItem(key) {
      try {
        return window.localStorage.getItem(key)
      } catch {
        return null
      }
    }

    function setStorageItem(key, value) {
      try {
        window.localStorage.setItem(key, value)
      } catch {
        // Ignore storage errors.
      }
    }

    if (Array.isArray(fanArtImages) && fanArtImages.length > 0) {
      const lastImage = getStorageItem('tnx-last-fanart')

      let availableImages = fanArtImages

      if (fanArtImages.length > 1 && lastImage) {
        availableImages = fanArtImages.filter((image) => image !== lastImage)
      }

      const randomImage = availableImages[Math.floor(Math.random() * availableImages.length)]

      if (randomImage) {
        if (topImg) {
          topImg.setAttribute('src', randomImage)
          topImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        if (bottomImg) {
          bottomImg.setAttribute('src', randomImage)
          bottomImg.setAttribute('alt', 'TNX6 Fan Art')
        }

        setStorageItem('tnx-last-fanart', randomImage)
      }
    }
  </script>
</Layout>
