---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'مراقبة الموقع',
  ignoreTitleTemplate: true,
}
---

<Layout metadata={metadata}>
  <main class="tnx-admin-activity" dir="rtl">
    <section class="activity-shell">
      <header class="activity-hero">
        <span class="activity-kicker">TNX6 Admin</span>
        <div>
          <h1>مراقبة الموقع</h1>
          <p>المستخدمون المسجلون النشطون داخل الموقع.</p>
        </div>
      </header>

      <section class="activity-stats" aria-label="إحصائيات الحضور">
        <article class="activity-stat">
          <span>المتصلون الآن</span>
          <strong id="presenceOnlineCount">0</strong>
        </article>
        <article class="activity-stat">
          <span>آخر 15 دقيقة</span>
          <strong id="presenceActiveCount">0</strong>
        </article>
        <article class="activity-stat">
          <span>آخر 24 ساعة</span>
          <strong id="presenceRecentCount">0</strong>
        </article>
        <article class="activity-stat">
          <span>آخر تحديث</span>
          <strong id="presenceUpdatedAt">---</strong>
        </article>
      </section>

      <section class="activity-panel">
        <div class="activity-toolbar">
          <label class="activity-search">
            <span>بحث</span>
            <input id="presenceSearch" type="search" placeholder="ابحث بالاسم أو login" autocomplete="off" />
          </label>

          <label class="activity-filter">
            <span>الفلتر</span>
            <select id="presenceScope">
              <option value="online">المتصلون الآن</option>
              <option value="active15">آخر 15 دقيقة</option>
              <option value="recent">آخر 24 ساعة</option>
            </select>
          </label>

          <button class="activity-refresh" id="presenceRefresh" type="button">تحديث</button>
        </div>

        <div class="activity-message" id="presenceMessage" role="status" aria-live="polite">جاري تحميل البيانات...</div>
        <div class="activity-grid" id="presenceUsers"></div>
      </section>
    </section>
  </main>

  <style>
    .tnx-admin-activity {
      min-height: 100vh;
      padding: 36px 18px 70px;
      color: #f4efe2;
      background:
        radial-gradient(circle at 18% 0%, rgba(212, 175, 55, .13), transparent 32%),
        linear-gradient(180deg, rgba(0,0,0,.10), rgba(0,0,0,.34));
    }

    .activity-shell {
      width: min(1120px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .activity-hero,
    .activity-panel,
    .activity-stat {
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(10,10,14,.78);
      box-shadow: 0 18px 52px rgba(0,0,0,.34);
      backdrop-filter: blur(18px);
    }

    .activity-hero {
      border-radius: 24px;
      padding: 24px;
      display: grid;
      gap: 12px;
    }

    .activity-kicker {
      width: fit-content;
      border-radius: 999px;
      border: 1px solid rgba(212,175,55,.24);
      background: rgba(212,175,55,.10);
      color: #f0d060;
      font-size: 12px;
      font-weight: 1000;
      padding: 6px 10px;
    }

    .activity-hero h1 {
      margin: 0;
      color: #fff7dd;
      font-size: clamp(28px, 4vw, 46px);
      font-weight: 1000;
      letter-spacing: 0;
    }

    .activity-hero p {
      margin: 8px 0 0;
      color: rgba(255,255,255,.66);
      font-weight: 800;
    }

    .activity-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .activity-stat {
      border-radius: 18px;
      padding: 16px;
      display: grid;
      gap: 8px;
    }

    .activity-stat span {
      color: rgba(255,255,255,.56);
      font-size: 12px;
      font-weight: 900;
    }

    .activity-stat strong {
      color: #f0d060;
      font-size: 24px;
      font-weight: 1000;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .activity-panel {
      border-radius: 24px;
      padding: 18px;
      display: grid;
      gap: 16px;
    }

    .activity-toolbar {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(180px, 240px) auto;
      gap: 12px;
      align-items: end;
    }

    .activity-search,
    .activity-filter {
      display: grid;
      gap: 7px;
      color: rgba(255,255,255,.62);
      font-size: 12px;
      font-weight: 1000;
    }

    .activity-search input,
    .activity-filter select {
      min-height: 46px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.045);
      color: #fff7dd;
      font: inherit;
      font-size: 14px;
      font-weight: 850;
      padding: 0 13px;
      outline: 0;
    }

    .activity-filter select option {
      color: #111;
    }

    .activity-search input:focus,
    .activity-filter select:focus,
    .activity-refresh:focus-visible,
    .activity-profile-link:focus-visible {
      outline: 2px solid rgba(240,208,96,.56);
      outline-offset: 3px;
    }

    .activity-refresh {
      min-height: 46px;
      border: 1px solid rgba(212,175,55,.28);
      border-radius: 14px;
      background: linear-gradient(135deg, #f0d060, #d4af37);
      color: #090907;
      font: inherit;
      font-size: 14px;
      font-weight: 1000;
      padding: 0 18px;
      cursor: pointer;
    }

    .activity-refresh:disabled {
      opacity: .58;
      cursor: wait;
    }

    .activity-message {
      min-height: 42px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.035);
      color: rgba(255,255,255,.68);
      display: flex;
      align-items: center;
      padding: 10px 13px;
      font-size: 13px;
      font-weight: 850;
    }

    .activity-message:empty {
      display: none;
    }

    .activity-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .activity-user-card {
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 18px;
      background: rgba(255,255,255,.035);
      padding: 14px;
      display: grid;
      gap: 13px;
    }

    .activity-user-main {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 12px;
      align-items: center;
    }

    .activity-avatar {
      position: relative;
      width: 52px;
      height: 52px;
      border-radius: 16px;
      border: 1px solid rgba(212,175,55,.18);
      background: rgba(212,175,55,.10);
      overflow: hidden;
      display: grid;
      place-items: center;
      color: #f0d060;
      font-weight: 1000;
    }

    .activity-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .activity-dot {
      position: absolute;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      left: 3px;
      bottom: 3px;
      border: 2px solid #111114;
      background: #6b7280;
    }

    .activity-dot.online {
      background: #22c55e;
      box-shadow: 0 0 16px rgba(34,197,94,.38);
    }

    .activity-user-name {
      min-width: 0;
      display: grid;
      gap: 3px;
    }

    .activity-user-name strong {
      overflow: hidden;
      color: #fff7dd;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-size: 16px;
      font-weight: 1000;
    }

    .activity-user-name span {
      overflow: hidden;
      color: rgba(255,255,255,.48);
      text-overflow: ellipsis;
      white-space: nowrap;
      direction: ltr;
      text-align: right;
      unicode-bidi: isolate;
      font-size: 12px;
      font-weight: 850;
    }

    .activity-meta {
      display: grid;
      gap: 7px;
      color: rgba(255,255,255,.64);
      font-size: 13px;
      font-weight: 850;
    }

    .activity-meta-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid rgba(255,255,255,.07);
      padding-top: 7px;
    }

    .activity-meta-row:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .activity-meta-row span:first-child {
      color: rgba(255,255,255,.42);
    }

    .activity-meta-row span:last-child {
      text-align: left;
    }

    .activity-profile-link {
      min-height: 40px;
      border-radius: 13px;
      border: 1px solid rgba(212,175,55,.24);
      background: rgba(212,175,55,.10);
      color: #f0d060;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 1000;
      text-decoration: none;
    }

    @media (max-width: 820px) {
      .activity-stats,
      .activity-grid {
        grid-template-columns: 1fr;
      }

      .activity-toolbar {
        grid-template-columns: 1fr;
      }

      .activity-refresh {
        width: 100%;
      }
    }
  </style>

  <script>
    const API_ORIGIN = 'https://api.tnx6.xyz'
    const ONLINE_SCOPE_LABELS = {
      online: 'لا يوجد مستخدمون متصلون حاليًا.',
      active15: 'لا يوجد نشاط خلال آخر 15 دقيقة.',
      recent: 'لا يوجد نشاط خلال آخر 24 ساعة.',
    }

    const state = {
      users: [],
      scope: 'online',
      query: '',
      loading: false,
      pollTimer: 0,
    }

    const $ = (id) => document.getElementById(id)

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
    }

    function safeProfileUrl(value) {
      const raw = String(value || '')
      try {
        const url = new URL(raw)
        return (url.protocol === 'https:' || url.protocol === 'http:') && url.pathname.startsWith('/profile-v2')
          ? url.toString()
          : '/profile-v2/'
      } catch {
        return '/profile-v2/'
      }
    }

    function formatNumber(value) {
      return new Intl.NumberFormat('ar-SA').format(Math.max(0, Number(value || 0)))
    }

    function relativeTime(iso) {
      const time = Date.parse(String(iso || ''))
      if (!Number.isFinite(time)) return 'غير معروف'

      const seconds = Math.max(0, Math.floor((Date.now() - time) / 1000))
      if (seconds < 10) return 'الآن'
      if (seconds < 60) return `قبل ${formatNumber(seconds)} ثانية`

      const minutes = Math.floor(seconds / 60)
      if (minutes === 1) return 'قبل دقيقة'
      if (minutes < 60) return `قبل ${formatNumber(minutes)} دقيقة`

      const hours = Math.floor(minutes / 60)
      if (hours === 1) return 'قبل ساعة'
      if (hours < 24) return `قبل ${formatNumber(hours)} ساعة`

      const days = Math.floor(hours / 24)
      if (days === 1) return 'قبل يوم'
      return `قبل ${formatNumber(days)} يوم`
    }

    function formatClock(iso) {
      const time = Date.parse(String(iso || ''))
      if (!Number.isFinite(time)) return '---'
      return new Intl.DateTimeFormat('ar-SA', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
      }).format(new Date(time))
    }

    function renderStats(payload = {}) {
      $('presenceOnlineCount').textContent = formatNumber(payload.onlineCount)
      $('presenceActiveCount').textContent = formatNumber(payload.active15Count)
      $('presenceRecentCount').textContent = formatNumber(payload.recent24hCount)
      $('presenceUpdatedAt').textContent = formatClock(payload.generatedAt)
    }

    function userInitial(user) {
      const text = String(user.displayName || user.login || '?').trim()
      return escapeHtml((text[0] || '?').toUpperCase())
    }

    function renderUsers() {
      const grid = $('presenceUsers')
      const message = $('presenceMessage')
      if (!grid || !message) return

      const query = state.query.trim().toLowerCase()
      const users = state.users.filter((user) => {
        if (!query) return true
        return [user.displayName, user.login]
          .map((value) => String(value || '').toLowerCase())
          .some((value) => value.includes(query))
      })

      if (!users.length) {
        grid.innerHTML = ''
        message.textContent = query ? 'لا توجد نتائج مطابقة.' : ONLINE_SCOPE_LABELS[state.scope]
        return
      }

      message.textContent = ''
      grid.innerHTML = users.map((user) => {
        const login = String(user.login || '').trim()
        const displayName = String(user.displayName || login || 'غير معروف').trim()
        const avatar = String(user.avatarUrl || '').trim()
        const profileUrl = safeProfileUrl(user.profileUrl)
        const dotClass = user.isOnline ? 'activity-dot online' : 'activity-dot'

        return `
          <article class="activity-user-card">
            <div class="activity-user-main">
              <div class="activity-avatar">
                ${avatar ? `<img src="${escapeHtml(avatar)}" alt="" loading="lazy" referrerpolicy="no-referrer" />` : userInitial(user)}
                <span class="${dotClass}" aria-hidden="true"></span>
              </div>
              <div class="activity-user-name">
                <strong>${escapeHtml(displayName)}</strong>
                <span>@${escapeHtml(login || 'unknown')}</span>
              </div>
            </div>
            <div class="activity-meta">
              <div class="activity-meta-row">
                <span>الصفحة</span>
                <span>${escapeHtml(user.currentPageLabel || 'صفحة أخرى')}</span>
              </div>
              <div class="activity-meta-row">
                <span>آخر ظهور</span>
                <span>${escapeHtml(relativeTime(user.lastSeenAt))}</span>
              </div>
              <div class="activity-meta-row">
                <span>أول ظهور</span>
                <span>${escapeHtml(relativeTime(user.firstSeenAt))}</span>
              </div>
            </div>
            <a class="activity-profile-link" href="${escapeHtml(profileUrl)}">فتح البروفايل</a>
          </article>
        `
      }).join('')
    }

    function showAccessMessage(text) {
      state.users = []
      renderStats({})
      $('presenceUsers').innerHTML = ''
      $('presenceMessage').textContent = text
    }

    async function loadPresence() {
      if (state.loading) return
      state.loading = true

      const button = $('presenceRefresh')
      if (button) button.disabled = true

      try {
        const response = await fetch(API_ORIGIN + '/api/admin/presence?scope=' + encodeURIComponent(state.scope), {
          credentials: 'include',
          cache: 'no-store',
        })

        if (response.status === 401) {
          showAccessMessage('يجب تسجيل الدخول أولًا.')
          return
        }

        if (response.status === 403) {
          showAccessMessage('ليس لديك صلاحية لفتح هذه الصفحة.')
          return
        }

        const data = await response.json().catch(() => null)
        if (!response.ok || !data?.ok) {
          showAccessMessage('تعذر تحميل بيانات المراقبة حاليًا.')
          return
        }

        state.users = Array.isArray(data.users) ? data.users : []
        renderStats(data)
        renderUsers()
      } catch {
        showAccessMessage('تعذر الاتصال بخدمة المراقبة حاليًا.')
      } finally {
        state.loading = false
        if (button) button.disabled = false
      }
    }

    function stopPolling() {
      if (state.pollTimer) {
        window.clearInterval(state.pollTimer)
        state.pollTimer = 0
      }
    }

    function startPolling() {
      if (document.visibilityState === 'hidden') {
        stopPolling()
        return
      }

      loadPresence()
      if (!state.pollTimer) {
        state.pollTimer = window.setInterval(loadPresence, 10_000)
      }
    }

    $('presenceSearch')?.addEventListener('input', (event) => {
      state.query = event.target.value || ''
      renderUsers()
    })

    $('presenceScope')?.addEventListener('change', (event) => {
      state.scope = event.target.value || 'online'
      loadPresence()
    })

    $('presenceRefresh')?.addEventListener('click', loadPresence)

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') stopPolling()
      else startPolling()
    })

    window.addEventListener('pagehide', stopPolling)
    window.addEventListener('pageshow', startPolling)

    startPolling()
  </script>
</Layout>
