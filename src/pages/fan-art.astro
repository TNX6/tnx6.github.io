---
import Layout from '~/layouts/PageLayout.astro'

const artworks = [
  { artist: "ليان",  discord: "@anyang_chii", image: "/FANART/Anyang.webp", twitch: "anyang_chii" },

  // رسمتين من ماريو
  { artist: "ماريو", discord: "@mariyo2468", image: "/FANART/Mariyo.webp", twitch: "mariyo2468" },
  { artist: "ماريو", discord: "@mariyo2468", image: "/FANART/Mariyo.png",  twitch: "mariyo2468" },

  { artist: "نورة",  discord: "@norhv17",    image: "/FANART/NORH.webp",  twitch: "norhv17" },
  { artist: "كاناي", discord: "@xkanaix",    image: "/FANART/kanai.webp", twitch: "xkanaix" },
  { artist: "معاذ",  discord: "@pekz0_",     image: "/FANART/pekz0.webp", twitch: "pekz0_" },

  { artist: "مازن",  discord: "@ker_a9", image: "/FANART/Mazen.png", twitch: "ker_a9" },
  { artist: "بعير",  discord: "@ba3eerwut", image: "/FANART/ba3eerwut.png", twitch: "ba3eerwut" },
]
---

<Layout metadata={{ title: "معرض الرسمات — TNX6", ignoreTitleTemplate: true }}>
  <section class="py-24 px-6 text-white">
    <h1
      class="text-5xl font-extrabold text-center mb-12 bg-gradient-to-r from-[#ffda6a] to-[#c29200] bg-clip-text text-transparent drop-shadow-[0_0_10px_rgba(198,164,79,0.5)]"
    >
      معرض الرسمات
    </h1>

    <!-- Fixed Grid مثل قبل -->
    <div class="fanart-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {artworks.map((a, index) => (
        <div
          class="fanart-card group relative overflow-hidden rounded-3xl bg-black/30 border border-transparent
                 shadow-lg backdrop-blur-sm cursor-pointer transition-transform will-change-transform hover:scale-[1.02]"
          role="button"
          tabindex="0"
          data-index={index}
          data-src={a.image}
          data-artist={a.artist}
          data-discord={a.discord}
          data-twitch={a.twitch}
          aria-label={`Open fan art by ${a.artist}`}
        >
          <img
            src={a.image}
            alt={`Fan art by ${a.artist}`}
            loading="lazy"
            class="fanart-img w-full h-[240px] sm:h-[260px] object-cover transition-transform duration-200"
          />

          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent pointer-events-none"></div>

          <div
            class="absolute left-3 bottom-3 z-10 bg-black/60 backdrop-blur-md rounded-xl px-3 py-2 border border-white/10"
          >
            <div class="text-sm font-extrabold text-[#f7e6ac] leading-none">
              {a.artist}
            </div>

{a.discord && (
  <div class="text-xs text-[#f7e6ac]/75 mt-1 leading-none">
    {a.discord}
  </div>
)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Popup -->
  <div
    id="popup"
    class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50 p-4"
    aria-hidden="true"
  >
    <div
      id="popupInner"
      class="popup-inner relative bg-black/55 border border-[#c6a44f]/40 rounded-2xl p-4
             shadow-[0_0_30px_rgba(198,164,79,0.35)] backdrop-blur-md"
    >
      <div class="flex items-start justify-between gap-3 mb-3">
        <div>
          <h2 id="popupName" class="text-2xl font-extrabold text-[#ffda6a] leading-tight"></h2>

          <div id="popupMeta" class="mt-1 flex items-center gap-2 text-sm text-[#f7e6ac]/75">
            <span id="popupHandle"></span>
            <span id="popupDivider" class="opacity-40 hidden">|</span>

            <a
              id="popupTwitchLink"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="hidden items-center text-[#a970ff] hover:text-[#c6a44f] transition"
              aria-label="Open Twitch profile"
              title="Open Twitch profile"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5"
                aria-hidden="true"
              >
                <path d="M4 3 2 8v11h4v3h3l3-3h4l6-6V3H4zm16 9-3 3h-4l-3 3v-3H6V5h14v7z"></path>
                <path d="M15 8h2v5h-2zM10 8h2v5h-2z"></path>
              </svg>
            </a>
          </div>
        </div>

        <button
          id="closePopup"
          class="w-9 h-9 rounded-lg bg-[#c29200]/30 hover:bg-[#ffda6a]/70 text-black text-xl leading-none font-black transition shrink-0"
          type="button"
          aria-label="Close"
          title="Close"
        >
          ×
        </button>
      </div>

      <!-- Zoom stage -->
      <div
        id="zoomStage"
        class="relative w-full max-h-[78vh] rounded-xl bg-black/20 border border-white/10 overflow-hidden select-none"
      >
        <img
          id="popupImg"
          class="block max-w-full w-auto h-auto max-h-[78vh] object-contain"
          alt=""
          draggable="false"
        />
      </div>

      <!-- Thumbnails -->
      <div id="thumbStrip" class="mt-4 flex gap-3 overflow-x-auto pb-2">
        {artworks.map((a, index) => (
          <button
            type="button"
            class="thumb-btn"
            data-index={index}
            aria-label={`Open art by ${a.artist}`}
            title={a.artist}
          >
            <img src={a.image} alt={a.artist} loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </div>

  <style is:global>
    .fanart-card {
      position: relative;
      isolation: isolate;
      animation: fadeScale 400ms ease both;
    }

    .fanart-card::before {
      content: "";
      position: absolute;
      inset: -2px;
      padding: 2px;
      border-radius: 1.5rem;
      background: conic-gradient(
        from 0deg,
        #ffda6a,
        #c29200,
        #c6a44f,
        #ffda6a,
        #c29200
      );

      -webkit-mask:
        linear-gradient(#000 0 0) content-box,
        linear-gradient(#000 0 0);
      -webkit-mask-composite: xor;
              mask-composite: exclude;

      opacity: 0.75;
      pointer-events: none;
      z-index: -1;
      transform: none;
    }

    .fanart-card:hover {
      box-shadow:
        0 0 22px rgba(198, 164, 79, 0.55),
        0 0 44px rgba(198, 164, 79, 0.35);
    }

    @media (hover: hover) and (pointer: fine) {
      .fanart-grid:hover > .fanart-card:not(:hover) .fanart-img {
        filter: brightness(0.38) saturate(0.25) blur(6px) contrast(1.1);
        transform: scale(1.02);
      }

      .fanart-grid:hover > .fanart-card:hover .fanart-img {
        filter: saturate(1.15) contrast(1.05);
        transform: scale(1.06);
      }
    }

    .popup-inner {
      width: min(1080px, 95vw);
      transition: width 220ms ease, max-width 220ms ease, transform 220ms ease;
    }

    .popup-inner.is-portrait {
      width: min(760px, 92vw);
    }

    .popup-inner.is-landscape {
      width: min(1280px, 96vw);
    }

    .popup-inner.is-square {
      width: min(940px, 93vw);
    }

    .popup-inner.animate-in {
      animation: fadeScale 260ms ease both;
    }

    @keyframes fadeScale {
      from { opacity: 0; transform: scale(.97); }
      to   { opacity: 1; transform: scale(1); }
    }

    @keyframes imageIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(.985);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    #zoomStage {
      cursor: zoom-in;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 320px;
    }

    #zoomStage.is-zoomed { cursor: grab; }
    #zoomStage.is-dragging { cursor: grabbing; }

    #popupImg {
      transform-origin: var(--ox, 50%) var(--oy, 50%);
      transform: translate(var(--tx, 0px), var(--ty, 0px)) scale(var(--s, 1));
      transition: transform 140ms ease;
      will-change: transform;
      backface-visibility: hidden;
    }

    #popupImg.animate-in {
      animation: imageIn 260ms ease both;
    }

    #zoomStage.is-dragging #popupImg {
      transition: none;
    }

    #thumbStrip {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.35) transparent;
    }

    #thumbStrip::-webkit-scrollbar {
      height: 8px;
    }

    #thumbStrip::-webkit-scrollbar-thumb {
      background: rgba(255, 218, 106, 0.25);
      border-radius: 999px;
    }

    .thumb-btn {
      flex: 0 0 auto;
      width: 74px;
      height: 74px;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.03);
      opacity: 0.55;
      transform: translateY(0);
      transition:
        opacity 180ms ease,
        transform 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .thumb-btn:hover {
      opacity: 0.9;
      transform: translateY(-2px);
    }

    .thumb-btn.is-active {
      opacity: 1;
      border-color: rgba(255, 218, 106, 0.65);
      box-shadow: 0 0 18px rgba(198, 164, 79, 0.28);
      transform: translateY(-2px);
    }

    .thumb-btn img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  </style>

  <script is:inline>
    const cards = document.querySelectorAll('.fanart-card');
    const popup = document.getElementById('popup');
    const popupInner = document.getElementById('popupInner');
    const popupImg = document.getElementById('popupImg');
    const popupName = document.getElementById('popupName');
    const popupMeta = document.getElementById('popupMeta');
    const popupHandle = document.getElementById('popupHandle');
    const popupDivider = document.getElementById('popupDivider');
    const popupTwitchLink = document.getElementById('popupTwitchLink');
    const closePopup = document.getElementById('closePopup');
    const zoomStage = document.getElementById('zoomStage');
    const thumbButtons = document.querySelectorAll('.thumb-btn');

    const items = [...cards].map((card) => ({
      src: card.dataset.src,
      artist: card.dataset.artist,
      discord: card.dataset.discord || '',
      twitch: card.dataset.twitch || ''
    }));

    let currentIndex = 0;
    let scale = 1;
    let tx = 0, ty = 0;
    let isDragging = false;
    let lastX = 0, lastY = 0;

    const clamp = (v, min, max) => Math.max(min, Math.min(max, v));

    const applyTransform = () => {
      popupImg.style.setProperty('--s', scale);
      popupImg.style.setProperty('--tx', `${tx}px`);
      popupImg.style.setProperty('--ty', `${ty}px`);
      zoomStage.classList.toggle('is-zoomed', scale > 1);
    };

    const setOriginFromEvent = (e) => {
      const r = zoomStage.getBoundingClientRect();
      const ox = ((e.clientX - r.left) / r.width) * 100;
      const oy = ((e.clientY - r.top) / r.height) * 100;
      popupImg.style.setProperty('--ox', `${clamp(ox, 0, 100)}%`);
      popupImg.style.setProperty('--oy', `${clamp(oy, 0, 100)}%`);
    };

    const resetZoom = () => {
      scale = 1;
      tx = 0;
      ty = 0;
      popupImg.style.setProperty('--ox', '50%');
      popupImg.style.setProperty('--oy', '50%');
      zoomStage.classList.remove('is-zoomed', 'is-dragging');
      applyTransform();
    };

    const animatePopupImage = () => {
      popupImg.classList.remove('animate-in');
      void popupImg.offsetWidth;
      popupImg.classList.add('animate-in');
    };

    const setPopupLayout = () => {
      popupInner.classList.remove('is-portrait', 'is-landscape', 'is-square');

      const w = popupImg.naturalWidth || 1;
      const h = popupImg.naturalHeight || 1;
      const ratio = w / h;

      if (ratio < 0.85) {
        popupInner.classList.add('is-portrait');
      } else if (ratio > 1.15) {
        popupInner.classList.add('is-landscape');
      } else {
        popupInner.classList.add('is-square');
      }
    };

    const setActiveThumb = (index) => {
      thumbButtons.forEach((btn) => {
        const active = Number(btn.dataset.index) === index;
        btn.classList.toggle('is-active', active);

        if (active) {
          btn.scrollIntoView({
            behavior: 'smooth',
            inline: 'center',
            block: 'nearest'
          });
        }
      });
    };

    const renderPopup = (index) => {
      const item = items[index];
      if (!item) return;

      currentIndex = index;
      popupImg.src = item.src;
      popupImg.alt = `Fan art by ${item.artist}`;
      popupName.textContent = item.artist;

      if (item.discord) {
        popupHandle.textContent = item.discord;
        popupHandle.classList.remove('hidden');
      } else {
        popupHandle.textContent = '';
        popupHandle.classList.add('hidden');
      }

      if (item.twitch) {
        popupTwitchLink.href = `https://www.twitch.tv/${item.twitch}`;
        popupTwitchLink.title = `twitch.tv/${item.twitch}`;
        popupTwitchLink.setAttribute('aria-label', `Open ${item.artist} Twitch`);
        popupTwitchLink.classList.remove('hidden');
        popupTwitchLink.classList.add('inline-flex');
      } else {
        popupTwitchLink.href = '#';
        popupTwitchLink.title = 'Open Twitch profile';
        popupTwitchLink.setAttribute('aria-label', 'Open Twitch profile');
        popupTwitchLink.classList.add('hidden');
        popupTwitchLink.classList.remove('inline-flex');
      }

      if (item.discord && item.twitch) {
        popupDivider.classList.remove('hidden');
      } else {
        popupDivider.classList.add('hidden');
      }

      if (item.discord || item.twitch) {
        popupMeta.classList.remove('hidden');
      } else {
        popupMeta.classList.add('hidden');
      }

      setActiveThumb(index);
      resetZoom();
    };

    const openPopup = (index) => {
      popup.classList.remove('hidden');
      popup.classList.add('flex');
      popup.setAttribute('aria-hidden', 'false');

      popupInner.classList.remove('animate-in');
      void popupInner.offsetWidth;
      popupInner.classList.add('animate-in');

      renderPopup(index);
    };

    const close = () => {
      popup.classList.remove('flex');
      popup.classList.add('hidden');
      popup.setAttribute('aria-hidden', 'true');
      popupInner.classList.remove('animate-in');
      popupInner.classList.remove('is-portrait', 'is-landscape', 'is-square');
      popupImg.src = '';
      popupImg.alt = '';

      popupHandle.textContent = '';
      popupHandle.classList.remove('hidden');
      popupDivider.classList.add('hidden');
      popupMeta.classList.remove('hidden');

      popupTwitchLink.href = '#';
      popupTwitchLink.title = 'Open Twitch profile';
      popupTwitchLink.setAttribute('aria-label', 'Open Twitch profile');
      popupTwitchLink.classList.add('hidden');
      popupTwitchLink.classList.remove('inline-flex');

      resetZoom();
    };

    popupImg.addEventListener('load', () => {
      setPopupLayout();
      animatePopupImage();
    });

    cards.forEach((card) => {
      const index = Number(card.dataset.index);

      card.addEventListener('click', () => openPopup(index));
      card.addEventListener('keyup', (e) => {
        if (e.key === 'Enter' || e.key === ' ') openPopup(index);
      });
    });

    thumbButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const index = Number(btn.dataset.index);
        renderPopup(index);
      });
    });

    closePopup.addEventListener('click', close);

    popup.addEventListener('click', (e) => {
      if (e.target === popup) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    // Click to zoom in/out
    zoomStage.addEventListener('click', (e) => {
      if (popup.classList.contains('hidden')) return;
      if (e.target !== popupImg && scale === 1) return;

      if (scale === 1) {
        setOriginFromEvent(e);
        scale = 2.6;
        tx = 0;
        ty = 0;
        applyTransform();
      } else {
        resetZoom();
      }
    });

    // Drag to pan when zoomed
    zoomStage.addEventListener('pointerdown', (e) => {
      if (scale <= 1) return;
      if (e.target !== popupImg) return;

      isDragging = true;
      zoomStage.classList.add('is-dragging');
      lastX = e.clientX;
      lastY = e.clientY;
      zoomStage.setPointerCapture(e.pointerId);
    });

    zoomStage.addEventListener('pointermove', (e) => {
      if (!isDragging) return;

      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;

      lastX = e.clientX;
      lastY = e.clientY;

      tx += dx;
      ty += dy;
      applyTransform();
    });

    zoomStage.addEventListener('pointerup', (e) => {
      if (!isDragging) return;
      isDragging = false;
      zoomStage.classList.remove('is-dragging');
      try { zoomStage.releasePointerCapture(e.pointerId); } catch {}
    });

    zoomStage.addEventListener('pointercancel', () => {
      isDragging = false;
      zoomStage.classList.remove('is-dragging');
    });

    // Wheel zoom
    zoomStage.addEventListener('wheel', (e) => {
      if (popup.classList.contains('hidden')) return;
      e.preventDefault();

      setOriginFromEvent(e);

      const delta = Math.sign(e.deltaY);
      const step = 0.25;

      if (delta > 0) scale -= step;
      else scale += step;

      scale = clamp(scale, 1, 6);

      if (scale === 1) {
        tx = 0;
        ty = 0;
      }

      applyTransform();
    }, { passive: false });
  </script>
</Layout>
