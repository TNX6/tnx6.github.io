          popupImg.alt = `Fan art by ${item.artist}`
        }

        if (popupName) popupName.textContent = item.artist

        if (item.discord) {
          popupHandle.textContent = item.discord
          popupHandle.classList.remove('hidden')
        } else {
          popupHandle.textContent = ''
          popupHandle.classList.add('hidden')
        }

        if (item.twitch) {
          popupTwitchLink.href = `https://www.twitch.tv/${item.twitch}`
          popupTwitchLink.textContent = `twitch.tv/${item.twitch}`
          popupTwitchLink.classList.remove('hidden')
        } else {
          popupTwitchLink.href = '#'
          popupTwitchLink.textContent = ''
          popupTwitchLink.classList.add('hidden')
        }

        popupDivider?.classList.toggle('hidden', !(item.discord && item.twitch))
        popupMeta?.classList.toggle('hidden', !(item.discord || item.twitch))

        history.replaceState(null, '', `#${item.id}`)
        setActiveThumb(index)
        setSelectedCard(index)
        resetZoom()
      }

      function openPopup(index) {
        popup?.classList.remove('hidden')
        popup?.setAttribute('aria-hidden', 'false')
        document.documentElement.style.overflow = 'hidden'
        renderPopup(index)
      }

      function closeModal() {
        popup?.classList.add('hidden')
        popup?.setAttribute('aria-hidden', 'true')
        document.documentElement.style.overflow = ''
        popupInner?.classList.remove('is-portrait', 'is-landscape', 'is-square')
        if (popupImg) {
          popupImg.src = ''
          popupImg.alt = ''
        }
        cards.forEach((card) => card.classList.remove('is-selected'))
        resetZoom()
      }

      function next(delta) {
        const nextIndex = (currentIndex + delta + items.length) % items.length
        renderPopup(nextIndex)
      }

      function openFromHash(options = {}) {
        const hash = decodeURIComponent((window.location.hash || '').replace('#', ''))
        if (!hash || !hash.startsWith('art-')) return false

        const item = items.find((entry) => entry.id === hash)
        if (!item) return false

        if (options.openModal) {
          openPopup(item.index)
        } else {
          const card = document.getElementById(item.id)
          if (card) {
            card.scrollIntoView({ behavior: options.instant ? 'auto' : 'smooth', block: 'center' })
            setSelectedCard(item.index)
          }
        }

        return true
      }

      function setupReveal() {
        const elements = Array.from(document.querySelectorAll('.tnx-reveal'))
        if (!elements.length) return

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              revealObserver.unobserve(entry.target)
            }
          })
        }, { threshold: 0.12 })

        elements.forEach((element) => revealObserver.observe(element))
      }

      function handleBackToTop() {
        backToTop?.classList.toggle('is-visible', window.scrollY > 520)
      }

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTop, { passive: true })

      cards.forEach((card) => {
        addListener(card, 'click', () => openPopup(Number(card.dataset.index)))
        addListener(card, 'keyup', (event) => {
          if (event.key === 'Enter' || event.key === ' ') openPopup(Number(card.dataset.index))
        })
      })

      addListener(featuredGrid, 'click', (event) => {
        const button = event.target.closest('[data-featured-index]')
        if (!button) return
        openPopup(Number(button.dataset.featuredIndex))
      })

      artistFilterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          currentArtistFilter = button.dataset.artistFilter || 'all'
          filterGallery()
          document.querySelector('.tnx-gallery')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        })
      })

      addListener(artSearch, 'input', filterGallery)
      addListener(clearArtSearch, 'click', () => {
        if (!artSearch) return
        artSearch.value = ''
        artSearch.focus()
        filterGallery()
      })

      thumbButtons.forEach((button) => {
        addListener(button, 'click', () => renderPopup(Number(button.dataset.index)))
      })

      addListener(closePopup, 'click', closeModal)
      addListener(popup, 'click', (event) => {
        if (event.target === popup) closeModal()
      })

      addListener(prevArt, 'click', () => next(-1))
      addListener(nextArt, 'click', () => next(1))

      addListener(copyArtLink, 'click', () => {
        const item = items[currentIndex]
        if (!item) return
        copyText(getArtLink(item), copyArtLink, 'تم نسخ الرابط')
      })

      addListener(popupImg, 'load', () => {
        setPopupLayout()
        animatePopupImage()
        applyTransform()
      })

      addListener(window, 'hashchange', () => openFromHash({ openModal: false }))

      addListener(document, 'keydown', (event) => {
        if (!popup || popup.classList.contains('hidden')) return
        if (event.key === 'Escape') closeModal()
        if (event.key === 'ArrowLeft') next(1)
        if (event.key === 'ArrowRight') next(-1)
      })

      addListener(zoomStage, 'pointerdown', (event) => {
        if (!popup || popup.classList.contains('hidden')) return
        if (!zoomStage || !popupImg) return
        if (event.target !== popupImg && event.target !== zoomStage) return

        activePointers.set(event.pointerId, {
          x: event.clientX,
          y: event.clientY,
        })

        try { zoomStage.setPointerCapture(event.pointerId) } catch {}

        if (activePointers.size === 1 && event.pointerType === 'touch' && scale === 1) {
          swipeStartX = event.clientX
          swipeStartY = event.clientY
          swipeLastX = event.clientX
          swipeLastY = event.clientY
          swipeStartTime = Date.now()
          isPotentialSwipe = true
          didPinchInGesture = false
        }

        if (activePointers.size >= 2) {
          event.preventDefault()
          event.stopPropagation()
          didPinchInGesture = true
          isPotentialSwipe = false
          startPinchZoom()
          return
        }

        if (scale > 1 && event.target === popupImg) {
          event.preventDefault()
          isDragging = true
          isPotentialSwipe = false
          zoomStage.classList.add('is-dragging')
          lastX = event.clientX
          lastY = event.clientY
        }
      })

      addListener(zoomStage, 'pointermove', (event) => {
        if (!zoomStage || !popupImg) return

        if (activePointers.has(event.pointerId)) {
          activePointers.set(event.pointerId, {
            x: event.clientX,
            y: event.clientY,
          })
        }

        if (isPotentialSwipe && activePointers.size === 1 && event.pointerType === 'touch' && scale === 1) {
          swipeLastX = event.clientX
          swipeLastY = event.clientY

          const dx = swipeLastX - swipeStartX
          const dy = swipeLastY - swipeStartY

          if (Math.abs(dx) > 12 && Math.abs(dx) > Math.abs(dy) * 1.15) {
            event.preventDefault()
            event.stopPropagation()
          }

          if (Math.abs(dy) > 34 && Math.abs(dy) > Math.abs(dx) * 1.35) {
            isPotentialSwipe = false
          }
        }

        if (isPinching && activePointers.size >= 2) {
          event.preventDefault()
          event.stopPropagation()
          updatePinchZoom()
          return
        }

        if (!isDragging) return

        event.preventDefault()

        const dx = event.clientX - lastX
        const dy = event.clientY - lastY
        lastX = event.clientX
        lastY = event.clientY
        tx += dx
        ty += dy
        applyTransform()
      })

      addListener(zoomStage, 'pointerup', (event) => {
        if (isPotentialSwipe && !didPinchInGesture && !isPinching && scale === 1 && event.pointerType === 'touch') {
          const endX = event.clientX || swipeLastX
          const endY = event.clientY || swipeLastY
          const dx = endX - swipeStartX
          const dy = endY - swipeStartY
          const elapsed = Date.now() - swipeStartTime
          const minDistance = 58
          const maxTime = 900

          if (
            Math.abs(dx) >= minDistance &&
            Math.abs(dx) > Math.abs(dy) * 1.45 &&
            elapsed <= maxTime
          ) {
            event.preventDefault()
            event.stopPropagation()

            // سحب يمين = الصورة التالية يمينًا، سحب يسار = الصورة التالية يسارًا
            if (dx > 0) next(1)
            else next(-1)
          }
        }

        stopPointerTracking(event.pointerId)
        resetSwipeState()
        try { zoomStage.releasePointerCapture(event.pointerId) } catch {}
      })

      addListener(zoomStage, 'pointercancel', (event) => {
        stopPointerTracking(event.pointerId)
        resetSwipeState()
        try { zoomStage.releasePointerCapture(event.pointerId) } catch {}
      })

      addListener(zoomStage, 'lostpointercapture', (event) => {
        stopPointerTracking(event.pointerId)
        if (activePointers.size === 0) resetSwipeState()
      })

      addListener(zoomStage, 'wheel', (event) => {
        if (!popup || popup.classList.contains('hidden')) return
        if (!popupImg || !zoomStage) return

        event.preventDefault()
        event.stopPropagation()

        const oldScale = scale
        const maxScale = 5
        const minScale = 1
        const zoomSpeed = 0.0018
        const stageRect = zoomStage.getBoundingClientRect()

        // deltaY سالب = سكرول للأمام/فوق = تكبير
        // deltaY موجب = سكرول للخلف/تحت = تصغير
        const nextScale = clamp(oldScale * Math.exp(-event.deltaY * zoomSpeed), minScale, maxScale)

        if (Math.abs(nextScale - oldScale) < 0.001) return

        // نخلي نقطة الماوس نفسها تقريبًا ثابتة أثناء التكبير/التصغير.
        // بعدها clampPan يمنع الصورة تطلع خارج الإطار.
        const pointerX = event.clientX - stageRect.left - stageRect.width / 2
        const pointerY = event.clientY - stageRect.top - stageRect.height / 2
        const ratio = nextScale / oldScale

        tx = pointerX - ((pointerX - tx) * ratio)
        ty = pointerY - ((pointerY - ty) * ratio)
        scale = nextScale

        // قريب من الطبيعي؟ رجعه طبيعي بالكامل حتى ما يبقى فرق بسيط مزعج.
        if (scale <= 1.02) {
          scale = 1
          tx = 0
          ty = 0
        }

        applyTransform()
      }, { passive: false })

      addListener(window, 'resize', () => {
        if (!popup || popup.classList.contains('hidden')) return
        applyTransform()
      }, { passive: true })

      renderFeatured()
      filterGallery()
      setupReveal()

      if (window.matchMedia('(max-width: 760px)').matches) {
        addTimer(window.setTimeout(() => {
          document.querySelectorAll('.tnx-reveal').forEach((element) => {
            element.classList.add('is-visible')
          })

          filterGallery()
        }, 80))
      }

      handleBackToTop()
      openFromHash({ instant: true, openModal: false })
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
