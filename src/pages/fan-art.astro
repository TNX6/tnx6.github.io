---
import Layout from '~/layouts/PageLayout.astro'

const artworks = [
  { artist: 'ليان', discord: '@lk21_n', image: '/FANART/Anyang.webp', twitch: 'lk21_n' },
  { artist: 'ماريو', discord: '@mariyo2468', image: '/FANART/Mariyo.webp', twitch: 'mariyo2468' },
  { artist: 'ماريو', discord: '@mariyo2468', image: '/FANART/Mariyo.png', twitch: 'mariyo2468' },
  { artist: 'نورة', discord: '@norhv17', image: '/FANART/NORH.webp', twitch: 'norhv17' },
  { artist: 'كاناي', discord: '@xkanaix', image: '/FANART/kanai.webp', twitch: 'xkanaix' },
  { artist: 'معاذ', discord: '@pekz0_', image: '/FANART/pekz0.webp', twitch: 'pekz0_' },
  { artist: 'مازن', discord: '@ker_a9', image: '/FANART/Mazen.png', twitch: 'ker_a9' },
  { artist: 'بعير', discord: '@ba3eerwut', image: '/FANART/ba3eerwut.png', twitch: 'itsbabaefr' },
  { artist: 'بيلو', discord: '@bello_787', image: '/FANART/Bello.webp', twitch: 'bello_787' },
  { artist: 'بيلو', discord: '@bello_787', image: '/FANART/Bello1.webp', twitch: 'bello_787' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/flory.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory3.png', twitch: 'flory_vt' },
  { artist: 'ليان', discord: '@lk21_n', image: '/FANART/anyang_chii.webp', twitch: 'lk21_n' },
  { artist: 'ايكو', discord: '@αιƙσღ', image: '/FANART/αιƙσღ.webp', twitch: 'a1kotsuki' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory2.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory4.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory5.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory6.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory7.webp', twitch: 'flory_vt' },
  { artist: 'فلوريي', discord: '@flory_vt', image: '/FANART/Flory8.webp', twitch: 'flory_vt' },
  { artist: 'عبود', discord: '@ardux74', image: '/FANART/agx74o.webp', twitch: 'agx74o' },
  { artist: 'ستار', discord: '@❥liliostar3ミ★', image: '/FANART/liliostar3.webp', twitch: 'liliostar3' },
]

const slugify = (value) =>
  String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[ًٌٍَُِّْـ]/g, '')
    .replace(/[أإآ]/g, 'ا')
    .replace(/ة/g, 'ه')
    .replace(/ى/g, 'ي')
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9\u0600-\u06ff-]/g, '')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '')

const artworkItems = artworks.map((art, index) => ({
  ...art,
  id: `art-${slugify(art.artist)}-${index + 1}`,
  index,
}))

const artistStats = Array.from(
  artworkItems.reduce((map, art) => {
    const key = art.artist
    map.set(key, (map.get(key) || 0) + 1)
    return map
  }, new Map())
)
  .map(([artist, count]) => ({ artist, count }))
  .sort((a, b) => b.count - a.count || a.artist.localeCompare(b.artist, 'ar'))

const artists = artistStats.map((entry) => entry.artist)
---

<Layout metadata={{ title: 'معرض الرسمات — TNX6', ignoreTitleTemplate: true }}>
  <main class="tnx-fanart-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX6 FAN ART GALLERY
        </div>

        <h1>معرض الرسمات</h1>

        <p>
          مساحة لرسمات المجتمع. كل عمل هنا له صاحبه، وتقدر تفتح الرسمة، تكبرها، وتشوف حساب الرسام.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong>{artworkItems.length}</strong>
            <span>رسمة</span>
          </div>

          <div>
            <strong>{artists.length}</strong>
            <span>فنان</span>
          </div>

        </div>
      </header>

      <section class="tnx-featured tnx-reveal">
        <div class="tnx-section-head">
          <span>FEATURED</span>
          <h2>من رسم المجتمع</h2>
          <p>تتغير كل مرة تحدث فيها الصفحة.</p>
        </div>

        <div id="featuredGrid" class="tnx-featured-grid" aria-live="polite"></div>
      </section>

      <section class="tnx-toolbar tnx-reveal">
        <div class="tnx-search">
          <span>⌕</span>
          <input id="artSearch" type="search" autocomplete="off" placeholder="ابحث باسم الفنان، أو Twitch..." />
          <button id="clearArtSearch" type="button" aria-label="مسح البحث">×</button>
        </div>

        <div id="artistFilters" class="tnx-filter-row">
          <button type="button" class="is-active" data-artist-filter="all">
            <span>الكل</span>
            <small>{artworkItems.length}</small>
          </button>

          {artistStats.map(({ artist, count }) => (
            <button type="button" data-artist-filter={artist}>
              <span>{artist}</span>
              <small>{count}</small>
            </button>
          ))}
        </div>
      </section>

      <section class="tnx-gallery tnx-reveal">
        <div class="tnx-gallery-top">
          <div class="tnx-section-head tnx-section-head-inline">
            <span>GALLERY</span>
            <h2>كل الرسمات</h2>
            <p>اضغط على أي رسمة للعرض الكامل مع التكبير والتنقل بين الأعمال.</p>
          </div>

          <div class="tnx-gallery-count">
            <strong id="visibleCount">{artworkItems.length}</strong>
            <span>نتيجة</span>
          </div>
        </div>

        <div class="fanart-grid" id="fanartGrid">
          {artworkItems.map((art) => (
            <button
              type="button"
              id={art.id}
              class="fanart-card"
              data-index={art.index}
              data-id={art.id}
              data-src={art.image}
              data-artist={art.artist}
              data-discord={art.discord}
              data-twitch={art.twitch}
              data-search={`${art.artist} ${art.discord} ${art.twitch}`}
              aria-label={`فتح رسمة ${art.artist}`}
            >
              <div class="fanart-image-wrap">
                <img src={art.image} alt={`Fan art by ${art.artist}`} loading="lazy" class="fanart-img" />
              </div>

              <div class="fanart-overlay"></div>

              <div class="fanart-info">
                <strong>{art.artist}</strong>
                {art.discord && <span>{art.discord}</span>}
              </div>

              {art.twitch && <div class="fanart-twitch">Twitch</div>}
            </button>
          ))}
        </div>

        <div id="fanartEmpty" class="tnx-empty hidden">
          <strong>ما فيه نتائج</strong>
          <span>جرّب اسم فنان.</span>
        </div>
      </section>
    </section>

    <div id="popup" class="tnx-modal hidden" aria-hidden="true">
      <div id="popupInner" class="tnx-modal-inner" role="dialog" aria-modal="true" aria-label="عرض الرسمة">
        <div class="tnx-modal-head">
          <div>
            <span class="tnx-modal-kicker">FAN ART</span>
            <h2 id="popupName"></h2>

            <div id="popupMeta" class="tnx-modal-meta">
              <span id="popupHandle"></span>
              <span id="popupDivider" class="hidden">•</span>
              <a id="popupTwitchLink" href="#" target="_blank" rel="noopener noreferrer" class="hidden">فتح Twitch</a>
            </div>
          </div>

          <div class="tnx-modal-actions">
            <button id="copyArtLink" class="tnx-modal-btn" type="button">نسخ الرابط</button>
            <button id="closePopup" class="tnx-modal-close" type="button" aria-label="إغلاق">×</button>
          </div>
        </div>

        <div class="tnx-modal-body">
          <button id="prevArt" class="tnx-nav-btn tnx-nav-prev" type="button" aria-label="السابق">‹</button>

          <div id="zoomStage" class="tnx-zoom-stage">
            <div id="zoomBadge" class="tnx-zoom-badge">100%</div>
            <img id="popupImg" alt="" draggable="false" />
          </div>

          <button id="nextArt" class="tnx-nav-btn tnx-nav-next" type="button" aria-label="التالي">›</button>
        </div>

        <div id="thumbStrip" class="tnx-thumb-strip">
          {artworkItems.map((art) => (
            <button type="button" class="thumb-btn" data-index={art.index} aria-label={`فتح رسمة ${art.artist}`} title={art.artist}>
              <img src={art.image} alt={art.artist} loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.38) rgba(0, 0, 0, 0.3);
    }

    html::-webkit-scrollbar {
      width: 10px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(0, 0, 0, 0.35);
    }

    html::-webkit-scrollbar-thumb {
      border: 2px solid rgba(0, 0, 0, 0.35);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 218, 106, 0.78), rgba(194, 146, 0, 0.5));
    }

    .hidden {
      display: none !important;
    }

    .tnx-fanart-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.14), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.12), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.1), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
      animation: tnxBgBreathe 9s ease-in-out infinite;
    }

    @keyframes tnxBgBreathe {
      0%, 100% { filter: saturate(1) brightness(1); transform: scale(1); }
      50% { filter: saturate(1.12) brightness(1.06); transform: scale(1.018); }
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.06;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.42) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.42) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background: rgba(7, 5, 11, 0.9);
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 22px rgba(255, 218, 106, 0.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.78);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 650ms ease, transform 650ms ease;
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 940px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.4);
      color: #ffda6a;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.16em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
      animation: tnxPulse 1.8s ease-in-out infinite;
    }

    @keyframes tnxPulse {
      0%, 100% { opacity: 0.75; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.25); }
    }

    .tnx-hero h1 {
      margin: 1.1rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.1rem, 7vw, 6.6rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.055em;
    }

    .tnx-hero p {
      max-width: 760px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.04rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 520px;
      margin: 1.35rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-featured,
    .tnx-toolbar,
    .tnx-gallery {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)), rgba(6, 6, 8, 0.78);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.44), inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 0.9rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.8rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.78rem;
      font-weight: 850;
    }

    .tnx-featured,
    .tnx-toolbar,
    .tnx-gallery {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head {
      text-align: center;
      margin-bottom: 1rem;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.35rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.45rem auto 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
      max-width: 620px;
    }

    .tnx-section-head-inline {
      text-align: right;
      margin: 0;
    }

    .tnx-section-head-inline p {
      margin-inline: 0;
    }

    .tnx-featured-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .tnx-featured-card {
      position: relative;
      min-height: 270px;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1.35rem;
      background: rgba(0, 0, 0, 0.32);
      cursor: pointer;
      transition: 260ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-featured-card:hover {
      transform: translateY(-5px) scale(1.012);
      border-color: rgba(255, 218, 106, 0.5);
      box-shadow: 0 22px 44px rgba(0, 0, 0, 0.42), 0 0 28px rgba(255, 218, 106, 0.12);
    }

    .tnx-featured-card img {
      width: 100%;
      height: 100%;
      min-height: 270px;
      object-fit: cover;
      display: block;
      filter: saturate(1.04) contrast(1.04);
      transition: 260ms ease;
    }

    .tnx-featured-card:hover img {
      transform: scale(1.06);
      filter: saturate(1.16) contrast(1.08);
    }

    .tnx-featured-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.82), rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.16));
      pointer-events: none;
    }

    .tnx-featured-info {
      position: absolute;
      right: 0.85rem;
      left: 0.85rem;
      bottom: 0.85rem;
      z-index: 1;
      display: grid;
      gap: 0.25rem;
      text-align: right;
    }

    .tnx-featured-info strong {
      color: #fff;
      font-size: 1.2rem;
      font-weight: 950;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.85);
    }

    .tnx-featured-info span {
      color: #ffda6a;
      font-size: 0.82rem;
      font-weight: 850;
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
      max-width: 720px;
      margin: 0 auto;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem auto 0;
      justify-content: center;
      max-width: 1060px;
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.6rem 0.8rem;
      font-size: 0.8rem;
      font-weight: 950;
      cursor: pointer;
      transition: 200ms ease;
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.66rem;
    }

    .tnx-gallery-top {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 218, 106, 0.1);
    }

    .tnx-gallery-count {
      display: grid;
      place-items: center;
      min-width: 92px;
      border: 1px solid rgba(255, 218, 106, 0.18);
      border-radius: 1rem;
      background: rgba(255, 218, 106, 0.06);
      padding: 0.75rem;
    }

    .tnx-gallery-count strong {
      color: #ffda6a;
      font-size: 1.45rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-gallery-count span {
      margin-top: 0.25rem;
      color: rgb(156, 163, 175);
      font-size: 0.72rem;
      font-weight: 850;
    }

    .fanart-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .fanart-card {
      --delay: 0ms;
      position: relative;
      isolation: isolate;
      min-height: 280px;
      overflow: hidden;
      border: 1px solid rgba(255, 218, 106, 0.14);
      border-radius: 1.4rem;
      background: rgba(0, 0, 0, 0.32);
      cursor: pointer;
      padding: 0;
      opacity: 0;
      transform: translateY(14px) scale(0.98);
      animation: fanartCascade 520ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      animation-delay: var(--delay);
      transition: 260ms cubic-bezier(0.22, 1, 0.36, 1);
