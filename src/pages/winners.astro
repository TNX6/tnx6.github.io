---
import Layout from '~/layouts/PageLayout.astro'

const metadata = {
  title: 'الفائزين — TNX6',
  ignoreTitleTemplate: true,
  description: 'قاعة فائزين مجتمع TNX6 — مسابقات، جوائز، تكريمات، وأسماء محفورة في المجلس.',
}
---

<Layout metadata={metadata}>
  <main class="tnx-winners-page" dir="rtl">
    <div class="tnx-bg"></div>
    <div class="tnx-grid-bg"></div>

    <button id="backToTop" class="tnx-back-top" type="button" aria-label="الرجوع للأعلى">↑</button>

    <section class="tnx-shell">
      <header class="tnx-hero tnx-reveal">
        <div class="tnx-eyebrow">
          <span></span>
          TNX6 HALL OF WINNERS
        </div>

        <h1>قاعة الفائزين</h1>

        <p>
          أسماء أخذت مكانها في تاريخ المجتمع. مسابقات، جوائز، حضور، دعم، ومواقف تستاهل التكريم.
        </p>

        <div class="tnx-hero-stats">
          <div>
            <strong id="statTotalWinners">0</strong>
            <span>فائزين</span>
          </div>
          <div>
            <strong id="statYearsCount">0</strong>
            <span>سنتين</span>
          </div>
          <div>
            <strong id="statFeaturedCount">0</strong>
            <span>تكريم بارز</span>
          </div>
          <div>
            <strong id="statContestsCount">0</strong>
            <span>مسابقة</span>
          </div>
        </div>
      </header>

      <section class="tnx-featured tnx-reveal">
        <div class="tnx-section-head">
          <span>FEATURED</span>
          <h2>أبرز الفائزين</h2>
          <p>الفائزون البارزون يتغيرون عشوائيًا مع كل تحديث للصفحة.</p>
        </div>

        <div id="featuredGrid" class="tnx-featured-grid"></div>
      </section>

      <section class="tnx-toolbar tnx-reveal">
        <div class="tnx-search">
          <span>⌕</span>
          <input id="winnerSearch" type="search" autocomplete="off" placeholder="ابحث باسم الفائز أو نوع الجائزة..." />
          <button type="button" id="clearWinnerSearch">×</button>
        </div>

        <div id="winnerFilters" class="tnx-filter-row">
          <button type="button" class="is-active" data-filter="all"><span>الكل</span><small id="count-all">0</small></button>
          <button type="button" data-filter="award"><span>🏆 جوائز</span><small id="count-award">0</small></button>
          <button type="button" data-filter="contest"><span>🎮 مسابقات</span><small id="count-contest">0</small></button>
        </div>
      </section>

      <section class="tnx-winners-vault tnx-reveal">
        <div class="tnx-section-head">
          <span>WINNERS VAULT</span>
          <h2>كل الفائزين</h2>
          <p>اضغط على أي بطاقة لعرض تفاصيل الفوز.</p>
        </div>

        <div id="winnersGrid" class="tnx-winners-grid"></div>

        <div id="winnersEmpty" class="tnx-empty hidden">
          <strong>ما فيه نتائج</strong>
          <span>جرّب تبحث باسم أبسط أو غيّر الفلتر.</span>
        </div>
      </section>
    </section>

    <div id="winnerModal" class="tnx-modal hidden" aria-hidden="true">
      <button id="winnerModalBackdrop" class="tnx-modal-backdrop" type="button" aria-label="إغلاق"></button>

      <section id="winnerModalCard" class="tnx-modal-card" role="dialog" aria-modal="true" aria-labelledby="winnerModalName">
        <button id="winnerModalClose" class="tnx-modal-close" type="button" aria-label="إغلاق">×</button>

        <div class="tnx-modal-top">
          <div class="tnx-modal-avatar-wrap">
            <img id="winnerModalAvatar" src="" alt="" referrerpolicy="no-referrer" />
          </div>

          <div>
            <span id="winnerModalBadge" class="tnx-modal-badge">الفائز</span>
            <h3 id="winnerModalName"></h3>
            <p id="winnerModalReason"></p>
          </div>
        </div>

        <div class="tnx-modal-meta">
          <div>
            <span>السنة</span>
            <strong id="winnerModalYear">—</strong>
          </div>
          <div>
            <span>التصنيف</span>
            <strong id="winnerModalCategory">—</strong>
          </div>
        </div>
      </section>
    </div>

  </main>

  <style is:global>
    html {
      scrollbar-width: thin;
      scrollbar-color: rgba(255, 218, 106, 0.55) rgba(7, 5, 11, 0.95);
    }

    html::-webkit-scrollbar {
      width: 12px;
    }

    html::-webkit-scrollbar-track {
      background: rgba(7, 5, 11, 0.96);
    }

    html::-webkit-scrollbar-thumb {
      border: 3px solid rgba(7, 5, 11, 0.96);
      border-radius: 999px;
      background: linear-gradient(180deg, #ffda6a, #c29200);
    }

    .hidden {
      display: none !important;
    }

    .tnx-winners-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      background: #07050b;
      color: white;
      font-family: Poppins, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .tnx-bg {
      position: fixed;
      inset: -2%;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 12% 9%, rgba(255, 218, 106, 0.16), transparent 28%),
        radial-gradient(circle at 86% 14%, rgba(194, 146, 0, 0.14), transparent 34%),
        radial-gradient(circle at 48% 92%, rgba(124, 58, 237, 0.11), transparent 38%),
        linear-gradient(135deg, #07050b 0%, #050507 55%, #130c05 100%);
      animation: tnxBgBreathe 11s ease-in-out infinite;
    }

    @keyframes tnxBgBreathe {
      0%, 100% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.025); filter: brightness(1.08); }
    }

    .tnx-grid-bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.06;
      background-image:
        linear-gradient(rgba(255, 218, 106, 0.42) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 218, 106, 0.42) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at center, black 0%, transparent 74%);
    }

    .tnx-shell {
      position: relative;
      z-index: 1;
      width: min(100%, 1240px);
      margin: 0 auto;
      padding: 6.5rem 1rem 5rem;
    }

    .tnx-back-top {
      position: fixed;
      left: 1.25rem;
      bottom: 1.25rem;
      z-index: 90;
      display: grid;
      place-items: center;
      width: 3.1rem;
      height: 3.1rem;
      border: 1px solid rgba(255, 218, 106, 0.42);
      border-radius: 999px;
      background:
        radial-gradient(circle at 35% 25%, rgba(255, 218, 106, 0.22), transparent 60%),
        rgba(7, 5, 11, 0.9);
      color: #ffda6a;
      font-size: 1.35rem;
      font-weight: 950;
      cursor: pointer;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45), 0 0 22px rgba(255, 218, 106, 0.12);
      backdrop-filter: blur(14px);
      opacity: 0;
      transform: translateY(16px) scale(0.92);
      pointer-events: none;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .tnx-back-top.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .tnx-back-top:hover {
      transform: translateY(-3px) scale(1.04);
      border-color: rgba(255, 218, 106, 0.78);
    }

    .tnx-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 650ms ease, transform 650ms ease;
    }

    .tnx-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tnx-hero {
      max-width: 960px;
      margin: 0 auto 1.25rem;
      text-align: center;
    }

    .tnx-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.3);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.4);
      color: #ffda6a;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.16em;
    }

    .tnx-eyebrow span {
      width: 0.48rem;
      height: 0.48rem;
      border-radius: 999px;
      background: #ffda6a;
      box-shadow: 0 0 14px #ffda6a;
      animation: tnxPulse 1.8s ease-in-out infinite;
    }

    @keyframes tnxPulse {
      0%, 100% { opacity: 0.75; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.25); }
    }

    .tnx-hero h1 {
      margin: 1.1rem 0 0;
      background: linear-gradient(90deg, #fff1a8, #ffda6a 44%, #c29200);
      background-clip: text;
      color: transparent;
      font-size: clamp(3.1rem, 7vw, 6.8rem);
      font-weight: 950;
      line-height: 0.95;
      letter-spacing: -0.055em;
    }

    .tnx-hero p {
      max-width: 780px;
      margin: 1.15rem auto 0;
      color: rgb(209, 213, 219);
      font-size: 1.04rem;
      font-weight: 760;
      line-height: 1.9;
    }

    .tnx-hero-stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
      max-width: 860px;
      margin: 1.35rem auto 0;
    }

    .tnx-hero-stats div,
    .tnx-featured,
    .tnx-toolbar,
    .tnx-winners-vault {
      border: 1px solid rgba(255, 218, 106, 0.18);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.012)), rgba(6, 6, 8, 0.78);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.44), inset 0 0 22px rgba(255, 218, 106, 0.025);
      backdrop-filter: blur(16px);
    }

    .tnx-hero-stats div {
      border-radius: 1.25rem;
      padding: 0.9rem;
    }

    .tnx-hero-stats strong {
      display: block;
      color: #ffda6a;
      font-size: 1.7rem;
      font-weight: 950;
      line-height: 1;
    }

    .tnx-hero-stats span {
      display: block;
      margin-top: 0.35rem;
      color: rgb(156, 163, 175);
      font-size: 0.78rem;
      font-weight: 850;
    }

    .tnx-featured,
    .tnx-toolbar,
    .tnx-winners-vault {
      margin-top: 1rem;
      border-radius: 1.8rem;
      padding: 1.25rem;
    }

    .tnx-section-head {
      text-align: center;
      margin-bottom: 1rem;
    }

    .tnx-section-head span {
      color: #c29200;
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
    }

    .tnx-section-head h2 {
      margin: 0.35rem 0 0;
      color: #f7e6ac;
      font-size: 2rem;
      font-weight: 950;
      line-height: 1.15;
    }

    .tnx-section-head p {
      margin: 0.45rem auto 0;
      color: rgb(156, 163, 175);
      font-size: 0.92rem;
      font-weight: 800;
      line-height: 1.75;
      max-width: 620px;
    }

    .tnx-featured-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .tnx-feature-card {
      position: relative;
      min-height: 245px;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 1.35rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.12), transparent 44%),
        rgba(0, 0, 0, 0.32);
      color: white;
      overflow: hidden;
      padding: 1rem;
      cursor: pointer;
      transition: 240ms cubic-bezier(0.22, 1, 0.36, 1);
      text-align: center;
    }

    .tnx-feature-card::before {
      content: '';
      position: absolute;
      inset: -35%;
      background: conic-gradient(from 0deg, transparent, rgba(255, 218, 106, 0.12), transparent 32%);
      animation: tnxShine 6s linear infinite;
      pointer-events: none;
      opacity: 0.75;
    }

    @keyframes tnxShine {
      to { transform: rotate(360deg); }
    }

    .tnx-feature-card > * {
      position: relative;
      z-index: 1;
    }

    .tnx-feature-card:hover {
      transform: translateY(-5px) scale(1.015);
      border-color: rgba(255, 218, 106, 0.62);
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.42), 0 0 32px rgba(255, 218, 106, 0.16);
    }

    .tnx-feature-avatar {
      width: 112px;
      height: 112px;
      margin: 0 auto 0.8rem;
      border-radius: 1.25rem;
      border: 2px solid rgba(255, 218, 106, 0.34);
      object-fit: cover;
      box-shadow: 0 16px 30px rgba(0, 0, 0, 0.35);
    }

    .tnx-feature-card strong {
      display: block;
      color: white;
      font-size: 1.1rem;
      font-weight: 950;
      line-height: 1.2;
    }

    .tnx-feature-card span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      margin-top: 0.55rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      padding: 0.35rem 0.65rem;
      font-size: 0.72rem;
      font-weight: 950;
    }

    .tnx-feature-card p {
      margin: 0.55rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 0.78rem;
      font-weight: 800;
      line-height: 1.55;
    }

    .tnx-search {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 1.15rem;
      background: rgba(0, 0, 0, 0.32);
      padding: 0.85rem;
      max-width: 720px;
      margin: 0 auto;
    }

    .tnx-search span {
      color: #ffda6a;
      font-size: 1.4rem;
      font-weight: 950;
    }

    .tnx-search input {
      width: 100%;
      border: 0;
      background: transparent;
      color: white;
      font-size: 0.95rem;
      font-weight: 850;
      outline: none;
    }

    .tnx-search button {
      display: grid;
      place-items: center;
      width: 2.2rem;
      height: 2.2rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.2rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-filter-row {
      position: sticky;
      top: 5.25rem;
      z-index: 30;
      display: flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 1rem auto 0;
      justify-content: center;
      max-width: 960px;
    }

    .tnx-filter-row button {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border: 1px solid rgba(255, 218, 106, 0.24);
      border-radius: 0.9rem;
      background: rgba(255, 218, 106, 0.08);
      color: #f7e6ac;
      padding: 0.6rem 0.8rem;
      font-size: 0.8rem;
      font-weight: 950;
      cursor: pointer;
      transition: 200ms ease;
      white-space: nowrap;
    }

    .tnx-filter-row button:hover,
    .tnx-filter-row button.is-active {
      transform: translateY(-1px);
      border-color: rgba(255, 218, 106, 0.55);
      background: rgba(255, 218, 106, 0.14);
      color: #ffda6a;
    }

    .tnx-filter-row small {
      display: grid;
      place-items: center;
      min-width: 1.35rem;
      height: 1.35rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.34);
      color: rgb(229, 231, 235);
      font-size: 0.66rem;
    }

    .tnx-winners-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.9rem;
    }

    .tnx-winner-card {
      position: relative;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.9rem;
      align-items: center;
      min-height: 142px;
      border: 1px solid rgba(255, 218, 106, 0.16);
      border-radius: 1.25rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.08), transparent 45%),
        rgba(0, 0, 0, 0.32);
      color: white;
      padding: 0.9rem;
      text-align: right;
      cursor: pointer;
      overflow: hidden;
      transition: 220ms cubic-bezier(0.22, 1, 0.36, 1);
      animation: tnxCardIn 420ms ease both;
      animation-delay: calc(var(--stagger, 0) * 45ms);
    }

    @keyframes tnxCardIn {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .tnx-winner-card:hover {
      transform: translateY(-4px) scale(1.01);
      border-color: rgba(255, 218, 106, 0.52);
      box-shadow: 0 18px 38px rgba(0, 0, 0, 0.36), 0 0 26px rgba(255, 218, 106, 0.11);
    }

    .tnx-winner-card-avatar {
      width: 78px;
      height: 78px;
      border-radius: 1rem;
      border: 1px solid rgba(255, 218, 106, 0.28);
      object-fit: cover;
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.32);
    }

    .tnx-winner-card-content {
      min-width: 0;
    }

    .tnx-winner-card-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      border: 1px solid rgba(255, 218, 106, 0.2);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.07);
      color: #ffda6a;
      padding: 0.22rem 0.55rem;
      font-size: 0.68rem;
      font-weight: 950;
      margin-bottom: 0.35rem;
    }

    .tnx-winner-card strong {
      display: block;
      color: white;
      font-size: 1.05rem;
      font-weight: 950;
      line-height: 1.25;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tnx-winner-card p {
      margin: 0.35rem 0 0;
      color: rgb(180, 180, 195);
      font-size: 0.78rem;
      font-weight: 800;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .tnx-empty {
      display: grid;
      place-items: center;
      gap: 0.35rem;
      border: 1px solid rgba(255, 218, 106, 0.13);
      border-radius: 1.5rem;
      background: rgba(0, 0, 0, 0.24);
      padding: 2rem;
      text-align: center;
      min-height: 200px;
    }

    .tnx-empty strong {
      color: #ffda6a;
      font-size: 1.3rem;
      font-weight: 950;
    }

    .tnx-empty span {
      color: rgb(156, 163, 175);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .tnx-modal {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: grid;
      place-items: center;
      padding: 1rem;
    }

    .tnx-modal-backdrop {
      position: absolute;
      inset: 0;
      border: 0;
      background: rgba(0, 0, 0, 0.72);
      backdrop-filter: blur(10px);
      cursor: pointer;
    }

    .tnx-modal-card {
      position: relative;
      z-index: 1;
      width: min(100%, 560px);
      border: 1px solid rgba(255, 218, 106, 0.34);
      border-radius: 1.5rem;
      background:
        radial-gradient(circle at top right, rgba(255, 218, 106, 0.13), transparent 45%),
        rgba(8, 7, 10, 0.92);
      box-shadow: 0 28px 90px rgba(0, 0, 0, 0.58), 0 0 34px rgba(255, 218, 106, 0.12);
      padding: 1.2rem;
      animation: tnxModalIn 260ms ease both;
    }

    @keyframes tnxModalIn {
      from { opacity: 0; transform: translateY(14px) scale(0.96); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .tnx-modal-close {
      position: absolute;
      top: 0.85rem;
      left: 0.85rem;
      display: grid;
      place-items: center;
      width: 2.3rem;
      height: 2.3rem;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      font-size: 1.3rem;
      font-weight: 950;
      cursor: pointer;
    }

    .tnx-modal-top {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 1rem;
      align-items: center;
    }

    .tnx-modal-avatar-wrap {
      position: relative;
      width: 132px;
      height: 132px;
      border-radius: 1.35rem;
      padding: 0.25rem;
      background: linear-gradient(135deg, #ffda6a, #c29200, #fff1a8);
      box-shadow: 0 16px 34px rgba(0, 0, 0, 0.38);
    }

    .tnx-modal-avatar-wrap img {
      width: 100%;
      height: 100%;
      border-radius: 1.1rem;
      object-fit: cover;
      background: #111;
    }

    .tnx-modal-badge {
      display: inline-flex;
      border: 1px solid rgba(255, 218, 106, 0.22);
      border-radius: 999px;
      background: rgba(255, 218, 106, 0.08);
      color: #ffda6a;
      padding: 0.28rem 0.65rem;
      font-size: 0.72rem;
      font-weight: 950;
      margin-bottom: 0.55rem;
    }

    .tnx-modal-card h3 {
      margin: 0;
      color: white;
      font-size: clamp(1.75rem, 4vw, 2.6rem);
      font-weight: 950;
      line-height: 1.1;
    }

    .tnx-modal-card p {
      margin: 0.65rem 0 0;
      color: rgb(209, 213, 219);
      font-size: 1rem;
      font-weight: 800;
      line-height: 1.75;
    }

    .tnx-modal-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }

.tnx-modal-meta div {
  display: grid;
  place-items: center;
  align-content: center;
  min-height: 5.3rem;
  border: 1px solid rgba(255, 218, 106, 0.12);
  border-radius: 1rem;
  background: rgba(0, 0, 0, 0.26);
  padding: 0.85rem;
  text-align: center;
}

.tnx-modal-meta span {
  display: block;
  width: 100%;
  color: rgb(148, 163, 184);
  font-size: 0.72rem;
  font-weight: 900;
  margin-bottom: 0.25rem;
  text-align: center;
}

.tnx-modal-meta strong {
  display: block;
  width: 100%;
  color: #ffda6a;
  font-size: 0.9rem;
  font-weight: 950;
  text-align: center;
}

    @media (max-width: 1100px) {
      .tnx-featured-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .tnx-winners-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .tnx-hero-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .tnx-featured-grid,
      .tnx-winners-grid {
        grid-template-columns: 1fr;
      }

      .tnx-filter-row {
        top: 4.75rem;
      }

      .tnx-modal-top {
        grid-template-columns: 1fr;
        text-align: center;
        justify-items: center;
      }

      .tnx-modal-meta {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .tnx-shell {
        padding-top: 5.5rem;
      }

      .tnx-hero h1 {
        font-size: 3rem;
      }

      .tnx-winner-card {
        grid-template-columns: 1fr;
        text-align: center;
        justify-items: center;
      }

      .tnx-winner-card strong {
        white-space: normal;
      }

      .tnx-back-top {
        left: 0.9rem;
        bottom: 0.9rem;
        width: 2.8rem;
        height: 2.8rem;
      }
    }
  </style>

  <script is:inline data-reinit>
    ;(async () => {
      const cleanupKey = '__tnxWinnersPageCleanup'

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      const listeners = []
      let revealObserver = null
      let allWinners = []

      function addListener(target, event, handler, options) {
        if (!target) return
        target.addEventListener(event, handler, options)
        listeners.push(() => target.removeEventListener(event, handler, options))
      }

      window[cleanupKey] = () => {
        listeners.forEach((cleanup) => cleanup())
        listeners.length = 0
        if (revealObserver) revealObserver.disconnect()
        document.body.style.overflow = ''
      }

      const CATEGORY_LABELS = {
        award: '🏆 جوائز',
        vip: '👑 VIP',
        contest: '🎮 مسابقات',
        support: '💛 دعم',
        chat: '🗣️ شات',
        mod: '🔨 مود',
        attendance: '⭐ حضور',
      }

      const CATEGORY_ICONS = {
        award: '🏆',
        vip: '👑',
        contest: '🎮',
        support: '💛',
        chat: '🗣️',
        mod: '🔨',
        attendance: '⭐',
      }

      const CATEGORY_TITLES = {
        award: 'فائز مميز',
        vip: 'تكريم VIP',
        contest: 'بطل مسابقة',
        support: 'داعم مميز',
        chat: 'متفاعل مميز',
        mod: 'مود مميز',
        attendance: 'حضور مستمر',
      }

      const state = {
        filter: 'all',
        search: '',
      }

      const featuredGrid = document.getElementById('featuredGrid')
      const winnersGrid = document.getElementById('winnersGrid')
      const winnersEmpty = document.getElementById('winnersEmpty')
      const winnerSearch = document.getElementById('winnerSearch')
      const clearWinnerSearch = document.getElementById('clearWinnerSearch')
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'))
      const backToTop = document.getElementById('backToTop')
      const modal = document.getElementById('winnerModal')
      const modalBackdrop = document.getElementById('winnerModalBackdrop')
      const modalClose = document.getElementById('winnerModalClose')
      const modalAvatar = document.getElementById('winnerModalAvatar')
      const modalName = document.getElementById('winnerModalName')
      const modalReason = document.getElementById('winnerModalReason')
      const modalYear = document.getElementById('winnerModalYear')
      const modalCategory = document.getElementById('winnerModalCategory')
      const modalBadge = document.getElementById('winnerModalBadge')

      const statTotalWinners = document.getElementById('statTotalWinners')
      const statYearsCount = document.getElementById('statYearsCount')
      const statFeaturedCount = document.getElementById('statFeaturedCount')
      const statContestsCount = document.getElementById('statContestsCount')

      function esc(value) {
        return String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;')
      }

      function normalize(value) {
        return String(value || '')
          .toLowerCase()
          .replace(/[ًٌٍَُِّْـ]/g, '')
          .replace(/[أإآ]/g, 'ا')
          .replace(/ة/g, 'ه')
          .replace(/ى/g, 'ي')
          .replace(/\s+/g, ' ')
          .trim()
      }

      function cleanCategory(category, awardText = '') {
        const raw = normalize(category)
        if (CATEGORY_LABELS[raw]) return raw

        const text = normalize(awardText)
        if (text.includes('vip')) return 'vip'
        if (text.includes('مود')) return 'mod'
        if (text.includes('شات') || text.includes('شاتر')) return 'chat'
        if (text.includes('داعم') || text.includes('دعم')) return 'support'
        if (text.includes('حضور')) return 'attendance'
        if (text.includes('مسابق') || text.includes('فاز') || text.includes('فائزة')) return 'contest'
        return 'award'
      }

      function makeTitle(winner) {
        const text = winner.reason || winner.award || ''
        if (winner.title) return winner.title
        if (text.includes('أفضل VIP')) return 'أفضل VIP'
        if (text.includes('أفضل داعم')) return 'أفضل داعم'
        if (text.includes('أفضل شاتر')) return 'أفضل شاتر'
        if (text.includes('أفضل مود')) return 'أفضل مود'
        if (text.includes('الحضور')) return 'الحضور المستمر'
        if (text.includes('الدنجن')) return 'بطل الدنجن'
        if (text.includes('الطبخ')) return 'بطل الطبخ'
        return CATEGORY_TITLES[winner.category] || 'فائز'
      }

      function normalizeWinner(raw, index) {
        const reason = String(raw.reason || raw.award || raw.title || 'تكريم من مجتمع TNX6').trim()
        const category = cleanCategory(raw.category, reason)
        const name = String(raw.userName || raw.name || raw.userLogin || raw.login || 'Unknown').trim()
        const login = String(raw.userLogin || raw.login || raw.name || '').trim()
        const avatar = String(raw.avatar || raw.profileImageUrl || raw.profileImage || '').trim()
        const year = String(raw.year || '').trim()
        const icon = raw.icon || CATEGORY_ICONS[category] || '🏆'

        return {
          ...raw,
          index,
          name,
          login,
          avatar,
          reason,
          year,
          category,
          icon,
          title: makeTitle({ ...raw, reason, category }),
          featured: Boolean(raw.featured),
          searchText: normalize([name, login, reason, year, category, CATEGORY_LABELS[category]].join(' ')),
        }
      }

      function updateStats() {
        const yearsCount = new Set(allWinners.map((winner) => winner.year).filter(Boolean)).size
        const featuredCount = allWinners.filter((winner) => winner.featured).length
        const contestsCount = allWinners.filter((winner) => winner.category === 'contest').length

        if (statTotalWinners) statTotalWinners.textContent = String(allWinners.length)
        if (statYearsCount) statYearsCount.textContent = String(yearsCount)
        if (statFeaturedCount) statFeaturedCount.textContent = String(featuredCount || Math.min(4, allWinners.length))
        if (statContestsCount) statContestsCount.textContent = String(contestsCount)
      }

      function getSearchText(winner) {
        return winner.searchText || normalize([
          winner.name,
          winner.login,
          winner.reason,
          winner.title,
          winner.year,
          winner.category,
          CATEGORY_LABELS[winner.category],
        ].join(' '))
      }

      function updateCounts() {
        const counts = {
          all: allWinners.length,
          award: 0,
          vip: 0,
          contest: 0,
          support: 0,
          chat: 0,
          mod: 0,
          attendance: 0,
        }

        allWinners.forEach((winner) => {
          if (counts[winner.category] !== undefined) counts[winner.category] += 1
          else counts.award += 1
        })

        Object.entries(counts).forEach(([key, value]) => {
          const el = document.getElementById(`count-${key}`)
          if (el) el.textContent = String(value)
        })
      }

      function getFilteredWinners() {
        const q = normalize(state.search)

        return allWinners.filter((winner) => {
          const filterMatch = state.filter === 'all' || winner.category === state.filter
          const searchMatch = !q || getSearchText(winner).includes(q)
          return filterMatch && searchMatch
        })
      }

      function getRandomFeaturedWinners() {
        const preferred = allWinners.filter((winner) => winner.featured)
        const pool = preferred.length >= 4 ? [...preferred] : [...allWinners]

        for (let i = pool.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1))
          const temp = pool[i]
          pool[i] = pool[j]
          pool[j] = temp
        }

        return pool.slice(0, 4)
      }

      function renderFeatured() {
        if (!featuredGrid) return

        const featured = getRandomFeaturedWinners()

        if (!featured.length) {
          featuredGrid.innerHTML = `
            <div class="tnx-empty" style="grid-column: 1 / -1;">
              <strong>ما فيه بيانات فائزين</strong>
              <span>شغّل أكشن Streamer.bot عشان ينشئ /api/winners.json.</span>
            </div>
          `
          return
        }

        featuredGrid.innerHTML = featured.map((winner, index) => `
          <button type="button" class="tnx-feature-card" data-winner-index="${winner.index}" style="--stagger:${index}">
            <img class="tnx-feature-avatar" src="${esc(winner.avatar)}" alt="${esc(winner.name)}" loading="lazy" referrerpolicy="no-referrer" />
            <strong>${esc(winner.name)}</strong>
            <span>${esc(winner.icon)} ${esc(winner.title)}</span>
            <p>${esc(winner.reason)}</p>
          </button>
        `).join('')
      }

      function renderFilterButtons() {
        filterButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.filter === state.filter)
        })
      }

      function renderWinners() {
        if (!winnersGrid) return

        const winners = getFilteredWinners()

        winnersEmpty?.classList.toggle('hidden', winners.length > 0)

        winnersGrid.innerHTML = winners.map((winner, index) => {
          const label = CATEGORY_LABELS[winner.category] || 'فائز'

          return `
            <button type="button" class="tnx-winner-card" data-winner-index="${winner.index}" style="--stagger:${index}">
              <img class="tnx-winner-card-avatar" src="${esc(winner.avatar)}" alt="${esc(winner.name)}" loading="lazy" referrerpolicy="no-referrer" />
              <div class="tnx-winner-card-content">
                <span class="tnx-winner-card-tag">${esc(label)} · ${esc(winner.year || '—')}</span>
                <strong>${esc(winner.name)}</strong>
                <p>${esc(winner.reason)}</p>
              </div>
            </button>
          `
        }).join('')
      }

      function openModal(winner) {
        if (!modal || !winner) return

        modalAvatar.src = winner.avatar
        modalAvatar.alt = winner.name
        modalName.textContent = winner.name
        modalReason.textContent = winner.reason
        modalYear.textContent = winner.year || '—'
        modalCategory.textContent = CATEGORY_LABELS[winner.category] || 'فائز'
        modalBadge.textContent = `${winner.icon || '🏆'} ${winner.title || 'فائز'}`

        modal.classList.remove('hidden')
        modal.setAttribute('aria-hidden', 'false')
        document.body.style.overflow = 'hidden'
      }

      function closeModal() {
        if (!modal) return
        modal.classList.add('hidden')
        modal.setAttribute('aria-hidden', 'true')
        document.body.style.overflow = ''
      }

      function handleBackToTop() {
        if (!backToTop) return
        backToTop.classList.toggle('is-visible', window.scrollY > 520)
      }

      function setupReveal() {
        const elements = Array.from(document.querySelectorAll('.tnx-reveal'))
        if (!elements.length) return

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              revealObserver.unobserve(entry.target)
            }
          })
        }, { threshold: 0.12 })

        elements.forEach((element) => revealObserver.observe(element))
      }

      async function loadWinners() {
        try {
          const response = await fetch('/api/winners.json', { cache: 'no-store' })
          if (!response.ok) throw new Error(`winners.json request failed: ${response.status}`)

          const json = await response.json()
          const list = Array.isArray(json) ? json : []

          allWinners = list
            .map(normalizeWinner)
            .filter((winner) => winner.name && winner.avatar)

          updateStats()
          updateCounts()
          renderFeatured()
          renderFilterButtons()
          renderWinners()
        } catch (error) {
          console.error('Failed to load /api/winners.json', error)

          allWinners = []
          updateStats()
          updateCounts()
          renderFeatured()
          renderWinners()

          if (winnersGrid) {
            winnersGrid.innerHTML = `
              <div class="tnx-empty" style="grid-column: 1 / -1;">
                <strong>تعذر تحميل الفائزين</strong>
                <span>تأكد أن أكشن Streamer.bot أنشأ الملف public/api/winners.json.</span>
              </div>
            `
          }
        }
      }

      addListener(featuredGrid, 'click', (event) => {
        const card = event.target.closest('[data-winner-index]')
        if (!card) return
        openModal(allWinners[Number(card.dataset.winnerIndex)])
      })

      addListener(winnersGrid, 'click', (event) => {
        const card = event.target.closest('[data-winner-index]')
        if (!card) return
        openModal(allWinners[Number(card.dataset.winnerIndex)])
      })

      addListener(winnerSearch, 'input', () => {
        state.search = winnerSearch.value
        renderWinners()
      })

      addListener(clearWinnerSearch, 'click', () => {
        if (!winnerSearch) return
        winnerSearch.value = ''
        state.search = ''
        winnerSearch.focus()
        renderWinners()
      })

      filterButtons.forEach((button) => {
        addListener(button, 'click', () => {
          state.filter = button.dataset.filter || 'all'
          renderFilterButtons()
          renderWinners()
        })
      })

      addListener(modalBackdrop, 'click', closeModal)
      addListener(modalClose, 'click', closeModal)
      addListener(document, 'keydown', (event) => {
        if (event.key === 'Escape') closeModal()
      })

      addListener(backToTop, 'click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })

      addListener(window, 'scroll', handleBackToTop, { passive: true })

      await loadWinners()
      setupReveal()
      handleBackToTop()
    })()
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</Layout>
