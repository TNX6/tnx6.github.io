<script is:inline>
  ;(() => {
    const cleanupKey = '__tnxLeaderboardsCleanup'

    if (window[cleanupKey]) {
      window[cleanupKey]()
    }

    const perPage = 20

    const boardConfig = {
      points: {
        title: 'النقاط',
        heading: 'ترتيب النقاط',
        subtitle: 'أكثر الأعضاء نقاطًا',
        description: 'أكثر الأعضاء نقاطًا في المجتمع.',
        icon: 'tabler:coins',
        unit: 'نقطة',
        emptyTitle: 'ما فيه بيانات نقاط',
        emptyText: 'تأكد أن ملف leaderboard_data.json يحتوي على points.',
      },
      gold: {
        title: 'الذهب',
        heading: 'ترتيب الذهب',
        subtitle: 'ترتيب الذهب',
        description: 'أكثر الأعضاء امتلاكًا للذهب.',
        icon: 'tabler:coin',
        unit: 'ذهب',
        emptyTitle: 'الذهب غير مفعل حاليًا',
        emptyText: 'القسم جاهز، وبيظهر الترتيب إذا بدأت تسجل بيانات gold.',
      },
      watchtime: {
        title: 'المشاهدة',
        heading: 'ترتيب المشاهدة',
        subtitle: 'أكثر الأعضاء مشاهدة',
        description: 'أكثر الأعضاء حضورًا ومشاهدة.',
        icon: 'tabler:clock-hour-4',
        unit: '',
        emptyTitle: 'ما فيه بيانات مشاهدة',
        emptyText: 'تأكد أن ملف leaderboard_data.json يحتوي على watchtime.',
      },
    }

    let activeBoard = 'points'
    let searchQuery = ''

    let allData = {
      points: [],
      gold: [],
      watchtime: [],
    }

    let filteredData = {
      points: [],
      gold: [],
      watchtime: [],
    }

    let indexes = {
      points: 0,
      gold: 0,
      watchtime: 0,
    }

    let revealObserver = null
    const listeners = []

    function addListener(target, event, handler, options) {
      if (!target) return

      target.addEventListener(event, handler, options)
      listeners.push(() => target.removeEventListener(event, handler, options))
    }

    window[cleanupKey] = () => {
      listeners.forEach((cleanup) => cleanup())
      listeners.length = 0

      if (revealObserver) {
        revealObserver.disconnect()
        revealObserver = null
      }
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;')
    }

    function toNumber(value) {
      if (typeof value === 'number') {
        return Number.isFinite(value) ? value : 0
      }

      const cleaned = String(value ?? '')
        .replaceAll(',', '')
        .replace(/[^\d.-]/g, '')

      const number = Number(cleaned)

      return Number.isFinite(number) ? number : 0
    }

    function formatNumber(value) {
      const number = toNumber(value)
      return new Intl.NumberFormat('en-US').format(number)
    }

    function isNumericValue(value) {
      if (typeof value === 'number') return Number.isFinite(value)

      const raw = String(value ?? '').trim()
      if (!raw) return false

      return /^-?[\d,]+(\.\d+)?$/.test(raw)
    }

    function getDisplayName(user) {
      return String(
        user?.UserName ||
        user?.UserLogin ||
        user?.username ||
        user?.name ||
        'Unknown'
      ).trim()
    }

    function getLogin(user) {
      return String(user?.UserLogin || user?.login || '').trim()
    }

    function getValue(user) {
      return user?.Value ?? user?.value ?? user?.points ?? user?.score ?? 0
    }

    function getAvatarLetter(name) {
      const clean = String(name || '').trim()
      return clean ? clean.charAt(0).toUpperCase() : '?'
    }

    function formatValue(boardId, value) {
      const config = boardConfig[boardId]
      const raw = String(value ?? '').trim()

      if (boardId === 'watchtime') {
        return raw || '0'
      }

      if (isNumericValue(value)) {
        return `${formatNumber(value)} ${config.unit}`.trim()
      }

      if (!raw) {
        return `0 ${config.unit}`.trim()
      }

      return `${raw} ${config.unit}`.trim()
    }

    function normalizeBoardData(data, boardId) {
      const list = Array.isArray(data?.[boardId]) ? data[boardId] : []

      return list
        .filter((user) => user && (user.UserName || user.UserLogin || user.username || user.name))
        .map((user) => ({
          ...user,
          __name: getDisplayName(user),
          __login: getLogin(user),
          __value: getValue(user),
          __number: toNumber(getValue(user)),
        }))
        .sort((a, b) => b.__number - a.__number)
        .map((user, index) => ({
          ...user,
          __globalRank: index + 1,
          __id: `${boardId}-${index + 1}-${String(user.__login || user.__name).toLowerCase()}`,
        }))
    }

    function getElements() {
      return {
        tabs: Array.from(document.querySelectorAll('[data-board-tab]')),
        panels: Array.from(document.querySelectorAll('[data-board-panel]')),
        search: document.getElementById('leaderboard-search'),
        boardHeading: document.getElementById('board-heading'),
        boardDescription: document.getElementById('board-description'),
        boardCount: document.getElementById('board-count'),
        activeBoardTitle: document.getElementById('active-board-title'),
        activeBoardSubtitle: document.getElementById('active-board-subtitle'),
        activeBoardPill: document.getElementById('active-board-pill'),
        activeBoardIcon: document.getElementById('active-board-icon'),
        topThreeList: document.getElementById('top-three-list'),
        compareA: document.getElementById('compare-user-a'),
        compareB: document.getElementById('compare-user-b'),
        compareResult: document.getElementById('compare-result'),
        shareSelect: document.getElementById('share-user-select'),
        shareCanvas: document.getElementById('share-card-canvas'),
        shareDownload: document.getElementById('download-share-card'),
        shareNative: document.getElementById('native-share-card'),
        shareStatus: document.getElementById('share-card-status'),
        containers: {
          points: document.getElementById('points-list'),
          gold: document.getElementById('gold-list'),
          watchtime: document.getElementById('watchtime-list'),
        },
        loadMoreButtons: {
          points: document.querySelector('[data-load-more="points"]'),
          gold: document.querySelector('[data-load-more="gold"]'),
          watchtime: document.querySelector('[data-load-more="watchtime"]'),
        },
        showLessButtons: {
          points: document.querySelector('[data-show-less="points"]'),
          gold: document.querySelector('[data-show-less="gold"]'),
          watchtime: document.querySelector('[data-show-less="watchtime"]'),
        },
      }
    }

    function initScrollReveal() {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

      if (reduceMotion || !('IntersectionObserver' in window)) {
        document.querySelectorAll('[data-reveal]').forEach((element) => {
          element.classList.add('is-visible')
        })
        return
      }

      if (!revealObserver) {
        revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return

              entry.target.classList.add('is-visible')
              revealObserver.unobserve(entry.target)
            })
          },
          {
            threshold: 0.12,
            rootMargin: '0px 0px -70px 0px',
          }
        )
      }

      document.querySelectorAll('[data-reveal]:not(.is-visible):not([data-reveal-observed])').forEach((element) => {
        element.setAttribute('data-reveal-observed', 'true')
        revealObserver.observe(element)
      })
    }

    function renderEmptyState(container, boardId, customTitle, customText) {
      const config = boardConfig[boardId]

      container.innerHTML = `
        <div class="tnx-lb-empty" data-reveal="up">
          <iconify-icon icon="tabler:database-off"></iconify-icon>
          <strong>${escapeHtml(customTitle || config.emptyTitle)}</strong>
          <span>${escapeHtml(customText || config.emptyText)}</span>
        </div>
      `

      initScrollReveal()
    }

    function renderRow(user, boardId) {
      const name = user.__name
      const login = user.__login
      const rank = user.__globalRank || 0
      const showLogin = login && login.toLowerCase() !== name.toLowerCase()
      const value = formatValue(boardId, user.__value)

      return `
        <article class="tnx-lb-row" data-reveal="up">
          <div class="tnx-lb-row-rank">#${rank}</div>

          <div class="tnx-lb-user">
            <div class="tnx-lb-avatar">${escapeHtml(getAvatarLetter(name))}</div>

            <div class="tnx-lb-user-main">
              <p class="tnx-lb-user-name" title="${escapeHtml(name)}">${escapeHtml(name)}</p>
              ${
                showLogin
                  ? `<p class="tnx-lb-user-login" title="${escapeHtml(login)}">@${escapeHtml(login)}</p>`
                  : ''
              }
            </div>
          </div>

          <div class="tnx-lb-row-value">${escapeHtml(value)}</div>
        </article>
      `
    }

    function renderEliteDivider() {
      return `
        <div class="tnx-lb-elite-divider" data-reveal="up">
          نهاية النخبة — بعد المركز 10
        </div>
      `
    }

    function renderSegment(boardId) {
      const elements = getElements()
      const container = elements.containers[boardId]
      const loadMoreButton = elements.loadMoreButtons[boardId]
      const showLessButton = elements.showLessButtons[boardId]
      const users = filteredData[boardId] || []

      if (!container) return

      if (users.length === 0) {
        const hasSearch = searchQuery.length > 0

        renderEmptyState(
          container,
          boardId,
          hasSearch ? 'ما حصلت العضو' : undefined,
          hasSearch ? 'جرّب تكتب الاسم أو اليوزر بطريقة ثانية.' : undefined
        )

        if (loadMoreButton) loadMoreButton.classList.add('hidden')
        if (showLessButton) showLessButton.classList.add('hidden')
        return
      }

      const start = indexes[boardId]
      const end = start + perPage
      const slice = users.slice(start, end)

      const html = slice
        .map((user) => {
          const needsDivider = !searchQuery && user.__globalRank === 11
          return `${needsDivider ? renderEliteDivider() : ''}${renderRow(user, boardId)}`
        })
        .join('')

      container.insertAdjacentHTML('beforeend', html)

      indexes[boardId] += slice.length

      if (loadMoreButton) {
        loadMoreButton.classList.toggle('hidden', indexes[boardId] >= users.length)
      }

      if (showLessButton) {
        showLessButton.classList.toggle('hidden', indexes[boardId] <= perPage)
      }

      initScrollReveal()
    }

    function resetBoard(boardId) {
      const elements = getElements()
      const container = elements.containers[boardId]
      const loadMoreButton = elements.loadMoreButtons[boardId]
      const showLessButton = elements.showLessButtons[boardId]

      if (!container) return

      container.innerHTML = ''
      indexes[boardId] = 0

      if (loadMoreButton) loadMoreButton.classList.remove('hidden')
      if (showLessButton) showLessButton.classList.add('hidden')

      renderSegment(boardId)
    }

    function resetAllBoards() {
      Object.keys(boardConfig).forEach((boardId) => resetBoard(boardId))
      updateBoardMeta()
      renderTopThree()
      updateCompareOptions()
      renderCompare()
      updateShareOptions()
      renderShareCard()
    }

    function showLess(boardId) {
      const elements = getElements()
      const container = elements.containers[boardId]
      const users = filteredData[boardId] || []
      const loadMoreButton = elements.loadMoreButtons[boardId]
      const showLessButton = elements.showLessButtons[boardId]

      if (!container || users.length === 0) return

      const newIndex = Math.max(perPage, indexes[boardId] - perPage)
      indexes[boardId] = newIndex

      container.innerHTML = users
        .slice(0, newIndex)
        .map((user) => {
          const needsDivider = !searchQuery && user.__globalRank === 11
          return `${needsDivider ? renderEliteDivider() : ''}${renderRow(user, boardId)}`
        })
        .join('')

      if (loadMoreButton) {
        loadMoreButton.classList.toggle('hidden', indexes[boardId] >= users.length)
      }

      if (showLessButton) {
        showLessButton.classList.toggle('hidden', indexes[boardId] <= perPage)
      }

      initScrollReveal()
    }

    function setActiveBoard(boardId) {
      if (!boardConfig[boardId]) return

      activeBoard = boardId

      const elements = getElements()

      elements.tabs.forEach((tab) => {
        const isActive = tab.dataset.boardTab === boardId
        tab.classList.toggle('is-active', isActive)
        tab.setAttribute('aria-selected', String(isActive))
      })

      elements.panels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.boardPanel === boardId)
      })

      updateBoardMeta()
      renderTopThree()
      updateCompareOptions()
      renderCompare()
      updateShareOptions()
      renderShareCard()
    }

    function updateBoardMeta() {
      const elements = getElements()
      const config = boardConfig[activeBoard]
      const count = filteredData[activeBoard]?.length || 0
      const totalCount = allData[activeBoard]?.length || 0

      if (elements.boardHeading) {
        elements.boardHeading.textContent = config.heading
      }

      if (elements.boardDescription) {
        elements.boardDescription.textContent = searchQuery
          ? `نتائج البحث تظهر برتبة العضو الأصلية من أصل ${formatNumber(totalCount)} عضو.`
          : config.description
      }

      if (elements.boardCount) {
        elements.boardCount.textContent = formatNumber(count)
      }

      if (elements.activeBoardTitle) {
        elements.activeBoardTitle.textContent = config.title
      }

      if (elements.activeBoardSubtitle) {
        elements.activeBoardSubtitle.textContent = searchQuery
          ? 'نتائج البحث بالترتيب الحقيقي'
          : config.subtitle
      }

      if (elements.activeBoardPill) {
        elements.activeBoardPill.textContent = searchQuery
          ? 'بحث بالترتيب الحقيقي'
          : config.heading
      }

      if (elements.activeBoardIcon) {
        elements.activeBoardIcon.setAttribute('icon', config.icon)
      }
    }

    function renderTopThree() {
      const elements = getElements()
      const container = elements.topThreeList
      const users = searchQuery
        ? filteredData[activeBoard] || []
        : allData[activeBoard] || []

      if (!container) return

      if (users.length === 0) {
        const config = boardConfig[activeBoard]

        container.innerHTML = `
          <article class="tnx-lb-top-card tnx-lb-top-card--first" data-reveal="up">
            <span class="tnx-lb-rank">TOP</span>
            <div class="tnx-lb-medal">
              <iconify-icon icon="tabler:trophy"></iconify-icon>
            </div>
            <p class="tnx-lb-top-name">${escapeHtml(searchQuery ? 'ما حصلت العضو' : config.emptyTitle)}</p>
            <p class="tnx-lb-top-value">${escapeHtml(searchQuery ? 'جرّب تبحث باسم ثاني' : config.emptyText)}</p>
          </article>
        `
        initScrollReveal()
        return
      }

      const medals = ['tabler:crown', 'tabler:medal-2', 'tabler:medal']

      container.innerHTML = users
        .slice(0, 3)
        .map((user, index) => {
          const rank = user.__globalRank || index + 1
          const name = user.__name
          const login = user.__login
          const showLogin = login && login.toLowerCase() !== name.toLowerCase()
          const firstClass = index === 0 ? ' tnx-lb-top-card--first' : ''

          return `
            <article class="tnx-lb-top-card${firstClass}" data-reveal="up">
              <span class="tnx-lb-rank">#${rank}</span>
              <div class="tnx-lb-medal">
                <iconify-icon icon="${medals[index] || 'tabler:user'}"></iconify-icon>
              </div>
              <p class="tnx-lb-top-name" title="${escapeHtml(name)}">${escapeHtml(name)}</p>
              ${
                showLogin
                  ? `<span class="tnx-lb-top-login">@${escapeHtml(login)}</span>`
                  : ''
              }
              <p class="tnx-lb-top-value">${escapeHtml(formatValue(activeBoard, user.__value))}</p>
            </article>
          `
        })
        .join('')

      initScrollReveal()
    }

    function updateCompareOptions() {
      const elements = getElements()
      const users = allData[activeBoard] || []

      if (!elements.compareA || !elements.compareB) return

      const currentA = elements.compareA.value
      const currentB = elements.compareB.value

      const options = users
        .map((user) => {
          const label = `#${user.__globalRank} — ${user.__name} — ${formatValue(activeBoard, user.__value)}`
          return `<option value="${escapeHtml(user.__id)}">${escapeHtml(label)}</option>`
        })
        .join('')

      elements.compareA.innerHTML = options
      elements.compareB.innerHTML = options

      if (users.some((user) => user.__id === currentA)) {
        elements.compareA.value = currentA
      } else if (users[0]) {
        elements.compareA.value = users[0].__id
      }

      if (users.some((user) => user.__id === currentB)) {
        elements.compareB.value = currentB
      } else if (users[1]) {
        elements.compareB.value = users[1].__id
      } else if (users[0]) {
        elements.compareB.value = users[0].__id
      }
    }

    function findUserById(userId) {
      return (allData[activeBoard] || []).find((user) => user.__id === userId) || null
    }

    function renderCompare() {
      const elements = getElements()

      if (!elements.compareResult || !elements.compareA || !elements.compareB) return

      const userA = findUserById(elements.compareA.value)
      const userB = findUserById(elements.compareB.value)

      if (!userA || !userB) {
        elements.compareResult.innerHTML = `
          <div class="tnx-lb-empty">
            <iconify-icon icon="tabler:arrows-diff"></iconify-icon>
            <strong>ما فيه بيانات كافية للمقارنة</strong>
            <span>اختر عضوين من القائمة بعد تحميل الترتيب.</span>
          </div>
        `
        return
      }

      const valueDiff = Math.abs(userA.__number - userB.__number)
      const rankDiff = Math.abs(userA.__globalRank - userB.__globalRank)
      const leader = userA.__number >= userB.__number ? userA : userB

      elements.compareResult.innerHTML = `
        <div class="tnx-lb-compare-grid">
          <div class="tnx-lb-compare-card">
            <strong>${escapeHtml(userA.__name)}</strong>
            <span>${escapeHtml(formatValue(activeBoard, userA.__value))}</span>
            <small>المركز #${userA.__globalRank}</small>
          </div>

          <div class="tnx-lb-compare-diff">
            <div>
              <strong>${escapeHtml(formatValue(activeBoard, valueDiff))}</strong>
              <span>فرق القيمة</span>
              <br />
              <strong>#${rankDiff}</strong>
              <span>فرق المراكز</span>
              <br />
              <span>المتقدم: ${escapeHtml(leader.__name)}</span>
            </div>
          </div>

          <div class="tnx-lb-compare-card">
            <strong>${escapeHtml(userB.__name)}</strong>
            <span>${escapeHtml(formatValue(activeBoard, userB.__value))}</span>
            <small>المركز #${userB.__globalRank}</small>
          </div>
        </div>
      `
    }

    function updateShareOptions() {
      const elements = getElements()
      const users = allData[activeBoard] || []

      if (!elements.shareSelect) return

      const current = elements.shareSelect.value

      elements.shareSelect.innerHTML = users
        .map((user) => {
          const label = `#${user.__globalRank} — ${user.__name}`
          return `<option value="${escapeHtml(user.__id)}">${escapeHtml(label)}</option>`
        })
        .join('')

      if (users.some((user) => user.__id === current)) {
        elements.shareSelect.value = current
      } else if (users[0]) {
        elements.shareSelect.value = users[0].__id
      }
    }

    function getSelectedShareUser() {
      const elements = getElements()
      if (!elements.shareSelect) return null
      return findUserById(elements.shareSelect.value)
    }

    function drawRoundedRect(ctx, x, y, width, height, radius) {
      ctx.beginPath()
      ctx.moveTo(x + radius, y)
      ctx.lineTo(x + width - radius, y)
      ctx.quadraticCurveTo(x + width, y, x + width, y + radius)
      ctx.lineTo(x + width, y + height - radius)
      ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height)
      ctx.lineTo(x + radius, y + height)
      ctx.quadraticCurveTo(x, y + height, x, y + height - radius)
      ctx.lineTo(x, y + radius)
      ctx.quadraticCurveTo(x, y, x + radius, y)
      ctx.closePath()
    }

    function drawTextFit(ctx, text, x, y, maxWidth, fontSize, fontFamily, weight = '900') {
      let size = fontSize
      ctx.font = `${weight} ${size}px ${fontFamily}`

      while (ctx.measureText(text).width > maxWidth && size > 34) {
        size -= 2
        ctx.font = `${weight} ${size}px ${fontFamily}`
      }

      ctx.fillText(text, x, y)
    }

    function renderShareCard() {
      const elements = getElements()
      const canvas = elements.shareCanvas
      const user = getSelectedShareUser()

      if (!canvas) return

      const ctx = canvas.getContext('2d')
      if (!ctx) return

      const width = canvas.width
      const height = canvas.height
      const font = 'Arial, Tahoma, sans-serif'
      const config = boardConfig[activeBoard]

      ctx.clearRect(0, 0, width, height)

      const bg = ctx.createLinearGradient(0, 0, width, height)
      bg.addColorStop(0, '#09050f')
      bg.addColorStop(0.45, '#05070d')
      bg.addColorStop(1, '#120905')
      ctx.fillStyle = bg
      ctx.fillRect(0, 0, width, height)

      const glow = ctx.createRadialGradient(width * 0.75, height * 0.18, 0, width * 0.75, height * 0.18, 620)
      glow.addColorStop(0, 'rgba(255, 218, 106, 0.30)')
      glow.addColorStop(1, 'rgba(255, 218, 106, 0)')
      ctx.fillStyle = glow
      ctx.fillRect(0, 0, width, height)

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.45)'
      ctx.lineWidth = 6
      drawRoundedRect(ctx, 52, 52, width - 104, height - 104, 54)
      ctx.stroke()

      ctx.direction = 'rtl'
      ctx.textAlign = 'center'

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 54px ${font}`
      ctx.fillText('TNX6 COMMUNITY', width / 2, 180)

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 34px ${font}`
      ctx.fillText(config.heading, width / 2, 238)

      if (!user) {
        ctx.fillStyle = '#ffffff'
        ctx.font = `900 58px ${font}`
        ctx.fillText('ما فيه بيانات', width / 2, 620)
        return
      }

      ctx.fillStyle = 'rgba(0,0,0,0.42)'
      drawRoundedRect(ctx, 140, 315, width - 280, 650, 46)
      ctx.fill()

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.28)'
      ctx.lineWidth = 3
      drawRoundedRect(ctx, 140, 315, width - 280, 650, 46)
      ctx.stroke()

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 86px ${font}`
      ctx.fillText(`#${user.__globalRank}`, width / 2, 450)

      ctx.fillStyle = '#ffffff'
      drawTextFit(ctx, user.__name, width / 2, 565, width - 260, 76, font, '900')

      if (user.__login && user.__login.toLowerCase() !== user.__name.toLowerCase()) {
        ctx.fillStyle = 'rgba(255,255,255,0.46)'
        ctx.font = `800 34px ${font}`
        ctx.direction = 'ltr'
        ctx.fillText(`@${user.__login}`, width / 2, 620)
        ctx.direction = 'rtl'
      }

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 60px ${font}`
      ctx.fillText(formatValue(activeBoard, user.__value), width / 2, 740)

      ctx.fillStyle = 'rgba(255,255,255,0.68)'
      ctx.font = `800 30px ${font}`
      ctx.fillText('مركزك داخل مجتمع TNX6', width / 2, 805)

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.22)'
      ctx.lineWidth = 2
      ctx.beginPath()
      ctx.moveTo(230, 860)
      ctx.lineTo(width - 230, 860)
      ctx.stroke()

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 32px ${font}`
      ctx.fillText('tnx6.xyz', width / 2, 930)

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 42px ${font}`
      ctx.fillText('شارك بطاقتك وورنا مركزك', width / 2, 1115)

      ctx.fillStyle = 'rgba(255,255,255,0.38)'
      ctx.font = `700 26px ${font}`
      ctx.fillText('Generated from TNX6 Leaderboards', width / 2, 1190)

      if (elements.shareStatus) {
        elements.shareStatus.textContent = `البطاقة جاهزة: ${user.__name} — المركز #${user.__globalRank}`
      }
    }

    function downloadShareCard() {
      const elements = getElements()
      const canvas = elements.shareCanvas
      const user = getSelectedShareUser()

      if (!canvas || !user) return

      const link = document.createElement('a')
      link.download = `tnx6-rank-${user.__globalRank}-${user.__name}.png`
      link.href = canvas.toDataURL('image/png')
      link.click()
    }

    function shareCardNative() {
      const elements = getElements()
      const canvas = elements.shareCanvas
      const user = getSelectedShareUser()

      if (!canvas || !user) return

      canvas.toBlob(async (blob) => {
        if (!blob) return

        const file = new File([blob], `tnx6-rank-${user.__globalRank}.png`, {
          type: 'image/png',
        })

        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          try {
            await navigator.share({
              files: [file],
              title: 'TNX6 Rank Card',
              text: `مركزي في TNX6: #${user.__globalRank}`,
            })
            return
          } catch {
            // fallback below
          }
        }

        downloadShareCard()
      }, 'image/png')
    }

    function handleSearch(query) {
      searchQuery = String(query || '').trim().toLowerCase()

      Object.keys(boardConfig).forEach((boardId) => {
        filteredData[boardId] = allData[boardId].filter((user) => {
          const name = String(user.__name || '').toLowerCase()
          const login = String(user.__login || '').toLowerCase()

          return name.includes(searchQuery) || login.includes(searchQuery)
        })
      })

      resetAllBoards()
    }

    async function loadData() {
      const elements = getElements()

      try {
        const response = await fetch(`/api/leaderboard_data.json?site=${Date.now()}`, {
          cache: 'no-store',
        })

        if (!response.ok) {
          throw new Error('Failed to load leaderboard data')
        }

        const data = await response.json()

        allData = {
          points: normalizeBoardData(data, 'points'),
          gold: normalizeBoardData(data, 'gold'),
          watchtime: normalizeBoardData(data, 'watchtime'),
        }

        filteredData = {
          points: [...allData.points],
          gold: [...allData.gold],
          watchtime: [...allData.watchtime],
        }

        resetAllBoards()
        setActiveBoard(activeBoard)
      } catch {
        Object.keys(boardConfig).forEach((boardId) => {
          const container = elements.containers[boardId]
          if (!container) return

          renderEmptyState(
            container,
            boardId,
            'تعذر تحميل الترتيب',
            'تأكد أن /api/leaderboard_data.json موجود ويرجع JSON صحيح.'
          )
        })

        renderTopThree()
        updateCompareOptions()
        renderCompare()
        updateShareOptions()
        renderShareCard()
      }
    }

    function bindEvents() {
      const elements = getElements()

      elements.tabs.forEach((tab) => {
        addListener(tab, 'click', () => {
          setActiveBoard(tab.dataset.boardTab)
        })
      })

      Object.keys(boardConfig).forEach((boardId) => {
        addListener(elements.loadMoreButtons[boardId], 'click', () => {
          renderSegment(boardId)
        })

        addListener(elements.showLessButtons[boardId], 'click', () => {
          showLess(boardId)
        })
      })

      addListener(elements.search, 'input', (event) => {
        handleSearch(event.target.value)
      })

      addListener(elements.compareA, 'change', renderCompare)
      addListener(elements.compareB, 'change', renderCompare)
      addListener(elements.shareSelect, 'change', renderShareCard)
      addListener(elements.shareDownload, 'click', downloadShareCard)
      addListener(elements.shareNative, 'click', shareCardNative)
    }

    function initLeaderboards() {
      bindEvents()
      updateBoardMeta()
      initScrollReveal()
      loadData()
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLeaderboards, { once: true })
    } else {
      initLeaderboards()
    }

    document.addEventListener('astro:page-load', () => {
      if (!document.querySelector('[data-board-tab]')) return

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      initLeaderboards()
    })
  })()
</script>
