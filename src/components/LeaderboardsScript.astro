<style is:global>
  .tnx-modal-open {
    overflow: hidden;
  }

  .tnx-lb-empty {
    display: grid;
    place-items: center;
    gap: 0.8rem;
    min-height: 240px;
    padding: 2rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(194, 146, 0, 0.18);
    background:
      radial-gradient(circle at top, rgba(255, 218, 106, 0.08), transparent 58%),
      rgba(0, 0, 0, 0.26);
    text-align: center;
  }

  .tnx-lb-empty iconify-icon {
    font-size: 2.7rem;
    color: #ffda6a;
    filter: drop-shadow(0 0 12px rgba(255, 218, 106, 0.25));
  }

  .tnx-lb-empty strong {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 950;
  }

  .tnx-lb-empty span {
    color: rgb(156, 163, 175);
    font-size: 0.9rem;
    line-height: 1.7;
    font-weight: 800;
  }

  .tnx-lb-row {
    position: relative;
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1rem 1.15rem;
    border-radius: 1.4rem;
    border: 1px solid rgba(194, 146, 0, 0.16);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    cursor: pointer;
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
    overflow: hidden;
  }

  .tnx-lb-row:hover,
  .tnx-lb-row:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(255, 218, 106, 0.34);
    box-shadow:
      0 0 0 1px rgba(255, 218, 106, 0.05),
      0 12px 36px rgba(0, 0, 0, 0.28),
      0 0 22px rgba(255, 218, 106, 0.08);
    outline: none;
  }

  .tnx-lb-row::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.22s ease;
    background: linear-gradient(
      90deg,
      rgba(255, 218, 106, 0.05),
      rgba(255, 218, 106, 0),
      rgba(255, 218, 106, 0.04)
    );
  }

  .tnx-lb-row:hover::before,
  .tnx-lb-row:focus-visible::before {
    opacity: 1;
  }

  .tnx-lb-row-rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(194, 146, 0, 0.22);
    background: rgba(255, 218, 106, 0.05);
    color: #ffda6a;
    font-size: 1rem;
    font-weight: 950;
    letter-spacing: 0.02em;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .tnx-lb-user {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }

  .tnx-lb-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex: 0 0 52px;
    border-radius: 1rem;
    border: 1px solid rgba(194, 146, 0, 0.22);
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 218, 106, 0.16), transparent 65%),
      rgba(255, 255, 255, 0.03);
    color: #ffda6a;
    font-size: 1rem;
    font-weight: 950;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .tnx-lb-user-main {
    min-width: 0;
    display: grid;
    gap: 0.16rem;
  }

  .tnx-lb-user-name {
    margin: 0;
    color: #fff;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tnx-lb-user-login {
    margin: 0;
    color: rgb(148, 163, 184);
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.35;
    direction: ltr;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tnx-lb-row-value {
    color: #fff;
    font-size: 1rem;
    font-weight: 950;
    text-align: right;
    white-space: nowrap;
  }

  .tnx-lb-elite-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0.75rem 0;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    border: 1px dashed rgba(255, 218, 106, 0.22);
    background: rgba(255, 218, 106, 0.045);
    color: #ffda6a;
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-align: center;
  }

  .tnx-lb-top-card {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 0.7rem;
    padding: 1.35rem 1rem 1.2rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(194, 146, 0, 0.18);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.012)),
      rgba(0, 0, 0, 0.28);
    text-align: center;
    cursor: pointer;
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
    overflow: hidden;
  }

  .tnx-lb-top-card:hover,
  .tnx-lb-top-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(255, 218, 106, 0.36);
    box-shadow:
      0 14px 30px rgba(0,0,0,0.28),
      0 0 24px rgba(255, 218, 106, 0.12);
    outline: none;
  }

  .tnx-lb-top-card .tnx-lb-rank {
    position: absolute;
    top: 0.9rem;
    inset-inline-start: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    min-height: 34px;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(194, 146, 0, 0.22);
    background: rgba(255, 218, 106, 0.07);
    color: #ffda6a;
    font-size: 0.78rem;
    font-weight: 950;
  }

  .tnx-lb-medal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 66px;
    height: 66px;
    border-radius: 1.3rem;
    border: 1px solid rgba(194, 146, 0, 0.22);
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 218, 106, 0.18), transparent 65%),
      rgba(255, 255, 255, 0.03);
    color: #ffda6a;
    font-size: 1.8rem;
  }

  .tnx-lb-top-name {
    margin: 0;
    color: #fff;
    font-size: 1.06rem;
    font-weight: 950;
    line-height: 1.35;
    max-width: 100%;
    word-break: break-word;
  }

  .tnx-lb-top-login {
    color: rgb(148, 163, 184);
    font-size: 0.82rem;
    font-weight: 800;
    direction: ltr;
  }

  .tnx-lb-top-value {
    margin: 0;
    color: #ffda6a;
    font-size: 0.95rem;
    font-weight: 950;
  }

  .tnx-lb-top-card--first {
    border-color: rgba(255, 218, 106, 0.34);
    box-shadow:
      0 0 0 1px rgba(255, 218, 106, 0.06),
      0 0 34px rgba(255, 218, 106, 0.11);
  }

  .tnx-lb-top-card--first .tnx-lb-medal {
    animation: tnx-firstPulse 2.6s ease-in-out infinite;
    box-shadow:
      0 0 0 0 rgba(255, 218, 106, 0.22),
      0 0 22px rgba(255, 218, 106, 0.14);
  }

  @keyframes tnx-firstPulse {
    0% {
      transform: scale(1);
      box-shadow:
        0 0 0 0 rgba(255, 218, 106, 0.20),
        0 0 18px rgba(255, 218, 106, 0.10);
    }

    50% {
      transform: scale(1.04);
      box-shadow:
        0 0 0 10px rgba(255, 218, 106, 0),
        0 0 28px rgba(255, 218, 106, 0.20);
    }

    100% {
      transform: scale(1);
      box-shadow:
        0 0 0 0 rgba(255, 218, 106, 0),
        0 0 18px rgba(255, 218, 106, 0.10);
    }
  }

  .tnx-lb-row--rank-1,
  .tnx-lb-row--rank-2,
  .tnx-lb-row--rank-3 {
    border-color: rgba(255, 218, 106, 0.34);
    box-shadow:
      0 0 0 1px rgba(255, 218, 106, 0.04),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .tnx-lb-row--rank-1 {
    background:
      linear-gradient(90deg, rgba(255, 218, 106, 0.18), rgba(255, 218, 106, 0.05) 32%, rgba(0,0,0,0.3) 85%),
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.26);
  }

  .tnx-lb-row--rank-2 {
    background:
      linear-gradient(90deg, rgba(255, 215, 140, 0.14), rgba(255, 218, 106, 0.04) 30%, rgba(0,0,0,0.3) 82%),
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.27);
  }

  .tnx-lb-row--rank-3 {
    background:
      linear-gradient(90deg, rgba(226, 180, 96, 0.12), rgba(255, 218, 106, 0.035) 28%, rgba(0,0,0,0.3) 82%),
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.28);
  }

  .tnx-lb-row--rank-1 .tnx-lb-row-rank,
  .tnx-lb-row--rank-2 .tnx-lb-row-rank,
  .tnx-lb-row--rank-3 .tnx-lb-row-rank {
    background: rgba(255, 218, 106, 0.12);
    border-color: rgba(255, 218, 106, 0.34);
    box-shadow: 0 0 18px rgba(255, 218, 106, 0.10);
  }

  .tnx-lb-row--rank-1 .tnx-lb-avatar,
  .tnx-lb-row--rank-2 .tnx-lb-avatar,
  .tnx-lb-row--rank-3 .tnx-lb-avatar {
    border-color: rgba(255, 218, 106, 0.34);
    box-shadow: 0 0 18px rgba(255, 218, 106, 0.08);
  }

  .tnx-lb-row--rank-1 .tnx-lb-row-value,
  .tnx-lb-row--rank-2 .tnx-lb-row-value,
  .tnx-lb-row--rank-3 .tnx-lb-row-value {
    color: #ffda6a;
    text-shadow: 0 0 16px rgba(255, 218, 106, 0.12);
  }

  .tnx-lb-row--rank-1::after,
  .tnx-lb-row--rank-2::after,
  .tnx-lb-row--rank-3::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: 0 999px 999px 0;
    background: linear-gradient(180deg, #ffefad, #ffda6a, #c29200);
    box-shadow: 0 0 16px rgba(255, 218, 106, 0.22);
  }

  .tnx-lb-row--rank-1 .tnx-lb-row-rank {
    animation: tnx-firstRowPulse 2.8s ease-in-out infinite;
  }

  @keyframes tnx-firstRowPulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(255, 218, 106, 0.18);
    }

    50% {
      transform: scale(1.035);
      box-shadow: 0 0 0 10px rgba(255, 218, 106, 0);
    }

    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(255, 218, 106, 0);
    }
  }

  .tnx-lb-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .tnx-lb-modal.hidden {
    display: none;
  }

  .tnx-lb-modal-card {
    width: min(100%, 1180px);
    max-height: calc(100vh - 2rem);
    overflow: auto;
    border-radius: 1.9rem;
    border: 1px solid rgba(194, 146, 0, 0.22);
    background:
      radial-gradient(circle at top, rgba(255, 218, 106, 0.07), transparent 48%),
      linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0.01)),
      rgba(10, 10, 12, 0.97);
    padding: 1.5rem;
    box-shadow:
      0 28px 80px rgba(0, 0, 0, 0.54),
      0 0 34px rgba(255, 218, 106, 0.08);
  }

  .tnx-lb-modal-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-inline-start: auto;
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 1px solid rgba(194, 146, 0, 0.24);
    background: rgba(255, 255, 255, 0.03);
    color: #ffda6a;
    font-size: 1.2rem;
    cursor: pointer;
    transition: 0.2s ease;
  }

  .tnx-lb-modal-close:hover {
    border-color: rgba(255, 218, 106, 0.45);
    box-shadow: 0 0 18px rgba(255, 218, 106, 0.12);
  }

  .tnx-lb-modal-layout,
  #leaderboard-user-modal .tnx-lb-modal-layout,
  #leaderboard-user-modal .tnx-lb-modal-content,
  #leaderboard-user-modal .tnx-lb-modal-body {
    display: grid;
    grid-template-columns: minmax(320px, 390px) minmax(0, 1fr);
    gap: 1.35rem;
    align-items: stretch;
    margin-top: 0.8rem;
  }

  .tnx-lb-preview-side,
  .tnx-lb-preview-box,
  .tnx-lb-preview-inner,
  #leaderboard-user-modal .tnx-lb-modal-layout > :first-child,
  #leaderboard-user-modal .tnx-lb-modal-content > :first-child,
  #leaderboard-user-modal .tnx-lb-modal-body > :first-child {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tnx-lb-preview-side,
  #leaderboard-user-modal .tnx-lb-modal-layout > :first-child,
  #leaderboard-user-modal .tnx-lb-modal-content > :first-child,
  #leaderboard-user-modal .tnx-lb-modal-body > :first-child {
    min-height: 100%;
    align-self: stretch;
  }

  .tnx-lb-preview-box {
    width: 100%;
    min-height: 100%;
    border-radius: 1.7rem;
    border: 1px solid rgba(194, 146, 0, 0.14);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.26);
    padding: 1.25rem;
  }

  .tnx-lb-preview-inner {
    width: 100%;
  }

  #share-card-canvas,
  .tnx-lb-preview-inner canvas,
  .tnx-lb-preview-inner img {
    display: block;
    max-width: 100%;
    width: 100%;
    height: auto;
    margin: auto;
    border-radius: 1.45rem;
    box-shadow:
      0 0 0 1px rgba(255, 218, 106, 0.1),
      0 0 26px rgba(255, 218, 106, 0.08);
  }

  .tnx-lb-info-side {
    border-radius: 1.7rem;
    border: 1px solid rgba(194, 146, 0, 0.14);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.24);
    padding: 1.2rem;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .tnx-lb-modal-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .tnx-lb-modal-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    border-radius: 1.5rem;
    border: 1px solid rgba(194, 146, 0, 0.24);
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 218, 106, 0.18), transparent 65%),
      rgba(255,255,255,0.03);
    color: #ffda6a;
    font-size: 2rem;
    font-weight: 950;
  }

  .tnx-lb-modal-name-wrap {
    min-width: 0;
    display: grid;
    gap: 0.35rem;
  }

  .tnx-lb-modal-board {
    color: #ffda6a;
    font-size: 0.95rem;
    font-weight: 900;
  }

  .tnx-lb-modal-name {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 950;
    line-height: 1.2;
    word-break: break-word;
  }

  .tnx-lb-modal-login {
    color: rgb(148, 163, 184);
    font-size: 0.92rem;
    font-weight: 800;
    direction: ltr;
    text-align: left;
  }

  .tnx-lb-stats-grid,
  .tnx-lb-modal-badges {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .tnx-lb-stat-box,
  .tnx-lb-modal-badge {
    border-radius: 1.2rem;
    border: 1px solid rgba(194, 146, 0, 0.18);
    background: rgba(0, 0, 0, 0.26);
    padding: 1rem;
    text-align: center;
  }

  .tnx-lb-stat-box span {
    display: block;
    color: rgb(148, 163, 184);
    font-size: 0.9rem;
    font-weight: 800;
    margin-bottom: 0.45rem;
  }

  .tnx-lb-stat-box strong,
  .tnx-lb-modal-badge {
    display: block;
    color: #ffda6a;
    font-size: 1.25rem;
    font-weight: 950;
  }

  .tnx-lb-panel {
    border-radius: 1.3rem;
    border: 1px solid rgba(194, 146, 0, 0.16);
    background: rgba(255,255,255,0.02);
    padding: 1rem;
  }

  .tnx-lb-panel h4 {
    margin: 0 0 0.8rem;
    color: #fff;
    font-size: 1rem;
    font-weight: 950;
  }

  .tnx-lb-modal-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .tnx-lb-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0.8rem 1.2rem;
    border-radius: 1rem;
    border: 1px solid rgba(194, 146, 0, 0.24);
    background: rgba(255, 218, 106, 0.08);
    color: #ffda6a;
    font-size: 0.95rem;
    font-weight: 950;
    cursor: pointer;
    transition: 0.2s ease;
  }

  .tnx-lb-btn:hover {
    border-color: rgba(255, 218, 106, 0.45);
    background: rgba(255, 218, 106, 0.14);
  }

  .tnx-lb-btn--solid {
    background: linear-gradient(180deg, rgba(255, 218, 106, 0.92), rgba(194, 146, 0, 0.92));
    color: #111;
  }

  .tnx-lb-btn--solid:hover {
    background: linear-gradient(180deg, rgba(255, 226, 132, 1), rgba(214, 162, 0, 1));
  }

  .tnx-lb-card-mode-control {
    border-radius: 1.3rem;
    border: 1px solid rgba(194, 146, 0, 0.18);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)),
      rgba(0, 0, 0, 0.22);
    padding: 1rem;
  }

  .tnx-lb-card-mode-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tnx-lb-card-mode-copy {
    display: grid;
    gap: 0.3rem;
  }

  .tnx-lb-card-mode-copy strong {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 950;
  }

  .tnx-lb-card-mode-copy span {
    color: rgb(156, 163, 175);
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.7;
  }

  .tnx-lb-card-mode-side {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
  }

  .tnx-lb-card-mode-status {
    min-width: 82px;
    text-align: center;
    border-radius: 999px;
    border: 1px solid rgba(194, 146, 0, 0.25);
    background: rgba(255, 218, 106, 0.08);
    color: #ffda6a;
    padding: 0.4rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 950;
  }

  .tnx-lb-switch {
    position: relative;
    width: 74px;
    height: 40px;
    border: 1px solid rgba(194, 146, 0, 0.3);
    background: rgba(255,255,255,0.06);
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.25s ease;
    display: inline-flex;
    align-items: center;
    padding: 0 5px;
  }

  .tnx-lb-switch-track {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .tnx-lb-switch-thumb {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: #c5c7cf;
    box-shadow:
      0 4px 14px rgba(0,0,0,0.28),
      inset 0 1px 1px rgba(255,255,255,0.28);
    transition: all 0.25s ease;
  }

  .tnx-lb-switch.is-on {
    background: linear-gradient(180deg, rgba(255, 218, 106, 0.28), rgba(194, 146, 0, 0.24));
    border-color: rgba(255, 218, 106, 0.68);
    box-shadow:
      0 0 0 1px rgba(255, 218, 106, 0.12),
      0 0 20px rgba(255, 218, 106, 0.18);
  }

  .tnx-lb-switch.is-on .tnx-lb-switch-thumb {
    right: calc(100% - 32px);
    background: linear-gradient(180deg, #ffea99, #ffda6a);
    box-shadow:
      0 4px 16px rgba(255, 218, 106, 0.22),
      inset 0 1px 1px rgba(255,255,255,0.42);
  }

  .tnx-lb-card-mode-hint {
    margin-top: 0.75rem;
    color: rgb(107, 114, 128);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.8;
  }

  .tnx-lb-share-wrap {
