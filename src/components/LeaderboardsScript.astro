<script is:inline>
  ;(() => {
    const cleanupKey = '__tnxLeaderboardsCleanup'

    if (window[cleanupKey]) {
      window[cleanupKey]()
    }

    const perPage = 20

    const boardConfig = {
      points: {
        title: 'النقاط',
        heading: 'ترتيب النقاط',
        subtitle: 'أكثر الأعضاء نقاطًا',
        description: 'أكثر الأعضاء نقاطًا في المجتمع.',
        icon: 'tabler:coins',
        unit: 'نقطة',
        emptyTitle: 'ما فيه بيانات نقاط',
        emptyText: 'تأكد أن ملف leaderboard_data.json يحتوي على points.',
      },
      gold: {
        title: 'الذهب',
        heading: 'ترتيب الذهب',
        subtitle: 'ترتيب الذهب',
        description: 'أكثر الأعضاء امتلاكًا للذهب.',
        icon: 'tabler:coin',
        unit: 'ذهب',
        emptyTitle: 'الذهب غير مفعل حاليًا',
        emptyText: 'القسم جاهز، وبيظهر الترتيب إذا بدأت تسجل بيانات gold.',
      },
      watchtime: {
        title: 'المشاهدة',
        heading: 'ترتيب المشاهدة',
        subtitle: 'أكثر الأعضاء مشاهدة',
        description: 'أكثر الأعضاء حضورًا ومشاهدة.',
        icon: 'tabler:clock-hour-4',
        unit: '',
        emptyTitle: 'ما فيه بيانات مشاهدة',
        emptyText: 'تأكد أن ملف leaderboard_data.json يحتوي على watchtime.',
      },
    }

    let activeBoard = 'points'
    let searchQuery = ''
    let activeModalUser = null
    let shareCardMode = 'single'

    let allData = {
      points: [],
      gold: [],
      watchtime: [],
    }

    let filteredData = {
      points: [],
      gold: [],
      watchtime: [],
    }

    let visibleCount = {
      points: perPage,
      gold: perPage,
      watchtime: perPage,
    }

    let revealObserver = null
    const listeners = []

    function addListener(target, event, handler, options) {
      if (!target) return
      target.addEventListener(event, handler, options)
      listeners.push(() => target.removeEventListener(event, handler, options))
    }

    window[cleanupKey] = () => {
      listeners.forEach((cleanup) => cleanup())
      listeners.length = 0

      if (revealObserver) {
        revealObserver.disconnect()
        revealObserver = null
      }

      document.body.classList.remove('tnx-modal-open')
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;')
    }

    function toNumber(value) {
      if (typeof value === 'number') {
        return Number.isFinite(value) ? value : 0
      }

      const cleaned = String(value ?? '')
        .replaceAll(',', '')
        .replace(/[^\d.-]/g, '')

      const number = Number(cleaned)
      return Number.isFinite(number) ? number : 0
    }

    function formatNumber(value) {
      const number = toNumber(value)
      return new Intl.NumberFormat('en-US').format(number)
    }

    function formatCardDate(date = new Date()) {
      const day = String(date.getDate()).padStart(2, '0')
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const year = String(date.getFullYear())
      return `${day}/${month}/${year}`
    }

    function isNumericValue(value) {
      if (typeof value === 'number') return Number.isFinite(value)

      const raw = String(value ?? '').trim()
      if (!raw) return false

      return /^-?[\d,]+(\.\d+)?$/.test(raw)
    }

    function getDisplayName(user) {
      return String(
        user?.UserName ||
        user?.UserLogin ||
        user?.username ||
        user?.name ||
        'Unknown'
      ).trim()
    }

    function getLogin(user) {
      return String(user?.UserLogin || user?.login || '').trim()
    }

    function getValue(user) {
      return user?.Value ?? user?.value ?? user?.points ?? user?.score ?? 0
    }

    function formatValue(boardId, value) {
      const config = boardConfig[boardId]
      const raw = String(value ?? '').trim()

      if (boardId === 'watchtime') {
        return raw || '0'
      }

      if (isNumericValue(value)) {
        return `${formatNumber(value)} ${config.unit}`.trim()
      }

      if (!raw) {
        return `0 ${config.unit}`.trim()
      }

      return `${raw} ${config.unit}`.trim()
    }

    function getAvatarLetter(name) {
      const clean = String(name || '').trim()
      return clean ? clean.charAt(0).toUpperCase() : '?'
    }

    function makeUserId(boardId, user, index) {
      const login = getLogin(user)
      const name = getDisplayName(user)
      return `${boardId}-${index + 1}-${String(login || name).toLowerCase()}`
    }

    function normalizeBoardData(data, boardId) {
      const list = Array.isArray(data?.[boardId]) ? data[boardId] : []

      return list
        .filter((user) => user && (user.UserName || user.UserLogin || user.username || user.name))
        .map((user) => ({
          ...user,
          __name: getDisplayName(user),
          __login: getLogin(user),
          __value: getValue(user),
          __number: toNumber(getValue(user)),
        }))
        .sort((a, b) => b.__number - a.__number)
        .map((user, index) => ({
          ...user,
          __rank: index + 1,
          __id: makeUserId(boardId, user, index),
        }))
    }

    function findMatchingUserInBoard(boardId, sourceUser) {
      if (!sourceUser) return null

      const users = allData[boardId] || []
      const sourceLogin = String(sourceUser.__login || '').trim().toLowerCase()
      const sourceName = String(sourceUser.__name || '').trim().toLowerCase()

      if (sourceLogin) {
        const byLogin = users.find((user) => String(user.__login || '').trim().toLowerCase() === sourceLogin)
        if (byLogin) return byLogin
      }

      if (sourceName) {
        const byName = users.find((user) => String(user.__name || '').trim().toLowerCase() === sourceName)
        if (byName) return byName
      }

      return null
    }

    function getCombinedCardStats(user) {
      const pointsUser = findMatchingUserInBoard('points', user)
      const watchtimeUser = findMatchingUserInBoard('watchtime', user)

      return {
        pointsUser,
        watchtimeUser,
        pointsRank: pointsUser ? `#${pointsUser.__rank}` : '--',
        pointsValue: pointsUser ? formatValue('points', pointsUser.__value) : '--',
        watchtimeRank: watchtimeUser ? `#${watchtimeUser.__rank}` : '--',
        watchtimeValue: watchtimeUser ? formatValue('watchtime', watchtimeUser.__value) : '--',
      }
    }

    function getElements() {
      return {
        tabs: Array.from(document.querySelectorAll('[data-board-tab]')),
        panels: Array.from(document.querySelectorAll('[data-board-panel]')),
        search: document.getElementById('leaderboard-search'),
        boardHeading: document.getElementById('board-heading'),
        boardDescription: document.getElementById('board-description'),
        boardCount: document.getElementById('board-count'),
        activeBoardTitle: document.getElementById('active-board-title'),
        activeBoardSubtitle: document.getElementById('active-board-subtitle'),
        activeBoardPill: document.getElementById('active-board-pill'),
        activeBoardIcon: document.getElementById('active-board-icon'),
        topThreeList: document.getElementById('top-three-list'),

        modal: document.getElementById('leaderboard-user-modal'),
        modalUserAvatar: document.getElementById('modal-user-avatar'),
        modalUserName: document.getElementById('modal-user-name'),
        modalUserLogin: document.getElementById('modal-user-login'),
        modalUserRank: document.getElementById('modal-user-rank'),
        modalUserValue: document.getElementById('modal-user-value'),
        modalBoardLabel: document.getElementById('modal-board-label'),

        compareTargetInput: document.getElementById('compare-target-input'),
        compareButton: document.getElementById('compare-button'),
        compareResult: document.getElementById('compare-result'),
        usersDatalist: document.getElementById('leaderboard-users-list'),

        shareCanvas: document.getElementById('share-card-canvas'),
        shareDownload: document.getElementById('download-share-card'),
        shareNative: document.getElementById('native-share-card'),
        shareCardModeSwitch: document.getElementById('share-card-mode-switch'),
        shareCardModeStatus: document.getElementById('share-card-mode-status'),
        shareCardModeHint: document.getElementById('share-card-mode-hint'),

        containers: {
          points: document.getElementById('points-list'),
          gold: document.getElementById('gold-list'),
          watchtime: document.getElementById('watchtime-list'),
        },

        loadMoreButtons: {
          points: document.querySelector('[data-load-more="points"]'),
          gold: document.querySelector('[data-load-more="gold"]'),
          watchtime: document.querySelector('[data-load-more="watchtime"]'),
        },

        showLessButtons: {
          points: document.querySelector('[data-show-less="points"]'),
          gold: document.querySelector('[data-show-less="gold"]'),
          watchtime: document.querySelector('[data-show-less="watchtime"]'),
        },
      }
    }

    function forceCenterSharePreview() {
      const modal = document.getElementById('leaderboard-user-modal')
      const canvas = document.getElementById('share-card-canvas')

      if (!modal || !canvas) return

      const modalCard = canvas.closest('.tnx-lb-modal-card')
      const directCanvasParent = canvas.parentElement

      const path = []
      let node = canvas.parentElement

      while (node && node !== modalCard && node !== document.body) {
        path.push(node)
        node = node.parentElement
      }

      const gridColumn = path.find((element) => {
        const parent = element.parentElement
        if (!parent) return false

        const style = window.getComputedStyle(parent)
        const isGrid = style.display.includes('grid')
        const hasSiblings = parent.children.length >= 2

        return isGrid && hasSiblings
      })

      const previewColumn =
        canvas.closest('.tnx-lb-preview-side') ||
        canvas.closest('.tnx-lb-share-preview') ||
        canvas.closest('.tnx-lb-card-preview') ||
        gridColumn ||
        directCanvasParent?.parentElement ||
        directCanvasParent

      const layout =
        canvas.closest('.tnx-lb-modal-layout') ||
        canvas.closest('.tnx-lb-modal-content') ||
        canvas.closest('.tnx-lb-modal-body') ||
        previewColumn?.parentElement ||
        null

      if (previewColumn) {
        previewColumn.classList.add('tnx-lb-force-preview-column')
      }

      if (directCanvasParent) {
        directCanvasParent.classList.add('tnx-lb-force-preview-wrapper')
      }

      window.requestAnimationFrame(() => {
        if (!previewColumn) return

        const rightSide = layout
          ? Array.from(layout.children).find((child) => !child.contains(canvas))
          : null

        const rightHeight = rightSide ? rightSide.getBoundingClientRect().height : 0
        const cardHeight = modalCard ? modalCard.getBoundingClientRect().height : 0
        const wantedHeight = Math.max(rightHeight, cardHeight - 110, 560)
        const maxHeight = Math.max(420, window.innerHeight - 120)

        previewColumn.style.minHeight = `${Math.min(wantedHeight, maxHeight)}px`
      })
    }

    function ensureCardModeControl() {
      const existingSwitch = document.getElementById('share-card-mode-switch')

      if (existingSwitch) {
        syncShareCardModeUI()
        return
      }

      const modalActions = document.querySelector('.tnx-lb-modal-actions')
      if (!modalActions || !modalActions.parentElement) return

      const wrapper = document.createElement('div')
      wrapper.className = 'tnx-lb-card-mode-control'
      wrapper.innerHTML = `
        <div class="tnx-lb-card-mode-row">
          <div class="tnx-lb-card-mode-copy">
            <strong>نوع البطاقة</strong>
            <span>تقدر تبدّل بين بطاقة منفصلة أو بطاقة مدمجة.</span>
          </div>

          <div class="tnx-lb-card-mode-side">
            <button
              type="button"
              id="share-card-mode-switch"
              class="tnx-lb-switch"
              role="switch"
              aria-checked="false"
              aria-label="تبديل نوع البطاقة"
              title="تبديل نوع البطاقة"
            >
              <span class="tnx-lb-switch-track">
                <span class="tnx-lb-switch-thumb"></span>
              </span>
            </button>

            <span id="share-card-mode-status" class="tnx-lb-card-mode-status">منفصلة</span>
          </div>
        </div>

        <div id="share-card-mode-hint" class="tnx-lb-card-mode-hint">
          الآن البطاقة تعرض ترتيب وقيمة التبويب الحالي فقط.
        </div>
      `

      modalActions.parentElement.insertBefore(wrapper, modalActions)
      syncShareCardModeUI()
    }

    function syncShareCardModeUI() {
      const elements = getElements()
      const isCombined = shareCardMode === 'combined'

      if (elements.shareCardModeSwitch) {
        elements.shareCardModeSwitch.classList.toggle('is-on', isCombined)
        elements.shareCardModeSwitch.setAttribute('aria-checked', String(isCombined))
      }

      if (elements.shareCardModeStatus) {
        elements.shareCardModeStatus.textContent = isCombined ? 'مدمجة' : 'منفصلة'
      }

      if (elements.shareCardModeHint) {
        elements.shareCardModeHint.textContent = isCombined
          ? 'الآن البطاقة تعرض النقاط والمشاهدة معًا في نفس الصورة.'
          : 'الآن البطاقة تعرض ترتيب وقيمة التبويب الحالي فقط.'
      }
    }

    function getCompareParts() {
      const input = document.getElementById('compare-target-input')
      const compareBox = input?.closest('.tnx-lb-compare-box')
      const movedBody = document.getElementById('tnx-compare-accordion-body')
      const originalPanel =
        document.querySelector('[data-tnx-original-compare-panel="true"]') ||
        input?.closest('.tnx-lb-panel')

      return {
        input,
        compareBox,
        movedBody,
        originalPanel,
      }
    }

    function ensureCompareAccordion() {
      const { input, compareBox, originalPanel } = getCompareParts()

      if (!input || !compareBox || !originalPanel) return

      const existingAccordion = document.getElementById('tnx-compare-accordion-root')

      if (existingAccordion) {
        originalPanel.classList.add('tnx-lb-original-compare-hidden')
        originalPanel.style.setProperty('display', 'none', 'important')
        originalPanel.setAttribute('data-tnx-original-compare-panel', 'true')
        setCompareAccordionOpen(false)
        return
      }

      const titleEl = originalPanel.querySelector('h4')
      const titleText = titleEl?.textContent?.trim() || 'قارن هذا العضو مع شخص ثاني'

      const accordion = document.createElement('div')
      accordion.id = 'tnx-compare-accordion-root'
      accordion.className = 'tnx-lb-compare-accordion-root'

      accordion.innerHTML = `
        <button
          type="button"
          id="tnx-compare-accordion-toggle"
          class="tnx-lb-compare-strip"
          aria-expanded="false"
          aria-controls="tnx-compare-accordion-body"
        >
          <span class="tnx-lb-compare-strip-text">
            <strong>${escapeHtml(titleText)}</strong>
            <small>اضغط لفتح المقارنة</small>
          </span>

          <span class="tnx-lb-compare-strip-icon" aria-hidden="true">
            <iconify-icon icon="tabler:chevron-down"></iconify-icon>
          </span>
        </button>

        <div id="tnx-compare-accordion-body" class="tnx-lb-compare-accordion-body"></div>
      `

      originalPanel.parentElement.insertBefore(accordion, originalPanel)

      const body = accordion.querySelector('#tnx-compare-accordion-body')
      body.appendChild(compareBox)

      compareBox.classList.remove('tnx-lb-compare-body')
      compareBox.classList.add('tnx-lb-compare-box-moved')

      originalPanel.setAttribute('data-tnx-original-compare-panel', 'true')
      originalPanel.classList.add('tnx-lb-original-compare-hidden')
      originalPanel.style.setProperty('display', 'none', 'important')
      originalPanel.style.setProperty('visibility', 'hidden', 'important')
      originalPanel.style.setProperty('height', '0', 'important')
      originalPanel.style.setProperty('max-height', '0', 'important')
      originalPanel.style.setProperty('overflow', 'hidden', 'important')
      originalPanel.style.setProperty('padding', '0', 'important')
      originalPanel.style.setProperty('margin', '0', 'important')
      originalPanel.style.setProperty('border', '0', 'important')

      const toggle = accordion.querySelector('#tnx-compare-accordion-toggle')

      addListener(toggle, 'click', () => {
        const isOpen = accordion.classList.contains('is-open')
        setCompareAccordionOpen(!isOpen)
      })

      setCompareAccordionOpen(false)
    }

    function setCompareAccordionOpen(open) {
      const accordion = document.getElementById('tnx-compare-accordion-root')
      const body = document.getElementById('tnx-compare-accordion-body')
      const toggle = document.getElementById('tnx-compare-accordion-toggle')
      const originalPanel = document.querySelector('[data-tnx-original-compare-panel="true"]')

      if (originalPanel) {
        originalPanel.classList.add('tnx-lb-original-compare-hidden')
        originalPanel.style.setProperty('display', 'none', 'important')
        originalPanel.style.setProperty('visibility', 'hidden', 'important')
        originalPanel.style.setProperty('height', '0', 'important')
        originalPanel.style.setProperty('max-height', '0', 'important')
        originalPanel.style.setProperty('overflow', 'hidden', 'important')
        originalPanel.style.setProperty('padding', '0', 'important')
        originalPanel.style.setProperty('margin', '0', 'important')
        originalPanel.style.setProperty('border', '0', 'important')
      }

      if (!accordion || !body) return

      accordion.classList.toggle('is-open', open)

      if (toggle) {
        toggle.setAttribute('aria-expanded', String(open))
      }

      if (open) {
        body.style.setProperty('display', 'grid', 'important')
        body.style.setProperty('opacity', '1', 'important')
        body.style.setProperty('max-height', '900px', 'important')
        body.style.setProperty('margin-top', '0.85rem', 'important')
        body.style.setProperty('pointer-events', 'auto', 'important')
        return
      }

      body.style.setProperty('display', 'none', 'important')
      body.style.setProperty('opacity', '0', 'important')
      body.style.setProperty('max-height', '0', 'important')
      body.style.setProperty('margin-top', '0', 'important')
      body.style.setProperty('pointer-events', 'none', 'important')
    }

    function initScrollReveal() {
      const revealElements = Array.from(document.querySelectorAll('[data-reveal]'))

      if (revealElements.length === 0) return

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

      if (reduceMotion || !('IntersectionObserver' in window)) {
        revealElements.forEach((element) => element.classList.add('is-visible'))
        return
      }

      if (revealObserver) {
        revealObserver.disconnect()
      }

      revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return
            entry.target.classList.add('is-visible')
            revealObserver.unobserve(entry.target)
          })
        },
        {
          threshold: 0,
          rootMargin: '260px 0px 260px 0px',
        }
      )

      revealElements.forEach((element) => {
        if (!element.classList.contains('is-visible')) {
          revealObserver.observe(element)
        }
      })

      forceRevealVisibleElements()
      window.requestAnimationFrame(forceRevealVisibleElements)
      window.setTimeout(forceRevealVisibleElements, 120)
      window.setTimeout(forceRevealVisibleElements, 420)
    }

    function forceRevealVisibleElements() {
      const buffer = 260
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight

      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((element) => {
        const rect = element.getBoundingClientRect()

        if (rect.top <= viewportHeight + buffer && rect.bottom >= -buffer) {
          element.classList.add('is-visible')

          if (revealObserver) {
            revealObserver.unobserve(element)
          }
        }
      })
    }

    function renderEmptyState(container, boardId, customTitle, customText) {
      const config = boardConfig[boardId]

      container.innerHTML = `
        <div class="tnx-lb-empty" data-reveal="up">
          <iconify-icon icon="tabler:database-off"></iconify-icon>
          <strong>${escapeHtml(customTitle || config.emptyTitle)}</strong>
          <span>${escapeHtml(customText || config.emptyText)}</span>
        </div>
      `

      initScrollReveal()
    }

    function getRankSpecialClass(rank) {
      if (rank === 1) return 'tnx-lb-row--rank-1'
      if (rank === 2) return 'tnx-lb-row--rank-2'
      if (rank === 3) return 'tnx-lb-row--rank-3'
      return ''
    }

    function renderRow(user, boardId) {
      const name = user.__name
      const login = user.__login
      const showLogin = login && login.toLowerCase() !== name.toLowerCase()
      const specialClass = getRankSpecialClass(user.__rank)

      return `
        <article
          class="tnx-lb-row ${specialClass}"
          data-reveal="up"
          data-open-user="${escapeHtml(user.__id)}"
          tabindex="0"
          role="button"
          aria-label="فتح بطاقة ${escapeHtml(name)}"
        >
          <div class="tnx-lb-row-rank">#${user.__rank}</div>

          <div class="tnx-lb-user">
            <div class="tnx-lb-avatar">${escapeHtml(getAvatarLetter(name))}</div>

            <div class="tnx-lb-user-main">
              <p class="tnx-lb-user-name" title="${escapeHtml(name)}">${escapeHtml(name)}</p>
              ${
                showLogin
                  ? `<p class="tnx-lb-user-login" title="${escapeHtml(login)}">@${escapeHtml(login)}</p>`
                  : ''
              }
            </div>
          </div>

          <div class="tnx-lb-row-value">${escapeHtml(formatValue(boardId, user.__value))}</div>
        </article>
      `
    }

    function renderEliteDivider() {
      return `
        <div class="tnx-lb-elite-divider" data-reveal="up">
          نهاية النخبة — بعد المركز 10
        </div>
      `
    }

    function getActiveUsers() {
      return filteredData[activeBoard] || []
    }

    function renderActiveBoard() {
      const elements = getElements()
      const container = elements.containers[activeBoard]
      const loadMoreButton = elements.loadMoreButtons[activeBoard]
      const showLessButton = elements.showLessButtons[activeBoard]
      const users = getActiveUsers()

      if (!container) return

      if (users.length === 0) {
        const hasSearch = searchQuery.length > 0

        renderEmptyState(
          container,
          activeBoard,
          hasSearch ? 'ما حصلت العضو' : undefined,
          hasSearch ? 'جرّب تكتب الاسم أو اليوزر بطريقة ثانية.' : undefined
        )

        if (loadMoreButton) loadMoreButton.classList.add('hidden')
        if (showLessButton) showLessButton.classList.add('hidden')
        return
      }

      const limit = visibleCount[activeBoard]
      const visibleUsers = users.slice(0, limit)

      container.innerHTML = visibleUsers
        .map((user) => {
          const needsDivider = !searchQuery && user.__rank === 11
          return `${needsDivider ? renderEliteDivider() : ''}${renderRow(user, activeBoard)}`
        })
        .join('')

      if (loadMoreButton) {
        loadMoreButton.classList.toggle('hidden', limit >= users.length)
      }

      if (showLessButton) {
        showLessButton.classList.toggle('hidden', limit <= perPage)
      }

      initScrollReveal()
    }

    function renderAllPanelsOnce() {
      const currentActive = activeBoard

      Object.keys(boardConfig).forEach((boardId) => {
        activeBoard = boardId
        visibleCount[boardId] = perPage
        renderActiveBoard()
      })

      activeBoard = currentActive
    }

    function setActiveBoard(boardId) {
      if (!boardConfig[boardId]) return

      activeBoard = boardId

      const elements = getElements()

      elements.tabs.forEach((tab) => {
        const isActive = tab.dataset.boardTab === boardId
        tab.classList.toggle('is-active', isActive)
        tab.setAttribute('aria-selected', String(isActive))
      })

      elements.panels.forEach((panel) => {
        panel.classList.toggle('is-active', panel.dataset.boardPanel === boardId)
      })

      updateBoardMeta()
      renderTopThree()
      updateUserDatalist()
      renderActiveBoard()

      if (activeModalUser) {
        const freshUser =
          findUserById(activeModalUser.__id) ||
          findUserByInput(activeModalUser.__login) ||
          findUserByInput(activeModalUser.__name)

        if (freshUser) {
          openUserModal(freshUser)
        }
      }

      initScrollReveal()
    }

    function updateBoardMeta() {
      const elements = getElements()
      const config = boardConfig[activeBoard]
      const count = filteredData[activeBoard]?.length || 0
      const totalCount = allData[activeBoard]?.length || 0

      if (elements.boardHeading) elements.boardHeading.textContent = config.heading

      if (elements.boardDescription) {
        elements.boardDescription.textContent = searchQuery
          ? `نتائج البحث تعرض الرتبة الأصلية من أصل ${formatNumber(totalCount)} عضو.`
          : config.description
      }

      if (elements.boardCount) elements.boardCount.textContent = formatNumber(count)
      if (elements.activeBoardTitle) elements.activeBoardTitle.textContent = config.title

      if (elements.activeBoardSubtitle) {
        elements.activeBoardSubtitle.textContent = searchQuery
          ? 'نتائج البحث بالترتيب الحقيقي'
          : config.subtitle
      }

      if (elements.activeBoardPill) {
        elements.activeBoardPill.textContent = searchQuery
          ? 'بحث بالترتيب الحقيقي'
          : config.heading
      }

      if (elements.activeBoardIcon) {
        elements.activeBoardIcon.setAttribute('icon', config.icon)
      }
    }

    function renderTopThree() {
      const elements = getElements()
      const container = elements.topThreeList
      const users = searchQuery ? getActiveUsers() : allData[activeBoard] || []

      if (!container) return

      if (users.length === 0) {
        const config = boardConfig[activeBoard]

        container.innerHTML = `
          <article class="tnx-lb-top-card tnx-lb-top-card--first" data-reveal="up">
            <span class="tnx-lb-rank">TOP</span>
            <div class="tnx-lb-medal">
              <iconify-icon icon="tabler:trophy"></iconify-icon>
            </div>
            <p class="tnx-lb-top-name">${escapeHtml(searchQuery ? 'ما حصلت العضو' : config.emptyTitle)}</p>
            <p class="tnx-lb-top-value">${escapeHtml(searchQuery ? 'جرّب تبحث باسم ثاني' : config.emptyText)}</p>
          </article>
        `

        initScrollReveal()
        return
      }

      const medals = ['tabler:crown', 'tabler:medal-2', 'tabler:medal']

      container.innerHTML = users
        .slice(0, 3)
        .map((user, index) => {
          const name = user.__name
          const login = user.__login
          const showLogin = login && login.toLowerCase() !== name.toLowerCase()
          const firstClass = index === 0 ? ' tnx-lb-top-card--first' : ''

          return `
            <article
              class="tnx-lb-top-card${firstClass}"
              data-reveal="up"
              data-open-user="${escapeHtml(user.__id)}"
              tabindex="0"
              role="button"
              aria-label="فتح بطاقة ${escapeHtml(name)}"
            >
              <span class="tnx-lb-rank">#${user.__rank}</span>
              <div class="tnx-lb-medal">
                <iconify-icon icon="${medals[index] || 'tabler:user'}"></iconify-icon>
              </div>
              <p class="tnx-lb-top-name" title="${escapeHtml(name)}">${escapeHtml(name)}</p>
              ${
                showLogin
                  ? `<span class="tnx-lb-top-login">@${escapeHtml(login)}</span>`
                  : ''
              }
              <p class="tnx-lb-top-value">${escapeHtml(formatValue(activeBoard, user.__value))}</p>
            </article>
          `
        })
        .join('')

      initScrollReveal()
    }

    function handleSearch(query) {
      searchQuery = String(query || '').trim().toLowerCase()

      Object.keys(boardConfig).forEach((boardId) => {
        filteredData[boardId] = allData[boardId].filter((user) => {
          const name = String(user.__name || '').toLowerCase()
          const login = String(user.__login || '').toLowerCase()
          return name.includes(searchQuery) || login.includes(searchQuery)
        })

        visibleCount[boardId] = perPage
      })

      renderAllPanelsOnce()
      updateBoardMeta()
      renderTopThree()
      renderActiveBoard()
      initScrollReveal()
    }

    function updateUserDatalist() {
      const elements = getElements()
      const users = allData[activeBoard] || []

      if (!elements.usersDatalist) return

      elements.usersDatalist.innerHTML = users
        .slice(0, 500)
        .map((user) => {
          const label = `#${user.__rank} — ${user.__name}`
          return `<option value="${escapeHtml(user.__name)}">${escapeHtml(label)}</option>`
        })
        .join('')
    }

    function findUserById(userId) {
      return (allData[activeBoard] || []).find((user) => user.__id === userId) || null
    }

    function findUserByInput(value) {
      const query = String(value || '').trim().toLowerCase()
      if (!query) return null

      const users = allData[activeBoard] || []

      return (
        users.find((user) => user.__name.toLowerCase() === query) ||
        users.find((user) => user.__login.toLowerCase() === query) ||
        users.find((user) => user.__name.toLowerCase().includes(query)) ||
        users.find((user) => user.__login.toLowerCase().includes(query)) ||
        null
      )
    }

    function openUserModal(user) {
      const elements = getElements()
      const config = boardConfig[activeBoard]

      if (!elements.modal || !user) return

      activeModalUser = user

      ensureCardModeControl()
      ensureCompareAccordion()
      setCompareAccordionOpen(false)
      syncShareCardModeUI()

      if (elements.modalUserAvatar) {
        elements.modalUserAvatar.textContent = getAvatarLetter(user.__name)
      }

      if (elements.modalUserName) {
        elements.modalUserName.textContent = user.__name
      }

      if (elements.modalUserLogin) {
        const showLogin = user.__login && user.__login.toLowerCase() !== user.__name.toLowerCase()
        elements.modalUserLogin.textContent = showLogin ? `@${user.__login}` : ''
      }

      if (elements.modalUserRank) {
        elements.modalUserRank.textContent = `#${user.__rank}`
      }

      if (elements.modalUserValue) {
        elements.modalUserValue.textContent = formatValue(activeBoard, user.__value)
      }

      if (elements.modalBoardLabel) {
        elements.modalBoardLabel.textContent = config.heading
      }

      if (elements.compareTargetInput) {
        elements.compareTargetInput.value = ''
      }

      if (elements.compareResult) {
        elements.compareResult.textContent = 'اختر عضو ثاني عشان تظهر المقارنة.'
      }

      renderShareCard(user)

      elements.modal.classList.remove('hidden')
      elements.modal.setAttribute('aria-hidden', 'false')
      document.body.classList.add('tnx-modal-open')

      setCompareAccordionOpen(false)

      forceCenterSharePreview()
      window.setTimeout(forceCenterSharePreview, 50)
      window.setTimeout(forceCenterSharePreview, 250)
      window.setTimeout(forceCenterSharePreview, 500)

      window.setTimeout(() => setCompareAccordionOpen(false), 0)
      window.setTimeout(() => setCompareAccordionOpen(false), 50)
      window.setTimeout(() => setCompareAccordionOpen(false), 250)
    }

    function closeUserModal() {
      const elements = getElements()

      activeModalUser = null
      setCompareAccordionOpen(false)

      if (elements.modal) {
        elements.modal.classList.add('hidden')
        elements.modal.setAttribute('aria-hidden', 'true')
      }

      document.body.classList.remove('tnx-modal-open')
    }

    function renderCompare() {
      const elements = getElements()

      if (!activeModalUser || !elements.compareTargetInput || !elements.compareResult) return

      setCompareAccordionOpen(true)

      const targetUser = findUserByInput(elements.compareTargetInput.value)

      if (!targetUser) {
        elements.compareResult.innerHTML = `
          <div class="text-center">
            <strong class="block text-white">ما حصلت العضو الثاني</strong>
            <span class="mt-1 block text-gray-500">اكتب الاسم أو اليوزر بشكل أوضح.</span>
          </div>
        `
        return
      }

      if (targetUser.__id === activeModalUser.__id) {
        elements.compareResult.innerHTML = `
          <div class="text-center">
            <strong class="block text-white">اختر عضو مختلف</strong>
            <span class="mt-1 block text-gray-500">ما تقدر تقارن الشخص بنفسه.</span>
          </div>
        `
        return
      }

      const valueDiff = Math.abs(activeModalUser.__number - targetUser.__number)
      const rankDiff = Math.abs(activeModalUser.__rank - targetUser.__rank)
      const betterRankUser = activeModalUser.__rank < targetUser.__rank ? activeModalUser : targetUser
      const higherValueUser = activeModalUser.__number >= targetUser.__number ? activeModalUser : targetUser

      elements.compareResult.innerHTML = `
        <div class="tnx-lb-compare-grid">
          <div class="tnx-lb-compare-card">
            <strong>${escapeHtml(activeModalUser.__name)}</strong>
            <span>${escapeHtml(formatValue(activeBoard, activeModalUser.__value))}</span>
            <small>المركز #${activeModalUser.__rank}</small>
          </div>

          <div class="tnx-lb-compare-diff">
            <div>
              <strong>${escapeHtml(formatValue(activeBoard, valueDiff))}</strong>
              <span>فرق القيمة</span>

              <strong class="mt-3">${formatNumber(rankDiff)}</strong>
              <span>فرق المراكز</span>

              <span class="mt-3">الأعلى ترتيبًا: ${escapeHtml(betterRankUser.__name)}</span>
              <span>الأعلى قيمة: ${escapeHtml(higherValueUser.__name)}</span>
            </div>
          </div>

          <div class="tnx-lb-compare-card">
            <strong>${escapeHtml(targetUser.__name)}</strong>
            <span>${escapeHtml(formatValue(activeBoard, targetUser.__value))}</span>
            <small>المركز #${targetUser.__rank}</small>
          </div>
        </div>
      `
    }

    function drawRoundedRect(ctx, x, y, width, height, radius) {
      ctx.beginPath()
      ctx.moveTo(x + radius, y)
      ctx.lineTo(x + width - radius, y)
      ctx.quadraticCurveTo(x + width, y, x + width, y + radius)
      ctx.lineTo(x + width, y + height - radius)
      ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height)
      ctx.lineTo(x + radius, y + height)
      ctx.quadraticCurveTo(x, y + height, x, y + height - radius)
      ctx.lineTo(x, y + radius)
      ctx.quadraticCurveTo(x, y, x + radius, y)
      ctx.closePath()
    }

    function drawTextFit(ctx, text, x, y, maxWidth, fontSize, fontFamily, weight = '900') {
      let size = fontSize
      ctx.font = `${weight} ${size}px ${fontFamily}`

      while (ctx.measureText(text).width > maxWidth && size > 34) {
        size -= 2
        ctx.font = `${weight} ${size}px ${fontFamily}`
      }

      ctx.fillText(text, x, y)
    }

    function drawMetricBox(ctx, options) {
      const {
        x,
        y,
        width,
        height,
        title,
        rank,
        value,
        font,
      } = options

      ctx.fillStyle = 'rgba(0,0,0,0.42)'
      drawRoundedRect(ctx, x, y, width, height, 34)
      ctx.fill()

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.26)'
      ctx.lineWidth = 3
      drawRoundedRect(ctx, x, y, width, height, 34)
      ctx.stroke()

      ctx.direction = 'rtl'
      ctx.textAlign = 'center'

      ctx.fillStyle = 'rgba(255,255,255,0.68)'
      ctx.font = `800 30px ${font}`
      ctx.fillText(title, x + width / 2, y + 58)

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 58px ${font}`
      ctx.fillText(rank, x + width / 2, y + 132)

      ctx.fillStyle = '#ffffff'
      drawTextFit(ctx, value, x + width / 2, y + 196, width - 52, 38, font, '900')
    }

    function drawDate(ctx, width, height, font, cardDate) {
      ctx.direction = 'ltr'
      ctx.textAlign = 'left'

      ctx.fillStyle = 'rgba(255,255,255,0.42)'
      ctx.font = `800 24px ${font}`
      ctx.fillText('DATE', 92, height - 130)

      ctx.fillStyle = 'rgba(255,255,255,0.68)'
      ctx.font = `900 30px ${font}`
      ctx.fillText(cardDate, 92, height - 96)

      ctx.direction = 'rtl'
      ctx.textAlign = 'center'
    }

    function renderSingleShareCard(ctx, user, width, height, font, cardDate) {
      const config = boardConfig[activeBoard]

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 54px ${font}`
      ctx.fillText('TNX6 COMMUNITY', width / 2, 180)

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 34px ${font}`
      ctx.fillText(config.heading, width / 2, 238)

      if (!user) {
        ctx.fillStyle = '#ffffff'
        ctx.font = `900 58px ${font}`
        ctx.fillText('ما فيه بيانات', width / 2, 620)
        drawDate(ctx, width, height, font, cardDate)
        return
      }

      ctx.fillStyle = 'rgba(0,0,0,0.42)'
      drawRoundedRect(ctx, 140, 315, width - 280, 650, 46)
      ctx.fill()

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.28)'
      ctx.lineWidth = 3
      drawRoundedRect(ctx, 140, 315, width - 280, 650, 46)
      ctx.stroke()

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 86px ${font}`
      ctx.fillText(`#${user.__rank}`, width / 2, 450)

      ctx.fillStyle = '#ffffff'
      drawTextFit(ctx, user.__name, width / 2, 565, width - 260, 76, font, '900')

      if (user.__login && user.__login.toLowerCase() !== user.__name.toLowerCase()) {
        ctx.fillStyle = 'rgba(255,255,255,0.46)'
        ctx.font = `800 34px ${font}`
        ctx.direction = 'ltr'
        ctx.fillText(`@${user.__login}`, width / 2, 620)
        ctx.direction = 'rtl'
      }

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 60px ${font}`
      ctx.fillText(formatValue(activeBoard, user.__value), width / 2, 740)

      ctx.fillStyle = 'rgba(255,255,255,0.68)'
      ctx.font = `800 30px ${font}`
      ctx.fillText('مركزك داخل مجتمع TNX6', width / 2, 805)

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.22)'
      ctx.lineWidth = 2
      ctx.beginPath()
      ctx.moveTo(230, 860)
      ctx.lineTo(width - 230, 860)
      ctx.stroke()

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 32px ${font}`
      ctx.fillText('tnx6.xyz', width / 2, 930)

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 42px ${font}`
      ctx.fillText('شارك بطاقتك وورنا مركزك', width / 2, 1115)

      ctx.fillStyle = 'rgba(255,255,255,0.38)'
      ctx.font = `700 26px ${font}`
      ctx.fillText('Generated from TNX6 Leaderboards', width / 2, 1190)

      drawDate(ctx, width, height, font, cardDate)
    }

    function renderCombinedShareCard(ctx, user, width, height, font, cardDate) {
      const combinedStats = getCombinedCardStats(user)

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 54px ${font}`
      ctx.fillText('TNX6 COMMUNITY', width / 2, 180)

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 34px ${font}`
      ctx.fillText('بطاقة المجتمع', width / 2, 238)

      if (!user) {
        ctx.fillStyle = '#ffffff'
        ctx.font = `900 58px ${font}`
        ctx.fillText('ما فيه بيانات', width / 2, 620)
        drawDate(ctx, width, height, font, cardDate)
        return
      }

      ctx.fillStyle = 'rgba(0,0,0,0.42)'
      drawRoundedRect(ctx, 140, 315, width - 280, 320, 46)
      ctx.fill()

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.28)'
      ctx.lineWidth = 3
      drawRoundedRect(ctx, 140, 315, width - 280, 320, 46)
      ctx.stroke()

      ctx.fillStyle = '#ffffff'
      drawTextFit(ctx, user.__name, width / 2, 445, width - 260, 82, font, '900')

      if (user.__login && user.__login.toLowerCase() !== user.__name.toLowerCase()) {
        ctx.fillStyle = 'rgba(255,255,255,0.46)'
        ctx.font = `800 34px ${font}`
        ctx.direction = 'ltr'
        ctx.fillText(`@${user.__login}`, width / 2, 505)
        ctx.direction = 'rtl'
      }

      ctx.fillStyle = 'rgba(255,255,255,0.66)'
      ctx.font = `800 30px ${font}`
      ctx.fillText('نقاطك ومشاهدتك في مجتمع TNX6', width / 2, 575)

      drawMetricBox(ctx, {
        x: 130,
        y: 700,
        width: 390,
        height: 250,
        title: 'المشاهدة',
        rank: combinedStats.watchtimeRank,
        value: combinedStats.watchtimeValue,
        font,
      })

      drawMetricBox(ctx, {
        x: 560,
        y: 700,
        width: 390,
        height: 250,
        title: 'النقاط',
        rank: combinedStats.pointsRank,
        value: combinedStats.pointsValue,
        font,
      })

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.22)'
      ctx.lineWidth = 2
      ctx.beginPath()
      ctx.moveTo(230, 1010)
      ctx.lineTo(width - 230, 1010)
      ctx.stroke()

      ctx.fillStyle = 'rgba(255,255,255,0.78)'
      ctx.font = `800 32px ${font}`
      ctx.fillText('tnx6.xyz', width / 2, 1080)

      ctx.fillStyle = '#ffda6a'
      ctx.font = `900 42px ${font}`
      ctx.fillText('شارك بطاقتك وورنا مركزك', width / 2, 1155)

      ctx.fillStyle = 'rgba(255,255,255,0.38)'
      ctx.font = `700 26px ${font}`
      ctx.fillText('Generated from TNX6 Leaderboards', width / 2, 1218)

      drawDate(ctx, width, height, font, cardDate)
    }

    function renderShareCard(user = activeModalUser) {
      const elements = getElements()
      const canvas = elements.shareCanvas

      if (!canvas) return

      const ctx = canvas.getContext('2d')
      if (!ctx) return

      const width = canvas.width
      const height = canvas.height
      const font = 'Arial, Tahoma, sans-serif'
      const cardDate = formatCardDate()

      ctx.clearRect(0, 0, width, height)

      const bg = ctx.createLinearGradient(0, 0, width, height)
      bg.addColorStop(0, '#09050f')
      bg.addColorStop(0.45, '#05070d')
      bg.addColorStop(1, '#120905')
      ctx.fillStyle = bg
      ctx.fillRect(0, 0, width, height)

      const glow = ctx.createRadialGradient(width * 0.75, height * 0.18, 0, width * 0.75, height * 0.18, 620)
      glow.addColorStop(0, 'rgba(255, 218, 106, 0.30)')
      glow.addColorStop(1, 'rgba(255, 218, 106, 0)')
      ctx.fillStyle = glow
      ctx.fillRect(0, 0, width, height)

      ctx.strokeStyle = 'rgba(255, 218, 106, 0.45)'
      ctx.lineWidth = 6
      drawRoundedRect(ctx, 52, 52, width - 104, height - 104, 54)
      ctx.stroke()

      ctx.direction = 'rtl'
      ctx.textAlign = 'center'

      if (shareCardMode === 'combined') {
        renderCombinedShareCard(ctx, user, width, height, font, cardDate)
      } else {
        renderSingleShareCard(ctx, user, width, height, font, cardDate)
      }
    }

    function getCardFilePrefix() {
      return shareCardMode === 'combined'
        ? 'tnx6-community-card'
        : `tnx6-${activeBoard}-card`
    }

    function downloadShareCard() {
      const elements = getElements()
      const canvas = elements.shareCanvas
      const user = activeModalUser

      if (!canvas || !user) return

      renderShareCard(user)

      const safeName = user.__name.replace(/[^\w\u0600-\u06FF-]+/g, '-')
      const link = document.createElement('a')

      link.download = `${getCardFilePrefix()}-${safeName}.png`
      link.href = canvas.toDataURL('image/png')
      link.click()
    }

    function shareCardNative() {
      const elements = getElements()
      const canvas = elements.shareCanvas
      const user = activeModalUser

      if (!canvas || !user) return

      renderShareCard(user)

      canvas.toBlob(async (blob) => {
        if (!blob) return

        const safeName = user.__name.replace(/[^\w\u0600-\u06FF-]+/g, '-')
        const file = new File([blob], `${getCardFilePrefix()}-${safeName}.png`, {
          type: 'image/png',
        })

        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          try {
            await navigator.share({
              files: [file],
              title: shareCardMode === 'combined' ? 'TNX6 Community Card' : 'TNX6 Rank Card',
              text: shareCardMode === 'combined'
                ? 'بطاقتي في مجتمع TNX6'
                : `مركزي في TNX6: #${user.__rank}`,
            })
            return
          } catch {
            // fallback
          }
        }

        downloadShareCard()
      }, 'image/png')
    }

    async function loadData() {
      const elements = getElements()

      try {
        const response = await fetch(`/api/leaderboard_data.json?site=${Date.now()}`, {
          cache: 'no-store',
        })

        if (!response.ok) {
          throw new Error('Failed to load leaderboard data')
        }

        const data = await response.json()

        allData = {
          points: normalizeBoardData(data, 'points'),
          gold: normalizeBoardData(data, 'gold'),
          watchtime: normalizeBoardData(data, 'watchtime'),
        }

        filteredData = {
          points: [...allData.points],
          gold: [...allData.gold],
          watchtime: [...allData.watchtime],
        }

        renderAllPanelsOnce()
        setActiveBoard(activeBoard)
        updateUserDatalist()
        ensureCompareAccordion()
        setCompareAccordionOpen(false)
        initScrollReveal()
      } catch {
        Object.keys(boardConfig).forEach((boardId) => {
          const container = elements.containers[boardId]
          if (!container) return

          renderEmptyState(
            container,
            boardId,
            'تعذر تحميل الترتيب',
            'تأكد أن /api/leaderboard_data.json موجود ويرجع JSON صحيح.'
          )
        })

        renderTopThree()
        initScrollReveal()
      }
    }

    function bindEvents() {
      const elements = getElements()

      elements.tabs.forEach((tab) => {
        addListener(tab, 'click', () => {
          setActiveBoard(tab.dataset.boardTab)
        })
      })

      Object.keys(boardConfig).forEach((boardId) => {
        addListener(elements.loadMoreButtons[boardId], 'click', () => {
          visibleCount[boardId] += perPage
          if (activeBoard === boardId) renderActiveBoard()
        })

        addListener(elements.showLessButtons[boardId], 'click', () => {
          visibleCount[boardId] = Math.max(perPage, visibleCount[boardId] - perPage)
          if (activeBoard === boardId) renderActiveBoard()
        })
      })

      addListener(elements.search, 'input', (event) => {
        handleSearch(event.target.value)
      })

      addListener(document, 'click', (event) => {
        const target = event.target

        if (!(target instanceof Element)) return

        const closeTrigger = target.closest('[data-close-user-modal]')
        if (closeTrigger) {
          closeUserModal()
          return
        }

        const switchTrigger = target.closest('#share-card-mode-switch')
        if (switchTrigger) {
          shareCardMode = shareCardMode === 'combined' ? 'single' : 'combined'
          syncShareCardModeUI()
          renderShareCard(activeModalUser)
          forceCenterSharePreview()
          window.setTimeout(forceCenterSharePreview, 50)
          window.setTimeout(forceCenterSharePreview, 250)
          return
        }

        const userTrigger = target.closest('[data-open-user]')
        if (!userTrigger) return

        const userId = userTrigger.getAttribute('data-open-user')
        const user = findUserById(userId)

        if (user) {
          openUserModal(user)
        }
      })

      addListener(document, 'keydown', (event) => {
        if (event.key === 'Escape') {
          closeUserModal()
          return
        }

        const target = event.target
        if (!(target instanceof Element)) return

        if (target.closest('#share-card-mode-switch') && (event.key === 'Enter' || event.key === ' ')) {
          event.preventDefault()
          shareCardMode = shareCardMode === 'combined' ? 'single' : 'combined'
          syncShareCardModeUI()
          renderShareCard(activeModalUser)
          forceCenterSharePreview()
          window.setTimeout(forceCenterSharePreview, 50)
          window.setTimeout(forceCenterSharePreview, 250)
          return
        }

        if (event.key !== 'Enter') return

        const userTrigger = target.closest('[data-open-user]')
        if (!userTrigger) return

        const userId = userTrigger.getAttribute('data-open-user')
        const user = findUserById(userId)

        if (user) {
          openUserModal(user)
        }
      })

      addListener(elements.compareButton, 'click', renderCompare)

      addListener(elements.compareTargetInput, 'keydown', (event) => {
        if (event.key === 'Enter') {
          renderCompare()
        }
      })

      addListener(elements.shareDownload, 'click', downloadShareCard)
      addListener(elements.shareNative, 'click', shareCardNative)

      addListener(window, 'scroll', forceRevealVisibleElements, { passive: true })

      addListener(window, 'resize', () => {
        forceRevealVisibleElements()
        forceCenterSharePreview()
      })
    }

    function initLeaderboards() {
      ensureCardModeControl()
      ensureCompareAccordion()
      setCompareAccordionOpen(false)
      syncShareCardModeUI()
      bindEvents()
      updateBoardMeta()
      initScrollReveal()
      loadData()

      window.requestAnimationFrame(() => {
        ensureCompareAccordion()
        setCompareAccordionOpen(false)
        initScrollReveal()
      })

      window.setTimeout(() => {
        ensureCompareAccordion()
        setCompareAccordionOpen(false)
        initScrollReveal()
      }, 300)

      window.setTimeout(initScrollReveal, 900)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initLeaderboards, { once: true })
    } else {
      initLeaderboards()
    }

    document.addEventListener('astro:page-load', () => {
      if (!document.querySelector('[data-board-tab]')) return

      if (window[cleanupKey]) {
        window[cleanupKey]()
      }

      initLeaderboards()
    })
  })()
</script>
