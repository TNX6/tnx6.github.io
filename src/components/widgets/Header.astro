---
import { Icon } from 'astro-icon/components'
import { SITE } from 'astrowind:config'
import { trimSlash } from '~/utils/permalinks'

const base = SITE.base
const makeHref = (p) => `${base}${trimSlash(p)}`.replace(/\/+$/, '/')
const currentUrl = new URL(Astro.url).pathname

const nav = [
  { text: 'الرئيسية', path: '' },
  { text: 'الأوامر', path: 'commands' },
  { text: 'الترتيب', path: 'leaderboards' },
  { text: 'البادجات', path: 'badges' },
  { text: 'الأغراض', path: 'items' },
  { text: 'الوظائف', path: 'jobs' },
  { text: 'معرض الرسمات', path: 'fan-art' },
  { text: 'الفائزين', path: 'winners' },
]
---

<style>
  @keyframes dropdownSlide {
    0% {
      opacity: 0;
      transform: translateY(-12px);
      filter: blur(4px);
    }
    60% {
      opacity: 1;
      transform: translateY(4px);
      filter: blur(0px);
    }
    100% {
      transform: translateY(0);
    }
  }

  .dropdown-animate {
    animation: dropdownSlide 0.35s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
  }

  @keyframes dropdownClose {
    0% {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0px);
    }
    100% {
      opacity: 0;
      transform: translateY(-12px);
      filter: blur(4px);
    }
  }

  .dropdown-close {
    animation: dropdownClose 0.28s ease-out forwards;
  }

  @keyframes pulseGlow {
    0% { box-shadow: 0 0 6px rgba(198,164,79,0.25); }
    50% { box-shadow: 0 0 14px rgba(198,164,79,0.55); }
    100% { box-shadow: 0 0 6px rgba(198,164,79,0.25); }
  }

  .menu-link {
    transition:
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background-color 0.25s ease,
      transform 0.15s ease;
  }

  .menu-link:hover {
    animation: pulseGlow 1.2s ease-in-out infinite;
    border-color: #c6a44f !important;
  }

  .menu-link:active {
    transform: scale(0.97);
    box-shadow: 0 0 10px rgba(198,164,79,0.5);
  }

  .menu-button {
    transition:
      transform 0.14s ease,
      box-shadow 0.14s ease,
      border-color 0.14s ease,
      background-color 0.14s ease;
    transform-origin: center;
  }

  .menu-button:active {
    transform: scale(0.92);
    box-shadow: 0 0 12px rgba(198,164,79,0.6);
  }

  .menu-icon {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 18px;
    height: 14px;
  }

  .menu-line {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 9999px;
    background-color: #ffda6a;
    transition: transform 0.22s ease, opacity 0.22s ease;
  }

  .menu-line.middle {
    margin: 3px 0;
  }

  .menu-button.menu-open .menu-line.top {
    transform: translateY(5px) rotate(45deg);
  }

  .menu-button.menu-open .menu-line.middle {
    opacity: 0;
  }

  .menu-button.menu-open .menu-line.bottom {
    transform: translateY(-5px) rotate(-45deg);
  }

  .tnx-login-btn {
    min-height: 42px;
    padding: 0 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    border: 1px solid rgba(145, 70, 255, .48);
    background: linear-gradient(135deg, rgba(145,70,255,.95), rgba(119,44,232,.92));
    color: #fff;
    font-weight: 950;
    font-size: .88rem;
    text-decoration: none;
    box-shadow: 0 12px 26px rgba(145,70,255,.22);
    transition: transform .16s ease, filter .16s ease;
  }

  .tnx-login-btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }

  .tnx-user-button {
    position: relative;
    width: 46px;
    height: 46px;
    padding: 3px;
    border-radius: 999px;
    border: 1px solid rgba(198,164,79,.42);
    background:
      radial-gradient(circle at 30% 0%, rgba(255,255,255,.16), transparent 38%),
      rgba(0,0,0,.42);
    box-shadow: 0 0 18px rgba(198,164,79,.18);
    cursor: pointer;
    transition: transform .16s ease, border-color .16s ease;
  }

  .tnx-user-button:hover {
    transform: translateY(-1px);
    border-color: rgba(255,218,106,.72);
  }

  .tnx-user-avatar {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 999px;
    object-fit: cover;
  }

  .user-market-notification-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 19px;
    height: 19px;
    padding: 0 5px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 2px solid #0a0a0c;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    font-weight: 950;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    box-shadow: 0 0 14px rgba(239, 68, 68, .42);
    pointer-events: none;
  }

  .user-market-notification-badge.is-visible {
    display: inline-flex;
    animation: userMarketBadgePulse 1.9s ease-in-out infinite;
  }

  @keyframes userMarketBadgePulse {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 0 14px rgba(239, 68, 68, .42);
    }
    50% {
      transform: scale(1.06);
      box-shadow: 0 0 20px rgba(239, 68, 68, .58);
    }
  }

  .tnx-user-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    width: 250px;
    padding: 12px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.10);
    background: rgba(12, 12, 15, .96);
    box-shadow: 0 26px 70px rgba(0,0,0,.58);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 80;
  }

  .tnx-user-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 8px 12px;
    margin-bottom: 8px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    text-align: right;
  }

  .tnx-user-card img {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid rgba(198,164,79,.35);
  }

  .tnx-user-card strong {
    display: block;
    color: rgba(255,255,255,.92);
    font-size: .92rem;
    font-weight: 950;
    line-height: 1.4;
  }

  .tnx-user-card span {
    display: block;
    color: rgba(255,218,106,.82);
    font-size: .82rem;
    font-weight: 850;
    direction: ltr;
  }

  .tnx-user-menu-item {
    width: 100%;
    min-height: 44px;
    padding: 0 12px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    border-radius: 12px;
    border: 0;
    background: transparent;
    color: rgba(255,255,255,.86);
    font-weight: 900;
    font-size: .9rem;
    text-decoration: none;
    cursor: pointer;
    text-align: right;
  }

  .tnx-user-menu-item:hover {
    background: rgba(255,255,255,.07);
  }

  .tnx-user-menu-item-notice {
    justify-content: space-between;
    gap: 10px;
  }

  .tnx-user-menu-notice-badge {
    min-width: 22px;
    height: 20px;
    padding: 0 7px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 11px;
    font-weight: 950;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .tnx-user-menu-notice-badge.is-visible {
    display: inline-flex;
  }

  .tnx-user-menu-item.danger {
    color: #ffb4b4;
  }

  .tnx-user-menu-item.danger:hover {
    background: rgba(255,60,60,.10);
  }

  @media (max-width: 520px) {
    .tnx-login-btn {
      padding: 0 12px;
      font-size: .78rem;
    }

    .tnx-user-menu {
      left: -10px;
      width: min(88vw, 250px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .user-market-notification-badge.is-visible {
      animation: none !important;
    }
  }

  /* Auth header visibility guard */
  #tnx-login-btn[data-auth-hidden="true"],
  #tnx-user-btn[data-auth-hidden="true"] {
    display: none !important;
  }

  #tnx-login-btn[data-auth-visible="true"] {
    display: inline-flex !important;
  }

  #tnx-user-btn[data-auth-visible="true"] {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
  }


  /* Larger balanced Twitch user avatar */
  #tnx-user-btn.tnx-user-button {
    width: 58px !important;
    height: 58px !important;
    min-width: 58px !important;
    min-height: 58px !important;
    padding: 3px !important;
    border-radius: 999px !important;
    border: 1px solid rgba(198, 164, 79, .52) !important;
    box-shadow:
      0 0 16px rgba(198, 164, 79, .22),
      inset 0 0 0 1px rgba(255,255,255,.04) !important;
  }

  #tnx-user-btn.tnx-user-button:hover {
    transform: translateY(-1px) scale(1.03) !important;
    border-color: rgba(255, 218, 106, .78) !important;
    box-shadow:
      0 0 22px rgba(198, 164, 79, .34),
      inset 0 0 0 1px rgba(255,255,255,.06) !important;
  }

  #tnx-user-avatar.tnx-user-avatar {
    width: 100% !important;
    height: 100% !important;
    border-radius: 999px !important;
    object-fit: cover !important;
    display: block !important;
  }

  @media (max-width: 520px) {
    #tnx-user-btn.tnx-user-button {
      width: 52px !important;
      height: 52px !important;
      min-width: 52px !important;
      min-height: 52px !important;
    }
  }

</style>

<header dir="rtl" class="top-0 z-40 relative w-full bg-[#0a0a0c]/95 border-b border-[#c6a44f]/30 shadow-[0_0_15px_rgba(198,164,79,0.3)] backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between py-4 gap-4">

    <a
      href={makeHref('')}
      class="flex items-center gap-3 text-[#d5b76c] font-extrabold text-2xl tracking-wide drop-shadow-[0_0_10px_rgba(198,164,79,0.6)]"
    >
      <Icon name="tabler:brand-twitch" class="w-7 h-7 text-[#c6a44f]" />
      <span>TNX</span>
    </a>

    <div class="flex items-center gap-3">
      <div id="tnx-auth-area" class="relative">
        <a
          id="tnx-login-btn"
          class="tnx-login-btn"
          href="https://api.tnx6.xyz/auth/twitch/login"
        >
          تسجيل الدخول
        </a>

        <button
          id="tnx-user-btn"
          class="tnx-user-button hidden"
          type="button"
          aria-label="فتح خيارات الحساب"
          aria-expanded="false"
        >
          <img id="tnx-user-avatar" class="tnx-user-avatar" src="" alt="صورة الحساب" />
          <span id="tnx-market-alert-badge" class="user-market-notification-badge" aria-hidden="true"></span>
        </button>

        <div id="tnx-user-menu" class="tnx-user-menu hidden">
          <div class="tnx-user-card">
            <img id="tnx-menu-avatar" src="" alt="صورة الحساب" />
            <div>
              <strong id="tnx-menu-name">---</strong>
              <span id="tnx-menu-handle">@---</span>
            </div>
          </div>

          <a id="tnx-profile-link" class="tnx-user-menu-item" href="/profile">
            الصفحة الرئيسية
          </a>

          <a id="tnx-market-alert-link" class="tnx-user-menu-item tnx-user-menu-item-notice" href="/market?tab=offers">
            <span>العروض</span>
            <span id="tnx-market-alert-menu-badge" class="tnx-user-menu-notice-badge" aria-hidden="true"></span>
          </a>

          <button id="tnx-logout-btn" class="tnx-user-menu-item danger" type="button">
            تسجيل الخروج
          </button>
        </div>
      </div>

      <button
        id="tnx-menu-btn"
        type="button"
        class="menu-button flex items-center gap-2 px-4 py-2 rounded-md border border-[#c6a44f]/40 text-[#ffda6a] bg-black/40 hover:bg-[#c6a44f]/10"
      >
        <div class="menu-icon">
          <span class="menu-line top"></span>
          <span class="menu-line middle"></span>
          <span class="menu-line bottom"></span>
        </div>
        <span>القائمة</span>
      </button>
    </div>
  </div>

  <div id="dropdownMenu" class="hidden px-6 pb-4 space-y-3">
    {nav.map(({ text, path }) => {
      const href = makeHref(path)
      const isActive = currentUrl === href
      return (
        <a
          href={href}
          class:list={[
            'menu-link block w-full text-center px-4 py-3 rounded-lg bg-black/40 border border-[#c6a44f]/30 text-[#ffda6a] hover:bg-[#c6a44f]/10 transition',
            { 'bg-[#c6a44f]/20': isActive },
          ]}
        >
          {text}
        </a>
      )
    })}
  </div>
</header>

<script is:inline data-reinit data-astro-rerun>
  ;(() => {
    const cleanupKey = '__tnxHeaderCleanup'
    if (window[cleanupKey]) window[cleanupKey]()

    const cleanups = []
    const on = (target, event, handler, options) => {
      if (!target) return
      target.addEventListener(event, handler, options)
      cleanups.push(() => target.removeEventListener(event, handler, options))
    }

    const API_BASE = 'https://api.tnx6.xyz'
    const $ = (id) => document.getElementById(id)

    const menuBtn = $('tnx-menu-btn')
    const menu = $('dropdownMenu')
    const loginBtn = $('tnx-login-btn')
    const userBtn = $('tnx-user-btn')
    const userMenu = $('tnx-user-menu')
    const avatar = $('tnx-user-avatar')
    const menuAvatar = $('tnx-menu-avatar')
    const menuName = $('tnx-menu-name')
    const menuHandle = $('tnx-menu-handle')
    const profileLink = $('tnx-profile-link')
    const marketAlertLink = $('tnx-market-alert-link')
    const logoutBtn = $('tnx-logout-btn')
    const marketAlertBadge = $('tnx-market-alert-badge')
    const marketAlertMenuBadge = $('tnx-market-alert-menu-badge')
    let marketAlertTimer = 0
    let marketAlertLoading = false

    function marketAlertLabel(count) {
      return count > 9 ? '9+' : String(Math.max(0, count))
    }

    function setMarketAlertCount(count) {
      const value = Math.max(0, Math.floor(Number(count || 0)))
      const label = marketAlertLabel(value)
      const visible = value > 0

      if (marketAlertBadge) {
        marketAlertBadge.textContent = visible ? label : ''
        marketAlertBadge.classList.toggle('is-visible', visible)
        marketAlertBadge.setAttribute('aria-hidden', visible ? 'false' : 'true')
      }

      if (marketAlertMenuBadge) {
        marketAlertMenuBadge.textContent = visible ? label : ''
        marketAlertMenuBadge.classList.toggle('is-visible', visible)
        marketAlertMenuBadge.setAttribute('aria-hidden', visible ? 'false' : 'true')
      }
    }

    function stopMarketAlerts() {
      if (marketAlertTimer) {
        window.clearInterval(marketAlertTimer)
        marketAlertTimer = 0
      }
      marketAlertLoading = false
      setMarketAlertCount(0)
    }

    function markMarketOffersSeen() {
      setMarketAlertCount(0)

      try {
        fetch(API_BASE + '/api/me/market/offers/mark-seen', {
          method: 'POST',
          credentials: 'include',
          cache: 'no-store',
          keepalive: true,
        }).catch(() => {})
      } catch {}
    }

    async function refreshMarketAlerts() {
      if (marketAlertLoading || document.hidden) return
      marketAlertLoading = true

      try {
        const res = await fetch(API_BASE + '/api/me/market/offers/status?v=' + Date.now(), {
          method: 'GET',
          credentials: 'include',
          cache: 'no-store',
        })

        if (res.status === 401) {
          setMarketAlertCount(0)
          return
        }

        if (!res.ok) return

        const data = await res.json().catch(() => null)
        const count = Number(
          data?.unreadIncomingOffers ??
          data?.unreadIncoming ??
          data?.incomingUnreadOffers ??
          0
        )
        setMarketAlertCount(count)
      } catch {
        // Keep the header quiet if the count endpoint is temporarily unavailable.
      } finally {
        marketAlertLoading = false
      }
    }

    function startMarketAlerts() {
      refreshMarketAlerts()
      if (marketAlertTimer) window.clearInterval(marketAlertTimer)
      marketAlertTimer = window.setInterval(() => {
        if (!document.hidden) refreshMarketAlerts()
      }, 60000)
    }

    function closeMainMenu() {
      if (!menu || !menuBtn || menu.classList.contains('hidden')) return

      menuBtn.classList.remove('menu-open')
      menu.classList.remove('dropdown-animate')
      menu.classList.add('dropdown-close')

      window.setTimeout(() => {
        menu.classList.add('hidden')
        menu.classList.remove('dropdown-close')
      }, 280)
    }

    function toggleMainMenu() {
      if (!menu || !menuBtn) return

      const isHidden = menu.classList.contains('hidden')

      if (isHidden) {
        menuBtn.classList.add('menu-open')
        menu.classList.remove('dropdown-close')
        menu.classList.remove('hidden')
        menu.classList.add('dropdown-animate')
        window.setTimeout(() => menu.classList.remove('dropdown-animate'), 400)
      } else {
        closeMainMenu()
      }
    }

    function closeUserMenu() {
      if (!userMenu || !userBtn) return
      userMenu.classList.add('hidden')
      userBtn.setAttribute('aria-expanded', 'false')
    }

    function toggleUserMenu() {
      if (!userMenu || !userBtn) return
      const willOpen = userMenu.classList.contains('hidden')
      userMenu.classList.toggle('hidden', !willOpen)
      userBtn.setAttribute('aria-expanded', String(willOpen))
      closeMainMenu()
    }

    async function getMe() {
      try {
        const res = await fetch(API_BASE + '/api/me', {
          method: 'GET',
          credentials: 'include',
          cache: 'no-store',
        })

        if (!res.ok) return null

        const data = await res.json()
        return data?.authenticated && data?.user ? data.user : null
      } catch {
        return null
      }
    }

    function setLoggedOut() {
      if (loginBtn) {
        loginBtn.classList.remove('hidden')
        loginBtn.dataset.authHidden = 'false'
        loginBtn.dataset.authVisible = 'true'
        loginBtn.style.display = 'inline-flex'
      }

      if (userBtn) {
        userBtn.classList.add('hidden')
        userBtn.dataset.authHidden = 'true'
        userBtn.dataset.authVisible = 'false'
        userBtn.style.display = 'none'
      }

      closeUserMenu()
      stopMarketAlerts()
    }

    function setLoggedIn(user) {
      const login = String(user.login || '').trim()
      const name = String(user.displayName || login || 'مستخدم Twitch').trim()
      const image = String(user.profileImageUrl || '').trim()

      if (loginBtn) {
        loginBtn.classList.add('hidden')
        loginBtn.dataset.authHidden = 'true'
        loginBtn.dataset.authVisible = 'false'
        loginBtn.style.display = 'none'
      }

      if (userBtn) {
        userBtn.classList.remove('hidden')
        userBtn.dataset.authHidden = 'false'
        userBtn.dataset.authVisible = 'true'
        userBtn.style.display = 'inline-flex'
      }

      if (avatar) avatar.src = image
      if (menuAvatar) menuAvatar.src = image
      if (menuName) menuName.textContent = name
      if (menuHandle) menuHandle.textContent = login ? '@' + login : '@---'
      if (profileLink) profileLink.href = '/profile'
      startMarketAlerts()
    }

    async function initAuth() {
      const user = await getMe()
      if (user) setLoggedIn(user)
      else setLoggedOut()
    }

    async function logout() {
      try {
        await fetch(API_BASE + '/auth/logout', {
          method: 'POST',
          credentials: 'include',
        })
      } catch {}

      window.location.href = '/profile'
    }

    on(menuBtn, 'click', (event) => {
      event.stopPropagation()
      toggleMainMenu()
      closeUserMenu()
    })

    on(userBtn, 'click', (event) => {
      event.stopPropagation()
      toggleUserMenu()
    })

    on(logoutBtn, 'click', logout)
    on(marketAlertLink, 'click', markMarketOffersSeen)

    on(document, 'visibilitychange', () => {
      if (!document.hidden && marketAlertTimer) refreshMarketAlerts()
    })

    on(document, 'click', (event) => {
      if (!event.target.closest?.('#tnx-auth-area')) closeUserMenu()
      if (!event.target.closest?.('#tnx-menu-btn') && !event.target.closest?.('#dropdownMenu')) closeMainMenu()
    })

    on(window, 'pageshow', initAuth)
    on(document, 'astro:page-load', initAuth)

    initAuth()
    window.setTimeout(initAuth, 800)

    window[cleanupKey] = () => {
      cleanups.forEach((fn) => fn())
      cleanups.length = 0
      if (marketAlertTimer) window.clearInterval(marketAlertTimer)
      marketAlertTimer = 0
    }
  })()
</script>
