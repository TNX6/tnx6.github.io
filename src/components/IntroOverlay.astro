<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>احتفالية مرور سنة على البثوث - نفس المقطع</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #000000;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* حاوية واجهة التحميل الافتتاحية */
        #intro-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: #000000;
            z-index: 10000;
            transition: opacity 1.5s ease-out;
            pointer-events: auto; /* يمكن النقر عليه في البداية */
        }

        #intro-overlay.fade-out {
            opacity: 0;
            pointer-events: none; /* للسماح بالنقر على محتوى الموقع */
        }

        /* لوحة القماش التي سيتم رسم الجسيمات عليها */
        #canvas {
            display: block;
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>

    <div id="intro-overlay">
        <canvas id="canvas"></canvas>
    </div>

    <script>
        const canvas = document.getElementById('canvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;
        let overlay = document.getElementById('intro-overlay')!;

        // ضبط حجم لوحة القماش لتغطي الشاشة
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        // إعدادات الجسيمات والجماليات
        const dotColor = '#ff66b2'; // اللون الوردي المتوهج من المقطع
        const finalHeartColor = '#ff0055'; // لون القلب النهائي
        const dotSize = 2; // حجم النقاط
        const dotGap = 6; // المسافة بين النقاط في النصوص
        const textFontSize = 100; // حجم خط النصوص

        let particles: Particle[] = [];
        let backgroundDots: BackgroundDot[] = [];
        let currentSequenceIndex = 0;
        let animationFrameId: number;
        let finalHeartActive = false;

        // دالة إنشاء مصفوفة من مواقع النقاط لنص معين
        function createTextDots(text: string): { x: number; y: number }[] {
            ctx.fillStyle = 'white';
            ctx.font = `bold ${textFontSize}px sans-serif`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            
            // قياس عرض النص
            let textMetrics = ctx.measureText(text);
            let textWidth = textMetrics.width;
            let textHeight = textFontSize;

            // مسح لوحة القماش للحصول على النقاط النقية
            ctx.clearRect(0, 0, width, height);
            ctx.fillText(text, width / 2, height / 2);

            let dots: { x: number; y: number }[] = [];
            let imageData = ctx.getImageData(0, 0, width, height);

            // مسح بيانات الصورة بحثًا عن النقاط المكتوبة
            for (let y = 0; y < height; y += dotGap) {
                for (let x = 0; x < width; x += dotGap) {
                    let index = (y * width + x) * 4;
                    if (imageData.data[index] > 0) { // تم كتابة نقطة هنا
                        dots.push({ x, y });
                    }
                }
            }
            return dots;
        }

        // جسيمات نصية تتحرك
        class Particle {
            x: number;
            y: number;
            targetX: number;
            targetY: number;
            velocityX: number;
            velocityY: number;
            size: number;
            friction: number;
            ease: number;
            color: string;

            constructor(x: number, y: number, color: string = dotColor) {
                this.x = x;
                this.y = y;
                this.targetX = x;
                this.targetY = y;
                this.velocityX = 0;
                this.velocityY = 0;
                this.size = dotSize;
                this.friction = 0.95;
                this.ease = 0.1;
                this.color = color;
            }

            draw() {
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }

            update() {
                // الحركة نحو الهدف
                let dx = this.targetX - this.x;
                let dy = this.targetY - this.y;
                let dist = Math.sqrt(dx * dx + dy * dy);

                if (dist > 1) {
                    this.velocityX += dx * this.ease;
                    this.velocityY += dy * this.ease;
                }

                // تطبيق الاحتكاك
                this.velocityX *= this.friction;
                this.velocityY *= this.friction;

                // تحديث الموقف
                this.x += this.velocityX;
                this.y += this.velocityY;
            }
        }

        // نقاط خلفية تتساقط
        class BackgroundDot {
            x: number;
            y: number;
            speed: number;
            isHeart: boolean;

            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * -height;
                this.speed = Math.random() * 2 + 1;
                this.isHeart = Math.random() < 0.1; // 10% قلوب
            }

            draw() {
                if (this.isHeart) {
                    // رسم قلب صغير بدلاً من نقطة
                    ctx.font = '10px sans-serif';
                    ctx.fillStyle = finalHeartColor;
                    ctx.fillText('❤️', this.x, this.y);
                } else {
                    ctx.fillStyle = 'rgba(255, 102, 178, 0.5)'; // وردي فاتح
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, 1, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            update() {
                this.y += this.speed;
                if (this.y > height) {
                    this.y = Math.random() * -100;
                    this.x = Math.random() * width;
                }
            }
        }

        // تهيئة نقاط الخلفية
        function initBackground() {
            backgroundDots = [];
            for (let i = 0; i < 200; i++) {
                backgroundDots.push(new BackgroundDot());
            }
        }

        // دالة إنشاء القلب النهائي
        function createHeartPattern(): { x: number; y: number }[] {
            // رسم قلب على الكانفاس أولاً للحصول على النقاط
            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = 'white';
            ctx.font = '200px serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('❤️', width / 2, height / 2);

            let dots: { x: number; y: number }[] = [];
            let imageData = ctx.getImageData(0, 0, width, height);

            for (let y = 0; y < height; y += dotGap) {
                for (let x = 0; x < width; x += dotGap) {
                    let index = (y * width + x) * 4;
                    if (imageData.data[index] > 0) {
                        dots.push({ x, y });
                    }
                }
            }
            return dots;
        }

        // تسلسل النصوص الخاصة بك باللغة العربية
        const ArabicMessages = [
            "3",
            "2",
            "1",
            "سنة كاملة",
            "من البثوث",
            "شكراً",
            "لكم ❤️"
        ];

        // دالة الانتقال للخطوة التالية في التسلسل
        function nextSequence() {
            if (currentSequenceIndex >= ArabicMessages.length) {
                startFinalHeart();
                return;
            }

            let message = ArabicMessages[currentSequenceIndex];
            let newTargets = createTextDots(message);
            particles = []; // مسح الجسيمات السابقة لبدء الحركة من جديد

            // إنشاء جسيمات جديدة في منتصف الشاشة للحركة نحو الأهداف
            for (let i = 0; i < newTargets.length; i++) {
                let p = new Particle(width / 2, height / 2);
                p.targetX = newTargets[i].x;
                p.targetY = newTargets[i].y;
                particles.push(p);
            }

            currentSequenceIndex++;
            setTimeout(nextSequence, 2000); // 2 ثانية لكل نص
        }

        // بدء شاشة القلب النهائي
        function startFinalHeart() {
            finalHeartActive = true;
            let heartTargets = createHeartPattern();
            particles = []; 

            // إنشاء جسيمات للقلب النهائي
            for (let i = 0; i < heartTargets.length; i++) {
                let p = new Particle(width / 2, height / 2, finalHeartColor);
                p.targetX = heartTargets[i].x;
                p.targetY = heartTargets[i].y;
                p.ease = 0.05; // أبطأ قليلاً لتعطيه شكل "تكوين"
                particles.push(p);
            }

            // بعد 3 ثوانٍ من ظهور القلب، ابدأ في إخفاء واجهة التراكب (Fade Out)
            setTimeout(() => {
                overlay.classList.add('fade-out');
            }, 3000);
        }

        // حلقة الرسم الرئيسية
        function animate() {
            ctx.clearRect(0, 0, width, height);

            // رسم وتحديث خلفية النقاط المتساقطة
            backgroundDots.forEach(dot => {
                dot.update();
                dot.draw();
            });

            // رسم وتحديث جسيمات النصوص
            particles.forEach(p => {
                p.update();
                p.draw();
            });

            animationFrameId = requestAnimationFrame(animate);
        }

        // تهيئة وبدء العرض
        initBackground();
        nextSequence();
        animate();

        // تحديث الحجم عند تغيير حجم النافذة
        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            initBackground();
            // لإعادة تشكيل النص الحالي عند التكبير/التصغير، يجب تعديل nextSequence ليكون أكثر مرونة،
            // لكن للتبسيط، دعنا نعيد تشغيل التسلسل.
            currentSequenceIndex = 0;
            finalHeartActive = false;
            overlay.classList.remove('fade-out');
            cancelAnimationFrame(animationFrameId);
            animate();
            nextSequence();
        });
    </script>
</body>
</html>
