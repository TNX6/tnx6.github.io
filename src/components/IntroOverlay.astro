---
// src/components/IntroOverlay.astro
// لا نحتاج لأكواد سيرفر هنا
---

<div id="intro-overlay">
    <canvas id="matrix-canvas"></canvas>
    <div id="text-container"></div>
</div>

<style>
    /* تنسيق الحاوية الرئيسية لتغطي كامل الشاشة */
    #intro-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #050505;
        z-index: 9999; /* لضمان ظهوره فوق كل محتوى الموقع */
        overflow: hidden;
        transition: opacity 1s ease-out; /* تأثير اختفاء سلس */
        direction: rtl;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    #matrix-canvas {
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
    }

    #text-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        text-align: center;
        width: 100%;
        pointer-events: none;
    }

    /* يجب استخدام is:global في Astro للتنسيقات التي يتم إضافتها عبر جافاسكريبت */
    <style is:global>
        .intro-message {
            font-size: 8vw;
            font-weight: 900;
            color: #ffffff;
            opacity: 0;
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            text-shadow: 0 0 10px #ff66b2, 0 0 20px #ff66b2, 0 0 40px #ff007f;
            white-space: nowrap;
            transition: opacity 1s ease-in-out, transform 1s ease-out;
        }

        .intro-message.active {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }

        .intro-heart-icon {
            font-size: 12vw;
            color: #ff0055;
            text-shadow: 0 0 20px #ff0055, 0 0 50px #ff0055;
        }
    </style>
</style>

<script>
    // نغلف الكود للتأكد من عمله بشكل صحيح مع Astro
    function initIntro() {
        const overlay = document.getElementById('intro-overlay');
        if (!overlay) return; // إذا تم إخفاء الواجهة مسبقاً، لا تقم بتشغيل السكريبت

        // إيقاف التمرير (النزول بالصفحة) أثناء عرض المقدمة
        document.body.style.overflow = 'hidden';

        const messages = [
            "3", 
            "2", 
            "1", 
            "سنة كاملة", 
            "من أجمل البثوث", 
            "شكراً لدعمكم المستمر", 
            "<span class='intro-heart-icon'>❤️</span><br><span style='font-size: 4vw;'>أحبكم</span>"
        ];

        const container = document.getElementById('text-container');
        let currentIndex = 0;

        function showNextText() {
            if (!container) return;
            container.innerHTML = ''; 

            if (currentIndex >= messages.length) {
                const finalDiv = document.createElement('div');
                finalDiv.className = 'intro-message active';
                finalDiv.innerHTML = messages[messages.length - 1];
                container.appendChild(finalDiv);

                // بعد 3 ثواني من ظهور الكلمة الأخيرة، قم بإخفاء الواجهة
                setTimeout(() => {
                    overlay.style.opacity = '0';
                    
                    // بعد انتهاء تأثير الاختفاء (1 ثانية)، نزيل الواجهة تماماً ونعيد تفعيل التمرير
                    setTimeout(() => {
                        overlay.style.display = 'none';
                        document.body.style.overflow = ''; // إعادة التمرير للصفحة الرئيسية
                        
                        // ملاحظة: إذا كنت تريد النقل لصفحة أخرى (Redirect) بدلاً من إخفاء الواجهة،
                        // يمكنك إزالة السطرين بالأعلى واستخدام السطر التالي:
                        // window.location.href = '/home'; 
                    }, 1000);

                }, 3000);
                return;
            }

            const div = document.createElement('div');
            div.className = 'intro-message';
            div.innerHTML = messages[currentIndex];
            container.appendChild(div);

            setTimeout(() => { div.classList.add('active'); }, 50);

            setTimeout(() => {
                div.classList.remove('active');
                setTimeout(() => {
                    currentIndex++;
                    showNextText();
                }, 1000); 
            }, 2500); 
        }

        setTimeout(showNextText, 1000);

        // برمجة الماتريكس
        const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
        if (!canvas) return;
        
        const ctx = canvas.getContext('2d');
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        const chars = '01ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*<>[]{}'.split('');
        const fontSize = 16;
        let columns = width / fontSize;
        let drops = [];

        for (let x = 0; x < columns; x++) { drops[x] = 1; }

        let matrixInterval = setInterval(() => {
            // توقف عن رسم الماتريكس إذا اختفت الواجهة لتخفيف العبء على المتصفح
            if (overlay.style.display === 'none') {
                clearInterval(matrixInterval);
                return;
            }

            ctx.fillStyle = 'rgba(5, 5, 5, 0.1)';
            ctx.fillRect(0, 0, width, height);
            ctx.fillStyle = '#ff66b2';
            ctx.font = fontSize + 'px monospace';

            for (let i = 0; i < drops.length; i++) {
                const text = chars[Math.floor(Math.random() * chars.length)];
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);

                if (drops[i] * fontSize > height && Math.random() > 0.975) {
                    drops[i] = 0;
                }
                drops[i]++;
            }
        }, 35);

        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            columns = width / fontSize;
            drops = [];
            for (let x = 0; x < columns; x++) { drops[x] = 1; }
        });
    }

    // تشغيل السكريبت عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', initIntro);
    // دعم View Transitions في Astro إذا كنت تستخدمها
    document.addEventListener('astro:page-load', initIntro);
</script>
