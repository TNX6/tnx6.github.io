---
---
<div id="intro-overlay">
    <canvas id="matrix-canvas"></canvas>
    <canvas id="particle-canvas"></canvas>
</div>

<style>
    #intro-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #050505;
        z-index: 9999;
        overflow: hidden;
        transition: opacity 1.5s ease-out;
    }
    canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }
    #matrix-canvas {
        z-index: 1;
        opacity: 0.6;
    }
    #particle-canvas {
        z-index: 2;
    }
</style>

<script is:inline>
    function initComplexIntro() {
        const overlay = document.getElementById('intro-overlay');
        const matrixCanvas = document.getElementById('matrix-canvas');
        const particleCanvas = document.getElementById('particle-canvas');
        
        if (!overlay || !matrixCanvas || !particleCanvas) return;
        
        document.body.style.overflow = 'hidden';

        const mCtx = matrixCanvas.getContext('2d');
        const pCtx = particleCanvas.getContext('2d', { willReadFrequently: true });
        
        let width = window.innerWidth;
        let height = window.innerHeight;
        
        matrixCanvas.width = particleCanvas.width = width;
        matrixCanvas.height = particleCanvas.height = height;

        // 1. برمجة خلفية الماتريكس (الشفرات)
        const matrixChars = '01ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*<>[]{}'.split('');
        const fontSize = 16;
        let columns = Math.floor(width / fontSize);
        let drops = Array(columns).fill(1);

        function drawMatrix() {
            mCtx.fillStyle = 'rgba(5, 5, 5, 0.1)';
            mCtx.fillRect(0, 0, width, height);
            mCtx.fillStyle = '#ff66b2';
            mCtx.font = fontSize + 'px monospace';
            
            for (let i = 0; i < drops.length; i++) {
                const text = matrixChars[Math.floor(Math.random() * matrixChars.length)];
                mCtx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }

        // 2. برمجة الجسيمات
        let particles = [];
        const fov = 250; 
        let isFirstWord = true; // متغير جديد لمنع الفوضى في البداية
        
        class Particle {
            constructor() {
                this.x = 0;
                this.y = 0;
                this.z = 0;
                this.tx = 0;
                this.ty = 0;
                this.tz = 0;
                this.vx = 0;
                this.vy = 0;
                this.vz = 0;
                this.color = '#ffffff';
                this.size = 2;
            }

            update() {
                let dx = this.tx - this.x;
                let dy = this.ty - this.y;
                let dz = this.tz - this.z;

                this.vx += dx * 0.02;
                this.vy += dy * 0.02;
                this.vz += dz * 0.02;

                this.vx *= 0.85;
                this.vy *= 0.85;
                this.vz *= 0.85;

                this.x += this.vx;
                this.y += this.vy;
                this.z += this.vz;
            }

            draw() {
                if (this.z < -fov) return;
                
                let scale = fov / (fov + this.z);
                let x2d = (this.x * scale) + width / 2;
                let y2d = (this.y * scale) + height / 2;
                
                pCtx.beginPath();
                pCtx.arc(x2d, y2d, this.size * scale, 0, Math.PI * 2);
                pCtx.fillStyle = this.color;
                pCtx.fill();
            }
        }

        function getTextCoords(text, isHeart = false) {
            const offscreen = document.createElement('canvas');
            const oCtx = offscreen.getContext('2d', { willReadFrequently: true });
            offscreen.width = width;
            offscreen.height = height;
            
            oCtx.fillStyle = 'white';
            oCtx.textAlign = 'center';
            oCtx.textBaseline = 'middle';
            
            if (isHeart) {
                oCtx.font = `bold ${Math.min(width * 0.4, 300)}px Arial`;
                oCtx.fillText('❤', width / 2, height / 2 - 50);
                oCtx.font = `bold ${Math.min(width * 0.1, 80)}px Arial`;
                oCtx.fillText('شكراً لكم', width / 2, height / 2 + 80);
            } else {
                oCtx.font = `bold ${Math.min(width * 0.2, 150)}px Arial`;
                oCtx.fillText(text, width / 2, height / 2);
            }

            const imageData = oCtx.getImageData(0, 0, width, height).data;
            let coords = [];
            for (let y = 0; y < height; y += 6) {
                for (let x = 0; x < width; x += 6) {
                    const alpha = imageData[(y * width + x) * 4 + 3];
                    if (alpha > 128) {
                        coords.push({ x: x - width / 2, y: y - height / 2, z: 0 });
                    }
                }
            }
            return coords;
        }

        function explodeParticles() {
            particles.forEach(p => {
                p.vz = (Math.random() - 0.5) * 800;
                p.vx = (Math.random() - 0.5) * 300;
                p.vy = (Math.random() - 0.5) * 300;
            });
        }

        function morphTo(text, isHeart = false) {
            const newCoords = getTextCoords(text, isHeart);
            
            // تفعيل الانفجار فقط إذا لم تكن هذه الكلمة الأولى
            if (!isFirstWord) {
                explodeParticles();
            }

            if (particles.length < newCoords.length) {
                const diff = newCoords.length - particles.length;
                for (let i = 0; i < diff; i++) {
                    particles.push(new Particle());
                }
            } else if (particles.length > newCoords.length) {
                particles.splice(newCoords.length);
            }

            newCoords.sort(() => Math.random() - 0.5);

            for (let i = 0; i < particles.length; i++) {
                particles[i].tx = newCoords[i].x;
                particles[i].ty = newCoords[i].y;
                particles[i].tz = newCoords[i].z;
                
                // إذا كانت الكلمة الأولى، نرتب النقاط في أماكنها فوراً بدون طيران
                if (isFirstWord) {
                    particles[i].x = particles[i].tx;
                    particles[i].y = particles[i].ty;
                    particles[i].z = particles[i].tz;
                }
                
                if (isHeart) {
                    particles[i].color = Math.random() > 0.3 ? '#ff0055' : '#ff66b2';
                } else {
                    particles[i].color = '#ffffff';
                }
            }
            
            isFirstWord = false; // تعطيل خاصية الكلمة الأولى للكلمات القادمة
        }

        // 3. التسلسل الزمني
        const words = ["3", "2", "1", "سنة كاملة", "من البثوث", "شكراً"];
        let wordIndex = 0;

        function nextWord() {
            if (wordIndex < words.length) {
                morphTo(words[wordIndex]);
                wordIndex++;
                setTimeout(nextWord, 2000); 
            } else if (wordIndex === words.length) {
                morphTo('heart', true); 
                setTimeout(() => {
                    overlay.style.opacity = '0';
                    setTimeout(() => {
                        overlay.style.display = 'none';
                        document.body.style.overflow = ''; 
                        cancelAnimationFrame(animationId);
                        clearInterval(matrixInterval);
                    }, 1500);
                }, 3000);
            }
        }

        let animationId;
        function animate() {
            pCtx.clearRect(0, 0, width, height);
            
            pCtx.shadowBlur = 15;
            pCtx.shadowColor = '#ff66b2';

            particles.forEach(p => {
                p.update();
                p.draw();
            });
            
            animationId = requestAnimationFrame(animate);
        }

        let matrixInterval = setInterval(drawMatrix, 40);
        
        // تشغيل الكلمة الأولى فوراً لتجنب أي شاشة فارغة أو فوضى
        nextWord(); 
        animate();
        
        window.addEventListener('resize', () => {
            width = window.innerWidth;
            height = window.innerHeight;
            matrixCanvas.width = particleCanvas.width = width;
            matrixCanvas.height = particleCanvas.height = height;
            columns = Math.floor(width / fontSize);
            drops = Array(columns).fill(1);
        });
    }

    document.addEventListener('DOMContentLoaded', initComplexIntro);
    document.addEventListener('astro:page-load', initComplexIntro);
</script>
