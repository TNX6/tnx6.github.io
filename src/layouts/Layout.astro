---
import '~/assets/styles/tailwind.css'
import { I18N } from 'astrowind:config'
import CommonMeta from '~/components/common/CommonMeta.astro'
import Favicons from '~/components/Favicons.astro'
import CustomStyles from '~/components/CustomStyles.astro'
import ApplyColorMode from '~/components/common/ApplyColorMode.astro'
import Metadata from '~/components/common/Metadata.astro'
import SiteVerification from '~/components/common/SiteVerification.astro'
import Analytics from '~/components/common/Analytics.astro'
import BasicScripts from '~/components/common/BasicScripts.astro'
import SitePresenceHeartbeat from '~/components/SitePresenceHeartbeat.astro'
import { ClientRouter } from 'astro:transitions'
import type { MetaData as MetaDataType } from '~/types'

const { metadata = {} } = Astro.props
const { language, textDirection } = I18N
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <slot name="head" />
    <SiteVerification />
    <Analytics />

    <!-- Iconify icons support -->
    <script
      src="https://code.iconify.design/iconify-icon/2.3.0/iconify-icon.min.js"
      defer
    ></script>

    <ClientRouter fallback="swap" />

    <style is:global>
      iconify-icon {
        display: inline-block;
        width: 1em;
        height: 1em;
        vertical-align: -0.125em;
      }
    </style>
  </head>

  <body class="antialiased text-default tracking-tight relative">
    <div
      class="fixed inset-0 -z-10 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/assets/03.webp');"
    ></div>

    <div class="fixed inset-0 -z-10 bg-black/40"></div>

    <slot />

    <SitePresenceHeartbeat />

    <BasicScripts />

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('script[data-reinit]').forEach((script) => {
          const clone = document.createElement('script')
          clone.textContent = script.textContent
          clone.setAttribute('data-reinit', '')
          script.replaceWith(clone)
        })
      })
    </script>
  </body>
</html>
